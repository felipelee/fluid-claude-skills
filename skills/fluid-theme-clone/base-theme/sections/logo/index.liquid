{%- style -%}
  .section-{{ section.id }} {
    {%- assign p = section.settings.section_padding -%}
    {%- if p -%}
      {%- capture pt -%}{{ p.top }}{%- endcapture -%}
      {%- capture pb -%}{{ p.bottom }}{%- endcapture -%}
      {%- capture pl -%}{{ p.left }}{%- endcapture -%}
      {%- capture pr -%}{{ p.right }}{%- endcapture -%}
      padding-top: {% if pt contains 'var(' %}{{ pt }}{% else %}{{ pt }}px{% endif %};
      padding-bottom: {% if pb contains 'var(' %}{{ pb }}{% else %}{{ pb }}px{% endif %};
      padding-left: {% if pl contains 'var(' %}{{ pl }}{% else %}{{ pl }}px{% endif %};
      padding-right: {% if pr contains 'var(' %}{{ pr }}{% else %}{{ pr }}px{% endif %};
    {%- endif -%}
    {%- assign sr = section.settings.section_border_radius -%}
    {%- if sr -%}
      {%- capture sr_tl -%}{{ sr.tl }}{%- endcapture -%}
      {%- capture sr_tr -%}{{ sr.tr }}{%- endcapture -%}
      {%- capture sr_br -%}{{ sr.br }}{%- endcapture -%}
      {%- capture sr_bl -%}{{ sr.bl }}{%- endcapture -%}
      border-radius: {% if sr_tl contains 'var(' %}{{ sr_tl }}{% else %}{{ sr_tl }}px{% endif %} {% if sr_tr contains 'var(' %}{{ sr_tr }}{% else %}{{ sr_tr }}px{% endif %} {% if sr_br contains 'var(' %}{{ sr_br }}{% else %}{{ sr_br }}px{% endif %} {% if sr_bl contains 'var(' %}{{ sr_bl }}{% else %}{{ sr_bl }}px{% endif %};
    {%- endif -%}
    {%- assign sb = section.settings.section_border -%}
    {%- if sb.width -%}
      border: {{ sb.width }} solid {{ sb.color }};
    {%- endif -%}
  }
{%- endstyle -%}

<section class="logo-section section-{{ section.id }}" 
         style="background-color: {{ section.settings.background_color | default: '#ffffff' }};
                {% if section.settings.background_image != blank %}
                background-image: url('{{ section.settings.background_image | image_url: width: 1920 }}');
                background-size: cover;
                background-position: center;
                background-repeat: no-repeat;
                {% endif %}
                position: relative;">
  
  {%- assign ov = section.settings.overlay -%}
  {%- if ov and ov.enabled -%}
    <div class="overlay-{{ section.id }}"></div>
    {%- style -%}
      .overlay-{{ section.id }} {
        position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1;
        {%- if ov.mode == 'gradient' and ov.colors.size > 1 -%}
          background:
            {%- if ov.gradientType == 'radial' -%}
              radial-gradient(
            {%- else -%}
              linear-gradient({{ ov.angle }}deg,
            {%- endif -%}
            {%- for stop in ov.colors -%}
              {{ stop.color }} {{ stop.position }}%{%- unless forloop.last -%},{%- endunless -%}
            {%- endfor -%}
          );
          opacity: {{ ov.colors.first.opacity | divided_by: 100.0 }};
        {%- else -%}
          {%- assign c = ov.colors | first -%}
          background-color: {{ c.color }};
          opacity: {{ c.opacity | divided_by: 100.0 }};
        {%- endif -%}
      }
    {%- endstyle -%}
  {%- endif -%}
  
  <div class="container" style="position: relative; z-index: 2;">
    <div class="logo-logos-grid grid grid-cols-2 md-tab-grid-cols-3 sm-desktop-grid-cols-5 gap-8 align-center justify-center">
          
          <!-- Logo 1 -->
          <div class="logo-item flex justify-center align-center">
            {% if section.settings.logo_1_image != blank %}
              {% if section.settings.logo_1_link != blank %}
                <a href="{{ section.settings.logo_1_link }}" class="logo-link">
              {% endif %}
              <img src="{{ section.settings.logo_1_image | image_url: width: 200 }}" 
                   alt="{{ section.settings.logo_1_alt | default: 'Company logo' }}"
                   class="logo-image">
              {% if section.settings.logo_1_link != blank %}
                </a>
              {% endif %}
            {% else %}
              <div class="logo-placeholder">
                <svg width="80" height="40" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                </svg>
                <p class="text-xs" style="margin-top: 4px; color: #9ca3af;">Logo 1</p>
              </div>
            {% endif %}
          </div>

          <!-- Logo 2 -->
          <div class="logo-item flex justify-center align-center">
            {% if section.settings.logo_2_image != blank %}
              {% if section.settings.logo_2_link != blank %}
                <a href="{{ section.settings.logo_2_link }}" class="logo-link">
              {% endif %}
              <img src="{{ section.settings.logo_2_image | image_url: width: 200 }}" 
                   alt="{{ section.settings.logo_2_alt | default: 'Company logo' }}"
                   class="logo-image">
              {% if section.settings.logo_2_link != blank %}
                </a>
              {% endif %}
            {% else %}
              <div class="logo-placeholder">
                <svg width="80" height="40" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                </svg>
                <p class="text-xs" style="margin-top: 4px; color: #9ca3af;">Logo 2</p>
              </div>
            {% endif %}
          </div>

          <!-- Logo 3 -->
          <div class="logo-item flex justify-center align-center">
            {% if section.settings.logo_3_image != blank %}
              {% if section.settings.logo_3_link != blank %}
                <a href="{{ section.settings.logo_3_link }}" class="logo-link">
              {% endif %}
              <img src="{{ section.settings.logo_3_image | image_url: width: 200 }}" 
                   alt="{{ section.settings.logo_3_alt | default: 'Company logo' }}"
                   class="logo-image">
              {% if section.settings.logo_3_link != blank %}
                </a>
              {% endif %}
            {% else %}
              <div class="logo-placeholder">
                <svg width="80" height="40" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                </svg>
                <p class="text-xs" style="margin-top: 4px; color: #9ca3af;">Logo 3</p>
              </div>
            {% endif %}
          </div>

          <!-- Logo 4 -->
          <div class="logo-item flex justify-center align-center">
            {% if section.settings.logo_4_image != blank %}
              {% if section.settings.logo_4_link != blank %}
                <a href="{{ section.settings.logo_4_link }}" class="logo-link">
              {% endif %}
              <img src="{{ section.settings.logo_4_image | image_url: width: 200 }}" 
                   alt="{{ section.settings.logo_4_alt | default: 'Company logo' }}"
                   class="logo-image">
              {% if section.settings.logo_4_link != blank %}
                </a>
              {% endif %}
            {% else %}
              <div class="logo-placeholder">
                <svg width="80" height="40" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                </svg>
                <p class="text-xs" style="margin-top: 4px; color: #9ca3af;">Logo 4</p>
              </div>
            {% endif %}
          </div>

          <!-- Logo 5 -->
          <div class="logo-item flex justify-center align-center">
            {% if section.settings.logo_5_image != blank %}
              {% if section.settings.logo_5_link != blank %}
                <a href="{{ section.settings.logo_5_link }}" class="logo-link">
              {% endif %}
              <img src="{{ section.settings.logo_5_image | image_url: width: 200 }}" 
                   alt="{{ section.settings.logo_5_alt | default: 'Company logo' }}"
                   class="logo-image">
              {% if section.settings.logo_5_link != blank %}
                </a>
              {% endif %}
            {% else %}
              <div class="logo-placeholder">
                <svg width="80" height="40" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                </svg>
                <p class="text-xs" style="margin-top: 4px; color: #9ca3af;">Logo 5</p>
              </div>
            {% endif %}
          </div>
    </div>
  </div>
</section>

<style>
.logo-section .logo-image {
  max-width: 120px;
  max-height: 60px;
  width: auto;
  height: auto;
  object-fit: contain;
  filter: {{ section.settings.logo_filter | default: 'none' }};
  transition: filter 0.3s ease;
}

.logo-section .logo-link:hover .logo-image {
  filter: none;
  opacity: 0.8;
}

.logo-section .logo-placeholder {
  width: 120px;
  height: 60px;
  background-color: #f3f4f6;
  border: 2px dashed #d1d5db;
  border-radius: 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #9ca3af;
}

@media (max-width: 1023px) {
  .logo-section .logo-logos-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

@media (max-width: 767px) {
  .logo-section .logo-logos-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  
  .logo-section .logo-image {
    max-width: 100px;
    max-height: 50px;
  }
  
  .logo-section .logo-placeholder {
    width: 100px;
    height: 50px;
  }
}
</style>

{% schema %}
{
  "name": "Logo",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo_1_image",
      "label": "Logo 1 - Image"
    },
    {
      "type": "select",
      "id": "media_fit",
      "label": "Image Fit",
      "options": [
        {
          "value": "cover",
          "label": "Cover (Fill Container)"
        },
        {
          "value": "contain",
          "label": "Contain (Fit Inside)"
        },
        {
          "value": "fit-width",
          "label": "Fit to Width"
        },
        {
          "value": "fit-height",
          "label": "Fit to Height"
        }
      ],
      "default": "cover"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 0,
      "max": 2000,
      "step": 1,
      "label": "Max Width (px)",
      "info": "Leave empty for no limit"
    },
    {
      "type": "range",
      "id": "max_height",
      "min": 0,
      "max": 2000,
      "step": 1,
      "label": "Max Height (px)",
      "info": "Leave empty for no limit"
    },
    {
      "type": "corner_radius",
      "id": "media_border_radius",
      "label": "Image Border Radius",
      "info": "Override theme default media radius"
    },
    {
      "type": "text",
      "id": "logo_1_alt",
      "label": "Logo 1 - Alt Text",
      "default": "Company logo"
    },
    {
      "type": "url",
      "id": "logo_1_link",
      "label": "Logo 1 - Link",
      "info": "Optional link for the logo"
    },
    {
      "type": "image_picker",
      "id": "logo_2_image",
      "label": "Logo 2 - Image"
    },
    {
      "type": "text",
      "id": "logo_2_alt",
      "label": "Logo 2 - Alt Text",
      "default": "Company logo"
    },
    {
      "type": "url",
      "id": "logo_2_link",
      "label": "Logo 2 - Link",
      "info": "Optional link for the logo"
    },
    {
      "type": "image_picker",
      "id": "logo_3_image",
      "label": "Logo 3 - Image"
    },
    {
      "type": "text",
      "id": "logo_3_alt",
      "label": "Logo 3 - Alt Text",
      "default": "Company logo"
    },
    {
      "type": "url",
      "id": "logo_3_link",
      "label": "Logo 3 - Link",
      "info": "Optional link for the logo"
    },
    {
      "type": "image_picker",
      "id": "logo_4_image",
      "label": "Logo 4 - Image"
    },
    {
      "type": "text",
      "id": "logo_4_alt",
      "label": "Logo 4 - Alt Text",
      "default": "Company logo"
    },
    {
      "type": "url",
      "id": "logo_4_link",
      "label": "Logo 4 - Link",
      "info": "Optional link for the logo"
    },
    {
      "type": "image_picker",
      "id": "logo_5_image",
      "label": "Logo 5 - Image"
    },
    {
      "type": "text",
      "id": "logo_5_alt",
      "label": "Logo 5 - Alt Text",
      "default": "Company logo"
    },
    {
      "type": "url",
      "id": "logo_5_link",
      "label": "Logo 5 - Link",
      "info": "Optional link for the logo"
    },
    {
      "type": "select",
      "id": "logo_filter",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "grayscale(100%)",
          "label": "Grayscale"
        },
        {
          "value": "opacity(0.6)",
          "label": "Faded"
        },
        {
          "value": "grayscale(100%) opacity(0.6)",
          "label": "Grayscale + Faded"
        }
      ],
      "default": "grayscale(100%) opacity(0.6)",
      "label": "Logo Filter",
      "info": "Visual treatment for logos"
    },
    {
      "type": "select",
      "id": "background_color",
      "label": "Background Color",
      "options": "background_colors",
      "default": "var(--clr-white)"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image",
      "info": "Optional background image (will override background color)"
    },
    {
      "type": "gradient_overlay",
      "id": "overlay",
      "label": "Overlay"
    },
    {
      "type": "padding",
      "id": "section_padding",
      "label": "Section Padding"
    },
    {
      "type": "corner_radius",
      "id": "section_border_radius",
      "label": "Section Border Radius",
      "info": "Default 0px. Four corners, link/unlink."
    },
    {
      "type": "border",
      "id": "section_border",
      "label": "Section Border"
    }
  ]
}
