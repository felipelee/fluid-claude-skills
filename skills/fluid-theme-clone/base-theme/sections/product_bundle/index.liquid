{%- style -%}
  .pbn.section-{{ section.id }} {
    {%- assign p = section.settings.section_padding -%}
    {%- if p -%}padding: {{ p.top | default: 80 }}px {{ p.right | default: 0 }}px {{ p.bottom | default: 80 }}px {{ p.left | default: 0 }}px;{%- else -%}padding: 80px 0;{%- endif -%}
    {%- assign r = section.settings.section_border_radius -%}
    {%- if r -%}border-radius: {{ r.tl }}px {{ r.tr }}px {{ r.br }}px {{ r.bl }}px;{%- endif -%}
    {% if section.settings.section_border_width > 0 %}border: {{ section.settings.section_border_width }}px solid {{ section.settings.section_border_color }};{% endif %}
    background-color: {{ section.settings.background_color | default: 'transparent' }};
    {%- if section.settings.background_image != blank -%}background-image: url({{ section.settings.background_image | img_url: '2400x' }});background-size:cover;background-position:center;background-repeat:no-repeat;{%- endif -%}
  }
  .pbn.section-{{ section.id }} .pbn__container {
    position: relative;
    max-width: {{ section.settings.container_max_width | default: '1280px' }};
    margin: 0 auto;
    {%- assign cp = section.settings.container_padding -%}
    {%- if cp -%}padding: {{ cp.top | default: 0 }}px {{ cp.right | default: 64 }}px {{ cp.bottom | default: 0 }}px {{ cp.left | default: 64 }}px;{%- else -%}padding: 0 64px;{%- endif -%}
    background-color: {{ section.settings.container_background_color | default: 'transparent' }};
    {%- if section.settings.container_background_image != blank -%}background-image: url({{ section.settings.container_background_image | img_url: '2400x' }});background-size:cover;background-position:center;background-repeat:no-repeat;{%- endif -%}
    {%- assign ccr = section.settings.container_border_radius -%}
    {%- if ccr -%}border-radius: {{ ccr.tl }}px {{ ccr.tr }}px {{ ccr.br }}px {{ ccr.bl }}px;{%- endif -%}
    {% if section.settings.container_border_width > 0 %}border: {{ section.settings.container_border_width }}px solid {{ section.settings.container_border_color }};{% endif %}
  }
  {%- if section.settings.container_overlay_color != blank and section.settings.container_overlay_opacity > 0 -%}
    {%- assign _cov = section.settings.container_overlay_opacity | divided_by: 100.0 -%}
    .pbn.section-{{ section.id }} .pbn__container::before { content: ""; position: absolute; inset: 0; background: {{ section.settings.container_overlay_color }}; opacity: {{ _cov }}; pointer-events: none; }
  {%- endif -%}
  .pbn.section-{{ section.id }} .pbn__container > * { position: relative; }
  @media (max-width: 991px) { .pbn.section-{{ section.id }} .pbn__container { padding-left: 24px; padding-right: 24px; } }
  @media (max-width: 767px) { .pbn.section-{{ section.id }} .pbn__container { padding-left: 16px; padding-right: 16px; } }

  .pbn.section-{{ section.id }} .pbn__intro {
    text-align: {{ section.settings.intro_alignment | default: 'center' }};
    {%- if section.settings.intro_alignment == 'center' -%}margin: 0 auto 48px; max-width: 640px;{%- else -%}margin-bottom: 48px;{%- endif -%}
    display: flex; flex-direction: column; gap: 10px;
  }

  .pbn.section-{{ section.id }} .pbn__layout {
    display: grid; grid-template-columns: 1fr auto; gap: 48px; align-items: center;
  }
  @media (max-width: 991px) { .pbn.section-{{ section.id }} .pbn__layout { grid-template-columns: 1fr; gap: 24px; } }

  .pbn.section-{{ section.id }} .pbn__cards {
    display: flex; flex-wrap: wrap; align-items: stretch; gap: 12px;
  }

  .pbn.section-{{ section.id }} .pbn__card {
    flex: 1 1 180px; min-width: 160px;
    display: flex; flex-direction: column; gap: 10px;
    padding: 16px;
    background: {{ section.settings.card_background | default: 'var(--clr-white)' }};
    border: 1.5px solid {{ section.settings.card_border | default: 'var(--clr-gray)' }};
    border-radius: 14px;
    position: relative;
    cursor: pointer;
    transition: border-color .15s, transform .15s;
  }
  .pbn.section-{{ section.id }} .pbn__card.is-selected {
    border-color: {{ section.settings.card_active_border | default: 'var(--clr-primary)' }};
    box-shadow: 0 0 0 3px {{ section.settings.card_active_ring | default: 'rgba(17, 24, 39, 0.08)' }};
  }
  .pbn.section-{{ section.id }} .pbn__card-img {
    width: 100%; aspect-ratio: 1/1;
    border-radius: 10px; overflow: hidden;
    background: var(--clr-gray);
  }
  .pbn.section-{{ section.id }} .pbn__card-img img { width: 100%; height: 100%; object-fit: cover; }
  .pbn.section-{{ section.id }} .pbn__card-img-placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    color: var(--clr-muted); opacity: 0.5;
    background: repeating-linear-gradient(45deg, var(--clr-gray) 0 14px, var(--clr-light) 14px 28px);
  }
  .pbn.section-{{ section.id }} .pbn__card-title {
    font-size: 14px; font-weight: 600; line-height: 1.3;
    color: {{ section.settings.title_color | default: 'var(--clr-primary)' }};
    margin: 0;
  }
  .pbn.section-{{ section.id }} .pbn__card-price {
    font-size: 13.5px; font-weight: 600;
    color: {{ section.settings.price_color | default: 'var(--clr-primary)' }};
  }
  .pbn.section-{{ section.id }} .pbn__card-check {
    position: absolute; top: 10px; right: 10px;
    width: 22px; height: 22px; border-radius: 50%;
    border: 1.5px solid {{ section.settings.card_border | default: 'var(--clr-gray)' }};
    background: {{ section.settings.card_background | default: 'var(--clr-white)' }};
    display: inline-flex; align-items: center; justify-content: center;
    color: transparent;
    transition: all .15s;
  }
  .pbn.section-{{ section.id }} .pbn__card.is-selected .pbn__card-check {
    background: {{ section.settings.card_active_border | default: 'var(--clr-primary)' }};
    border-color: {{ section.settings.card_active_border | default: 'var(--clr-primary)' }};
    color: {{ section.settings.card_check_color | default: 'var(--clr-white)' }};
  }
  .pbn.section-{{ section.id }} .pbn__card-check svg { width: 12px; height: 12px; }

  .pbn.section-{{ section.id }} .pbn__plus {
    display: inline-flex; align-items: center; justify-content: center;
    width: 28px; font-size: 24px; font-weight: 300;
    color: {{ section.settings.plus_color | default: 'var(--clr-muted)' }};
    flex: 0 0 28px;
  }
  @media (max-width: 991px) { .pbn.section-{{ section.id }} .pbn__plus { width: 100%; height: 8px; } }

  .pbn.section-{{ section.id }} .pbn__summary {
    padding: 24px 28px;
    background: {{ section.settings.summary_background | default: 'var(--clr-primary)' }};
    color: {{ section.settings.summary_color | default: 'var(--clr-white)' }};
    border-radius: 16px;
    min-width: 280px;
    display: flex; flex-direction: column; gap: 12px;
  }
  .pbn.section-{{ section.id }} .pbn__summary-label {
    font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
    opacity: 0.75;
  }
  .pbn.section-{{ section.id }} .pbn__total-row {
    display: flex; align-items: baseline; gap: 10px;
  }
  .pbn.section-{{ section.id }} .pbn__total {
    font-size: 32px; font-weight: 700; letter-spacing: -0.02em;
    font-family: {{ section.settings.total_font | default: 'var(--ff-heading)' }};
    line-height: 1;
  }
  .pbn.section-{{ section.id }} .pbn__original {
    font-size: 15px; opacity: 0.65; text-decoration: line-through;
  }
  .pbn.section-{{ section.id }} .pbn__savings {
    display: inline-flex; align-items: center;
    padding: 3px 10px;
    font-size: 11px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase;
    background: {{ section.settings.savings_background | default: 'var(--clr-accent)' }};
    color: {{ section.settings.savings_color | default: 'var(--clr-white)' }};
    border-radius: 999px;
    width: fit-content;
  }
  .pbn.section-{{ section.id }} .pbn__cta {
    display: inline-flex; align-items: center; justify-content: center;
    padding: 14px 28px;
    background: {{ section.settings.cta_background | default: 'var(--clr-white)' }};
    color: {{ section.settings.cta_color | default: 'var(--clr-primary)' }};
    border: none; border-radius: 999px;
    font-size: 14px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase;
    cursor: pointer;
    text-decoration: none;
    transition: opacity .15s, transform .1s;
  }
  .pbn.section-{{ section.id }} .pbn__cta:hover { opacity: 0.92; }
{%- endstyle -%}

<section class="pbn section-{{ section.id }}" {{ section.fluid_attributes }}>
  <div class="pbn__container">

    {%- assign eyebrow_blocks = section.blocks | where: 'type', 'eyebrow' -%}
    {%- assign heading_blocks = section.blocks | where: 'type', 'heading' -%}
    {%- assign subhead_blocks = section.blocks | where: 'type', 'subhead' -%}
    {%- assign bundle_blocks  = section.blocks | where: 'type', 'bundle_product' -%}

    {% if eyebrow_blocks.size > 0 or heading_blocks.size > 0 or subhead_blocks.size > 0 %}
      <div class="pbn__intro">
        {% for block in eyebrow_blocks %}<div class="rte" {{ block.fluid_attributes }}>{{ block.settings.text }}</div>{% endfor %}
        {% for block in heading_blocks %}<div class="rte" {{ block.fluid_attributes }}>{{ block.settings.text }}</div>{% endfor %}
        {% for block in subhead_blocks %}<div class="rte" {{ block.fluid_attributes }}>{{ block.settings.text }}</div>{% endfor %}
      </div>
    {% endif %}

    {% if bundle_blocks.size > 0 %}
      <div class="pbn__layout">

        <div class="pbn__cards">
          {% for block in bundle_blocks %}
            {%- assign p = block.settings.product -%}
            {%- assign _title = block.settings.title_override | default: p.title | default: 'Product' -%}
            {%- assign _price = block.settings.price_override | default: p.price -%}
            {%- assign _img   = '' -%}
            {%- if block.settings.image_override -%}{%- assign _img = block.settings.image_override | img_url: '600x' -%}
            {%- elsif p.images and p.images.size > 0 -%}{%- assign _img = p.images[0].src -%}
            {%- elsif p.image_url != blank -%}{%- assign _img = p.image_url -%}
            {%- endif -%}

            <div class="pbn__card{% if block.settings.selected_by_default %} is-selected{% endif %}" data-pbn-card data-price="{{ _price | default: 0 }}" {{ block.fluid_attributes }}>
              <span class="pbn__card-check"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>
              <div class="pbn__card-img">
                {% if _img != blank %}<img src="{{ _img }}" alt="{{ _title | escape }}" loading="lazy">{% else %}<div class="pbn__card-img-placeholder"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" width="40" height="40"><rect x="3" y="4" width="18" height="16" rx="2"/><circle cx="8.5" cy="10" r="1.5"/><path d="M3 16l5-4 4 3 4-5 5 6"/></svg></div>{% endif %}
              </div>
              <h3 class="pbn__card-title">{{ _title | escape }}</h3>
              <div class="pbn__card-price">{{ _price | default: '—' }}</div>
            </div>
            {% unless forloop.last %}<span class="pbn__plus" aria-hidden="true">+</span>{% endunless %}
          {% endfor %}
        </div>

        <div class="pbn__summary">
          <span class="pbn__summary-label">{{ section.settings.summary_label | default: 'Bundle total' | escape }}</span>
          <div class="pbn__total-row">
            <span class="pbn__total" data-pbn-total>{{ section.settings.currency_symbol | default: '$' }}0</span>
            {% if section.settings.show_original_price %}<span class="pbn__original" data-pbn-original>{{ section.settings.currency_symbol | default: '$' }}0</span>{% endif %}
          </div>
          {% if section.settings.bundle_discount_pct != blank %}
            <span class="pbn__savings">Save {{ section.settings.bundle_discount_pct }}%</span>
          {% endif %}
          {% if section.settings.cta_url != blank %}
            <a href="{{ section.settings.cta_url }}" class="pbn__cta">{{ section.settings.cta_label | default: 'Add bundle to cart' | escape }}</a>
          {% else %}
            <button type="button" class="pbn__cta">{{ section.settings.cta_label | default: 'Add bundle to cart' | escape }}</button>
          {% endif %}
        </div>

      </div>
    {% endif %}

  </div>
</section>

{% if bundle_blocks.size > 0 %}
<script>
(function () {
  function init(root) {
    var cards = root.querySelectorAll('[data-pbn-card]');
    var totalEl = root.querySelector('[data-pbn-total]');
    var origEl  = root.querySelector('[data-pbn-original]');
    var discountPct = parseFloat('{{ section.settings.bundle_discount_pct | default: 0 }}') || 0;
    var currency = '{{ section.settings.currency_symbol | default: "$" }}';

    function format(n) {
      if (n % 1 === 0) return currency + n;
      return currency + n.toFixed(2);
    }
    function update() {
      var subtotal = 0;
      cards.forEach(function (c) {
        if (c.classList.contains('is-selected')) {
          var p = parseFloat(c.getAttribute('data-price') || '0');
          if (!isNaN(p)) subtotal += p;
        }
      });
      var discounted = subtotal * (1 - discountPct / 100);
      if (totalEl) totalEl.textContent = format(Math.round(discounted));
      if (origEl && discountPct > 0) origEl.textContent = format(Math.round(subtotal));
      if (origEl && discountPct === 0) origEl.style.display = 'none';
    }
    cards.forEach(function (c) {
      c.addEventListener('click', function () {
        c.classList.toggle('is-selected');
        update();
      });
    });
    update();
  }
  function boot() { document.querySelectorAll('.section-{{ section.id }}').forEach(init); }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot); else boot();
})();
</script>
{% endif %}

{% schema %}
{
  "name": "Product Bundle",
  "tag": "section",
  "class": "product-bundle-section",
  "settings": [
    { "type": "header", "content": "Summary" },
    { "type": "text",   "id": "summary_label",       "label": "Summary label",       "default": "Bundle total" },
    { "type": "text",   "id": "bundle_discount_pct", "label": "Bundle discount %",   "default": "15",
      "info": "Percent off applied to the sum of selected items." },
    { "type": "text",   "id": "currency_symbol",     "label": "Currency symbol",     "default": "$" },
    { "type": "checkbox","id": "show_original_price","label": "Show original price (strikethrough)", "default": true },

    { "type": "header", "content": "CTA" },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "Add bundle to cart" },
    { "type": "url",  "id": "cta_url",   "label": "Button URL (optional)" },

    { "type": "header", "content": "Card" },
    { "type": "select", "id": "card_background",     "label": "Card background",        "options": "background_colors", "default": "var(--clr-white)" },
    { "type": "select", "id": "card_border",         "label": "Card border",            "options": "background_colors", "default": "var(--clr-gray)" },
    { "type": "select", "id": "card_active_border",  "label": "Active border color",    "options": "background_colors", "default": "var(--clr-primary)" },
    { "type": "select", "id": "card_active_ring",    "label": "Active ring color",      "options": "background_colors", "default": "var(--clr-primary)" },
    { "type": "select", "id": "card_check_color",    "label": "Check icon color",       "options": "background_colors", "default": "var(--clr-white)" },
    { "type": "select", "id": "title_color",         "label": "Title color",            "options": "background_colors", "default": "var(--clr-primary)" },
    { "type": "select", "id": "price_color",         "label": "Price color",            "options": "background_colors", "default": "var(--clr-primary)" },
    { "type": "select", "id": "plus_color",          "label": "Plus sign color",        "options": "background_colors", "default": "var(--clr-muted)" },

    { "type": "header", "content": "Summary Card" },
    { "type": "select", "id": "summary_background", "label": "Summary background", "options": "background_colors", "default": "var(--clr-primary)" },
    { "type": "select", "id": "summary_color",      "label": "Summary text",       "options": "background_colors", "default": "var(--clr-white)" },
    { "type": "select", "id": "total_font",         "label": "Total number font",  "options": "font_families",    "default": "var(--ff-heading)" },
    { "type": "select", "id": "savings_background", "label": "Savings pill bg",    "options": "background_colors", "default": "var(--clr-accent)" },
    { "type": "select", "id": "savings_color",      "label": "Savings pill text",  "options": "background_colors", "default": "var(--clr-white)" },
    { "type": "select", "id": "cta_background",     "label": "CTA background",     "options": "background_colors", "default": "var(--clr-white)" },
    { "type": "select", "id": "cta_color",          "label": "CTA text",           "options": "background_colors", "default": "var(--clr-primary)" },

    { "type": "header", "content": "Layout" },
    { "type": "select", "id": "intro_alignment", "label": "Intro Alignment", "default": "center",
      "options": [ { "value": "left", "label": "Left" }, { "value": "center", "label": "Center" }, { "value": "right", "label": "Right" } ]
    },

    { "type": "header", "content": "Container" },
    { "type": "select", "id": "container_max_width", "label": "Max Width", "default": "1280px",
      "options": [
        { "value": "1080px", "label": "Comfy (1080px)" },
        { "value": "1280px", "label": "Default (1280px)" },
        { "value": "1440px", "label": "Wide (1440px)" },
        { "value": "100%",   "label": "Full (100%)" }
      ]
    },
    { "type": "padding", "id": "container_padding", "label": "Container Padding" },
    { "type": "corner_radius", "id": "container_border_radius", "label": "Container Border Radius" },
    { "type": "select", "id": "container_background_color", "label": "Container Background Color", "options": "background_colors", "default": "transparent" },
    { "type": "image_picker", "id": "container_background_image", "label": "Container Background Image" },
    { "type": "select", "id": "container_overlay_color", "label": "Container Overlay Color", "options": "background_colors", "default": "transparent" },
    { "type": "range", "id": "container_overlay_opacity", "label": "Container Overlay Opacity", "min": 0, "max": 100, "step": 5, "default": 0, "unit": "%" },
    { "type": "range", "id": "container_border_width", "label": "Container Border Width", "min": 0, "max": 10, "step": 1, "default": 0, "unit": "px" },
    { "type": "select", "id": "container_border_color", "label": "Container Border Color", "options": "background_colors", "default": "var(--clr-primary)" },

    { "type": "header", "content": "Section Shell" },
    { "type": "padding", "id": "section_padding", "label": "Section Padding" },
    { "type": "corner_radius", "id": "section_border_radius", "label": "Section Border Radius" },
    { "type": "select", "id": "background_color", "label": "Background Color", "options": "background_colors", "default": "var(--clr-light)" },
    { "type": "image_picker", "id": "background_image", "label": "Background Image" },
    { "type": "range", "id": "section_border_width", "label": "Section Border Width", "min": 0, "max": 10, "step": 1, "default": 0, "unit": "px" },
    { "type": "select", "id": "section_border_color", "label": "Section Border Color", "options": "background_colors", "default": "var(--clr-primary)" }
  ],
  "blocks": [
    { "type": "eyebrow", "name": "Eyebrow",
      "settings": [ { "type": "richtext", "id": "text", "label": "Text", "default": "<h5 style=\"color: var(--clr-primary); text-transform: uppercase; letter-spacing: 0.08em;\">Complete the routine</h5>" } ]
    },
    { "type": "heading", "name": "Heading",
      "settings": [ { "type": "richtext", "id": "text", "label": "Text", "default": "<h2 style=\"color: var(--clr-primary);\">Save 15% when you bundle.</h2>" } ]
    },
    { "type": "subhead", "name": "Subhead",
      "settings": [ { "type": "richtext", "id": "text", "label": "Text", "default": "<p style=\"color: var(--clr-body); font-size: 16px;\">Hand-picked pairings, better together.</p>" } ]
    },
    { "type": "bundle_product", "name": "Bundle Item",
      "settings": [
        { "type": "product", "id": "product", "label": "Product (optional)",
          "info": "Pick a Fluid product to auto-fill title, price, and image. Overrides below take priority." },
        { "type": "text",     "id": "title_override", "label": "Title override" },
        { "type": "text",     "id": "price_override", "label": "Price override (number only, e.g. 29)" },
        { "type": "image_picker", "id": "image_override", "label": "Image override" },
        { "type": "checkbox", "id": "selected_by_default", "label": "Selected by default", "default": true }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Bundle",
      "blocks": [
        { "type": "eyebrow" },
        { "type": "heading" },
        { "type": "subhead" },
        { "type": "bundle_product", "settings": { "title_override": "This item",        "price_override": "29", "selected_by_default": true } },
        { "type": "bundle_product", "settings": { "title_override": "Daily Boost",      "price_override": "24", "selected_by_default": true } },
        { "type": "bundle_product", "settings": { "title_override": "Travel Pack",     "price_override": "18", "selected_by_default": true } }
      ]
    }
  ]
}
{% endschema %}
