</section>

<style>
.feature5-section .feature5-item-image {
  width: 64px;
  height: 64px;
  object-fit: cover;
  border-radius: 8px;
}

.feature5-section .feature5-icon-placeholder {
  width: 64px;
  height: 64px;
  background-color: #f3f4f6;
  border: 2px dashed #d1d5db;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6b7280;
}

.feature5-section .feature5-item {
  display: flex;
  flex-direction: column;
  height: 100%;
}

.feature5-section .feature5-buttons {
  margin-top: auto;
}

@media (max-width: 767px) {
  .feature5-section .feature5-header {
    margin-bottom: 48px;
  }
  
  .feature5-section .feature5-grid {
    gap: 48px;
  }
  
  .feature5-section .feature5-item-description {
    margin-bottom: 32px;
  }
}

@media (min-width: 768px) and (max-width: 1023px) {
  .feature5-section .feature5-grid {
    gap: 32px;
  }
}
</style>

{% schema %}
{
  "name": "Feature 5",
  "settings": [
    {
      "type": "richtext",
      "id": "tagline",
      "label": "Tagline",
      "info": "Optional tagline above the heading"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "info": "Optional main heading for the section"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "info": "Optional description below the heading"
    },
    {
      "type": "image_picker",
      "id": "feature_1_image",
      "label": "Feature 1 - Image"
    },
    {
      "type": "select",
      "id": "media_fit",
      "label": "Image Fit",
      "options": [
        {
          "value": "cover",
          "label": "Cover (Fill Container)"
        },
        {
          "value": "contain",
          "label": "Contain (Fit Inside)"
        },
        {
          "value": "fit-width",
          "label": "Fit to Width"
        },
        {
          "value": "fit-height",
          "label": "Fit to Height"
        }
      ],
      "default": "cover"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 0,
      "max": 2000,
      "step": 1,
      "label": "Max Width (px)",
      "info": "Leave empty for no limit"
    },
    {
      "type": "range",
      "id": "max_height",
      "min": 0,
      "max": 2000,
      "step": 1,
      "label": "Max Height (px)",
      "info": "Leave empty for no limit"
    },
    {
      "type": "corner_radius",
      "id": "media_border_radius",
      "label": "Image Border Radius",
      "info": "Override theme default media radius"
    },
    {
      "type": "text",
      "id": "feature_1_image_alt",
      "label": "Feature 1 - Image Alt Text",
      "info": "Describe the image for accessibility"
    },
    {
      "type": "richtext",
      "id": "feature_1_heading",
      "default": "<p>Medium length section heading goes here</p>",
      "label": "Feature 1 - Heading"
    },
    {
      "type": "richtext",
      "id": "feature_1_description",
