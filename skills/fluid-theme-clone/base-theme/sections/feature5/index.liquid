{%- style -%}
  .section-{{ section.id }} {
    {%- assign p = section.settings.section_padding -%}
    {%- if p -%}
      {%- capture pt -%}{{ p.top }}{%- endcapture -%}
      {%- capture pb -%}{{ p.bottom }}{%- endcapture -%}
      {%- capture pl -%}{{ p.left }}{%- endcapture -%}
      {%- capture pr -%}{{ p.right }}{%- endcapture -%}
      padding-top: {% if pt contains 'var(' %}{{ pt }}{% else %}{{ pt }}px{% endif %};
      padding-bottom: {% if pb contains 'var(' %}{{ pb }}{% else %}{{ pb }}px{% endif %};
      padding-left: {% if pl contains 'var(' %}{{ pl }}{% else %}{{ pl }}px{% endif %};
      padding-right: {% if pr contains 'var(' %}{{ pr }}{% else %}{{ pr }}px{% endif %};
    {%- endif -%}
    {%- assign sr = section.settings.section_border_radius -%}
    {%- if sr -%}
      {%- capture sr_tl -%}{{ sr.tl }}{%- endcapture -%}
      {%- capture sr_tr -%}{{ sr.tr }}{%- endcapture -%}
      {%- capture sr_br -%}{{ sr.br }}{%- endcapture -%}
      {%- capture sr_bl -%}{{ sr.bl }}{%- endcapture -%}
      border-radius: {% if sr_tl contains 'var(' %}{{ sr_tl }}{% else %}{{ sr_tl }}px{% endif %} {% if sr_tr contains 'var(' %}{{ sr_tr }}{% else %}{{ sr_tr }}px{% endif %} {% if sr_br contains 'var(' %}{{ sr_br }}{% else %}{{ sr_br }}px{% endif %} {% if sr_bl contains 'var(' %}{{ sr_bl }}{% else %}{{ sr_bl }}px{% endif %};
    {%- endif -%}
    {%- assign sb = section.settings.section_border -%}
    {%- if sb.width -%}
      border: {{ sb.width }} solid {{ sb.color }};
    {%- endif -%}
  }
{%- endstyle -%}

<section class="feature5-section section-{{ section.id }}" 
         style="background-color: {{ section.settings.background_color | default: '#ffffff' }};
                {% if section.settings.background_image != blank %}
                background-image: url('{{ section.settings.background_image | image_url: width: 1920 }}');
                background-size: cover;
                background-position: center;
                background-repeat: no-repeat;
                {% endif %}
                position: relative;">
  
  {%- assign ov = section.settings.overlay -%}
  {%- if ov and ov.enabled -%}
    <div class="overlay-{{ section.id }}"></div>
    {%- style -%}
      .overlay-{{ section.id }} {
        position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1;
        {%- if ov.mode == 'gradient' and ov.colors.size > 1 -%}
          background:
            {%- if ov.gradientType == 'radial' -%}
              radial-gradient(
            {%- else -%}
              linear-gradient({{ ov.angle }}deg,
            {%- endif -%}
            {%- for stop in ov.colors -%}
              {{ stop.color }} {{ stop.position }}%{%- unless forloop.last -%},{%- endunless -%}
            {%- endfor -%}
          );
          opacity: {{ ov.colors.first.opacity | divided_by: 100.0 }};
        {%- else -%}
          {%- assign c = ov.colors | first -%}
          background-color: {{ c.color }};
          opacity: {{ c.opacity | divided_by: 100.0 }};
        {%- endif -%}
      }
    {%- endstyle -%}
  {%- endif -%}
  
  <div class="container" style="position: relative; z-index: 2;">
    
    <!-- Header Section -->
    {% if section.settings.tagline != blank or section.settings.heading != blank or section.settings.description != blank %}
      <div class="feature5-header text-center mb-10xl">
        {% if section.settings.tagline != blank %}
          <div class="feature5-tagline rte mb-lg">
            {{ section.settings.tagline }}
          </div>
        {% endif %}
        
        {% if section.settings.heading != blank %}
          <div class="feature5__heading rte mb-2xl">{{ section.settings.heading }}</div>
        {% endif %}
        
        {% if section.settings.description != blank %}
          <div class="feature5-description rte max-w-3xl mx-auto">
            {{ section.settings.description }}
          </div>
        {% endif %}
      </div>
    {% endif %}

    <!-- Features Grid -->
    <div class="feature5-grid grid grid-cols-1 md-tab-grid-cols-2 sm-desktop-grid-cols-3 space-7xl">
      
      <!-- Feature 1 -->
      <div class="feature5-item text-center">
        <div class="feature5-icon mb-2xl flex justify-center">
              {% assign feature_1_image = section.settings.feature_1_image %}
              {% assign feature_1_fluid_media_id = '' %}
              
              {% if feature_1_image.fluid_media_id %}
                {% assign feature_1_fluid_media_id = feature_1_image.fluid_media_id %}
                {% assign feature_1_embed_type = feature_1_image.embed_type %}
              {% endif %}

              {% assign use_feature_1_fluid_image_widget = false %}
              
              {% if feature_1_fluid_media_id != blank %}
                {% assign use_feature_1_fluid_image_widget = true %}
              {% endif %}

              {% if use_feature_1_fluid_image_widget %}
                <fluid-media-widget class="fluid-media-widget-image" media-id="{{ feature_1_fluid_media_id }}" responsive="true" embed-type="{{ feature_1_embed_type | default:'inline' }}" data-fluid-widget="true"></fluid-media-widget>
              {% else %}
                {% if feature_1_image != blank %}
                    <img src="{{ feature_1_image | image_url }}" 
                      alt="{{ section.settings.feature_1_image_alt | default: section.settings.feature_1_heading }}" 
                      class="feature5-item-image" loading="lazy" width="" height=""/>
                {% else %}
                  <div class="feature5-icon-placeholder">
                    <svg width="48" height="48" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M21 16.5c0 .38-.21.71-.53.88l-7.9 4.44c-.16.12-.36.18-.57.18-.21 0-.41-.06-.57-.18l-7.9-4.44A.991.991 0 0 1 3 16.5v-9c0-.38.21-.71.53-.88l7.9-4.44c.16-.12.36-.18.57-.18.21 0 .41.06.57.18l7.9 4.44c.32.17.53.5.53.88v9z"/>
                    </svg>
                  </div>
                {% endif %}
              {% endif %}
        </div>
        
        <div class="feature5-item-heading rte mb-lg">
          {{ section.settings.feature_1_heading | default: '<p>Medium length section heading goes here</p>' }}
        </div>
        
        <div class="feature5-item-description rte mb-4xl">
          {{ section.settings.feature_1_description | default: '<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique. Duis cursus, mi quis viverra ornare, eros dolor interdum nulla.</p>' }}
        </div>
        
        <div class="feature5-buttons flex flex-wrap gap-md justify-center">
          {% if section.settings.feature_1_primary_button_text != blank %}
            {%- assign cr = section.settings.feature_1_primary_button_border_radius -%}{%- assign _cr_attr = '' -%}{%- if cr -%}{%- capture cr_tl -%}{{ cr.tl }}{%- endcapture -%}{%- capture cr_tr -%}{{ cr.tr }}{%- endcapture -%}{%- capture cr_br -%}{{ cr.br }}{%- endcapture -%}{%- capture cr_bl -%}{{ cr.bl }}{%- endcapture -%}{%- capture _br_val -%}{% if cr_tl contains 'var(' %}{{ cr_tl }}{% else %}{{ cr_tl }}px{% endif %} {% if cr_tr contains 'var(' %}{{ cr_tr }}{% else %}{{ cr_tr }}px{% endif %} {% if cr_br contains 'var(' %}{{ cr_br }}{% else %}{{ cr_br }}px{% endif %} {% if cr_bl contains 'var(' %}{{ cr_bl }}{% else %}{{ cr_bl }}px{% endif %}{%- endcapture -%}{%- assign _cr_attr = 'style="border-radius: ' | append: _br_val | append: ';"' -%}{%- endif -%}
            {% render 'button', href: section.settings.feature_1_primary_button_link | default: '#', text: section.settings.feature_1_primary_button_text, variant: section.settings.feature_1_primary_button_style | default: 'btn-bg-primary', attr: _cr_attr %}
          {% endif %}

          {% if section.settings.feature_1_secondary_button_text != blank %}
            {%- assign cr = section.settings.feature_1_secondary_button_border_radius -%}{%- assign _cr_attr = '' -%}{%- if cr -%}{%- capture cr_tl -%}{{ cr.tl }}{%- endcapture -%}{%- capture cr_tr -%}{{ cr.tr }}{%- endcapture -%}{%- capture cr_br -%}{{ cr.br }}{%- endcapture -%}{%- capture cr_bl -%}{{ cr.bl }}{%- endcapture -%}{%- capture _br_val -%}{% if cr_tl contains 'var(' %}{{ cr_tl }}{% else %}{{ cr_tl }}px{% endif %} {% if cr_tr contains 'var(' %}{{ cr_tr }}{% else %}{{ cr_tr }}px{% endif %} {% if cr_br contains 'var(' %}{{ cr_br }}{% else %}{{ cr_br }}px{% endif %} {% if cr_bl contains 'var(' %}{{ cr_bl }}{% else %}{{ cr_bl }}px{% endif %}{%- endcapture -%}{%- assign _cr_attr = 'style="border-radius: ' | append: _br_val | append: ';"' -%}{%- endif -%}
            {% render 'button', href: section.settings.feature_1_secondary_button_link | default: '#', text: section.settings.feature_1_secondary_button_text, variant: section.settings.feature_1_secondary_button_style | default: 'btn-border-black', attr: _cr_attr %}
          {% endif %}
        </div>
      </div>

      <!-- Feature 2 -->
      <div class="feature5-item text-center">
        <div class="feature5-icon mb-2xl flex justify-center">
          {% assign feature_2_image = section.settings.feature_2_image %}
              {% assign feature_2_fluid_media_id = '' %}
              
              {% if feature_2_image.fluid_media_id %}
                {% assign feature_2_fluid_media_id = feature_2_image.fluid_media_id %}
                {% assign feature_2_embed_type = feature_2_image.embed_type %}
              {% endif %}

              {% assign use_feature_2_fluid_image_widget = false %}
              
              {% if feature_2_fluid_media_id != blank %}
                {% assign use_feature_2_fluid_image_widget = true %}
              {% endif %}

              {% if use_feature_2_fluid_image_widget %}
                <fluid-media-widget class="fluid-media-widget-image" media-id="{{ feature_2_fluid_media_id }}" responsive="true" embed-type="{{ feature_2_embed_type | default:'inline' }}" data-fluid-widget="true"></fluid-media-widget>
              {% else %}
                {% if feature_2_image != blank %}
                    <img src="{{ feature_2_image | image_url }}" 
                      alt="{{ section.settings.feature_2_image_alt | default: section.settings.feature_2_heading }}" 
                      class="feature5-item-image" loading="lazy" width="" height=""/>
                {% else %}
                  <div class="feature5-icon-placeholder">
                    <svg width="48" height="48" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M21 16.5c0 .38-.21.71-.53.88l-7.9 4.44c-.16.12-.36.18-.57.18-.21 0-.41-.06-.57-.18l-7.9-4.44A.991.991 0 0 1 3 16.5v-9c0-.38.21-.71.53-.88l7.9-4.44c.16-.12.36-.18.57-.18.21 0 .41.06.57.18l7.9 4.44c.32.17.53.5.53.88v9z"/>
                    </svg>
                  </div>
                {% endif %}
              {% endif %}
        </div>
        
        <div class="feature5-item-heading rte mb-lg">
          {{ section.settings.feature_2_heading | default: '<p>Medium length section heading goes here</p>' }}
        </div>
        
        <div class="feature5-item-description rte mb-4xl">
          {{ section.settings.feature_2_description | default: '<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique. Duis cursus, mi quis viverra ornare, eros dolor interdum nulla.</p>' }}
        </div>
        
        <div class="feature5-buttons flex flex-wrap gap-md justify-center">
          {% if section.settings.feature_2_primary_button_text != blank %}
            {%- assign cr = section.settings.feature_2_primary_button_border_radius -%}{%- assign _cr_attr = '' -%}{%- if cr -%}{%- capture cr_tl -%}{{ cr.tl }}{%- endcapture -%}{%- capture cr_tr -%}{{ cr.tr }}{%- endcapture -%}{%- capture cr_br -%}{{ cr.br }}{%- endcapture -%}{%- capture cr_bl -%}{{ cr.bl }}{%- endcapture -%}{%- capture _br_val -%}{% if cr_tl contains 'var(' %}{{ cr_tl }}{% else %}{{ cr_tl }}px{% endif %} {% if cr_tr contains 'var(' %}{{ cr_tr }}{% else %}{{ cr_tr }}px{% endif %} {% if cr_br contains 'var(' %}{{ cr_br }}{% else %}{{ cr_br }}px{% endif %} {% if cr_bl contains 'var(' %}{{ cr_bl }}{% else %}{{ cr_bl }}px{% endif %}{%- endcapture -%}{%- assign _cr_attr = 'style="border-radius: ' | append: _br_val | append: ';"' -%}{%- endif -%}
            {% render 'button', href: section.settings.feature_2_primary_button_link | default: '#', text: section.settings.feature_2_primary_button_text, variant: section.settings.feature_2_primary_button_style | default: 'btn-bg-primary', attr: _cr_attr %}
          {% endif %}

          {% if section.settings.feature_2_secondary_button_text != blank %}
            {%- assign cr = section.settings.feature_2_secondary_button_border_radius -%}{%- assign _cr_attr = '' -%}{%- if cr -%}{%- capture cr_tl -%}{{ cr.tl }}{%- endcapture -%}{%- capture cr_tr -%}{{ cr.tr }}{%- endcapture -%}{%- capture cr_br -%}{{ cr.br }}{%- endcapture -%}{%- capture cr_bl -%}{{ cr.bl }}{%- endcapture -%}{%- capture _br_val -%}{% if cr_tl contains 'var(' %}{{ cr_tl }}{% else %}{{ cr_tl }}px{% endif %} {% if cr_tr contains 'var(' %}{{ cr_tr }}{% else %}{{ cr_tr }}px{% endif %} {% if cr_br contains 'var(' %}{{ cr_br }}{% else %}{{ cr_br }}px{% endif %} {% if cr_bl contains 'var(' %}{{ cr_bl }}{% else %}{{ cr_bl }}px{% endif %}{%- endcapture -%}{%- assign _cr_attr = 'style="border-radius: ' | append: _br_val | append: ';"' -%}{%- endif -%}
            {% render 'button', href: section.settings.feature_2_secondary_button_link | default: '#', text: section.settings.feature_2_secondary_button_text, variant: section.settings.feature_2_secondary_button_style | default: 'btn-border-black', attr: _cr_attr %}
          {% endif %}
        </div>
      </div>

      <!-- Feature 3 -->
      <div class="feature5-item text-center">
        <div class="feature5-icon mb-2xl flex justify-center">
          {% assign feature_3_image = section.settings.feature_3_image %}
              {% assign feature_3_fluid_media_id = '' %}
              
              {% if feature_3_image.fluid_media_id %}
                {% assign feature_3_fluid_media_id = feature_3_image.fluid_media_id %}
                {% assign feature_3_embed_type = feature_3_image.embed_type %}
              {% endif %}

              {% assign use_feature_3_fluid_image_widget = false %}
              
              {% if feature_3_fluid_media_id != blank %}
                {% assign use_feature_3_fluid_image_widget = true %}
              {% endif %}

              {% if use_feature_3_fluid_image_widget %}
                <fluid-media-widget class="fluid-media-widget-image" media-id="{{ feature_3_fluid_media_id }}" responsive="true" embed-type="{{ feature_3_embed_type | default:'inline' }}" data-fluid-widget="true"></fluid-media-widget>
              {% else %}
                {% if feature_3_image != blank %}
                    <img src="{{ feature_3_image | image_url }}" 
                      alt="{{ section.settings.feature_3_image_alt | default: section.settings.feature_3_heading }}" 
                      class="feature5-item-image" loading="lazy" width="" height=""/>
                {% else %}
                  <div class="feature5-icon-placeholder">
                    <svg width="48" height="48" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M21 16.5c0 .38-.21.71-.53.88l-7.9 4.44c-.16.12-.36.18-.57.18-.21 0-.41-.06-.57-.18l-7.9-4.44A.991.991 0 0 1 3 16.5v-9c0-.38.21-.71.53-.88l7.9-4.44c.16-.12.36-.18.57-.18.21 0 .41.06.57.18l7.9 4.44c.32.17.53.5.53.88v9z"/>
                    </svg>
                  </div>
                {% endif %}
              {% endif %}
        </div>
        
        <div class="feature5-item-heading rte mb-lg">
          {{ section.settings.feature_3_heading | default: '<p>Medium length section heading goes here</p>' }}
        </div>
        
        <div class="feature5-item-description rte mb-4xl">
          {{ section.settings.feature_3_description | default: '<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique. Duis cursus, mi quis viverra ornare, eros dolor interdum nulla.</p>' }}
        </div>
        
        <div class="feature5-buttons flex flex-wrap gap-md justify-center">
          {% if section.settings.feature_3_primary_button_text != blank %}
            {%- assign cr = section.settings.feature_3_primary_button_border_radius -%}{%- assign _cr_attr = '' -%}{%- if cr -%}{%- capture cr_tl -%}{{ cr.tl }}{%- endcapture -%}{%- capture cr_tr -%}{{ cr.tr }}{%- endcapture -%}{%- capture cr_br -%}{{ cr.br }}{%- endcapture -%}{%- capture cr_bl -%}{{ cr.bl }}{%- endcapture -%}{%- capture _br_val -%}{% if cr_tl contains 'var(' %}{{ cr_tl }}{% else %}{{ cr_tl }}px{% endif %} {% if cr_tr contains 'var(' %}{{ cr_tr }}{% else %}{{ cr_tr }}px{% endif %} {% if cr_br contains 'var(' %}{{ cr_br }}{% else %}{{ cr_br }}px{% endif %} {% if cr_bl contains 'var(' %}{{ cr_bl }}{% else %}{{ cr_bl }}px{% endif %}{%- endcapture -%}{%- assign _cr_attr = 'style="border-radius: ' | append: _br_val | append: ';"' -%}{%- endif -%}
            {% render 'button', href: section.settings.feature_3_primary_button_link | default: '#', text: section.settings.feature_3_primary_button_text, variant: section.settings.feature_3_primary_button_style | default: 'btn-bg-primary', attr: _cr_attr %}
          {% endif %}

          {% if section.settings.feature_3_secondary_button_text != blank %}
            {%- assign cr = section.settings.feature_3_secondary_button_border_radius -%}{%- assign _cr_attr = '' -%}{%- if cr -%}{%- capture cr_tl -%}{{ cr.tl }}{%- endcapture -%}{%- capture cr_tr -%}{{ cr.tr }}{%- endcapture -%}{%- capture cr_br -%}{{ cr.br }}{%- endcapture -%}{%- capture cr_bl -%}{{ cr.bl }}{%- endcapture -%}{%- capture _br_val -%}{% if cr_tl contains 'var(' %}{{ cr_tl }}{% else %}{{ cr_tl }}px{% endif %} {% if cr_tr contains 'var(' %}{{ cr_tr }}{% else %}{{ cr_tr }}px{% endif %} {% if cr_br contains 'var(' %}{{ cr_br }}{% else %}{{ cr_br }}px{% endif %} {% if cr_bl contains 'var(' %}{{ cr_bl }}{% else %}{{ cr_bl }}px{% endif %}{%- endcapture -%}{%- assign _cr_attr = 'style="border-radius: ' | append: _br_val | append: ';"' -%}{%- endif -%}
            {% render 'button', href: section.settings.feature_3_secondary_button_link | default: '#', text: section.settings.feature_3_secondary_button_text, variant: section.settings.feature_3_secondary_button_style | default: 'btn-border-black', attr: _cr_attr %}
