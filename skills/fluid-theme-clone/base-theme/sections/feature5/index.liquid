      "label": "Feature 1 - Primary Button Link"
    },
    {
      "type": "select",
      "id": "feature_1_primary_button_style",
      "label": "Feature 1 - Primary Button Style",
      "options": [
        {
          "value": "btn-bg-white",
          "label": "White"
        },
        {
          "value": "btn-bg-primary",
          "label": "Primary"
        },
        {
          "value": "btn-border-white",
          "label": "White Border"
        },
        {
          "value": "btn-border-black",
          "label": "Black Border"
        },
        {
          "value": "btn-border-primary",
