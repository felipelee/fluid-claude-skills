{%- style -%}
  .section-{{ section.id }} {
    {%- assign p = section.settings.section_padding -%}
    {%- if p -%}
      {%- capture pt -%}{{ p.top }}{%- endcapture -%}
      {%- capture pb -%}{{ p.bottom }}{%- endcapture -%}
      {%- capture pl -%}{{ p.left }}{%- endcapture -%}
      {%- capture pr -%}{{ p.right }}{%- endcapture -%}
      padding-top: {% if pt contains 'var(' %}{{ pt }}{% else %}{{ pt }}px{% endif %};
      padding-bottom: {% if pb contains 'var(' %}{{ pb }}{% else %}{{ pb }}px{% endif %};
      padding-left: {% if pl contains 'var(' %}{{ pl }}{% else %}{{ pl }}px{% endif %};
      padding-right: {% if pr contains 'var(' %}{{ pr }}{% else %}{{ pr }}px{% endif %};
    {%- endif -%}
    {%- assign sr = section.settings.section_border_radius -%}
    {%- if sr -%}
      {%- capture sr_tl -%}{{ sr.tl }}{%- endcapture -%}
      {%- capture sr_tr -%}{{ sr.tr }}{%- endcapture -%}
      {%- capture sr_br -%}{{ sr.br }}{%- endcapture -%}
      {%- capture sr_bl -%}{{ sr.bl }}{%- endcapture -%}
      border-radius: {% if sr_tl contains 'var(' %}{{ sr_tl }}{% else %}{{ sr_tl }}px{% endif %} {% if sr_tr contains 'var(' %}{{ sr_tr }}{% else %}{{ sr_tr }}px{% endif %} {% if sr_br contains 'var(' %}{{ sr_br }}{% else %}{{ sr_br }}px{% endif %} {% if sr_bl contains 'var(' %}{{ sr_bl }}{% else %}{{ sr_bl }}px{% endif %};
    {%- endif -%}
  }
{%- endstyle -%}

<section class="logo2-section section-{{ section.id }}" 
         style="background-color: {{ section.settings.background_color | default: '#ffffff' }};
                {% if section.settings.background_image != blank %}
                background-image: url('{{ section.settings.background_image | image_url: width: 1920 }}');
                background-size: cover;
                background-position: center;
                background-repeat: no-repeat;
                {% endif %}
                position: relative;">
  
  {%- assign ov = section.settings.overlay -%}
  {%- if ov and ov.enabled -%}
    <div class="overlay-{{ section.id }}"></div>
    {%- style -%}
      .overlay-{{ section.id }} {
        position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1;
        {%- if ov.mode == 'gradient' and ov.colors.size > 1 -%}
          background:
            {%- if ov.gradientType == 'radial' -%}
              radial-gradient(
            {%- else -%}
              linear-gradient({{ ov.angle }}deg,
            {%- endif -%}
            {%- for stop in ov.colors -%}
              {{ stop.color }} {{ stop.position }}%{%- unless forloop.last -%},{%- endunless -%}
            {%- endfor -%}
          );
          opacity: {{ ov.colors.first.opacity | divided_by: 100.0 }};
        {%- else -%}
          {%- assign c = ov.colors | first -%}
          background-color: {{ c.color }};
          opacity: {{ c.opacity | divided_by: 100.0 }};
        {%- endif -%}
      }
    {%- endstyle -%}
  {%- endif -%}
  
  <!-- Edge-to-Edge Scrolling Logos -->
  <div class="logo2-scroll-container" style="position: relative; z-index: 2;">
    <div class="logo2-scroll-track">
      
      <!-- First Set of Logos -->
      {% for i in (1..12) %}
        {% assign logo_image = 'logo_' | append: i | append: '_image' %}
        {% assign logo_alt = 'logo_' | append: i | append: '_alt' %}
        {% assign logo_link = 'logo_' | append: i | append: '_link' %}
        
        <div class="logo2-item">
          {% if section.settings[logo_image] != blank %}
            {% if section.settings[logo_link] != blank %}
              <a href="{{ section.settings[logo_link] }}" class="logo2-link">
            {% endif %}
            <img src="{{ section.settings[logo_image] | image_url: width: 200 }}" 
                 alt="{{ section.settings[logo_alt] | default: 'Company logo' }}"
                 class="logo2-image">
            {% if section.settings[logo_link] != blank %}
              </a>
            {% endif %}
          {% else %}
            <div class="logo2-placeholder">
              <svg width="80" height="40" fill="currentColor" viewBox="0 0 24 24">
                <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
              </svg>
              <p class="text-xs" style="margin-top: 4px; color: #9ca3af;">Logo {{ i }}</p>
            </div>
          {% endif %}
        </div>
      {% endfor %}

      <!-- Duplicate Set for Seamless Loop -->
      {% for i in (1..12) %}
        {% assign logo_image = 'logo_' | append: i | append: '_image' %}
        {% assign logo_alt = 'logo_' | append: i | append: '_alt' %}
        {% assign logo_link = 'logo_' | append: i | append: '_link' %}
        
        <div class="logo2-item">
          {% if section.settings[logo_image] != blank %}
            {% if section.settings[logo_link] != blank %}
              <a href="{{ section.settings[logo_link] }}" class="logo2-link">
            {% endif %}
            <img src="{{ section.settings[logo_image] | image_url: width: 200 }}" 
                 alt="{{ section.settings[logo_alt] | default: 'Company logo' }}"
                 class="logo2-image">
            {% if section.settings[logo_link] != blank %}
              </a>
            {% endif %}
          {% else %}
            <div class="logo2-placeholder">
              <svg width="80" height="40" fill="currentColor" viewBox="0 0 24 24">
                <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
              </svg>
              <p class="text-xs" style="margin-top: 4px; color: #9ca3af;">Logo {{ i }}</p>
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
.logo2-section .logo2-scroll-container {
  width: 100vw;
  margin-left: calc(-50vw + 50%);
  overflow: hidden;
  padding: 0 40px;
}

.logo2-section .logo2-scroll-track {
  display: flex;
  gap: 48px;
  animation: logo-scroll 60s linear infinite;
  width: max-content;
}

.logo2-section .logo2-scroll-track:hover {
  animation-play-state: paused;
}

.logo2-section .logo2-item {
  flex: 0 0 200px;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100px;
}

.logo2-section .logo2-image {
  max-width: 160px;
  max-height: 80px;
  width: auto;
  height: auto;
  object-fit: contain;
  filter: {{ section.settings.logo_filter | default: 'none' }};
  transition: filter 0.3s ease;
}

.logo2-section .logo2-link:hover .logo2-image {
  filter: none;
  opacity: 0.8;
}

.logo2-section .logo2-placeholder {
  width: 160px;
  height: 80px;
  background-color: #f3f4f6;
  border: 2px dashed #d1d5db;
  border-radius: 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #9ca3af;
}

@keyframes logo-scroll {
  from {
    transform: translateX(0);
  }
  to {
    transform: translateX(-50%);
  }
}

@media (max-width: 1023px) {
  .logo2-section .logo2-scroll-container {
    padding: 0 24px;
  }
  
  .logo2-section .logo2-scroll-track {
    gap: 32px;
    animation-duration: 50s;
  }
  
  .logo2-section .logo2-item {
    flex: 0 0 160px;
    height: 80px;
  }
  
  .logo2-section .logo2-image {
    max-width: 120px;
    max-height: 60px;
  }
  
  .logo2-section .logo2-placeholder {
    width: 120px;
    height: 60px;
  }
}

@media (max-width: 767px) {
  .logo2-section .logo2-scroll-container {
    padding: 0 20px;
  }
  
  .logo2-section .logo2-scroll-track {
    gap: 24px;
    animation-duration: 45s;
  }
  
  .logo2-section .logo2-item {
    flex: 0 0 120px;
    height: 60px;
  }
  
  .logo2-section .logo2-image {
    max-width: 100px;
    max-height: 50px;
  }
  
  .logo2-section .logo2-placeholder {
    width: 100px;
    height: 50px;
  }
}
</style>

