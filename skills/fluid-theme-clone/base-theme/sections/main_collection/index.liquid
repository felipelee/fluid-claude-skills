{% comment %}
  sections/main_collection/index.liquid

  Collection carousel section with block-driven structure.
  Blocks:
    section_header   → collection title + optional view-all button
    product_carousel → product carousel display with typography controls
{% endcomment %}

{% assign carousel_id = section.id | append: '-carousel-' | append: collection.handle | append: '-' | append: collection.id %}
<div class="container" id="dummy-container"></div>

{% comment %} ── Defaults ──────────────────────────────────────────────────── {% endcomment %}
{%- assign show_collection_title          = true -%}
{%- assign title_font_weight              = 'font-bold' -%}
{%- assign title_color                    = '#000000' -%}

{%- assign show_view_all_button           = true -%}
{%- assign view_all_button_text           = 'View All' -%}
{%- assign button_style                   = 'btn-border-black' -%}
{%- assign button_background_color        = 'transparent' -%}
{%- assign button_text_color              = '#000000' -%}
{%- assign button_border                  = nil -%}

{%- assign products_limit                 = 6 -%}
{%- assign show_product_variant           = true -%}
{%- assign hide_price                     = false -%}
{%- assign show_carousel_arrows           = true -%}
{%- assign arrow_color                    = '#000000' -%}
{%- assign arrow_size                     = 48 -%}

{%- assign product_title_font_weight      = 'font-semibold' -%}
{%- assign product_title_color            = '#000000' -%}

{%- assign product_variant_font_size        = 'text-sm' -%}
{%- assign product_variant_font_size_desktop = 'xl-tab-text-sm' -%}
{%- assign product_variant_font_weight      = 'font-normal' -%}
{%- assign product_variant_color            = '#666666' -%}

{%- assign product_price_font_size        = 'text-lg' -%}
{%- assign product_price_font_size_desktop = 'xl-tab-text-xl' -%}
{%- assign product_price_font_weight      = 'font-bold' -%}
{%- assign product_price_color            = '#000000' -%}

{% comment %} ── Extract block settings ───────────────────────────────────── {% endcomment %}
{%- for block in section.blocks -%}
  {%- if block.type == 'section_header' -%}
    {%- assign section_header_block = block -%}
    {%- assign show_collection_title   = block.settings.show_collection_title -%}
    {%- assign title_heading_tag        = block.settings.title_heading_tag | default: 'h2' -%}
    {%- assign title_font_weight       = block.settings.title_font_weight | default: 'font-bold' -%}
    {%- assign title_color             = block.settings.title_color | default: '#000000' -%}
    {%- assign show_view_all_button    = block.settings.show_view_all_button -%}
    {%- assign view_all_button_text    = block.settings.view_all_button_text | default: 'View All' -%}
    {%- assign button_style            = block.settings.button_style | default: 'btn-border-black' -%}
    {%- assign button_background_color = block.settings.button_background_color | default: 'transparent' -%}
    {%- assign button_text_color       = block.settings.button_text_color | default: '#000000' -%}
    {%- assign button_border           = block.settings.button_border -%}

  {%- elsif block.type == 'product_carousel' -%}
    {%- assign product_carousel_block            = block -%}
    {%- assign products_limit                    = block.settings.products_limit | default: 6 -%}
    {%- assign show_product_variant              = block.settings.show_product_variant -%}
    {%- assign hide_price                        = block.settings.hide_price -%}
    {%- assign show_carousel_arrows              = block.settings.show_carousel_arrows -%}
    {%- assign arrow_color                       = block.settings.arrow_color | default: '#000000' -%}
    {%- assign arrow_size                        = block.settings.arrow_size | default: 48 -%}
    {%- assign product_title_tag                 = block.settings.product_title_tag | default: 'h5' -%}
    {%- assign product_title_font_weight         = block.settings.product_title_font_weight | default: 'font-semibold' -%}
    {%- assign product_title_color               = block.settings.product_title_color | default: '#000000' -%}
    {%- assign product_variant_font_size         = block.settings.product_variant_font_size | default: 'text-sm' -%}
    {%- assign product_variant_font_size_desktop = block.settings.product_variant_font_size_desktop | default: 'xl-tab-text-sm' -%}
    {%- assign product_variant_font_weight       = block.settings.product_variant_font_weight | default: 'font-normal' -%}
    {%- assign product_variant_color             = block.settings.product_variant_color | default: '#666666' -%}
    {%- assign product_price_font_size           = block.settings.product_price_font_size | default: 'text-lg' -%}
    {%- assign product_price_font_size_desktop   = block.settings.product_price_font_size_desktop | default: 'xl-tab-text-xl' -%}
    {%- assign product_price_font_weight         = block.settings.product_price_font_weight | default: 'font-bold' -%}
    {%- assign product_price_color               = block.settings.product_price_color | default: '#000000' -%}
  {%- endif -%}
{%- endfor -%}

{%- style -%}
  .section-{{ section.id }} {
    {%- assign p = section.settings.section_padding -%}
    {%- if p -%}
      {%- capture pt -%}{{ p.top }}{%- endcapture -%}
      {%- capture pb -%}{{ p.bottom }}{%- endcapture -%}
      {%- capture pl -%}{{ p.left }}{%- endcapture -%}
      {%- capture pr -%}{{ p.right }}{%- endcapture -%}
      padding-top: {% if pt contains 'var(' %}{{ pt }}{% else %}{{ pt }}px{% endif %};
      padding-bottom: {% if pb contains 'var(' %}{{ pb }}{% else %}{{ pb }}px{% endif %};
      padding-left: {% if pl contains 'var(' %}{{ pl }}{% else %}{{ pl }}px{% endif %};
      padding-right: {% if pr contains 'var(' %}{{ pr }}{% else %}{{ pr }}px{% endif %};
    {%- endif -%}
    background-color: {{ section.settings.background_color | default: 'transparent' }};
    {%- assign sr = section.settings.section_border_radius -%}
    {%- if sr -%}
      {%- capture sr_tl -%}{{ sr.tl }}{%- endcapture -%}
      {%- capture sr_tr -%}{{ sr.tr }}{%- endcapture -%}
      {%- capture sr_br -%}{{ sr.br }}{%- endcapture -%}
      {%- capture sr_bl -%}{{ sr.bl }}{%- endcapture -%}
      border-radius: {% if sr_tl contains 'var(' %}{{ sr_tl }}{% else %}{{ sr_tl }}px{% endif %} {% if sr_tr contains 'var(' %}{{ sr_tr }}{% else %}{{ sr_tr }}px{% endif %} {% if sr_br contains 'var(' %}{{ sr_br }}{% else %}{{ sr_br }}px{% endif %} {% if sr_bl contains 'var(' %}{{ sr_bl }}{% else %}{{ sr_bl }}px{% endif %};
    {%- endif -%}
  }
{%- endstyle -%}

{% for collection in collections %}
    <section class="product-collection-section section-t-spacing section-{{ section.id }}">

        {%- if section_header_block -%}
            <div class="header-section" {{ section_header_block.fluid_attributes }}>
                <div class="container">
                    <div class="wrapper flex flex-wrap align-end">
                        {%- if show_collection_title -%}
                            <div class="desc">
                               
                                <{{ title_heading_tag | default: 'h2' }}
                                    class="{{ title_font_weight }}"
                                    style="color: {{ title_color }};">
                                    {{ collection.title | default: 'Collection' }}
                                </{{ title_heading_tag | default: 'h2' }}>
                            </div>
                        {%- endif -%}
                        {%- if show_view_all_button -%}
                            <div class="btn-section text-right hidden sm-desktop-block">
                                <a href="{{ collection.url }}"
                                    class="btn text-center {{ button_style }}"
                                    style="
                                    background-color: {{ button_background_color }};
                                    color: {{ button_text_color }};
                                    {%- if button_border -%}border: {{ button_border.width }} solid {{ button_border.color }};{%- endif -%}
                                    ">
                                    {{ view_all_button_text }}
                                </a>
                            </div>
                        {%- endif -%}
                    </div>
                </div>
            </div>
            <!-- .header-section -->
        {%- endif -%}

        {%- if product_carousel_block -%}
        <div class="product-list-section carousel-container mt-12" {{ product_carousel_block.fluid_attributes }}>
            <div class="container">
                <div class="product-carousel {{ carousel_id }} splide" data-carousel-id="{{ carousel_id }}">
                    <div class="splide__track">
                        <ul class="splide__list">
                            {% for product in collection.products limit: products_limit %}
                                <li class="splide__slide">
                                    <div class="carousel-product">
                                        <div class="image-section">
                                            {% if product.images.size > 0 %}
                                                <img
                                                src="{{ product.images[0].src }}"
                                                alt="{{ product.title }}"
                                                class="image-cover"
                                                />
                                            {% else %}
                                                <img
                                                src="{{ product.image | image_url }}"
                                                alt="{{ product.title }}"
                                                class="image-cover"
                                                />
                                            {% endif %}
                                        </div>
                                        <div class="desc pt-4">
                                            <{{ product_title_tag }} class="{{ product_title_font_weight }}"
                                                style="color: {{ product_title_color }};">
                                                {{ product.title }}
                                            </{{ product_title_tag }}>
                                            {% if show_product_variant %}
                                                <p class="{{ product_variant_font_size }} {{ product_variant_font_size_desktop }} {{ product_variant_font_weight }} pt-1"
                                                    style="color: {{ product_variant_color }};">
                                                    Variant
                                                </p>
                                            {% endif %}
                                            {% unless hide_price %}
                                                <div class="{{ product_price_font_size }} {{ product_price_font_size_desktop }} {{ product_price_font_weight }} pt-2"
                                                    style="color: {{ product_price_color }};">
                                                    {{ product.price }}
                                                </div>
                                            {% endunless %}
                                        </div>
                                    </div>
                                </li>
                            {% endfor %}
                        </ul>
                    </div>

                    {% if show_carousel_arrows %}
                    <div class="splide__arrows splide-arrow-section mt-12">
                        <button class="slide-arrow splide__arrow splide__arrow--prev arrow-prev-btn"
                                style="
                                color: {{ arrow_color }};
                                width: {{ arrow_size }}px;
                                height: {{ arrow_size }}px;
                                ">
                            <svg
                                width="{{ arrow_size | default: 24 }}"
                                height="{{ arrow_size | default: 25 }}"
                                viewBox="0 0 24 25"
                                fill="none"
                                xmlns="http://www.w3.org/2000/svg"
                            >
                                <path
                                d="M20 11.4004H7.83L13.42 5.81039L12 4.40039L4 12.4004L12 20.4004L13.41 18.9904L7.83 13.4004H20V11.4004Z"
                                fill="{{ arrow_color }}"
                                />
                            </svg>
                        </button>
                        <button class="slide-arrow splide__arrow splide__arrow--next arrow-next-btn"
                                style="
                                color: {{ arrow_color }};
                                width: {{ arrow_size }}px;
                                height: {{ arrow_size }}px;
                                ">
                            <svg
                                width="{{ arrow_size | default: 24 }}"
                                height="{{ arrow_size | default: 25 }}"
                                viewBox="0 0 24 25"
                                fill="none"
                                xmlns="http://www.w3.org/2000/svg"
                            >
                                <path
                                d="M20 11.4004H7.83L13.42 5.81039L12 4.40039L4 12.4004L12 20.4004L13.41 18.9904L7.83 13.4004H20V11.4004Z"
                                fill="{{ arrow_color }}"
                                />
                            </svg>
                        </button>
                    </div>
                    {% endif %}
                </div>
            <!-- .product-carousel -->
            </div>
        </div>
        <!-- .carousel-section -->
        {%- endif -%}
    </section>
{% endfor %}
<script>
    document.addEventListener("DOMContentLoaded", () => {
      // Initialize all collection carousels on the page
      function initializeAllCollectionCarousels() {
        // Find all collection carousels
        const collectionCarousels = document.querySelectorAll('.product-carousel');

        collectionCarousels.forEach((carousel, index) => {
          // Get the carousel ID from the data attribute
          const carouselId = carousel.getAttribute('data-carousel-id');

          if (carouselId) {
            // Initialize this specific carousel using the carousel element directly
            const productCarousel = new Splide(carousel, {
              perPage: 1,
              perMove: 1,
              speed: 500,
              mediaQuery: "min",
              interval: 5000,
              padding: {
                right: "64px",
              },
              gap: "24px",
              breakpoints: {
                576: {
                  perPage: 2,
                },
                768: {
                  perPage: 3,
                },
                1200: {
                  gap: "48px",
                  padding: {
                    right: "80px",
                  },
                },
              },
            });
            productCarousel.mount();
          }
        });
      }

      // Set spacing for carousel containers
      function setCarouselContainerSpacing() {
        const dummyContainer = document.getElementById('dummy-container');
        if (!dummyContainer) {
          return;
        }

        const containerRect = dummyContainer.getBoundingClientRect();
        const paddingLeft = containerRect.left;

        $('.carousel-container').each(function() {
          $(this).css('padding-left', paddingLeft + 'px');
        });
      }

      // Initialize all carousels
      initializeAllCollectionCarousels();
      setCarouselContainerSpacing();

      // Handle window resize
      $(window).resize(function() {
        setCarouselContainerSpacing();
      });
    });
</script>

{% schema %}
