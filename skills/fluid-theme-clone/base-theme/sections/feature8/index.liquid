<style>
.feature8-section .feature8-feature-image {
  width: 48px;
  height: 48px;
  object-fit: cover;
  border-radius: 6px;
}

.feature8-section .feature8-image-placeholder {
  width: 48px;
  height: 48px;
  background-color: #f3f4f6;
  border: 2px dashed #d1d5db;
  border-radius: 6px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #9ca3af;
}

@media (max-width: 1023px) {
  .feature8-section .feature8-wrapper {
    gap: 48px;
    grid-template-columns: 1fr;
  }
  
  .feature8-section .feature8-heading-column {
    text-align: center;
  }
  
  .feature8-section .feature8-features-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

@media (max-width: 767px) {
  .feature8-section .feature8-features-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  
  .feature8-section .feature8-wrapper {
    gap: 32px;
  }
}
</style>

{% schema %}
{
  "name": "Feature 8",
  "settings": [
    {
      "type": "richtext",
      "id": "tagline",
      "label": "Tagline",
      "info": "Optional tagline above the heading"
    },
    {
      "type": "richtext",
      "id": "heading",
      "default": "<p>Amazing <em>features</em></p>",
      "label": "Heading",
      "info": "Main heading text — use italic for emphasis"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "info": "Optional description below the heading"
    },
    {
      "type": "image_picker",
      "id": "feature_1_image",
      "label": "Feature 1 - Image"
    },
    {
      "type": "select",
      "id": "media_fit",
      "label": "Image Fit",
      "options": [
        { "value": "cover", "label": "Cover (Fill Container)" },
        { "value": "contain", "label": "Contain (Fit Inside)" },
        { "value": "fit-width", "label": "Fit to Width" },
        { "value": "fit-height", "label": "Fit to Height" }
      ],
      "default": "cover"
    },

    {

      "type": "range",

      "id": "max_width",

      "min": 0,

      "max": 2000,

      "step": 1,

      "label": "Max Width (px)",

      "info": "Leave empty for no limit"

    },

    {

      "type": "range",

      "id": "max_height",

      "min": 0,

      "max": 2000,

      "step": 1,

      "label": "Max Height (px)",

      "info": "Leave empty for no limit"

    },
    {
      "type": "corner_radius",
      "id": "media_border_radius",
      "label": "Image Border Radius",
      "info": "Override theme default media radius"
    },
    {
      "type": "text",
      "id": "feature_1_image_alt",
      "label": "Feature 1 - Image Alt Text"
    },
    {
      "type": "richtext",
      "id": "feature_1_text",
      "default": "<p>Feature benefit one</p>",
      "label": "Feature 1 - Text"
    },
