              {% if feature_1_image_input.fluid_media_id %}
                {% assign feature_1_image_input_fluid_media_id = feature_1_image_input.fluid_media_id %}
                {% assign feature_1_image_input_embed_type = feature_1_image_input.embed_type %}
              {% endif %}

              {% assign use_feature_1_image_fluid_image_widget = false %}
              
              {% if feature_1_image_input_fluid_media_id != '' %}
                {% assign use_feature_1_image_fluid_image_widget = true %}
              {% endif %}

              {% if use_feature_1_image_fluid_image_widget %}
                <fluid-media-widget class="fluid-media-widget-image" media-id="{{ feature_1_image_input_fluid_media_id }}" responsive="true" embed-type="{{ feature_1_image_input_embed_type | default:'inline' }}" data-fluid-widget="true"></fluid-media-widget>
              {% else %}
                {% if feature_1_image_input != blank %}
                  
                    <img src="{{ feature_1_image_input | image_url }}" alt="{{ block.settings.feature_1_image_alt | default: section.settings.feature_1_text}}" class="feature8-feature-image" loading="lazy" width="" height=""/>
                  
                {% else %}
                  
                  <div class="feature8-image-placeholder">
