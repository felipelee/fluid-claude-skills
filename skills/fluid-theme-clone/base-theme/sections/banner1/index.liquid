{% comment %} Handle background_image - can be string URL or object with url/fluid_media_id {% endcomment %}
{% assign bg_url = '' %}
{% assign bg_fluid_media_id = '' %}

{% if section.settings.background_image %}
  {% if section.settings.background_image.url %}
    {% comment %} It's an object with url property {% endcomment %}
    {% assign bg_url = section.settings.background_image.url %}
    {% comment %} Check if it also has fluid_media_id from media picker {% endcomment %}
    {% if section.settings.background_image.fluid_media_id %}
      {% assign bg_fluid_media_id = section.settings.background_image.fluid_media_id %}
      {% assign bg_embed_type = section.settings.background_image.embed_type %}
    {% endif %}
  {% else %}
    {% comment %} It's a string URL {% endcomment %}
    {% assign bg_url = section.settings.background_image %}
  {% endif %}
{% endif %}

{% comment %} Determine whether to use fluid widget - if fluid_media_id exists, use widget {% endcomment %}
{% assign use_fluid_widget = false %}

{% if bg_fluid_media_id != '' %}
  {% assign use_fluid_widget = true %}
{% endif %}
{%- style -%}
  .section-{{ section.id }} {
    {%- assign p = section.settings.section_padding -%}
    {%- if p -%}
      {%- capture pt -%}{{ p.top }}{%- endcapture -%}
      {%- capture pb -%}{{ p.bottom }}{%- endcapture -%}
      {%- capture pl -%}{{ p.left }}{%- endcapture -%}
      {%- capture pr -%}{{ p.right }}{%- endcapture -%}
      padding-top: {% if pt contains 'var(' %}{{ pt }}{% else %}{{ pt }}px{% endif %};
      padding-bottom: {% if pb contains 'var(' %}{{ pb }}{% else %}{{ pb }}px{% endif %};
      padding-left: {% if pl contains 'var(' %}{{ pl }}{% else %}{{ pl }}px{% endif %};
      padding-right: {% if pr contains 'var(' %}{{ pr }}{% else %}{{ pr }}px{% endif %};
    {%- endif -%}
    {%- assign sr = section.settings.section_border_radius -%}
    {%- if sr -%}
      {%- capture sr_tl -%}{{ sr.tl }}{%- endcapture -%}
      {%- capture sr_tr -%}{{ sr.tr }}{%- endcapture -%}
      {%- capture sr_br -%}{{ sr.br }}{%- endcapture -%}
      {%- capture sr_bl -%}{{ sr.bl }}{%- endcapture -%}
      border-radius: {% if sr_tl contains 'var(' %}{{ sr_tl }}{% else %}{{ sr_tl }}px{% endif %} {% if sr_tr contains 'var(' %}{{ sr_tr }}{% else %}{{ sr_tr }}px{% endif %} {% if sr_br contains 'var(' %}{{ sr_br }}{% else %}{{ sr_br }}px{% endif %} {% if sr_bl contains 'var(' %}{{ sr_bl }}{% else %}{{ sr_bl }}px{% endif %};
    {%- endif -%}
    {%- assign sb = section.settings.section_border -%}
    {%- if sb.width -%}
      border: {{ sb.width }} solid {{ sb.color }};
    {%- endif -%}
  }
{%- endstyle -%}
<!-- Heading section -->
<section class="heading-section section-{{ section.id }}" data-bg="{% unless use_fluid_widget %}{{ bg_url }}{% endunless %}" style="
  background-color: {{ section.settings.background_color | default: '#000000' }}; 
">
  {% if use_fluid_widget %}
    <fluid-media-widget class="fluid-media-widget-background" media-id="{{ bg_fluid_media_id }}" responsive="true" embed-type="{{ bg_embed_type | default: 'inline' }}" data-fluid-widget="true"></fluid-media-widget>
  {% endif %}
   <div class="container">
     {%- assign tagline_block = section.blocks | where: 'type', 'tagline' | first -%}
     {%- assign heading_block = section.blocks | where: 'type', 'heading' | first -%}
     {%- assign description_block = section.blocks | where: 'type', 'description' | first -%}
     {%- assign subheading_blocks = section.blocks | where: 'type', 'subheading_item' -%}
     {%- assign button_blocks = section.blocks | where: 'type', 'button' -%}
     {%- assign link_blocks = section.blocks | where: 'type', 'link' -%}
     <div class="grid {{ section.settings.content_gap_mobile | default: 'space-3xl' }} {{ section.settings.content_gap_desktop | default: 'lg:space-4xl' }} heading-grid">
       <div
         class="heading text-white flex flex-col justify-start lg-tab-justify-end {{ section.settings.heading_spacing_mobile | default: 'space-md' }} {{ section.settings.heading_spacing_desktop | default: 'lg:space-lg' }} "
       >
        {% if tagline_block %}
          <h6 class="rte" {{ tagline_block.fluid_attributes }}>
            {{ tagline_block.settings.text }}
          </h6>
        {% endif %}
        {% if heading_block %}
          <div class="rte" {{ heading_block.fluid_attributes }}>
            {{ heading_block.settings.text }}
          </div>
        {% endif %}
       </div>
       <div class="heading-item flex flex-col {{ section.settings.content_gap_mobile | default: 'space-3xl' }} {{ section.settings.content_gap_desktop | default: 'lg:space-4xl' }} text-white">
        {% if description_block %}
          <p class="rte" {{ description_block.fluid_attributes }}>
            {{ description_block.settings.text }}
          </p>
        {% endif %}
         <div class="grid {{ section.settings.content_gap_mobile | default: 'space-3xl' }} {{ section.settings.content_gap_desktop | default: 'lg:space-4xl' }} sub-heading-grid">
           {% for block in subheading_blocks %}
             <div class="flex flex-col {{ section.settings.sub_heading_gap | default: 'space-md' }} " {{ block.fluid_attributes }}>
              <div class="rte">
                {{ block.settings.title }}
              </div>
              <p class="rte">
                {{ block.settings.description }}
              </p>
             </div>
           {% endfor %}
         </div>
         <div class="flex justify-start align-center {{ section.settings.sub_heading_gap | default: 'space-md' }} ">
          {% for block in button_blocks %}
            {% if block.settings.text != blank %}
              {% capture _btn_style %}
                {% if block.settings.background_color != blank %}background-color: {{ block.settings.background_color }};{% endif %}
                {% if block.settings.text_color != blank %}color: {{ block.settings.text_color }};{% endif %}
                {% if block.settings.font_size != blank %}font-size: {{ block.settings.font_size }}px;{% endif %}
                {% if block.settings.font_family != blank %}font-family: {{ block.settings.font_family | font_family }};{% endif %}
                {% assign p = block.settings.padding %}{% if p %}padding: {{ p.top }}px {{ p.right }}px {{ p.bottom }}px {{ p.left }}px;{% endif %}
                {% assign br = block.settings.border_radius %}{% if br %}border-radius: {{ br.tl }}px {{ br.tr }}px {{ br.br }}px {{ br.bl }}px;{% endif %}
                {% assign bd = block.settings.border %}{% if bd.width %}border: {{ bd.width }} solid {{ bd.color }};{% endif %}
              {% endcapture %}
              <a href="{{ block.settings.link | default: '#' }}"
                 class="btn btn--{{ block.settings.style | default: 'filled' }}"
                 style="{{ _btn_style | strip_newlines }}"
                 {% if block.settings.open_new_tab %}target="_blank" rel="noopener"{% endif %}
                 {{ block.fluid_attributes }}>
                {{ block.settings.text | escape }}
              </a>
            {% endif %}
          {% endfor %}
          {% for block in link_blocks %}
            {% if block.settings.text != blank %}
              {% render 'link',
                href: block.settings.url | default: '#',
                text: block.settings.text,
                underline: block.settings.underline_style,
                icon_position: block.settings.icon_position,
                color: block.settings.color,
                font_weight: block.settings.font_weight,
                attr: block.fluid_attributes
              %}
            {% endif %}
          {% endfor %}
         </div>
       </div>
     </div>
   </div>
 </section>

