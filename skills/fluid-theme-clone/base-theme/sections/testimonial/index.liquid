{% comment %} Handle background_image - can be string URL or object with url/fluid_media_id {% endcomment %}
{% assign bg_url = '' %}
{% assign bg_fluid_media_id = '' %}

{% if section.settings.background_image %}
  {% if section.settings.background_image.url %}
    {% comment %} It's an object with url property {% endcomment %}
    {% assign bg_url = section.settings.background_image.url %}
    
    {% comment %} Check if it also has fluid_media_id from media picker {% endcomment %}
    {% if section.settings.background_image.fluid_media_id %}
      {% assign bg_fluid_media_id = section.settings.background_image.fluid_media_id %}
      {% assign bg_embed_type = section.settings.background_image.embed_type %}
    {% endif %}
  {% else %}
    {% comment %} It's a string URL {% endcomment %}
    {% assign bg_url = section.settings.background_image %}
  {% endif %}
{% endif %}

{% comment %} Determine whether to use fluid widget - if fluid_media_id exists, use widget {% endcomment %}
{% assign use_fluid_widget = false %}

{% if bg_fluid_media_id != '' %}
  {% assign use_fluid_widget = true %}
{% endif %}

<!-- Testimonial section -->
{%- style -%}
  .section-{{ section.id }} {
    background-color: {{ section.settings.background_color | default: '#ffffff' }};
    {%- assign p = section.settings.section_padding -%}
    {%- if p -%}
      {%- capture pt -%}{{ p.top }}{%- endcapture -%}
      {%- capture pb -%}{{ p.bottom }}{%- endcapture -%}
      {%- capture pl -%}{{ p.left }}{%- endcapture -%}
      {%- capture pr -%}{{ p.right }}{%- endcapture -%}
      padding-top: {% if pt contains 'var(' %}{{ pt }}{% else %}{{ pt }}px{% endif %};
      padding-bottom: {% if pb contains 'var(' %}{{ pb }}{% else %}{{ pb }}px{% endif %};
      padding-left: {% if pl contains 'var(' %}{{ pl }}{% else %}{{ pl }}px{% endif %};
      padding-right: {% if pr contains 'var(' %}{{ pr }}{% else %}{{ pr }}px{% endif %};
    {%- endif -%}
    {%- assign sr = section.settings.section_border_radius -%}
    {%- if sr -%}
      {%- capture sr_tl -%}{{ sr.tl }}{%- endcapture -%}
      {%- capture sr_tr -%}{{ sr.tr }}{%- endcapture -%}
      {%- capture sr_br -%}{{ sr.br }}{%- endcapture -%}
      {%- capture sr_bl -%}{{ sr.bl }}{%- endcapture -%}
      border-radius: {% if sr_tl contains 'var(' %}{{ sr_tl }}{% else %}{{ sr_tl }}px{% endif %} {% if sr_tr contains 'var(' %}{{ sr_tr }}{% else %}{{ sr_tr }}px{% endif %} {% if sr_br contains 'var(' %}{{ sr_br }}{% else %}{{ sr_br }}px{% endif %} {% if sr_bl contains 'var(' %}{{ sr_bl }}{% else %}{{ sr_bl }}px{% endif %};
    {%- endif -%}
    {%- assign sb = section.settings.section_border -%}
    {%- if sb.width -%}
      border: {{ sb.width }} solid {{ sb.color }};
    {%- endif -%}
  }
{%- endstyle -%}

<section class="testimonial-section section-{{ section.id }}" data-bg="{% unless use_fluid_widget %}{{ bg_url }}{% endunless %}">
  {% if use_fluid_widget %}
    <fluid-media-widget class="fluid-media-widget-background" media-id="{{ bg_fluid_media_id }}" responsive="true" embed-type="{{ bg_embed_type | default: 'inline' }}" data-fluid-widget="true"></fluid-media-widget>
  {% endif %}
  <div class="container">
    {%- assign section_title_block = section.blocks | where: 'type', 'section_title' | first -%}
    {%- assign section_description_block = section.blocks | where: 'type', 'section_description' | first -%}
    <div class="flex flex-col justify-center align-center {{ section.settings.title_spacing_mobile | default: 'space-xl' }} {{ section.settings.title_spacing_desktop | default: 'lg:space-2xl' }} section-title">
      {%- if section_title_block -%}
        <div class="rte" {{ section_title_block.fluid_attributes }}>{{ section_title_block.settings.text }}</div>
      {%- endif -%}
      {%- if section_description_block -%}
        <div class="rte" {{ section_description_block.fluid_attributes }}>{{ section_description_block.settings.text }}</div>
      {%- endif -%}
    </div>
    <div class="grid grid-cols-3 {{ section.settings.content_gap_mobile | default: 'space-4xl' }} {{ section.settings.content_gap_desktop | default: 'lg:space-5xl' }} testimonial-grid">
            {% assign in_card = false %}
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'testimonial_item' %}
            {% if in_card %}</div>{% endif %}
            <div class="testimonial-col flex flex-col justify-center align-center {{ section.settings.testimonial_spacing_mobile | default: 'space-lg' }} {{ section.settings.testimonial_spacing_desktop | default: 'lg:space-2xl' }} text-center" {{ block.fluid_attributes }}>
            {% assign in_card = true %}
          {% when 'image' %}
            {% if in_card %}
              {% assign _img = block.settings.image %}
              {% assign _alt = block.settings.alt | default: _img.alt | default: '' %}
              {% assign _ar = block.settings.aspect_ratio | default: 'auto' %}
              {% capture _wrap_style %}
                {% if _ar != 'auto' %}aspect-ratio: {{ _ar }};{% endif %}
                {% assign br = block.settings.border_radius %}{% if br %}border-radius: {{ br.tl }}px {{ br.tr }}px {{ br.br }}px {{ br.bl }}px;{% endif %}
                {% assign bd = block.settings.border %}{% if bd.width %}border: {{ bd.width }} solid {{ bd.color }};{% endif %}
              {% endcapture %}
              {% capture _img_style %}
                {% if _ar != 'auto' %}width:100%;height:100%;{% endif %}
                object-fit: {{ block.settings.fit | default: 'cover' }};
                object-position: {{ block.settings.object_position | default: 'center' }};
              {% endcapture %}
              {% if block.settings.link != blank %}<a href="{{ block.settings.link }}" class="media-link" {% if block.settings.open_new_tab %}target="_blank" rel="noopener"{% endif %}>{% endif %}
              <div class="media-wrap" style="{{ _wrap_style | strip_newlines }}" {{ block.fluid_attributes }}>
                {% if _img %}
                  <img src="{{ _img | img_url: '600x' }}" alt="{{ _alt | escape }}" loading="lazy" style="{{ _img_style | strip_newlines }}">
                {% endif %}
                {% if block.settings.overlay_color != blank and block.settings.overlay_opacity > 0 %}
                  {% assign _a = block.settings.overlay_opacity | divided_by: 100.0 %}
                  <div class="media-wrap__overlay" style="background: {{ block.settings.overlay_color }}; opacity: {{ _a }};"></div>
                {% endif %}
              </div>
              {% if block.settings.link != blank %}</a>{% endif %}
            {% endif %}
          {% when 'testimonial_text' %}
            {% if in_card %}
              <div class="rte testimonial-text" {{ block.fluid_attributes }}>{{ block.settings.text }}</div>
            {% endif %}
          {% when 'author' %}
            {% if in_card %}
              <div class="author text-center flex justify-center align-center flex-col {{ section.settings.author_spacing_mobile | default: 'space-xs' }} {{ section.settings.author_spacing_desktop | default: 'lg:space-sm' }}" {{ block.fluid_attributes }}>
                {% if block.settings.author_name != blank %}
                  <div class="author-name">{{ block.settings.author_name }}</div>
                {% endif %}
                {% if block.settings.author_position != blank %}
                  <p class="author-position">{{ block.settings.author_position }}{% if block.settings.company_name != blank %}, {{ block.settings.company_name }}{% endif %}</p>
                {% endif %}
              </div>
            {% endif %}
        {% endcase %}
      {% endfor %}
      {% if in_card %}</div>{% endif %}
    
    </div>
  </div>
</section>

