{%- comment -%}
  related_products (v2) — award-winning PDP recommendations grid.
  Pulls from product.recommendations (auto) or a collection picker.
{%- endcomment -%}

{%- style -%}
  .rp2.section-{{ section.id }} {
    {%- assign p = section.settings.section_padding -%}
    {%- if p -%}padding: {{ p.top | default: 80 }}px {{ p.right | default: 0 }}px {{ p.bottom | default: 80 }}px {{ p.left | default: 0 }}px;{%- else -%}padding: 80px 0;{%- endif -%}
    {%- assign r = section.settings.section_border_radius -%}
    {%- if r -%}border-radius: {{ r.tl }}px {{ r.tr }}px {{ r.br }}px {{ r.bl }}px;{%- endif -%}
    {% if section.settings.section_border_width > 0 %}border: {{ section.settings.section_border_width }}px solid {{ section.settings.section_border_color }};{% endif %}
    background-color: {{ section.settings.background_color | default: 'transparent' }};
    {%- if section.settings.background_image != blank -%}background-image: url({{ section.settings.background_image | img_url: '2400x' }});background-size:cover;background-position:center;background-repeat:no-repeat;{%- endif -%}
  }
  .rp2.section-{{ section.id }} .rp2__container {
    position: relative;
    max-width: {{ section.settings.container_max_width | default: '1280px' }};
    margin: 0 auto;
    {%- assign cp = section.settings.container_padding -%}
    {%- if cp -%}padding: {{ cp.top | default: 0 }}px {{ cp.right | default: 64 }}px {{ cp.bottom | default: 0 }}px {{ cp.left | default: 64 }}px;{%- else -%}padding: 0 64px;{%- endif -%}
    background-color: {{ section.settings.container_background_color | default: 'transparent' }};
    {%- if section.settings.container_background_image != blank -%}background-image: url({{ section.settings.container_background_image | img_url: '2400x' }});background-size:cover;background-position:center;background-repeat:no-repeat;{%- endif -%}
    {%- assign ccr = section.settings.container_border_radius -%}
    {%- if ccr -%}border-radius: {{ ccr.tl }}px {{ ccr.tr }}px {{ ccr.br }}px {{ ccr.bl }}px;{%- endif -%}
    {% if section.settings.container_border_width > 0 %}border: {{ section.settings.container_border_width }}px solid {{ section.settings.container_border_color }};{% endif %}
  }
  {%- if section.settings.container_overlay_color != blank and section.settings.container_overlay_opacity > 0 -%}
    {%- assign _cov = section.settings.container_overlay_opacity | divided_by: 100.0 -%}
    .rp2.section-{{ section.id }} .rp2__container::before { content: ""; position: absolute; inset: 0; background: {{ section.settings.container_overlay_color }}; opacity: {{ _cov }}; pointer-events: none; }
  {%- endif -%}
  .rp2.section-{{ section.id }} .rp2__container > * { position: relative; }
  @media (max-width: 991px) { .rp2.section-{{ section.id }} .rp2__container { padding-left: 24px; padding-right: 24px; } }
  @media (max-width: 767px) { .rp2.section-{{ section.id }} .rp2__container { padding-left: 16px; padding-right: 16px; } }

  .rp2.section-{{ section.id }} .rp2__head {
    display: flex; align-items: baseline; justify-content: space-between; gap: 24px;
    margin-bottom: 40px;
    flex-wrap: wrap;
  }
  .rp2.section-{{ section.id }} .rp2__head-left { display: flex; flex-direction: column; gap: 8px; }
  .rp2.section-{{ section.id }} .rp2__eyebrow {
    font-size: 12px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase;
    color: {{ section.settings.eyebrow_color | default: 'var(--clr-muted)' }};
  }
  .rp2.section-{{ section.id }} .rp2__title {
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 700; letter-spacing: -0.02em; line-height: 1.1;
    color: {{ section.settings.title_color | default: 'var(--clr-primary)' }};
    font-family: {{ section.settings.title_font | default: 'var(--ff-heading)' }};
    margin: 0;
  }
  .rp2.section-{{ section.id }} .rp2__view-all {
    font-size: 14px; font-weight: 600;
    color: {{ section.settings.title_color | default: 'var(--clr-primary)' }};
    text-decoration: none;
    padding: 10px 20px;
    border: 1.5px solid {{ section.settings.view_all_border | default: 'var(--clr-primary)' }};
    border-radius: 999px;
    transition: background-color .15s, color .15s;
  }
  .rp2.section-{{ section.id }} .rp2__view-all:hover {
    background: {{ section.settings.view_all_hover_bg | default: 'var(--clr-primary)' }};
    color: {{ section.settings.view_all_hover_color | default: 'var(--clr-white)' }};
  }

  .rp2.section-{{ section.id }} .rp2__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop | default: 4 }}, minmax(0, 1fr));
    gap: {{ section.settings.gap | default: 24 }}px;
  }
  @media (max-width: 991px) { .rp2.section-{{ section.id }} .rp2__grid { grid-template-columns: repeat({{ section.settings.columns_tablet | default: 3 }}, minmax(0, 1fr)); } }
  @media (max-width: 767px) { .rp2.section-{{ section.id }} .rp2__grid { grid-template-columns: repeat({{ section.settings.columns_mobile | default: 2 }}, minmax(0, 1fr)); gap: 12px; } }

  .rp2.section-{{ section.id }} .rp2__card {
    display: flex; flex-direction: column; gap: 10px;
    text-decoration: none;
    color: inherit;
    transition: transform .2s;
  }
  .rp2.section-{{ section.id }} .rp2__card:hover { transform: translateY(-2px); }
  .rp2.section-{{ section.id }} .rp2__img-wrap {
    position: relative;
    aspect-ratio: {{ section.settings.image_aspect_ratio | default: '1/1' }};
    background: {{ section.settings.image_placeholder_background | default: 'var(--clr-light)' }};
    {%- assign ibr = section.settings.image_border_radius -%}
    {%- if ibr -%}border-radius: {{ ibr.tl }}px {{ ibr.tr }}px {{ ibr.br }}px {{ ibr.bl }}px;{%- else -%}border-radius: 12px;{%- endif -%}
    overflow: hidden;
  }
  .rp2.section-{{ section.id }} .rp2__img-wrap img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover; object-position: center;
    transition: transform .4s ease;
  }
  .rp2.section-{{ section.id }} .rp2__card:hover .rp2__img-wrap img { transform: scale(1.04); }
  .rp2.section-{{ section.id }} .rp2__img-placeholder {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    color: var(--clr-muted); opacity: 0.5;
    background: repeating-linear-gradient(45deg, var(--clr-gray) 0 16px, var(--clr-light) 16px 32px);
  }

  .rp2.section-{{ section.id }} .rp2__badge {
    position: absolute; top: 10px; left: 10px; z-index: 2;
    padding: 4px 10px;
    font-size: 10.5px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
    background: {{ section.settings.badge_background | default: 'var(--clr-accent)' }};
    color: {{ section.settings.badge_color | default: 'var(--clr-white)' }};
    border-radius: 999px;
  }

  .rp2.section-{{ section.id }} .rp2__title-row {
    font-size: 15px; font-weight: 500; line-height: 1.3;
    color: {{ section.settings.card_title_color | default: 'var(--clr-primary)' }};
    margin: 4px 0 0;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .rp2.section-{{ section.id }} .rp2__price-row {
    display: flex; align-items: baseline; gap: 8px;
    font-size: 15px;
    color: {{ section.settings.price_color | default: 'var(--clr-primary)' }};
  }
  .rp2.section-{{ section.id }} .rp2__price { font-weight: 600; }
  .rp2.section-{{ section.id }} .rp2__compare {
    font-size: 13px;
    color: {{ section.settings.compare_color | default: 'var(--clr-muted)' }};
    text-decoration: line-through;
  }

  .rp2.section-{{ section.id }} .rp2__rating { display: flex; align-items: center; gap: 6px; font-size: 12px; color: {{ section.settings.rating_text_color | default: 'var(--clr-muted)' }}; }
  .rp2.section-{{ section.id }} .rp2__stars { display: inline-flex; gap: 1px; color: {{ section.settings.star_color | default: 'var(--clr-warning)' }}; }
  .rp2.section-{{ section.id }} .rp2__stars svg { width: 12px; height: 12px; fill: currentColor; }
{%- endstyle -%}

{%- comment -%} Source resolution: product.recommendations → collection → empty {%- endcomment -%}
{%- assign source_products = empty -%}
{%- if section.settings.source == 'collection' and section.settings.collection.products and section.settings.collection.products.size > 0 -%}
  {%- assign source_products = section.settings.collection.products -%}
{%- elsif product.recommendations and product.recommendations.size > 0 -%}
  {%- assign source_products = product.recommendations -%}
{%- elsif products and products.size > 0 -%}
  {%- assign source_products = products -%}
{%- endif -%}

<section class="rp2 section-{{ section.id }}" {{ section.fluid_attributes }}>
  <div class="rp2__container">

    <header class="rp2__head">
      <div class="rp2__head-left">
        {% if section.settings.eyebrow != blank %}<span class="rp2__eyebrow">{{ section.settings.eyebrow | escape }}</span>{% endif %}
        <h2 class="rp2__title">{{ section.settings.heading | default: 'You may also like' | escape }}</h2>
      </div>
      {% if section.settings.view_all_url != blank %}
        <a href="{{ section.settings.view_all_url }}" class="rp2__view-all">{{ section.settings.view_all_label | default: 'View all' | escape }}</a>
      {% endif %}
    </header>

    <div class="rp2__grid">
      {% if source_products and source_products.size > 0 %}
        {% for p in source_products limit: section.settings.products_to_show %}
          {%- if p.id == product.id and section.settings.source != 'collection' -%}{%- continue -%}{%- endif -%}
          {%- assign _img = '' -%}
          {%- if p.images and p.images.size > 0 -%}{%- assign _img = p.images[0].src -%}
          {%- elsif p.image_url != blank -%}{%- assign _img = p.image_url -%}
          {%- elsif p.image -%}{%- assign _img = p.image | image_url -%}
          {%- endif -%}

          {%- assign _has_compare = false -%}
          {%- if p.compare_at_price and p.compare_at_price != blank -%}
            {%- assign _cmp = p.compare_at_price | plus: 0.0 -%}
            {%- assign _cur = p.price | plus: 0.0 -%}
            {%- if _cmp > _cur and _cur > 0 -%}
              {%- assign _has_compare = true -%}
              {%- assign _save_pct = _cmp | minus: _cur | times: 100.0 | divided_by: _cmp | round -%}
            {%- endif -%}
          {%- endif -%}

          <a class="rp2__card" href="{{ p.url | default: p.canonical_url | default: '#' }}">
            <div class="rp2__img-wrap">
              {% if _has_compare and section.settings.show_sale_badge %}<span class="rp2__badge">−{{ _save_pct }}%</span>{% endif %}
              {% if _img != blank %}
                <img src="{{ _img }}" alt="{{ p.title | escape }}" loading="lazy">
              {% else %}
                <div class="rp2__img-placeholder">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" width="44" height="44"><rect x="3" y="4" width="18" height="16" rx="2"/><circle cx="8.5" cy="10" r="1.5"/><path d="M3 16l5-4 4 3 4-5 5 6"/></svg>
                </div>
              {% endif %}
            </div>
            {% if section.settings.show_rating and p.ratings %}
              <div class="rp2__rating">
                <span class="rp2__stars">
                  {% for i in (1..5) %}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>{% endfor %}
                </span>
                <span>{{ p.ratings }}</span>
              </div>
            {% endif %}
            {% if section.settings.show_title %}<h3 class="rp2__title-row">{{ p.title | escape }}</h3>{% endif %}
            {% if section.settings.show_price %}
              <div class="rp2__price-row">
                <span class="rp2__price">{{ p.price }}</span>
                {% if _has_compare %}<span class="rp2__compare">{{ p.compare_at_price }}</span>{% endif %}
              </div>
            {% endif %}
          </a>
        {% endfor %}
      {% else %}
        {% for i in (1..section.settings.products_to_show) %}
          {%- if i > 4 -%}{%- break -%}{%- endif -%}
          <div class="rp2__card">
            <div class="rp2__img-wrap">
              <div class="rp2__img-placeholder">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" width="44" height="44"><rect x="3" y="4" width="18" height="16" rx="2"/><circle cx="8.5" cy="10" r="1.5"/><path d="M3 16l5-4 4 3 4-5 5 6"/></svg>
              </div>
            </div>
            {% if section.settings.show_title %}<h3 class="rp2__title-row">Product {{ i }}</h3>{% endif %}
            {% if section.settings.show_price %}<div class="rp2__price-row"><span class="rp2__price">$—</span></div>{% endif %}
          </div>
        {% endfor %}
      {% endif %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Related Products",
  "tag": "section",
  "class": "related-products-section",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "You may also like" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Complete your lineup" },
    { "type": "text", "id": "view_all_label", "label": "View-all button label", "default": "Shop all" },
    { "type": "url",  "id": "view_all_url",   "label": "View-all button URL (optional)" },

    { "type": "header", "content": "Source" },
    { "type": "radio",      "id": "source", "label": "Recommendations source", "default": "auto",
      "options": [
        { "value": "auto",       "label": "Auto — Fluid's product.recommendations" },
        { "value": "collection", "label": "Collection — pick one below" }
      ]
    },
    { "type": "collection", "id": "collection", "label": "Collection (if source = Collection)" },
    { "type": "range",      "id": "products_to_show", "label": "Products to show", "min": 2, "max": 12, "step": 1, "default": 4 },

    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "columns_desktop", "label": "Columns (desktop)", "min": 2, "max": 5, "step": 1, "default": 4 },
    { "type": "range", "id": "columns_tablet",  "label": "Columns (tablet)",  "min": 2, "max": 4, "step": 1, "default": 3 },
    { "type": "range", "id": "columns_mobile",  "label": "Columns (mobile)",  "min": 1, "max": 2, "step": 1, "default": 2 },
    { "type": "range", "id": "gap", "label": "Gap (px)", "min": 8, "max": 40, "step": 2, "default": 24 },

    { "type": "header", "content": "Card" },
    { "type": "select", "id": "image_aspect_ratio", "label": "Image aspect ratio", "default": "1/1",
      "options": [
        { "value": "1/1",  "label": "Square (1:1)" },
        { "value": "4/5",  "label": "Portrait (4:5)" },
        { "value": "3/4",  "label": "Portrait (3:4)" },
        { "value": "4/3",  "label": "Standard (4:3)" }
      ]
    },
    { "type": "corner_radius", "id": "image_border_radius", "label": "Image border radius" },
    { "type": "select", "id": "image_placeholder_background", "label": "Placeholder background", "options": "background_colors", "default": "var(--clr-light)" },
    { "type": "checkbox", "id": "show_title", "label": "Show product title", "default": true },
    { "type": "checkbox", "id": "show_price", "label": "Show product price", "default": true },
    { "type": "checkbox", "id": "show_rating", "label": "Show star rating (from product.ratings)", "default": false },
    { "type": "checkbox", "id": "show_sale_badge", "label": "Show \u2212% badge on sale items", "default": true },

    { "type": "header", "content": "Colors" },
    { "type": "select", "id": "eyebrow_color",   "label": "Eyebrow color",      "options": "background_colors", "default": "var(--clr-muted)" },
    { "type": "select", "id": "title_font",      "label": "Heading font",       "options": "font_families",     "default": "var(--ff-heading)" },
    { "type": "select", "id": "title_color",     "label": "Heading color",      "options": "background_colors", "default": "var(--clr-primary)" },
    { "type": "select", "id": "view_all_border", "label": "View-all border",    "options": "background_colors", "default": "var(--clr-primary)" },
    { "type": "select", "id": "view_all_hover_bg", "label": "View-all hover bg", "options": "background_colors", "default": "var(--clr-primary)" },
    { "type": "select", "id": "view_all_hover_color", "label": "View-all hover text", "options": "background_colors", "default": "var(--clr-white)" },
    { "type": "select", "id": "card_title_color", "label": "Card title color",  "options": "background_colors", "default": "var(--clr-primary)" },
    { "type": "select", "id": "price_color",      "label": "Price color",       "options": "background_colors", "default": "var(--clr-primary)" },
    { "type": "select", "id": "compare_color",    "label": "Compare-at color",  "options": "background_colors", "default": "var(--clr-muted)" },
    { "type": "select", "id": "badge_background", "label": "Sale badge bg",     "options": "background_colors", "default": "var(--clr-accent)" },
    { "type": "select", "id": "badge_color",      "label": "Sale badge text",   "options": "background_colors", "default": "var(--clr-white)" },
    { "type": "select", "id": "star_color",       "label": "Star color",        "options": "background_colors", "default": "var(--clr-warning)" },
    { "type": "select", "id": "rating_text_color","label": "Rating text color", "options": "background_colors", "default": "var(--clr-muted)" },

    { "type": "header", "content": "Container" },
    { "type": "select", "id": "container_max_width", "label": "Max Width", "default": "1280px",
      "options": [
        { "value": "1080px", "label": "Comfy (1080px)" },
        { "value": "1280px", "label": "Default (1280px)" },
        { "value": "1440px", "label": "Wide (1440px)" },
        { "value": "100%",   "label": "Full (100%)" }
      ]
    },
    { "type": "padding", "id": "container_padding", "label": "Container Padding" },
    { "type": "corner_radius", "id": "container_border_radius", "label": "Container Border Radius" },
    { "type": "select", "id": "container_background_color", "label": "Container Background Color", "options": "background_colors", "default": "transparent" },
    { "type": "image_picker", "id": "container_background_image", "label": "Container Background Image" },
    { "type": "select", "id": "container_overlay_color", "label": "Container Overlay Color", "options": "background_colors", "default": "transparent" },
    { "type": "range", "id": "container_overlay_opacity", "label": "Container Overlay Opacity", "min": 0, "max": 100, "step": 5, "default": 0, "unit": "%" },
    { "type": "range", "id": "container_border_width", "label": "Container Border Width", "min": 0, "max": 10, "step": 1, "default": 0, "unit": "px" },
    { "type": "select", "id": "container_border_color", "label": "Container Border Color", "options": "background_colors", "default": "var(--clr-primary)" },

    { "type": "header", "content": "Section Shell" },
    { "type": "padding", "id": "section_padding", "label": "Section Padding" },
    { "type": "corner_radius", "id": "section_border_radius", "label": "Section Border Radius" },
    { "type": "select", "id": "background_color", "label": "Background Color", "options": "background_colors", "default": "transparent" },
    { "type": "image_picker", "id": "background_image", "label": "Background Image" },
    { "type": "range", "id": "section_border_width", "label": "Section Border Width", "min": 0, "max": 10, "step": 1, "default": 0, "unit": "px" },
    { "type": "select", "id": "section_border_color", "label": "Section Border Color", "options": "background_colors", "default": "var(--clr-primary)" }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "Related Products",
      "settings": {
        "source": "auto",
        "products_to_show": 4,
        "show_title": true,
        "show_price": true,
        "show_sale_badge": true
      }
    }
  ]
}
{% endschema %}
