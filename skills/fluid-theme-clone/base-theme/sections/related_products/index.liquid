{%- style -%}
  .section-{{ section.id }} {
    background-color: {{ section.settings.background_color | default: '#ffffff' }};
    color: {{ section.settings.text_color | default: '#000000' }};
    {%- assign p = section.settings.section_padding -%}
    {%- if p -%}
      {%- capture pt -%}{{ p.top }}{%- endcapture -%}
      {%- capture pb -%}{{ p.bottom }}{%- endcapture -%}
      {%- capture pl -%}{{ p.left }}{%- endcapture -%}
      {%- capture pr -%}{{ p.right }}{%- endcapture -%}
      padding-top: {% if pt contains 'var(' %}{{ pt }}{% else %}{{ pt }}px{% endif %};
      padding-bottom: {% if pb contains 'var(' %}{{ pb }}{% else %}{{ pb }}px{% endif %};
      padding-left: {% if pl contains 'var(' %}{{ pl }}{% else %}{{ pl }}px{% endif %};
      padding-right: {% if pr contains 'var(' %}{{ pr }}{% else %}{{ pr }}px{% endif %};
    {%- endif -%}
    {%- assign sr = section.settings.section_border_radius -%}
    {%- if sr -%}
      {%- capture sr_tl -%}{{ sr.tl }}{%- endcapture -%}
      {%- capture sr_tr -%}{{ sr.tr }}{%- endcapture -%}
      {%- capture sr_br -%}{{ sr.br }}{%- endcapture -%}
      {%- capture sr_bl -%}{{ sr.bl }}{%- endcapture -%}
      border-radius: {% if sr_tl contains 'var(' %}{{ sr_tl }}{% else %}{{ sr_tl }}px{% endif %} {% if sr_tr contains 'var(' %}{{ sr_tr }}{% else %}{{ sr_tr }}px{% endif %} {% if sr_br contains 'var(' %}{{ sr_br }}{% else %}{{ sr_br }}px{% endif %} {% if sr_bl contains 'var(' %}{{ sr_bl }}{% else %}{{ sr_bl }}px{% endif %};
    {%- endif -%}
  }
{%- endstyle -%}

<section class="product-collection-section section-{{ section.id }}" data-bg="{{ section.settings.background_image }}">
  <div class="container">
    {%- if section.blocks.size > 0 -%}
      <div class="header-block-area">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'tagline' -%}
              {% if block.settings.text != blank %}
                <div class="rte" {{ block.fluid_attributes }}>{{ block.settings.text }}</div>
              {% endif %}
            {%- when 'heading' -%}
              {% if block.settings.text != blank %}
                <div class="rte {{ section.settings.heading_spacing_mobile | default: 'py-md' }} {{ section.settings.heading_spacing_desktop | default: 'lg:py-lg' }}" {{ block.fluid_attributes }}>{{ block.settings.text }}</div>
              {% endif %}
            {%- when 'description' -%}
              {% if block.settings.text != blank %}
                <div class="rte" {{ block.fluid_attributes }}>{{ block.settings.text }}</div>
              {% endif %}
          {%- endcase -%}
        {%- endfor -%}
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'product_list' -%}
          <div class="product-list-section {{ section.settings.product_list_spacing_mobile | default: 'mt-4xl' }} {{ section.settings.product_list_spacing_desktop | default: 'lg:mt-7xl' }}" {{ block.fluid_attributes }}>
            <ul class="grid grid-cols-1 xl-phone-grid-cols-2 md-tab-grid-cols-3 {{ section.settings.grid_gap_x_mobile | default: 'space-x-4xl' }} {{ section.settings.grid_gap_x_desktop | default: 'lg:space-x-7xl' }} {{ section.settings.grid_gap_y_mobile | default: 'space-y-7xl' }} {{ section.settings.grid_gap_y_desktop | default: 'lg:space-y-9xl' }}">
              {% for recommendation in product.recommendations limit: section.settings.products_to_show %}
                <li>
                  <a href="{{ recommendation.url }}" class="product block">
                    <div class="image-section product-image-height">
                      <img
                        src="{{ recommendation.image_url }}"
                        alt="{{ recommendation.title }}"
                        class="image-cover"
                        loading="lazy"
                        width=""
                        height=""
                      />
                    </div>
                    <div class="desc {{ section.settings.product_content_spacing_mobile | default: 'pt-md' }} {{ section.settings.product_content_spacing_desktop | default: 'lg:pt-lg' }} text-center  ">
                      <div class="{{ section.settings.product_title_font_size | default: 'text-base' }} {{ section.settings.product_title_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.product_title_font_weight | default: 'font-medium' }}" style="color: {{ section.settings.product_title_color | default: '#000000' }};">
                        {{ recommendation.title}}
                      </div>
                      <p class="{{ section.settings.product_variant_font_size | default: 'text-sm' }} {{ section.settings.product_variant_font_size_desktop | default: 'lg:text-sm' }} {{ section.settings.product_variant_font_weight | default: 'font-normal' }}" style="color: {{ section.settings.product_variant_color | default: '#666666' }};">
                        {{ 'product.variant' | t }}
                      </p>
                      <div class="{{ section.settings.product_price_font_size | default: 'text-lg' }} {{ section.settings.product_price_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.product_price_font_weight | default: 'font-semibold' }}" style="color: {{ section.settings.product_price_color | default: '#000000' }};">
                        {{ recommendation.price }}
                      </div>
                    </div>
                  </a>
                </li>
              {% endfor %}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}

      {%- for block in section.blocks -%}
        {%- if block.type == 'buttons' -%}
          <div class="btn-section {{ section.settings.button_spacing_mobile | default: 'mt-7xl' }} {{ section.settings.button_spacing_desktop | default: 'lg:mt-10xl' }} flex justify-center" {{ block.fluid_attributes }}>
            {% if block.settings.show_button_1 and block.settings.button_1_text != blank %}
              {%- assign cr = block.settings.button_1_border_radius -%}
              {%- assign _cr_style = '' -%}
              {%- if cr -%}
                {%- capture cr_tl -%}{{ cr.tl }}{%- endcapture -%}{%- capture cr_tr -%}{{ cr.tr }}{%- endcapture -%}{%- capture cr_br -%}{{ cr.br }}{%- endcapture -%}{%- capture cr_bl -%}{{ cr.bl }}{%- endcapture -%}
                {%- capture _cr_style -%}border-radius: {% if cr_tl contains 'var(' %}{{ cr_tl }}{% else %}{{ cr_tl }}px{% endif %} {% if cr_tr contains 'var(' %}{{ cr_tr }}{% else %}{{ cr_tr }}px{% endif %} {% if cr_br contains 'var(' %}{{ cr_br }}{% else %}{{ cr_br }}px{% endif %} {% if cr_bl contains 'var(' %}{{ cr_bl }}{% else %}{{ cr_bl }}px{% endif %};{%- endcapture -%}
              {%- endif -%}
              <a href="{{ block.settings.button_1_link | default: '#' }}" class="btn {{ block.settings.button_1_style | default: 'btn-border-primary' }}" {% if _cr_style != '' %}style="{{ _cr_style }}"{% endif %}>
                {{ block.settings.button_1_text }}
              </a>
            {% endif %}
          </div>
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>
