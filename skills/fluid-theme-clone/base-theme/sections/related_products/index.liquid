{%- comment -%}
  Related Products — premium PDP recommendations carousel.
  Source: product.recommendations (default), all products list, or curated collection.
  Layout: horizontal scroll-snap with arrow nav + dot indicators. Cards have hover quick-add.
{%- endcomment -%}

{%- style -%}
  .relp.section-{{ section.id }} {
    {%- assign p = section.settings.section_padding -%}
    {%- if p -%}padding: {{ p.top | default: 80 }}px {{ p.right | default: 0 }}px {{ p.bottom | default: 80 }}px {{ p.left | default: 0 }}px;{%- else -%}padding: 80px 0;{%- endif -%}
    {%- assign r = section.settings.section_border_radius -%}
    {%- if r -%}border-radius: {{ r.tl }}px {{ r.tr }}px {{ r.br }}px {{ r.bl }}px;{%- endif -%}
    {% if section.settings.section_border_width > 0 %}border: {{ section.settings.section_border_width }}px solid {{ section.settings.section_border_color }};{% endif %}
    background-color: {{ section.settings.background_color | default: 'transparent' }};
    {%- if section.settings.background_image != blank -%}background-image: url({{ section.settings.background_image | img_url: '2400x' }});background-size:cover;background-position:center;background-repeat:no-repeat;{%- endif -%}
  }
  .relp.section-{{ section.id }} .relp__container {
    position: relative;
    max-width: {{ section.settings.container_max_width | default: '1280px' }};
    margin: 0 auto;
    {%- assign cp = section.settings.container_padding -%}
    {%- if cp -%}padding: {{ cp.top | default: 0 }}px {{ cp.right | default: 64 }}px {{ cp.bottom | default: 0 }}px {{ cp.left | default: 64 }}px;{%- else -%}padding: 0 64px;{%- endif -%}
    background-color: {{ section.settings.container_background_color | default: 'transparent' }};
    {%- if section.settings.container_background_image != blank -%}background-image: url({{ section.settings.container_background_image | img_url: '2400x' }});background-size:cover;background-position:center;background-repeat:no-repeat;{%- endif -%}
    {%- assign ccr = section.settings.container_border_radius -%}
    {%- if ccr -%}border-radius: {{ ccr.tl }}px {{ ccr.tr }}px {{ ccr.br }}px {{ ccr.bl }}px;{%- endif -%}
    {% if section.settings.container_border_width > 0 %}border: {{ section.settings.container_border_width }}px solid {{ section.settings.container_border_color }};{% endif %}
  }
  {%- if section.settings.container_overlay_color != blank and section.settings.container_overlay_opacity > 0 -%}
    {%- assign _cov = section.settings.container_overlay_opacity | divided_by: 100.0 -%}
    .relp.section-{{ section.id }} .relp__container::before { content: ""; position: absolute; inset: 0; background: {{ section.settings.container_overlay_color }}; opacity: {{ _cov }}; pointer-events: none; }
  {%- endif -%}
  .relp.section-{{ section.id }} .relp__container > * { position: relative; }
  @media (max-width: 991px) { .relp.section-{{ section.id }} .relp__container { padding-left: 24px; padding-right: 24px; } }
  @media (max-width: 767px) { .relp.section-{{ section.id }} .relp__container { padding-left: 16px; padding-right: 16px; } }

  .relp.section-{{ section.id }} .relp__head {
    display: flex; align-items: end; justify-content: space-between; gap: 24px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }
  .relp.section-{{ section.id }} .relp__intro { display: flex; flex-direction: column; gap: 8px; max-width: 640px; }
  .relp.section-{{ section.id }} .relp__eyebrow {
    font-size: 12px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase;
    color: {{ section.settings.eyebrow_color | default: 'var(--clr-muted)' }};
  }
  .relp.section-{{ section.id }} .relp__title {
    font-size: clamp(28px, 3.4vw, 42px);
    font-weight: 700; letter-spacing: -0.02em; line-height: 1.05;
    color: {{ section.settings.title_color | default: 'var(--clr-primary)' }};
    font-family: {{ section.settings.title_font | default: 'var(--ff-heading)' }};
    margin: 0;
  }
  .relp.section-{{ section.id }} .relp__subhead {
    font-size: 15px; line-height: 1.5;
    color: {{ section.settings.body_color | default: 'var(--clr-body)' }};
    margin: 4px 0 0;
  }

  .relp.section-{{ section.id }} .relp__nav { display: flex; align-items: center; gap: 8px; }
  .relp.section-{{ section.id }} .relp__nav-btn {
    width: 44px; height: 44px;
    display: inline-flex; align-items: center; justify-content: center;
    background: {{ section.settings.nav_background | default: 'var(--clr-white)' }};
    color: {{ section.settings.nav_color | default: 'var(--clr-primary)' }};
    border: 1.5px solid {{ section.settings.nav_border | default: 'var(--clr-gray)' }};
    border-radius: 999px;
    cursor: pointer;
    transition: background-color .15s, border-color .15s, transform .1s;
  }
  .relp.section-{{ section.id }} .relp__nav-btn:hover { background: {{ section.settings.nav_hover_background | default: 'var(--clr-primary)' }}; color: {{ section.settings.nav_hover_color | default: 'var(--clr-white)' }}; border-color: {{ section.settings.nav_hover_background | default: 'var(--clr-primary)' }}; }
  .relp.section-{{ section.id }} .relp__nav-btn:active { transform: scale(0.95); }
  .relp.section-{{ section.id }} .relp__nav-btn:disabled { opacity: 0.35; cursor: not-allowed; }
  .relp.section-{{ section.id }} .relp__nav-btn svg { width: 18px; height: 18px; }

  .relp.section-{{ section.id }} .relp__rail {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: calc((100% - {{ section.settings.gap | default: 24 }}px * ({{ section.settings.cards_visible_desktop | default: 4 }} - 1)) / {{ section.settings.cards_visible_desktop | default: 4 }});
    gap: {{ section.settings.gap | default: 24 }}px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-bottom: 4px;
  }
  .relp.section-{{ section.id }} .relp__rail::-webkit-scrollbar { display: none; }
  @media (max-width: 991px) {
    .relp.section-{{ section.id }} .relp__rail {
      grid-auto-columns: calc((100% - {{ section.settings.gap | default: 24 }}px * ({{ section.settings.cards_visible_tablet | default: 2 }} - 1)) / {{ section.settings.cards_visible_tablet | default: 2 }});
    }
  }
  @media (max-width: 767px) {
    .relp.section-{{ section.id }} .relp__rail {
      grid-auto-columns: calc((100% - {{ section.settings.gap | default: 24 }}px * ({{ section.settings.cards_visible_mobile | default: 1 }} - 1)) / {{ section.settings.cards_visible_mobile | default: 1 }});
      gap: 12px;
    }
  }

  .relp.section-{{ section.id }} .relp__card {
    scroll-snap-align: start;
    display: flex; flex-direction: column;
    background: {{ section.settings.card_background | default: 'var(--clr-white)' }};
    border: 1px solid {{ section.settings.card_border | default: 'transparent' }};
    border-radius: 18px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease;
    position: relative;
  }
  .relp.section-{{ section.id }} .relp__card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 32px -12px rgba(0, 0, 0, 0.18);
    border-color: {{ section.settings.card_hover_border | default: 'var(--clr-gray)' }};
  }

  .relp.section-{{ section.id }} .relp__img-wrap {
    position: relative;
    aspect-ratio: {{ section.settings.image_aspect_ratio | default: '1/1' }};
    background: {{ section.settings.image_placeholder_background | default: 'var(--clr-light)' }};
    overflow: hidden;
  }
  .relp.section-{{ section.id }} .relp__img-wrap img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: center;
    transition: transform .5s ease;
  }
  .relp.section-{{ section.id }} .relp__card:hover .relp__img-wrap img { transform: scale(1.05); }
  .relp.section-{{ section.id }} .relp__img-placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    color: var(--clr-muted); opacity: 0.4;
    background: repeating-linear-gradient(45deg, var(--clr-gray) 0 14px, var(--clr-light) 14px 28px);
  }

  .relp.section-{{ section.id }} .relp__badge {
    position: absolute;
    top: 12px; left: 12px;
    z-index: 2;
    padding: 5px 12px;
    font-size: 11px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;
    background: {{ section.settings.sale_badge_background | default: 'var(--clr-accent)' }};
    color: {{ section.settings.sale_badge_color | default: 'var(--clr-white)' }};
    border-radius: 999px;
  }

  .relp.section-{{ section.id }} .relp__quick-add {
    position: absolute;
    bottom: 12px; left: 12px; right: 12px;
    z-index: 3;
    padding: 12px 18px;
    font-size: 13px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase;
    background: {{ section.settings.quick_add_background | default: 'var(--clr-primary)' }};
    color: {{ section.settings.quick_add_color | default: 'var(--clr-white)' }};
    border: none;
    border-radius: 999px;
    cursor: pointer;
    text-align: center;
    text-decoration: none;
    display: inline-flex; align-items: center; justify-content: center; gap: 8px;
    opacity: 0; transform: translateY(8px);
    transition: opacity .25s ease, transform .25s ease, background-color .15s;
    pointer-events: none;
  }
  .relp.section-{{ section.id }} .relp__card:hover .relp__quick-add,
  .relp.section-{{ section.id }} .relp__card:focus-within .relp__quick-add {
    opacity: 1; transform: translateY(0);
    pointer-events: auto;
  }
  .relp.section-{{ section.id }} .relp__quick-add:hover { opacity: 0.92; }
  .relp.section-{{ section.id }} .relp__quick-add svg { width: 14px; height: 14px; }
  @media (max-width: 767px) {
    .relp.section-{{ section.id }} .relp__quick-add { opacity: 1; transform: none; pointer-events: auto; }
  }

  .relp.section-{{ section.id }} .relp__body {
    padding: 18px 16px 22px;
    display: flex; flex-direction: column; gap: 8px;
  }
  .relp.section-{{ section.id }} .relp__rating { display: inline-flex; align-items: center; gap: 6px; font-size: 12px; color: {{ section.settings.rating_text_color | default: 'var(--clr-muted)' }}; }
  .relp.section-{{ section.id }} .relp__stars { display: inline-flex; gap: 1px; color: {{ section.settings.star_color | default: 'var(--clr-warning)' }}; }
  .relp.section-{{ section.id }} .relp__stars svg { width: 12px; height: 12px; fill: currentColor; }

  .relp.section-{{ section.id }} .relp__name {
    font-size: 16px; font-weight: 600; line-height: 1.3;
    color: {{ section.settings.card_title_color | default: 'var(--clr-primary)' }};
    margin: 0;
  }
  .relp.section-{{ section.id }} .relp__price-row {
    display: flex; align-items: baseline; gap: 8px;
    margin-top: 2px;
  }
  .relp.section-{{ section.id }} .relp__price {
    font-size: 16px; font-weight: 700; letter-spacing: -0.01em;
    color: {{ section.settings.price_color | default: 'var(--clr-primary)' }};
    font-family: {{ section.settings.price_font | default: 'var(--ff-heading)' }};
  }
  .relp.section-{{ section.id }} .relp__compare {
    font-size: 13px; text-decoration: line-through;
    color: {{ section.settings.compare_color | default: 'var(--clr-muted)' }};
  }

  .relp.section-{{ section.id }} .relp__dots {
    display: flex; justify-content: center; gap: 8px;
    margin-top: 24px;
  }
  .relp.section-{{ section.id }} .relp__dot {
    width: 6px; height: 6px; border-radius: 999px;
    background: {{ section.settings.dot_inactive_color | default: 'var(--clr-gray)' }};
    border: none; padding: 0; cursor: pointer;
    transition: background-color .15s, width .15s;
  }
  .relp.section-{{ section.id }} .relp__dot.is-active {
    background: {{ section.settings.dot_active_color | default: 'var(--clr-primary)' }};
    width: 24px;
  }

  .relp.section-{{ section.id }} .relp__empty {
    padding: 60px 24px;
    text-align: center;
    color: var(--clr-muted);
    background: var(--clr-light);
    border-radius: 14px;
    font-size: 14px;
  }
{%- endstyle -%}

{%- comment -%} Source resolution — strict: "collection" uses ONLY the picked collection, "auto" uses ONLY product.recommendations {%- endcomment -%}
{%- assign _src = section.settings.source | default: 'auto' -%}
{%- assign source_products = empty -%}
{%- assign source_note = '' -%}
{%- if _src == 'collection' -%}
  {%- if section.settings.collection and section.settings.collection.products and section.settings.collection.products.size > 0 -%}
    {%- assign source_products = section.settings.collection.products -%}
  {%- else -%}
    {%- assign source_note = 'Pick a collection with products in the Source panel.' -%}
  {%- endif -%}
{%- else -%}
  {%- if product.recommendations and product.recommendations.size > 0 -%}
    {%- assign source_products = product.recommendations -%}
  {%- else -%}
    {%- assign source_note = 'No recommendations yet for this product \u2014 switch Source to "Collection" to curate manually.' -%}
  {%- endif -%}
{%- endif -%}

{%- capture star_svg -%}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>{%- endcapture -%}

<section class="relp section-{{ section.id }}" {{ section.fluid_attributes }}>
  <div class="relp__container">

    <header class="relp__head">
      <div class="relp__intro">
        {% if section.settings.eyebrow != blank %}<span class="relp__eyebrow">{{ section.settings.eyebrow | escape }}</span>{% endif %}
        <h2 class="relp__title">{{ section.settings.heading | default: 'You may also like' | escape }}</h2>
        {% if section.settings.subhead != blank %}<p class="relp__subhead">{{ section.settings.subhead | escape }}</p>{% endif %}
      </div>
      {% if section.settings.show_arrows %}
        <div class="relp__nav">
          <button type="button" class="relp__nav-btn" data-relp-prev aria-label="Previous">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <button type="button" class="relp__nav-btn" data-relp-next aria-label="Next">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        </div>
      {% endif %}
    </header>

    {% if source_products and source_products.size > 0 %}
      <div class="relp__rail" data-relp-rail>
        {%- assign rendered = 0 -%}
        {% for p in source_products limit: section.settings.products_to_show %}
          {%- if p.id == product.id and section.settings.source != 'collection' -%}{%- continue -%}{%- endif -%}
          {%- assign rendered = rendered | plus: 1 -%}

          {%- assign _img = '' -%}
          {%- if p.images and p.images.size > 0 -%}{%- assign _img = p.images[0].src -%}
          {%- elsif p.image_url != blank -%}{%- assign _img = p.image_url -%}
          {%- elsif p.image -%}{%- assign _img = p.image | image_url -%}
          {%- endif -%}

          {%- assign _href = p.url | default: p.canonical_url | default: '#' -%}

          {%- assign _has_compare = false -%}
          {%- if p.compare_at_price and p.compare_at_price != blank -%}
            {%- assign _cmp = p.compare_at_price | plus: 0.0 -%}
            {%- assign _cur = p.price | plus: 0.0 -%}
            {%- if _cmp > _cur and _cur > 0 -%}
              {%- assign _has_compare = true -%}
              {%- assign _save_pct = _cmp | minus: _cur | times: 100.0 | divided_by: _cmp | round -%}
            {%- endif -%}
          {%- endif -%}

          <article class="relp__card">
            <a href="{{ _href }}" class="relp__img-wrap" aria-label="{{ p.title | escape }}">
              {% if _has_compare and section.settings.show_sale_badge %}<span class="relp__badge">−{{ _save_pct }}%</span>{% endif %}
              {% if _img != blank %}
                <img src="{{ _img }}" alt="{{ p.title | escape }}" loading="lazy">
              {% else %}
                <div class="relp__img-placeholder">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" width="44" height="44"><rect x="3" y="4" width="18" height="16" rx="2"/><circle cx="8.5" cy="10" r="1.5"/><path d="M3 16l5-4 4 3 4-5 5 6"/></svg>
                </div>
              {% endif %}
              {% if section.settings.show_quick_add %}
                <span class="relp__quick-add">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                  {{ section.settings.quick_add_label | default: 'View product' | escape }}
                </span>
              {% endif %}
            </a>
            <div class="relp__body">
              {% if section.settings.show_rating and p.ratings %}
                <div class="relp__rating">
                  <span class="relp__stars">{% for i in (1..5) %}{{ star_svg }}{% endfor %}</span>
                  <span>{{ p.ratings }}</span>
                </div>
              {% endif %}
              {% if section.settings.show_title %}<h3 class="relp__name"><a href="{{ _href }}" style="color: inherit; text-decoration: none;">{{ p.title | escape }}</a></h3>{% endif %}
              {% if section.settings.show_price %}
                <div class="relp__price-row">
                  <span class="relp__price">{{ p.price }}</span>
                  {% if _has_compare %}<span class="relp__compare">{{ p.compare_at_price }}</span>{% endif %}
                </div>
              {% endif %}
            </div>
          </article>
        {% endfor %}

        {% if rendered == 0 %}
          <div class="relp__empty">{% if source_note != '' %}{{ source_note | escape }}{% else %}{{ section.settings.empty_text | default: 'More products coming soon.' | escape }}{% endif %}</div>
        {% endif %}
      </div>

      {% if section.settings.show_dots %}
        <div class="relp__dots" data-relp-dots aria-hidden="true"></div>
      {% endif %}
    {% else %}
      <div class="relp__empty">{% if source_note != '' %}{{ source_note | escape }}{% else %}{{ section.settings.empty_text | default: 'More products coming soon.' | escape }}{% endif %}</div>
    {% endif %}

  </div>
</section>

<script>
(function () {
  function init(root) {
    var rail = root.querySelector('[data-relp-rail]');
    if (!rail) return;
    var prev = root.querySelector('[data-relp-prev]');
    var next = root.querySelector('[data-relp-next]');
    var dots = root.querySelector('[data-relp-dots]');

    function cardWidth() {
      var first = rail.querySelector('.relp__card');
      if (!first) return rail.clientWidth;
      var style = getComputedStyle(rail);
      var gap = parseFloat(style.columnGap || style.gap) || 0;
      return first.getBoundingClientRect().width + gap;
    }
    function update() {
      if (prev) prev.disabled = rail.scrollLeft <= 4;
      if (next) next.disabled = rail.scrollLeft + rail.clientWidth >= rail.scrollWidth - 4;
      if (dots) {
        var pages = Math.max(1, Math.ceil(rail.scrollWidth / rail.clientWidth));
        var idx = Math.round(rail.scrollLeft / rail.clientWidth);
        dots.innerHTML = '';
        for (var i = 0; i < pages; i++) {
          var d = document.createElement('button');
          d.type = 'button';
          d.className = 'relp__dot' + (i === idx ? ' is-active' : '');
          d.setAttribute('aria-label', 'Go to slide ' + (i + 1));
          (function (page) { d.addEventListener('click', function () { rail.scrollTo({ left: page * rail.clientWidth, behavior: 'smooth' }); }); })(i);
          dots.appendChild(d);
        }
      }
    }
    if (prev) prev.addEventListener('click', function () { rail.scrollBy({ left: -cardWidth(), behavior: 'smooth' }); });
    if (next) next.addEventListener('click', function () { rail.scrollBy({ left: cardWidth(), behavior: 'smooth' }); });
    rail.addEventListener('scroll', function () { window.requestAnimationFrame(update); }, { passive: true });
    window.addEventListener('resize', update);
    update();
  }
  function boot() { document.querySelectorAll('.section-{{ section.id }}').forEach(init); }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot); else boot();
})();
</script>

{% schema %}
{
  "name": "Related Products",
  "tag": "section",
  "class": "related-products-section",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "eyebrow",  "label": "Eyebrow", "default": "You may also like" },
    { "type": "text", "id": "heading",  "label": "Heading", "default": "Complete the lineup" },
    { "type": "text", "id": "subhead",  "label": "Subhead (optional)", "default": "Hand-picked pairings our customers love." },
    { "type": "text", "id": "empty_text", "label": "Empty state text", "default": "More products coming soon." },

    { "type": "header", "content": "Source" },
    { "type": "select",     "id": "source", "label": "Recommendations source", "default": "auto",
      "options": [
        { "value": "auto",       "label": "Auto \u2014 Fluid recommendations" },
        { "value": "collection", "label": "Collection \u2014 pick one below" }
      ]
    },
    { "type": "collection", "id": "collection", "label": "Collection", "visible_if": "{{ section.settings.source == 'collection' }}" },
    { "type": "range",      "id": "products_to_show", "label": "Products to show", "min": 2, "max": 16, "step": 1, "default": 8 },

    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "cards_visible_desktop", "label": "Cards visible (desktop)", "min": 2, "max": 5, "step": 1, "default": 4 },
    { "type": "range", "id": "cards_visible_tablet",  "label": "Cards visible (tablet)",  "min": 1, "max": 4, "step": 1, "default": 2 },
    { "type": "range", "id": "cards_visible_mobile",  "label": "Cards visible (mobile)",  "min": 1, "max": 2, "step": 1, "default": 1 },
    { "type": "range", "id": "gap", "label": "Gap (px)", "min": 8, "max": 40, "step": 2, "default": 24 },
    { "type": "checkbox", "id": "show_arrows", "label": "Show prev/next arrows", "default": true },
    { "type": "checkbox", "id": "show_dots",   "label": "Show pagination dots",  "default": true },

    { "type": "header", "content": "Card" },
    { "type": "select", "id": "image_aspect_ratio", "label": "Image aspect ratio", "default": "1/1",
      "options": [
        { "value": "1/1",  "label": "Square (1:1)" },
        { "value": "4/5",  "label": "Portrait (4:5)" },
        { "value": "3/4",  "label": "Portrait (3:4)" },
        { "value": "4/3",  "label": "Standard (4:3)" }
      ]
    },
