                        {% endif %}
                        {% if current_feature_image.settings.overlay_color != blank and current_feature_image.settings.overlay_opacity > 0 %}
                          {% assign _a = current_feature_image.settings.overlay_opacity | divided_by: 100.0 %}
                          <div class="media-wrap__overlay" style="background: {{ current_feature_image.settings.overlay_color }}; opacity: {{ _a }};"></div>
                        {% endif %}
                      </div>
                      {% if _link != blank %}</a>{% endif %}
                    {% endif %}
            </div>
          </div>
        </div>
      </div>
    </section>
  {% endif %}
  </div>

