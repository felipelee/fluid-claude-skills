{% comment %} Handle background_image - can be string URL or object with url/fluid_media_id {% endcomment %}
{% assign bg_url = '' %}
{% assign bg_fluid_media_id = '' %}

{% if section.settings.background_image %}
  {% if section.settings.background_image.url %}
    {% comment %} It's an object with url property {% endcomment %}
    {% assign bg_url = section.settings.background_image.url %}
    
    {% comment %} Check if it also has fluid_media_id from media picker {% endcomment %}
    {% if section.settings.background_image.fluid_media_id %}
      {% assign bg_fluid_media_id = section.settings.background_image.fluid_media_id %}
      {% assign bg_embed_type = section.settings.background_image.embed_type %}
    {% endif %}
  {% else %}
    {% comment %} It's a string URL {% endcomment %}
    {% assign bg_url = section.settings.background_image %}
  {% endif %}
{% endif %}

{% comment %} Determine whether to use fluid widget - if fluid_media_id exists, use widget {% endcomment %}
{% assign use_fluid_widget = false %}

{% if bg_fluid_media_id != blank %}
  {% assign use_fluid_widget = true %}
{% endif %}

{%- style -%}
  .section-{{ section.id }} {
    {%- assign p = section.settings.section_padding -%}
    {%- if p -%}
      {%- capture pt -%}{{ p.top }}{%- endcapture -%}
      {%- capture pb -%}{{ p.bottom }}{%- endcapture -%}
      {%- capture pl -%}{{ p.left }}{%- endcapture -%}
      {%- capture pr -%}{{ p.right }}{%- endcapture -%}
      padding-top: {% if pt contains 'var(' %}{{ pt }}{% else %}{{ pt }}px{% endif %};
      padding-bottom: {% if pb contains 'var(' %}{{ pb }}{% else %}{{ pb }}px{% endif %};
      padding-left: {% if pl contains 'var(' %}{{ pl }}{% else %}{{ pl }}px{% endif %};
      padding-right: {% if pr contains 'var(' %}{{ pr }}{% else %}{{ pr }}px{% endif %};
    {%- endif -%}
    {%- assign sr = section.settings.section_border_radius -%}
    {%- if sr -%}
      {%- capture sr_tl -%}{{ sr.tl }}{%- endcapture -%}
      {%- capture sr_tr -%}{{ sr.tr }}{%- endcapture -%}
      {%- capture sr_br -%}{{ sr.br }}{%- endcapture -%}
      {%- capture sr_bl -%}{{ sr.bl }}{%- endcapture -%}
      border-radius: {% if sr_tl contains 'var(' %}{{ sr_tl }}{% else %}{{ sr_tl }}px{% endif %} {% if sr_tr contains 'var(' %}{{ sr_tr }}{% else %}{{ sr_tr }}px{% endif %} {% if sr_br contains 'var(' %}{{ sr_br }}{% else %}{{ sr_br }}px{% endif %} {% if sr_bl contains 'var(' %}{{ sr_bl }}{% else %}{{ sr_bl }}px{% endif %};
    {%- endif -%}
    {%- assign sb = section.settings.section_border -%}
    {%- if sb.width -%}
      border: {{ sb.width }} solid {{ sb.color }};
    {%- endif -%}
  }
{%- endstyle -%}

<!-- Feature section-->
<div class="feature-wrapper section-{{ section.id }}" data-bg="{% unless use_fluid_widget %}{{ bg_url }}{% endunless %}" style="background-color: {{ section.settings.background_color | default: '#ffffff' }};">
  {% if use_fluid_widget %}
    <fluid-media-widget class="fluid-media-widget-background" media-id="{{ bg_fluid_media_id }}" responsive="true" embed-type="{{ bg_embed_type | default: 'inline' }}" data-fluid-widget="true"></fluid-media-widget>
  {% endif %}
  {% assign current_feature_item = null %}
  {% assign current_heading = null %}
  {% assign current_description = null %}
  {% assign current_feature_image = null %}
  {% assign current_button_1 = null %}
  {% assign current_button_2 = null %}
  {% assign current_link = null %}
  {% for block in section.blocks %}
    {% case block.type %}
      {% when 'feature_item' %}
        {% if current_feature_item %}
          {% assign feature_class = 'feature-section-' | append: forloop.index0 %}
          <section class="feature-section {{ feature_class }}" {{ current_feature_item.fluid_attributes }}>
            <div class="container ">
              <div class="grid {{ section.settings.content_gap_mobile | default: 'space-4xl' }} {{ section.settings.content_gap_desktop | default: 'lg:space-5xl' }} feature-grid">
                <div class="feature-content flex justify-center h-full flex-col {{ section.settings.content_spacing_mobile | default: 'space-lg' }} {{ section.settings.content_spacing_desktop | default: 'lg:space-2xl' }} flex-1">
                  {% if current_heading %}
                    <div class="rte" {{ current_heading.fluid_attributes }}>{{ current_heading.settings.text | default: "<p>Medium length hero heading goes here</p>" }}</div>
                  {% endif %}
                  {% if current_description %}
                    <div class="rte" {{ current_description.fluid_attributes }}>{{ current_description.settings.text | default: "<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique. Duis cursus, mi quis viverra ornare, eros dolor interdum nulla, ut commodo diam libero vitae erat.</p>" }}</div>
                  {% endif %}
                  {% if current_button_1 or current_button_2 %}
                    <div class="flex justify-start align-center {{ section.settings.button_gap | default: 'space-lg' }}">
                      {% if current_button_1 %}
                        {% capture _btn1_style %}
                          {% if current_button_1.settings.background_color != blank %}background-color: {{ current_button_1.settings.background_color }};{% endif %}
                          {% if current_button_1.settings.text_color != blank %}color: {{ current_button_1.settings.text_color }};{% endif %}
                          {% if current_button_1.settings.font_size != blank %}font-size: {{ current_button_1.settings.font_size }}px;{% endif %}
                          {% if current_button_1.settings.font_family != blank %}font-family: {{ current_button_1.settings.font_family | font_family }};{% endif %}
                          {% assign p = current_button_1.settings.padding %}{% if p %}padding: {{ p.top }}px {{ p.right }}px {{ p.bottom }}px {{ p.left }}px;{% endif %}
                          {% assign br = current_button_1.settings.border_radius %}{% if br %}border-radius: {{ br.tl }}px {{ br.tr }}px {{ br.br }}px {{ br.bl }}px;{% endif %}
                          {% assign bd = current_button_1.settings.border %}{% if bd.width %}border: {{ bd.width }} solid {{ bd.color }};{% endif %}
                        {% endcapture %}
                        <a href="{{ current_button_1.settings.link | default: '#' }}"
                           class="btn btn--{{ current_button_1.settings.style | default: 'filled' }}"
                           style="{{ _btn1_style | strip_newlines }}"
                           {% if current_button_1.settings.open_new_tab %}target="_blank" rel="noopener"{% endif %}
                           {{ current_button_1.fluid_attributes }}>
                          {{ current_button_1.settings.text | default: 'Button' | escape }}
                        </a>
                      {% endif %}
                      {% if current_button_2 %}
                        {% capture _btn2_style %}
                          {% if current_button_2.settings.background_color != blank %}background-color: {{ current_button_2.settings.background_color }};{% endif %}
                          {% if current_button_2.settings.text_color != blank %}color: {{ current_button_2.settings.text_color }};{% endif %}
                          {% if current_button_2.settings.font_size != blank %}font-size: {{ current_button_2.settings.font_size }}px;{% endif %}
                          {% if current_button_2.settings.font_family != blank %}font-family: {{ current_button_2.settings.font_family | font_family }};{% endif %}
                          {% assign p = current_button_2.settings.padding %}{% if p %}padding: {{ p.top }}px {{ p.right }}px {{ p.bottom }}px {{ p.left }}px;{% endif %}
                          {% assign br = current_button_2.settings.border_radius %}{% if br %}border-radius: {{ br.tl }}px {{ br.tr }}px {{ br.br }}px {{ br.bl }}px;{% endif %}
                          {% assign bd = current_button_2.settings.border %}{% if bd.width %}border: {{ bd.width }} solid {{ bd.color }};{% endif %}
                        {% endcapture %}
                        <a href="{{ current_button_2.settings.link | default: '#' }}"
                           class="btn btn--{{ current_button_2.settings.style | default: 'filled' }}"
                           style="{{ _btn2_style | strip_newlines }}"
                           {% if current_button_2.settings.open_new_tab %}target="_blank" rel="noopener"{% endif %}
                           {{ current_button_2.fluid_attributes }}>
                          {{ current_button_2.settings.text | default: 'Button' | escape }}
                        </a>
                      {% endif %}
                    </div>
                  {% endif %}
                  {% if current_link %}
                    {% if current_link.settings.text != blank %}
                      {% render 'link',
                        href: current_link.settings.url | default: '#',
                        text: current_link.settings.text,
                        underline: current_link.settings.underline_style,
                        icon_position: current_link.settings.icon_position,
                        color: current_link.settings.color,
                        font_weight: current_link.settings.font_weight,
                        attr: current_link.fluid_attributes
                      %}
                    {% endif %}
                  {% endif %}
                </div>
                <div class="feature-image-wrapper">
                  <div class="feature-image feature-image-right">
                    {% if current_feature_image %}
                      {% assign _img = current_feature_image.settings.image %}
                      {% assign _alt = current_feature_image.settings.alt | default: _img.alt | default: 'feature' %}
                      {% assign _ar = current_feature_image.settings.aspect_ratio | default: 'auto' %}
                      {% assign _fit = current_feature_image.settings.fit | default: 'cover' %}
                      {% capture _wrap_style %}
                        {% if _ar != 'auto' %}aspect-ratio: {{ _ar }};{% endif %}
                        {% assign br = current_feature_image.settings.border_radius %}{% if br %}border-radius: {{ br.tl }}px {{ br.tr }}px {{ br.br }}px {{ br.bl }}px;{% endif %}
                        {% assign bd = current_feature_image.settings.border %}{% if bd.width %}border: {{ bd.width }} solid {{ bd.color }};{% endif %}
                      {% endcapture %}
                      {% capture _img_style %}
                        {% if _ar != 'auto' %}width: 100%; height: 100%;{% endif %}
                        object-fit: {{ _fit }};
                        object-position: {{ current_feature_image.settings.object_position | default: 'center' }};
                      {% endcapture %}
                      {% capture _link %}{{ current_feature_image.settings.link }}{% endcapture %}
                      {% if _link != blank %}<a href="{{ _link }}" class="media-link" {% if current_feature_image.settings.open_new_tab %}target="_blank" rel="noopener"{% endif %}>{% endif %}
                      <div class="media-wrap" style="{{ _wrap_style | strip_newlines }}" {{ current_feature_image.fluid_attributes }}>
                        {% if _img %}
                          <img src="{{ _img | img_url: '1600x' }}" alt="{{ _alt | escape }}" loading="lazy" style="{{ _img_style | strip_newlines }}" />
                        {% endif %}
                        {% if current_feature_image.settings.overlay_color != blank and current_feature_image.settings.overlay_opacity > 0 %}
                          {% assign _a = current_feature_image.settings.overlay_opacity | divided_by: 100.0 %}
                          <div class="media-wrap__overlay" style="background: {{ current_feature_image.settings.overlay_color }}; opacity: {{ _a }};"></div>
                        {% endif %}
                      </div>
                      {% if _link != blank %}</a>{% endif %}
                    {% endif %}
                  </div>
                </div>
              </div>
            </div>
          </section>
        {% endif %}
        {% assign current_feature_item = block %}
        {% assign current_heading = null %}
        {% assign current_description = null %}
        {% assign current_feature_image = null %}
        {% assign current_button_1 = null %}
        {% assign current_button_2 = null %}
        {% assign current_link = null %}
      {% when 'heading' %}
        {% if current_feature_item %}
          {% assign current_heading = block %}
        {% endif %}
      {% when 'description' %}
        {% if current_feature_item %}
          {% assign current_description = block %}
        {% endif %}
      {% when 'image' %}
        {% if current_feature_item %}
          {% assign current_feature_image = block %}
        {% endif %}
      {% when 'button' %}
        {% if current_feature_item %}
          {% if current_button_1 == null %}
            {% assign current_button_1 = block %}
          {% elsif current_button_2 == null %}
            {% assign current_button_2 = block %}
          {% endif %}
        {% endif %}
      {% when 'link' %}
        {% if current_feature_item %}
          {% assign current_link = block %}
        {% endif %}
    {% endcase %}
  {% endfor %}
  {% if current_feature_item %}
    {% assign feature_class = 'feature-section-' | append: section.blocks.size %}
    <section class="feature-section {{ feature_class }}" {{ current_feature_item.fluid_attributes }}>
      <div class="container ">
        <div class="grid {{ section.settings.content_gap_mobile | default: 'space-4xl' }} {{ section.settings.content_gap_desktop | default: 'lg:space-5xl' }} feature-grid">
          <div class="feature-content flex justify-center h-full flex-col {{ section.settings.content_spacing_mobile | default: 'space-lg' }} {{ section.settings.content_spacing_desktop | default: 'lg:space-2xl' }} flex-1">
            {% if current_heading %}
              <div class="rte" {{ current_heading.fluid_attributes }}>{{ current_heading.settings.text | default: "<p>Medium length hero heading goes here</p>" }}</div>
            {% endif %}
            {% if current_description %}
              <div class="rte" {{ current_description.fluid_attributes }}>{{ current_description.settings.text | default: "<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique. Duis cursus, mi quis viverra ornare, eros dolor interdum nulla, ut commodo diam libero vitae erat.</p>" }}</div>
            {% endif %}
            {% if current_button_1 or current_button_2 %}
              <div class="flex justify-start align-center {{ section.settings.button_gap | default: 'space-lg' }}">
                {% if current_button_1 %}
                  {% capture _btn1_style %}
                          {% if current_button_1.settings.background_color != blank %}background-color: {{ current_button_1.settings.background_color }};{% endif %}
                          {% if current_button_1.settings.text_color != blank %}color: {{ current_button_1.settings.text_color }};{% endif %}
                          {% if current_button_1.settings.font_size != blank %}font-size: {{ current_button_1.settings.font_size }}px;{% endif %}
                          {% if current_button_1.settings.font_family != blank %}font-family: {{ current_button_1.settings.font_family | font_family }};{% endif %}
                          {% assign p = current_button_1.settings.padding %}{% if p %}padding: {{ p.top }}px {{ p.right }}px {{ p.bottom }}px {{ p.left }}px;{% endif %}
                          {% assign br = current_button_1.settings.border_radius %}{% if br %}border-radius: {{ br.tl }}px {{ br.tr }}px {{ br.br }}px {{ br.bl }}px;{% endif %}
                          {% assign bd = current_button_1.settings.border %}{% if bd.width %}border: {{ bd.width }} solid {{ bd.color }};{% endif %}
                        {% endcapture %}
                        <a href="{{ current_button_1.settings.link | default: '#' }}"
                           class="btn btn--{{ current_button_1.settings.style | default: 'filled' }}"
                           style="{{ _btn1_style | strip_newlines }}"
                           {% if current_button_1.settings.open_new_tab %}target="_blank" rel="noopener"{% endif %}
                           {{ current_button_1.fluid_attributes }}>
                          {{ current_button_1.settings.text | default: 'Button' | escape }}
                        </a>
                {% endif %}
                {% if current_button_2 %}
                  {% capture _btn2_style %}
                          {% if current_button_2.settings.background_color != blank %}background-color: {{ current_button_2.settings.background_color }};{% endif %}
                          {% if current_button_2.settings.text_color != blank %}color: {{ current_button_2.settings.text_color }};{% endif %}
                          {% if current_button_2.settings.font_size != blank %}font-size: {{ current_button_2.settings.font_size }}px;{% endif %}
                          {% if current_button_2.settings.font_family != blank %}font-family: {{ current_button_2.settings.font_family | font_family }};{% endif %}
                          {% assign p = current_button_2.settings.padding %}{% if p %}padding: {{ p.top }}px {{ p.right }}px {{ p.bottom }}px {{ p.left }}px;{% endif %}
                          {% assign br = current_button_2.settings.border_radius %}{% if br %}border-radius: {{ br.tl }}px {{ br.tr }}px {{ br.br }}px {{ br.bl }}px;{% endif %}
                          {% assign bd = current_button_2.settings.border %}{% if bd.width %}border: {{ bd.width }} solid {{ bd.color }};{% endif %}
                        {% endcapture %}
                        <a href="{{ current_button_2.settings.link | default: '#' }}"
                           class="btn btn--{{ current_button_2.settings.style | default: 'filled' }}"
                           style="{{ _btn2_style | strip_newlines }}"
                           {% if current_button_2.settings.open_new_tab %}target="_blank" rel="noopener"{% endif %}
                           {{ current_button_2.fluid_attributes }}>
                          {{ current_button_2.settings.text | default: 'Button' | escape }}
                        </a>
                {% endif %}
              </div>
            {% endif %}
            {% if current_link %}
              {% if current_link.settings.text != blank %}
                {% render 'link',
                  href: current_link.settings.url | default: '#',
                  text: current_link.settings.text,
                  underline: current_link.settings.underline_style,
                  icon_position: current_link.settings.icon_position,
                  color: current_link.settings.color,
                  font_weight: current_link.settings.font_weight,
                  attr: current_link.fluid_attributes
                %}
              {% endif %}
            {% endif %}
          </div>
          <div class="feature-image-wrapper">
            <div class="feature-image feature-image-right">
              {% if current_feature_image %}
                      {% assign _img = current_feature_image.settings.image %}
                      {% assign _alt = current_feature_image.settings.alt | default: _img.alt | default: 'feature' %}
                      {% assign _ar = current_feature_image.settings.aspect_ratio | default: 'auto' %}
                      {% assign _fit = current_feature_image.settings.fit | default: 'cover' %}
                      {% capture _wrap_style %}
                        {% if _ar != 'auto' %}aspect-ratio: {{ _ar }};{% endif %}
                        {% assign br = current_feature_image.settings.border_radius %}{% if br %}border-radius: {{ br.tl }}px {{ br.tr }}px {{ br.br }}px {{ br.bl }}px;{% endif %}
                        {% assign bd = current_feature_image.settings.border %}{% if bd.width %}border: {{ bd.width }} solid {{ bd.color }};{% endif %}
                      {% endcapture %}
                      {% capture _img_style %}
                        {% if _ar != 'auto' %}width: 100%; height: 100%;{% endif %}
                        object-fit: {{ _fit }};
                        object-position: {{ current_feature_image.settings.object_position | default: 'center' }};
                      {% endcapture %}
                      {% capture _link %}{{ current_feature_image.settings.link }}{% endcapture %}
                      {% if _link != blank %}<a href="{{ _link }}" class="media-link" {% if current_feature_image.settings.open_new_tab %}target="_blank" rel="noopener"{% endif %}>{% endif %}
                      <div class="media-wrap" style="{{ _wrap_style | strip_newlines }}" {{ current_feature_image.fluid_attributes }}>
                        {% if _img %}
