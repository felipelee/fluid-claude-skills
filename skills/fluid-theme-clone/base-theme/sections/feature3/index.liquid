{%- style -%}
  .section-{{ section.id }} {
    {%- assign p = section.settings.section_padding -%}
    {%- if p -%}
      {%- capture pt -%}{{ p.top }}{%- endcapture -%}
      {%- capture pb -%}{{ p.bottom }}{%- endcapture -%}
      {%- capture pl -%}{{ p.left }}{%- endcapture -%}
      {%- capture pr -%}{{ p.right }}{%- endcapture -%}
      padding-top: {% if pt contains 'var(' %}{{ pt }}{% else %}{{ pt }}px{% endif %};
      padding-bottom: {% if pb contains 'var(' %}{{ pb }}{% else %}{{ pb }}px{% endif %};
      padding-left: {% if pl contains 'var(' %}{{ pl }}{% else %}{{ pl }}px{% endif %};
      padding-right: {% if pr contains 'var(' %}{{ pr }}{% else %}{{ pr }}px{% endif %};
    {%- endif -%}
    {%- assign sr = section.settings.section_border_radius -%}
    {%- if sr -%}
      {%- capture sr_tl -%}{{ sr.tl }}{%- endcapture -%}
      {%- capture sr_tr -%}{{ sr.tr }}{%- endcapture -%}
      {%- capture sr_br -%}{{ sr.br }}{%- endcapture -%}
      {%- capture sr_bl -%}{{ sr.bl }}{%- endcapture -%}
      border-radius: {% if sr_tl contains 'var(' %}{{ sr_tl }}{% else %}{{ sr_tl }}px{% endif %} {% if sr_tr contains 'var(' %}{{ sr_tr }}{% else %}{{ sr_tr }}px{% endif %} {% if sr_br contains 'var(' %}{{ sr_br }}{% else %}{{ sr_br }}px{% endif %} {% if sr_bl contains 'var(' %}{{ sr_bl }}{% else %}{{ sr_bl }}px{% endif %};
    {%- endif -%}
  }
{%- endstyle -%}

<section class="feature3-section section-{{ section.id }}" 
         style="background-color: {{ section.settings.background_color | default: '#ffffff' }};
                {% if section.settings.background_image != blank %}
                background-image: url('{{ section.settings.background_image | image_url: width: 1920 }}');
                background-size: cover;
                background-position: center;
                background-repeat: no-repeat;
                {% endif %}
                position: relative;">
  
  {%- assign ov = section.settings.overlay -%}
  {%- if ov and ov.enabled -%}
    <div class="overlay-{{ section.id }}"></div>
    {%- style -%}
      .overlay-{{ section.id }} {
        position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1;
        {%- if ov.mode == 'gradient' and ov.colors.size > 1 -%}
          background:
            {%- if ov.gradientType == 'radial' -%}
              radial-gradient(
            {%- else -%}
              linear-gradient({{ ov.angle }}deg,
            {%- endif -%}
            {%- for stop in ov.colors -%}
              {{ stop.color }} {{ stop.position }}%{%- unless forloop.last -%},{%- endunless -%}
            {%- endfor -%}
          );
          opacity: {{ ov.colors.first.opacity | divided_by: 100.0 }};
        {%- else -%}
          {%- assign c = ov.colors | first -%}
          background-color: {{ c.color }};
          opacity: {{ c.opacity | divided_by: 100.0 }};
        {%- endif -%}
      }
    {%- endstyle -%}
  {%- endif -%}
  
  <div class="container" style="position: relative; z-index: 2;">
    <div class="feature3-wrapper grid grid-cols-1 sm-desktop-grid-cols-2 space-7xl align-center {% if section.settings.image_on_left %}feature3-flipped{% endif %}">
      
      <!-- Content Column -->
      <div class="feature3-content">
        <!-- Feature Points Grid (2x2) -->
        <div class="feature3-points grid grid-cols-1 sm-desktop-grid-cols-2 space-4xl mb-4xl">
          {%- assign point_blocks = section.blocks | where: 'type', 'point' -%}
          {%- for block in point_blocks -%}
            <div class="feature3-point" {{ block.fluid_attributes }}>
              <div class="feature3-icon mb-lg">
                {% assign img_input = block.settings.image %}
                {% assign img_fluid_media_id = '' %}
                {% if img_input.fluid_media_id %}
                  {% assign img_fluid_media_id = img_input.fluid_media_id %}
                  {% assign img_embed_type = img_input.embed_type %}
                {% endif %}
                {%- assign _fit_class = 'image-cover' -%}
                {%- case block.settings.media_fit -%}
                  {%- when 'contain' -%}{%- assign _fit_class = 'image-contain' -%}
                  {%- when 'fit-width' -%}{%- assign _fit_class = 'image-cover' -%}
                  {%- when 'fit-height' -%}{%- assign _fit_class = 'image-contain' -%}
                {%- endcase -%}
                {%- capture _media_style -%}
                  {% if block.settings.max_width != blank %}max-width: {{ block.settings.max_width }}px;{% endif %}
                  {% if block.settings.max_height != blank %}max-height: {{ block.settings.max_height }}px;{% endif %}
                {%- endcapture -%}
                {% if img_fluid_media_id != '' %}
                  <fluid-media-widget class="fluid-media-widget-image" media-id="{{ img_fluid_media_id }}" responsive="true" embed-type="{{ img_embed_type | default:'inline' }}" data-fluid-widget="true"></fluid-media-widget>
                {% elsif block.settings.image != blank %}
                  <div class="media-container" style="{{ _media_style }}">
                  <img src="{{ block.settings.image | image_url }}" alt="{{ block.settings.image_alt | default: block.settings.heading }}" class="{{ _fit_class }} feature3-point-image media-container" style="{{ _media_style }}" loading="lazy" width="" height=""/>
                  </div>
                {% else %}
                  <div class="feature3-icon-placeholder">
                    <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg>
                  </div>
                {% endif %}
              </div>
              <div class="rte mb-md" {{ block.fluid_attributes }}>{{ block.settings.heading }}</div>
              <div class="rte" {{ block.fluid_attributes }}>{{ block.settings.description }}</div>
            </div>
          {%- endfor -%}
        </div>
      </div>

      <!-- Image Column -->
      <div class="feature3-image-wrapper">
        {% assign feature_image_input = section.settings.feature_image %}
          {% assign feature_image_input_fluid_media_id = '' %}
          
          {% if feature_image_input.fluid_media_id %}
            {% assign feature_image_input_fluid_media_id = feature_image_input.fluid_media_id %}
            {% assign feature_image_input_embed_type = feature_image_input.embed_type %}
          {% endif %}

          {% assign use_feature_image_fluid_image_widget = false %}
          
          {% if feature_image_input_fluid_media_id != '' %}
            {% assign use_feature_image_fluid_image_widget = true %}
          {% endif %}

          {% if use_feature_image_fluid_image_widget %}
            <fluid-media-widget class="fluid-media-widget-image" media-id="{{ feature_image_input_fluid_media_id }}" responsive="true" embed-type="{{ feature_image_input_embed_type | default:'inline' }}" data-fluid-widget="true"></fluid-media-widget>
          {% else %}
            {% if feature_image_input != blank %}
                <img src="{{ feature_image_input }}" alt="{{ section.settings.image_alt | default: 'Feature image' }}" class="feature2-image image-cover" loading="lazy" width="" height=""/>
            {% else %}
              <div class="feature3-image-placeholder">
                <svg width="80" height="80" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                </svg>
                <p class="text-sm mt-md" style=" color: #9ca3af;">Upload feature image</p>
              </div>
            {% endif %}
          {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
.feature3-section .feature3-wrapper {
  min-height: 400px;
}

.feature3-section .feature3-content {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

/* Flipped layout - image on left, content on right */
.feature3-section .feature3-flipped .feature3-content {
  order: 2;
}

.feature3-section .feature3-flipped .feature3-image-wrapper {
  order: 1;
}

.feature3-section .feature3-image-wrapper {
  position: relative;
  min-height: 300px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.feature3-section .feature3-image {
  width: 100%;
  height: 400px;
  border-radius: 8px;
  object-fit: cover;
}

.feature3-section .feature3-image-placeholder {
  width: 100%;
  height: 400px;
  background-color: #f3f4f6;
  border: 2px dashed #d1d5db;
  border-radius: 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #9ca3af;
}

.feature3-section .feature3-point-image {
  width: 48px;
  height: 48px;
  object-fit: cover;
  border-radius: 4px;
}

.feature3-section .feature3-icon-placeholder {
  width: 48px;
  height: 48px;
  background-color: #f3f4f6;
  border: 2px dashed #d1d5db;
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9ca3af;
}

@media (max-width: 959px) {
  .feature3-section .feature3-wrapper {
    min-height: auto;
    gap: 32px;
  }
  
  .feature3-section .feature3-image,
  .feature3-section .feature3-image-placeholder {
    height: 300px;
  }

  .feature3-section .feature3-points {
    gap: 24px;
    margin-bottom: 32px;
  }

  /* Reset order on mobile - always show content first, then image */
  .feature3-section .feature3-flipped .feature3-content,
  .feature3-section .feature3-flipped .feature3-image-wrapper {
    order: initial;
  }
}

@media (max-width: 767px) {
  .feature3-section .feature3-wrapper {
    gap: 24px;
  }
  
  .feature3-section .feature3-image,
  .feature3-section .feature3-image-placeholder {
    height: 250px;
  }

  .feature3-section .feature3-points {
    grid-template-columns: 1fr;
    gap: 20px;
    margin-bottom: 24px;
  }
}
</style>

{% schema %}
{
  "name": "Feature 3",
  "settings": [
    {
      "type": "image_picker",
      "id": "feature_image",
      "label": "Feature Image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image Alt Text",
      "info": "Describe the image for accessibility"
    },
    {
      "type": "checkbox",
      "id": "image_on_left",
      "default": false,
      "label": "Image on Left",
      "info": "Check to place image on left side and content on right"
    },
    {
      "type": "color_background",
      "id": "background_color",
      "default": "#ffffff",
      "label": "Background Color"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image",
      "info": "Optional background image (will override background color)"
    },
    {
      "type": "gradient_overlay",
      "id": "overlay",
      "label": "Overlay"
    },
    {
      "type": "padding",
      "id": "section_padding",
      "label": "Section Padding"
    },
    {
      "type": "corner_radius",
      "id": "section_border_radius",
      "label": "Section Border Radius",
      "info": "Default 0px. Four corners, link/unlink."
    }
  ],
  "blocks": [
    {
      "type": "point",
      "name": "Feature Point",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Icon / Image" },
        { "type": "text", "id": "image_alt", "label": "Image Alt" },
        {
          "type": "select",
          "id": "media_fit",
          "label": "Image Fit",
          "options": [
            { "value": "cover", "label": "Cover (Fill Container)" },
            { "value": "contain", "label": "Contain (Fit Inside)" },
            { "value": "fit-width", "label": "Fit to Width" },
            { "value": "fit-height", "label": "Fit to Height" }
          ],
          "default": "cover"
        },

        {

          "type": "range",

          "id": "max_width",

          "min": 0,

          "max": 2000,

          "step": 1,

          "label": "Max Width (px)",

          "info": "Leave empty for no limit"

        },

        {

          "type": "range",

          "id": "max_height",

          "min": 0,

          "max": 2000,

          "step": 1,

          "label": "Max Height (px)",

          "info": "Leave empty for no limit"

        },
        {
          "type": "corner_radius",
          "id": "media_border_radius",
          "label": "Image Border Radius",
          "info": "Override theme default media radius"
        },
        { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>Short heading here</p>" },
        { "type": "richtext", "id": "description", "label": "Description", "default": "<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Feature 3",
      "blocks": [
        { "type": "point", "settings": { "heading": "<p>Point 1</p>", "description": "<p>Lorem ipsum dolor sit amet.</p>" } },
        { "type": "point", "settings": { "heading": "<p>Point 2</p>", "description": "<p>Lorem ipsum dolor sit amet.</p>" } },
        { "type": "point", "settings": { "heading": "<p>Point 3</p>", "description": "<p>Lorem ipsum dolor sit amet.</p>" } },
        { "type": "point", "settings": { "heading": "<p>Point 4</p>", "description": "<p>Lorem ipsum dolor sit amet.</p>" } }
      ]
    }
  ]
}
{% endschema %}