<!-- Intro section -->
{%- style -%}
  .section-{{ section.id }} {
    background-color: {{ section.settings.background_color | default: '#ffffff' }};
    {%- assign p = section.settings.section_padding -%}
    {%- if p -%}
      {%- capture pt -%}{{ p.top }}{%- endcapture -%}
      {%- capture pb -%}{{ p.bottom }}{%- endcapture -%}
      {%- capture pl -%}{{ p.left }}{%- endcapture -%}
      {%- capture pr -%}{{ p.right }}{%- endcapture -%}
      padding-top: {% if pt contains 'var(' %}{{ pt }}{% else %}{{ pt }}px{% endif %};
      padding-bottom: {% if pb contains 'var(' %}{{ pb }}{% else %}{{ pb }}px{% endif %};
      padding-left: {% if pl contains 'var(' %}{{ pl }}{% else %}{{ pl }}px{% endif %};
      padding-right: {% if pr contains 'var(' %}{{ pr }}{% else %}{{ pr }}px{% endif %};
    {%- endif -%}
    {%- assign sr = section.settings.section_border_radius -%}
    {%- if sr -%}
      {%- capture sr_tl -%}{{ sr.tl }}{%- endcapture -%}
      {%- capture sr_tr -%}{{ sr.tr }}{%- endcapture -%}
      {%- capture sr_br -%}{{ sr.br }}{%- endcapture -%}
      {%- capture sr_bl -%}{{ sr.bl }}{%- endcapture -%}
      border-radius: {% if sr_tl contains 'var(' %}{{ sr_tl }}{% else %}{{ sr_tl }}px{% endif %} {% if sr_tr contains 'var(' %}{{ sr_tr }}{% else %}{{ sr_tr }}px{% endif %} {% if sr_br contains 'var(' %}{{ sr_br }}{% else %}{{ sr_br }}px{% endif %} {% if sr_bl contains 'var(' %}{{ sr_bl }}{% else %}{{ sr_bl }}px{% endif %};
    {%- endif -%}
  }
{%- endstyle -%}

<section class="intro-section section-{{ section.id }}">
    <div class="container">
        <div class="flex flex-col justify-center align-center {{ section.settings.content_gap_mobile | default: 'space-3xl' }} {{ section.settings.content_gap_desktop | default: 'lg:space-4xl' }} ">
            {%- for block in section.blocks -%}
                {%- case block.type -%}
                    {%- when 'heading' -%}
                        {% if block.settings.text != blank %}
                            <div class="rte leading-1" {{ block.fluid_attributes }}>{{ block.settings.text }}</div>
                        {% endif %}
                    {%- when 'description' -%}
                        {% if block.settings.text != blank %}
                            <div class="rte" {{ block.fluid_attributes }}>{{ block.settings.text }}</div>
                        {% endif %}
                {%- endcase -%}
            {%- endfor -%}
        </div>
    </div>
</section>

{% schema %}
{
  "name": "Intro Section",
  "tag": "section",
  "class": "intro-section",
  "settings": [
    {
      "type": "header",
      "content": "content spacing"
    },
    {
      "type": "select",
      "id": "content_gap_mobile",
      "label": "Content Gap (Mobile)",
      "options": [
        { "value": "space-xs", "label": "XS" },
        { "value": "space-sm", "label": "SM" },
        { "value": "space-md", "label": "MD" },
        { "value": "space-lg", "label": "LG" },
        { "value": "space-xl", "label": "XL" },
        { "value": "space-2xl", "label": "2XL" },
        { "value": "space-3xl", "label": "3XL" },
        { "value": "space-4xl", "label": "4XL" },
        { "value": "space-5xl", "label": "5XL" }
      ],
      "default": "space-3xl"
    },
    {
      "type": "select",
      "id": "content_gap_desktop",
      "label": "Content Gap (Desktop)",
      "options": [
        { "value": "lg:space-xs", "label": "XS" },
        { "value": "lg:space-sm", "label": "SM" },
        { "value": "lg:space-md", "label": "MD" },
        { "value": "lg:space-lg", "label": "LG" },
        { "value": "lg:space-xl", "label": "XL" },
        { "value": "lg:space-2xl", "label": "2XL" },
        { "value": "lg:space-3xl", "label": "3XL" },
        { "value": "lg:space-4xl", "label": "4XL" },
        { "value": "lg:space-5xl", "label": "5XL" }
      ],
      "default": "lg:space-4xl"
    },
    {
      "type": "header",
      "content": "Layout & Colors"
    },
    {
      "type": "color_background",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
   
    {
      "type": "padding",
      "id": "section_padding",
      "label": "Section Padding"
    },
    {
      "type": "corner_radius",
      "id": "section_border_radius",
      "label": "Section Border Radius",
      "info": "Default 0px. Four corners, link/unlink."
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        { "type": "richtext", "id": "text", "label": "Heading", "default": "<p>Project name here</p>" }
      ]
    },
    {
      "type": "description",
      "name": "Paragraph",
      "settings": [
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Lorem ipsum dolor sit amet. Est optio omnis ex quas voluptas ea corporis fugit id nobis quia.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Intro Section",
      "blocks": [
        { "type": "heading", "settings": { "text": "<p>Project name here</p>" } },
        { "type": "description", "settings": { "text": "<p>Lorem ipsum dolor sit amet. Est optio omnis ex quas voluptas ea corporis fugit id nobis quia. Qui ducimus nesciunt et earum enim in accusamus officia? Ut dolores nesciunt qui distinctio qua qui officiis voluptatem.</p>" } },
        { "type": "description", "settings": { "text": "<p>Lorem ipsum dolor sit amet. Est optio omnis ex quas voluptas ea corporis fugit id nobis quia. Qui ducimus nesciunt et earum enim in accusamus officia? Ut dolores nesciunt qui distinctio qua qui officiis voluptatem.</p>" } }
      ]
    }
  ]
}
{% endschema %}