<!-- Brand -->
{%- style -%}
  .section-{{ section.id }} {
    background-color: {{ section.settings.background_color | default: '#ffffff' }};
    {%- assign p = section.settings.section_padding -%}
    {%- if p -%}
      {%- capture pt -%}{{ p.top }}{%- endcapture -%}
      {%- capture pb -%}{{ p.bottom }}{%- endcapture -%}
      {%- capture pl -%}{{ p.left }}{%- endcapture -%}
      {%- capture pr -%}{{ p.right }}{%- endcapture -%}
      padding-top: {% if pt contains 'var(' %}{{ pt }}{% else %}{{ pt }}px{% endif %};
      padding-bottom: {% if pb contains 'var(' %}{{ pb }}{% else %}{{ pb }}px{% endif %};
      padding-left: {% if pl contains 'var(' %}{{ pl }}{% else %}{{ pl }}px{% endif %};
      padding-right: {% if pr contains 'var(' %}{{ pr }}{% else %}{{ pr }}px{% endif %};
    {%- endif -%}
    {%- assign sr = section.settings.section_border_radius -%}
    {%- if sr -%}
      {%- capture sr_tl -%}{{ sr.tl }}{%- endcapture -%}
      {%- capture sr_tr -%}{{ sr.tr }}{%- endcapture -%}
      {%- capture sr_br -%}{{ sr.br }}{%- endcapture -%}
      {%- capture sr_bl -%}{{ sr.bl }}{%- endcapture -%}
      border-radius: {% if sr_tl contains 'var(' %}{{ sr_tl }}{% else %}{{ sr_tl }}px{% endif %} {% if sr_tr contains 'var(' %}{{ sr_tr }}{% else %}{{ sr_tr }}px{% endif %} {% if sr_br contains 'var(' %}{{ sr_br }}{% else %}{{ sr_br }}px{% endif %} {% if sr_bl contains 'var(' %}{{ sr_bl }}{% else %}{{ sr_bl }}px{% endif %};
    {%- endif -%}
  }
{%- endstyle -%}

<section class="brands section-{{ section.id }}">
  <div class="container"></div>
    {% if section.blocks.size > 0 %}
    <div class="brand-slider splide" id="brand-slider-{{ section.id }}">
      <div class="splide__track">
        <ul class="splide__list">
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'brand_item' %}
                <li class="splide__slide" {{ block.fluid_attributes }}>
                  <figure>
                    {% if block.settings.brand_link != blank %}
                      <a href="{{ block.settings.brand_link }}" target="{{ block.settings.link_target }}">
                    {% endif %}
                    {%- assign _fit_class = 'image-cover' -%}
                    {%- case block.settings.media_fit -%}
                      {%- when 'contain' -%}{%- assign _fit_class = 'image-contain' -%}
                      {%- when 'fit-width' -%}{%- assign _fit_class = 'image-cover' -%}
                      {%- when 'fit-height' -%}{%- assign _fit_class = 'image-contain' -%}
                    {%- endcase -%}
                    {%- capture _media_style -%}
                      {% if block.settings.max_width != blank %}max-width: {{ block.settings.max_width }}px;{% endif %}
                      {% if block.settings.max_height != blank %}max-height: {{ block.settings.max_height }}px;{% endif %}
                    {%- endcapture -%}
                    {% if block.settings.brand_image != blank %}
                      <div class="media-container" style="{{ _media_style }}">
                      <img src="{{ block.settings.brand_image | image_url: width: 200 }}" alt="{{ block.settings.brand_alt | default: 'Brand logo' }}" class="{{ _fit_class }} media-container" style="{{ _media_style }}" loading="lazy" width="" height=""/>
                      </div>
                    {% else %}
                      <div class="placeholder-brand" style="width: 120px; height: 60px; background-color: #f0f0f0; display: flex; align-items: center; justify-content: center; border: 1px solid #ddd;">
                        <span style="font-size: 12px; color: #999;">Brand Logo</span>
                      </div>
                    {% endif %}
                    {% if block.settings.brand_link != blank %}
                      </a>
                    {% endif %}
                  </figure>
                </li>
            {% endcase %}
          {% endfor %}
        </ul>
      </div>
    </div>
    {% endif %}
</section>

<script>
document.addEventListener("DOMContentLoaded", () => {
  // Initialize brand slider
  const brandSlider = new Splide('#brand-slider-{{ section.id }}', {
    type: "loop",
    perPage: 8,
    perMove: 1,
    autoplay: true,
    interval: 2000,
    speed: 6000,
    pauseOnHover: true,
    pauseOnFocus: true,
    gap: "32px",
    pagination: false,
    arrows: false,
    breakpoints: {
      480: {
        perPage: 3,
      },
      768: {
        perPage: 5,
      },
      1024: {
        perPage: 8,
      },
    },
  });
  
  brandSlider.mount();
});
</script>

{% schema %}
{
  "name": "Brand Section",
  "tag": "section",
  "class": "brands",
  "settings": [
    {
      "type": "header",
      "content": "Background & Spacing"
    },
    {
      "type": "color_background",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "padding",
      "id": "section_padding",
      "label": "Section Padding"
    },
    {
      "type": "corner_radius",
      "id": "section_border_radius",
      "label": "Section Border Radius",
      "info": "Default 0px. Four corners, link/unlink."
    }
  ],
  "blocks": [
    {
      "type": "brand_item",
      "name": "Brand Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "brand_image",
          "label": "Brand Logo",
          "info": "Recommended size: 200x100px"
        },
        {
          "type": "text",
          "id": "brand_alt",
          "label": "Alt Text",
          "default": "Brand logo"
        },
        {
          "type": "url",
          "id": "brand_link",
          "label": "Brand Link (Optional)"
        },
        {
          "type": "select",
          "id": "link_target",
          "label": "Link Target",
          "options": [
            { "value": "_self", "label": "Same Window" },
            { "value": "_blank", "label": "New Window" }
          ],
          "default": "_self"
        },
        {
          "type": "select",
          "id": "media_fit",
          "label": "Image Fit",
          "options": [
            { "value": "cover", "label": "Cover (Fill Container)" },
            { "value": "contain", "label": "Contain (Fit Inside)" },
            { "value": "fit-width", "label": "Fit to Width" },
            { "value": "fit-height", "label": "Fit to Height" }
          ],
          "default": "cover"
        },

        {

          "type": "range",

          "id": "max_width",

          "min": 0,

          "max": 2000,

