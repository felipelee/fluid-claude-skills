<!-- Brand -->
{%- style -%}
  .section-{{ section.id }} {
    background-color: {{ section.settings.background_color | default: '#ffffff' }};
    {%- assign p = section.settings.section_padding -%}
    {%- if p -%}
      {%- capture pt -%}{{ p.top }}{%- endcapture -%}
      {%- capture pb -%}{{ p.bottom }}{%- endcapture -%}
      {%- capture pl -%}{{ p.left }}{%- endcapture -%}
      {%- capture pr -%}{{ p.right }}{%- endcapture -%}
      padding-top: {% if pt contains 'var(' %}{{ pt }}{% else %}{{ pt }}px{% endif %};
      padding-bottom: {% if pb contains 'var(' %}{{ pb }}{% else %}{{ pb }}px{% endif %};
      padding-left: {% if pl contains 'var(' %}{{ pl }}{% else %}{{ pl }}px{% endif %};
      padding-right: {% if pr contains 'var(' %}{{ pr }}{% else %}{{ pr }}px{% endif %};
    {%- endif -%}
    {%- assign sr = section.settings.section_border_radius -%}
    {%- if sr -%}
      {%- capture sr_tl -%}{{ sr.tl }}{%- endcapture -%}
      {%- capture sr_tr -%}{{ sr.tr }}{%- endcapture -%}
      {%- capture sr_br -%}{{ sr.br }}{%- endcapture -%}
      {%- capture sr_bl -%}{{ sr.bl }}{%- endcapture -%}
      border-radius: {% if sr_tl contains 'var(' %}{{ sr_tl }}{% else %}{{ sr_tl }}px{% endif %} {% if sr_tr contains 'var(' %}{{ sr_tr }}{% else %}{{ sr_tr }}px{% endif %} {% if sr_br contains 'var(' %}{{ sr_br }}{% else %}{{ sr_br }}px{% endif %} {% if sr_bl contains 'var(' %}{{ sr_bl }}{% else %}{{ sr_bl }}px{% endif %};
    {%- endif -%}
    {%- assign sb = section.settings.section_border -%}
    {%- if sb.width -%}
      border: {{ sb.width }} solid {{ sb.color }};
    {%- endif -%}
  }
{%- endstyle -%}

<section class="brands section-{{ section.id }}">
  <div class="container"></div>
    {% if section.blocks.size > 0 %}
    <div class="brand-slider splide" id="brand-slider-{{ section.id }}">
      <div class="splide__track">
        <ul class="splide__list">
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'image' %}
                {% assign _img = block.settings.image %}
                {% assign _alt = block.settings.alt | default: _img.alt | default: 'Brand logo' %}
                {% assign _ar = block.settings.aspect_ratio | default: 'auto' %}
                {% assign _fit = block.settings.fit | default: 'contain' %}
                {% capture _wrap_style %}
                  {% if _ar != 'auto' %}aspect-ratio: {{ _ar }};{% endif %}
                  {% assign br = block.settings.border_radius %}{% if br %}border-radius: {{ br.tl }}px {{ br.tr }}px {{ br.br }}px {{ br.bl }}px;{% endif %}
                  {% assign bd = block.settings.border %}{% if bd.width %}border: {{ bd.width }} solid {{ bd.color }};{% endif %}
                {% endcapture %}
                {% capture _img_style %}
                  {% if _ar != 'auto' %}width:100%;height:100%;{% endif %}
                  object-fit: {{ _fit }};
                  object-position: {{ block.settings.object_position | default: 'center' }};
                {% endcapture %}
                <li class="splide__slide">
                  {% if block.settings.link != blank %}
                    <a href="{{ block.settings.link }}" class="media-link" {% if block.settings.open_new_tab %}target="_blank" rel="noopener"{% endif %}>
                  {% endif %}
                  <div class="media-wrap" style="{{ _wrap_style | strip_newlines }}" {{ block.fluid_attributes }}>
                    {% if _img %}
                      <img src="{{ _img | img_url: '600x' }}" alt="{{ _alt | escape }}" loading="lazy" style="{{ _img_style | strip_newlines }}">
                    {% endif %}
                    {% if block.settings.overlay_color != blank and block.settings.overlay_opacity > 0 %}
                      {% assign _a = block.settings.overlay_opacity | divided_by: 100.0 %}
                      <div class="media-wrap__overlay" style="background: {{ block.settings.overlay_color }}; opacity: {{ _a }};"></div>
                    {% endif %}
                  </div>
                  {% if block.settings.link != blank %}</a>{% endif %}
                </li>
            {% endcase %}
          {% endfor %}
        </ul>
      </div>
    </div>
    {% endif %}
</section>

<script>
document.addEventListener("DOMContentLoaded", () => {
  // Initialize brand slider
  const brandSlider = new Splide('#brand-slider-{{ section.id }}', {
    type: "loop",
    perPage: 8,
    perMove: 1,
    autoplay: true,
    interval: 2000,
    speed: 6000,
    pauseOnHover: true,
    pauseOnFocus: true,
    gap: "32px",
    pagination: false,
    arrows: false,
    breakpoints: {
      480: {
        perPage: 3,
      },
      768: {
        perPage: 5,
      },
      1024: {
        perPage: 8,
      },
    },
  });
  
  brandSlider.mount();
});
</script>

{% schema %}
{
  "name": "Brand Section",
  "tag": "section",
  "class": "brands",
  "settings": [
    {
      "type": "header",
      "content": "Background & Spacing"
    },
    {
      "type": "select",
      "id": "background_color",
      "label": "Background Color",
      "options": "background_colors",
      "default": "var(--clr-white)"
    },
    {
      "type": "padding",
      "id": "section_padding",
      "label": "Section Padding"
    },
    {
      "type": "corner_radius",
      "id": "section_border_radius",
      "label": "Section Border Radius",
      "info": "Default 0px. Four corners, link/unlink."
    },
    {
      "type": "border",
      "id": "section_border",
      "label": "Section Border"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "brand_image",
          "label": "Brand Logo",
          "info": "Recommended size: 200x100px"
        },
        {
          "type": "text",
          "id": "brand_alt",
          "label": "Alt Text",
          "default": "Brand logo"
        },
        {
          "type": "url",
          "id": "brand_link",
          "label": "Brand Link (Optional)"
        },
        {
          "type": "select",
          "id": "link_target",
          "label": "Link Target",
          "options": [
            {
              "value": "_self",
              "label": "Same Window"
            },
            {
              "value": "_blank",
              "label": "New Window"
            }
          ],
          "default": "_self"
        },
        {
          "type": "select",
          "id": "media_fit",
          "label": "Image Fit",
          "options": [
            {
              "value": "cover",
              "label": "Cover (Fill Container)"
            },
            {
              "value": "contain",
              "label": "Contain (Fit Inside)"
            },
            {
              "value": "fit-width",
              "label": "Fit to Width"
            },
            {
              "value": "fit-height",
              "label": "Fit to Height"
            }
          ],
          "default": "cover"
        },
        {
          "type": "range",
          "id": "max_width",
          "min": 0,
          "max": 2000,
