{%- style -%}
  .section-{{ section.id }} {
    {%- assign p = section.settings.section_padding -%}
    {%- if p -%}
      {%- capture pt -%}{{ p.top }}{%- endcapture -%}
      {%- capture pb -%}{{ p.bottom }}{%- endcapture -%}
      {%- capture pl -%}{{ p.left }}{%- endcapture -%}
      {%- capture pr -%}{{ p.right }}{%- endcapture -%}
      padding-top: {% if pt contains 'var(' %}{{ pt }}{% else %}{{ pt }}px{% endif %};
      padding-bottom: {% if pb contains 'var(' %}{{ pb }}{% else %}{{ pb }}px{% endif %};
      padding-left: {% if pl contains 'var(' %}{{ pl }}{% else %}{{ pl }}px{% endif %};
      padding-right: {% if pr contains 'var(' %}{{ pr }}{% else %}{{ pr }}px{% endif %};
    {%- endif -%}
    {%- assign sr = section.settings.section_border_radius -%}
    {%- if sr -%}
      {%- capture sr_tl -%}{{ sr.tl }}{%- endcapture -%}
      {%- capture sr_tr -%}{{ sr.tr }}{%- endcapture -%}
      {%- capture sr_br -%}{{ sr.br }}{%- endcapture -%}
      {%- capture sr_bl -%}{{ sr.bl }}{%- endcapture -%}
      border-radius: {% if sr_tl contains 'var(' %}{{ sr_tl }}{% else %}{{ sr_tl }}px{% endif %} {% if sr_tr contains 'var(' %}{{ sr_tr }}{% else %}{{ sr_tr }}px{% endif %} {% if sr_br contains 'var(' %}{{ sr_br }}{% else %}{{ sr_br }}px{% endif %} {% if sr_bl contains 'var(' %}{{ sr_bl }}{% else %}{{ sr_bl }}px{% endif %};
    {%- endif -%}
    {%- assign sb = section.settings.section_border -%}
    {%- if sb.width -%}
      border: {{ sb.width }} solid {{ sb.color }};
    {%- endif -%}
  }
{%- endstyle -%}

<section class="testimonial3-section section-{{ section.id }}" 
         style="background-color: {{ section.settings.background_color | default: '#f8f9fa' }};
                {% if section.settings.background_image != blank %}
                background-image: url('{{ section.settings.background_image | image_url: width: 1920 }}');
                background-size: cover;
                background-position: center;
                background-repeat: no-repeat;
                {% endif %}
                position: relative;">
  
  {%- assign ov = section.settings.overlay -%}
  {%- if ov and ov.enabled -%}
    <div class="overlay-{{ section.id }}"></div>
    {%- style -%}
      .overlay-{{ section.id }} {
        position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1;
        {%- if ov.mode == 'gradient' and ov.colors.size > 1 -%}
          background:
            {%- if ov.gradientType == 'radial' -%}
              radial-gradient(
            {%- else -%}
              linear-gradient({{ ov.angle }}deg,
            {%- endif -%}
            {%- for stop in ov.colors -%}
              {{ stop.color }} {{ stop.position }}%{%- unless forloop.last -%},{%- endunless -%}
            {%- endfor -%}
          );
          opacity: {{ ov.colors.first.opacity | divided_by: 100.0 }};
        {%- else -%}
          {%- assign c = ov.colors | first -%}
          background-color: {{ c.color }};
          opacity: {{ c.opacity | divided_by: 100.0 }};
        {%- endif -%}
      }
    {%- endstyle -%}
  {%- endif -%}
  
  <!-- Edge-to-edge scrolling container -->
  <div class="testimonials3-scroll-container" style="position: relative; z-index: 2;">
    <div class="testimonials3-scroll-track">
      {% for i in (1..6) limit: section.settings.testimonials_to_show %}
        {% assign testimonial_text = 'testimonial_' | append: i | append: '_text' %}
        {% assign testimonial_name = 'testimonial_' | append: i | append: '_name' %}
        {% assign testimonial_position = 'testimonial_' | append: i | append: '_position' %}
        {% assign testimonial_image = 'testimonial_' | append: i | append: '_image' %}
        
        <div class="testimonial3-card" 
             style="background-color: {{ section.settings.card_background_color | default: '#ffffff' }};">
          <div class="testimonial-content mb-4xl">
            <div class="rte text-md">
              {{ section.settings[testimonial_text] }}
            </div>
          </div>

          <div class="author-info flex align-center space-lg">
            <div class="author-avatar">
              {% assign img_input = section.settings[testimonial_image] %}
              {% assign img_fluid_media_id = '' %}
              {% if img_input.fluid_media_id %}
                {% assign img_fluid_media_id = img_input.fluid_media_id %}
                {% assign img_embed_type = img_input.embed_type %}
              {% endif %}
              {% assign use_fluid_image_widget = false %}
              {% if img_fluid_media_id != blank %}
                {% assign use_fluid_image_widget = true %}
              {% endif %}

              {% if use_fluid_image_widget %}
                <fluid-media-widget class="fluid-media-widget-image" media-id="{{ img_fluid_media_id }}" responsive="true" embed-type="{{ img_embed_type | default:'inline' }}" data-fluid-widget="true"></fluid-media-widget>
              {% elsif img_input != blank %}
                <img src="{{ img_input | image_url }}" alt="{{ section.settings[testimonial_name] | default: 'Author' }}" class="image-cover" loading="lazy" width="" height=""/>
              {% else %}
                <div class="avatar-placeholder">
                  <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                  </svg>
                </div>
              {% endif %}
            </div>
            <div class="author-details">
              {% if section.settings[testimonial_name] != blank %}
                <p class="text-md font-semibold mb-xs">{{ section.settings[testimonial_name] }}</p>
              {% endif %}
              {% if section.settings[testimonial_position] != blank %}
                <p class="text-sm">{{ section.settings[testimonial_position] }}</p>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}

      {% for i in (1..6) limit: section.settings.testimonials_to_show %}
        {% assign testimonial_text = 'testimonial_' | append: i | append: '_text' %}
        {% assign testimonial_name = 'testimonial_' | append: i | append: '_name' %}
        {% assign testimonial_position = 'testimonial_' | append: i | append: '_position' %}
        {% assign testimonial_image = 'testimonial_' | append: i | append: '_image' %}
        
        <div class="testimonial3-card" 
             style="background-color: {{ section.settings.card_background_color | default: '#ffffff' }};">
          <div class="testimonial-content mb-4xl">
            <div class="rte text-md">
              {{ section.settings[testimonial_text] }}
            </div>
          </div>

          <div class="author-info flex align-center space-lg">
            <div class="author-avatar">
              {% assign img_input = section.settings[testimonial_image] %}
              {% assign img_fluid_media_id = '' %}
              {% if img_input.fluid_media_id %}
                {% assign img_fluid_media_id = img_input.fluid_media_id %}
                {% assign img_embed_type = img_input.embed_type %}
              {% endif %}
              {% assign use_fluid_image_widget = false %}
              {% if img_fluid_media_id != blank %}
                {% assign use_fluid_image_widget = true %}
              {% endif %}

              {% if use_fluid_image_widget %}
                <fluid-media-widget class="fluid-media-widget-image" media-id="{{ img_fluid_media_id }}" responsive="true" embed-type="{{ img_embed_type | default:'inline' }}" data-fluid-widget="true"></fluid-media-widget>
              {% elsif img_input != blank %}
                <img src="{{ img_input | image_url }}" alt="{{ section.settings[testimonial_name] | default: 'Author' }}" class="image-cover" loading="lazy" width="" height=""/>
              {% else %}
                <div class="avatar-placeholder">
                  <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                  </svg>
                </div>
              {% endif %}
            </div>
            <div class="author-details">
              {% if section.settings[testimonial_name] != blank %}
                <p class="text-md font-semibold mb-1">{{ section.settings[testimonial_name] }}</p>
              {% endif %}
              {% if section.settings[testimonial_position] != blank %}
                <p class="text-sm">{{ section.settings[testimonial_position] }}</p>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
.testimonial3-section .testimonials3-scroll-container {
  overflow: hidden;
  position: relative;
  width: 100vw;
  margin-left: calc(-50vw + 50%);
  padding: 0 20px;
}

.testimonial3-section .testimonials3-scroll-track {
  display: flex;
  gap: 32px;
  animation: testimonials-scroll 60s linear infinite;
  width: max-content;
}

.testimonial3-section .testimonials3-scroll-track:hover {
  animation-play-state: paused;
}

@keyframes testimonials-scroll {
  0% {
    transform: translateX(0);
  }
  100% {
    transform: translateX(-50%);
  }
}

.testimonial3-section .testimonial3-card {
  flex: 0 0 400px;
  padding: 40px 32px;
  border: 1px solid #e5e7eb;
  border-radius: 8px;
  background-color: #ffffff;
  display: flex;
  flex-direction: column;
  min-height: 280px;
}

.testimonial3-section .testimonial-content {
  flex: 1;
}

.testimonial3-section .author-info {
  margin-top: auto;
}

.testimonial3-section .avatar-image {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  object-fit: cover;
}

.testimonial3-section .avatar-placeholder {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background-color: #e5e5e5;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
}

@media (max-width: 959px) {
  .testimonial3-section .testimonial3-card {
    flex: 0 0 320px;
    padding: 32px 24px;
    min-height: 260px;
  }
  
  .testimonial3-section .testimonials3-scroll-track {
    gap: 24px;
    animation-duration: 50s;
  }
  
  .testimonial3-section .testimonials3-scroll-container {
    padding: 0 15px;
  }
}

@media (max-width: 767px) {
  .testimonial3-section .testimonial3-card {
    flex: 0 0 280px;
    padding: 28px 20px;
    min-height: 240px;
  }
  
  .testimonial3-section .testimonials3-scroll-track {
    gap: 20px;
    animation-duration: 45s;
  }
  
  .testimonial3-section .testimonials3-scroll-container {
    padding: 0 10px;
  }
}
</style>

