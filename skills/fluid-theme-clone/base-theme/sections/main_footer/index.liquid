{%- comment -%}
  main_footer — award-winning, block-based footer.
  - Brand column: logo (image block), tagline (richtext block), social icon blocks
  - Link column blocks: each with heading + link_list (pick a Fluid menu)
  - Newsletter: inline form (email) with Fluid mailto / list endpoint
  - Bottom bar: copyright + legal link blocks + optional payment icon row
{%- endcomment -%}

{%- style -%}
  .ft.section-{{ section.id }} {
    {%- assign p = section.settings.section_padding -%}
    {%- if p -%}padding: {{ p.top | default: 80 }}px {{ p.right | default: 0 }}px {{ p.bottom | default: 0 }}px {{ p.left | default: 0 }}px;{%- else -%}padding: 80px 0 0;{%- endif -%}
    {%- assign r = section.settings.section_border_radius -%}
    {%- if r -%}border-radius: {{ r.tl }}px {{ r.tr }}px {{ r.br }}px {{ r.bl }}px;{%- endif -%}
    background-color: {{ section.settings.background_color | default: 'var(--clr-primary)' }};
    color: {{ section.settings.text_color | default: 'var(--clr-white)' }};
    {%- if section.settings.background_image != blank -%}background-image: url({{ section.settings.background_image | img_url: '2400x' }});background-size:cover;background-position:center;{%- endif -%}
    {% if section.settings.section_border_width > 0 %}border: {{ section.settings.section_border_width }}px solid {{ section.settings.section_border_color }};{% endif %}
  }
  .ft.section-{{ section.id }} a { color: inherit; text-decoration: none; transition: opacity .15s; }
  .ft.section-{{ section.id }} a:hover { opacity: 0.75; }

  .ft.section-{{ section.id }} .ft__container {
    max-width: {{ section.settings.container_max_width | default: '1280px' }};
    margin: 0 auto;
    padding: 0 64px;
  }
  @media (max-width: 991px) { .ft.section-{{ section.id }} .ft__container { padding: 0 24px; } }
  @media (max-width: 767px) { .ft.section-{{ section.id }} .ft__container { padding: 0 16px; } }

  /* ── Main grid ─────────────────────────────────────────────── */
  .ft.section-{{ section.id }} .ft__grid {
    display: grid;
    grid-template-columns: 1.6fr repeat({{ section.settings.link_columns | default: 3 }}, 1fr);
    gap: 48px;
    padding-bottom: 56px;
  }
  @media (max-width: 991px) {
    .ft.section-{{ section.id }} .ft__grid { grid-template-columns: 1fr 1fr; gap: 40px 32px; }
  }
  @media (max-width: 575px) {
    .ft.section-{{ section.id }} .ft__grid { grid-template-columns: 1fr; gap: 32px; }
  }

  /* ── Brand column ──────────────────────────────────────────── */
  .ft.section-{{ section.id }} .ft__brand { display: flex; flex-direction: column; gap: 16px; max-width: 360px; }
  .ft.section-{{ section.id }} .ft__logo img { max-width: {{ section.settings.logo_max_width | default: 160 }}px; height: auto; display: block; }
  .ft.section-{{ section.id }} .ft__logo-text {
    font-size: clamp(22px, 2vw, 26px);
    font-weight: 700; letter-spacing: -0.015em;
    font-family: {{ section.settings.title_font | default: 'var(--ff-heading)' }};
  }
  .ft.section-{{ section.id }} .ft__tagline {
    font-size: 14.5px; line-height: 1.55;
    opacity: 0.82;
  }
  .ft.section-{{ section.id }} .ft__tagline p { margin: 0 0 0.6em; }
  .ft.section-{{ section.id }} .ft__tagline p:last-child { margin-bottom: 0; }

  .ft.section-{{ section.id }} .ft__socials {
    display: inline-flex; align-items: center; gap: 10px;
    flex-wrap: wrap;
    margin-top: 6px;
  }
  .ft.section-{{ section.id }} .ft__social {
    width: 38px; height: 38px;
    display: inline-flex; align-items: center; justify-content: center;
    border-radius: 999px;
    background: {{ section.settings.social_background | default: 'rgba(255,255,255,0.12)' }};
    color: inherit;
    transition: background-color .15s;
  }
  .ft.section-{{ section.id }} .ft__social:hover { background: {{ section.settings.social_hover_background | default: 'rgba(255,255,255,0.24)' }}; opacity: 1; }
  .ft.section-{{ section.id }} .ft__social svg { width: 16px; height: 16px; fill: currentColor; }

  /* ── Link columns ──────────────────────────────────────────── */
  .ft.section-{{ section.id }} .ft__col { display: flex; flex-direction: column; gap: 14px; }
  .ft.section-{{ section.id }} .ft__col-heading {
    margin: 0;
    font-size: 12px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase;
    color: inherit;
    opacity: 0.72;
  }
  .ft.section-{{ section.id }} .ft__links { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 8px; }
  .ft.section-{{ section.id }} .ft__link {
    font-size: 14.5px;
    line-height: 1.45;
  }

  /* ── Newsletter ────────────────────────────────────────────── */
  .ft.section-{{ section.id }} .ft__newsletter {
    grid-column: 1 / -1;
    display: grid; grid-template-columns: 1.3fr 1fr;
    gap: 40px;
    padding: 40px 0;
    border-top: 1px solid {{ section.settings.divider_color | default: 'rgba(255,255,255,0.12)' }};
    border-bottom: 1px solid {{ section.settings.divider_color | default: 'rgba(255,255,255,0.12)' }};
    align-items: center;
  }
  @media (max-width: 991px) { .ft.section-{{ section.id }} .ft__newsletter { grid-template-columns: 1fr; gap: 20px; padding: 28px 0; } }
  .ft.section-{{ section.id }} .ft__newsletter-copy h3 {
    margin: 0 0 6px;
    font-size: clamp(20px, 2vw, 26px);
    font-weight: 700; letter-spacing: -0.01em; line-height: 1.2;
    font-family: {{ section.settings.title_font | default: 'var(--ff-heading)' }};
  }
  .ft.section-{{ section.id }} .ft__newsletter-copy p {
    margin: 0; font-size: 14.5px; line-height: 1.5; opacity: 0.82;
  }
  .ft.section-{{ section.id }} .ft__newsletter-form {
    display: flex;
    gap: 10px;
  }
  .ft.section-{{ section.id }} .ft__newsletter-form input[type="email"] {
    flex: 1 1 auto;
    padding: 14px 18px;
    font-size: 15px;
    background: {{ section.settings.newsletter_input_background | default: 'rgba(255,255,255,0.08)' }};
    color: inherit;
    border: 1.5px solid {{ section.settings.newsletter_input_border | default: 'rgba(255,255,255,0.16)' }};
    border-radius: 999px;
    font-family: inherit;
    outline: none;
    transition: border-color .15s, background-color .15s;
  }
  .ft.section-{{ section.id }} .ft__newsletter-form input[type="email"]::placeholder { color: currentColor; opacity: 0.5; }
  .ft.section-{{ section.id }} .ft__newsletter-form input[type="email"]:focus {
    border-color: {{ section.settings.newsletter_focus_border | default: 'rgba(255,255,255,0.4)' }};
    background: {{ section.settings.newsletter_focus_background | default: 'rgba(255,255,255,0.14)' }};
  }
  .ft.section-{{ section.id }} .ft__newsletter-form button {
    padding: 14px 26px;
    font-size: 13px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
    background: {{ section.settings.cta_background | default: 'var(--clr-white)' }};
    color: {{ section.settings.cta_color | default: 'var(--clr-primary)' }};
    border: none; border-radius: 999px;
    cursor: pointer; font-family: inherit;
    transition: opacity .15s;
  }
  .ft.section-{{ section.id }} .ft__newsletter-form button:hover { opacity: 0.88; }

  /* ── Bottom bar ────────────────────────────────────────────── */
  .ft.section-{{ section.id }} .ft__bottom {
    display: flex; align-items: center; justify-content: space-between;
    gap: 24px; flex-wrap: wrap;
    padding: 28px 0 32px;
  }
  .ft.section-{{ section.id }} .ft__copy {
    font-size: 13px; opacity: 0.72;
  }
  .ft.section-{{ section.id }} .ft__legal {
    list-style: none; margin: 0; padding: 0;
    display: inline-flex; align-items: center; gap: 18px; flex-wrap: wrap;
    font-size: 13px; opacity: 0.82;
  }
  .ft.section-{{ section.id }} .ft__payments {
    display: inline-flex; align-items: center; gap: 8px; flex-wrap: wrap;
  }
  .ft.section-{{ section.id }} .ft__payment {
    height: 24px;
    padding: 4px 8px;
    background: rgba(255,255,255,0.92);
    border-radius: 4px;
    display: inline-flex; align-items: center;
    font-size: 11px; font-weight: 700; letter-spacing: 0.04em;
    color: {{ section.settings.background_color | default: 'var(--clr-primary)' }};
  }
  .ft.section-{{ section.id }} .ft__payment svg { height: 14px; width: auto; }
{%- endstyle -%}

<footer class="ft section-{{ section.id }} site-footer" {{ section.fluid_attributes }}>
  <div class="ft__container">

    <div class="ft__grid">

      {%- comment -%} Brand column {%- endcomment -%}
      <div class="ft__brand">
        {%- assign logo_block = section.blocks | where: 'type', 'logo' | first -%}
        {%- assign tagline_block = section.blocks | where: 'type', 'tagline' | first -%}
        {%- assign social_blocks = section.blocks | where: 'type', 'social' -%}

        {% if logo_block %}
          <a href="{{ company.home_page_url | default: '/' }}" class="ft__logo" {{ logo_block.fluid_attributes }}>
            {% if logo_block.settings.image %}
              <img src="{{ logo_block.settings.image | img_url: '360x' }}" alt="{{ company.name | default: 'Brand' | escape }}">
            {% else %}
              <span class="ft__logo-text">{{ logo_block.settings.text | default: company.name | default: 'Brand' | escape }}</span>
            {% endif %}
          </a>
        {% endif %}

        {% if tagline_block %}
          <div class="ft__tagline rte" {{ tagline_block.fluid_attributes }}>{{ tagline_block.settings.text }}</div>
        {% endif %}

        {% if social_blocks.size > 0 %}
          <div class="ft__socials">
            {% for b in social_blocks %}
              <a href="{{ b.settings.url | default: '#' }}" class="ft__social" aria-label="{{ b.settings.network | escape }}" target="_blank" rel="noopener noreferrer" {{ b.fluid_attributes }}>
                {% case b.settings.network %}
                  {% when 'instagram' %}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 2c2.7 0 3 0 4.1.05 1 .04 1.7.22 2.3.47.7.26 1.3.6 1.8 1.2.6.5.9 1.1 1.2 1.8.3.7.4 1.4.5 2.3C22 8.9 22 9.3 22 12c0 2.7 0 3-.05 4.1-.04 1-.22 1.7-.47 2.3-.26.7-.6 1.3-1.2 1.8-.5.6-1.1.9-1.8 1.2-.7.3-1.4.4-2.3.5C15 22 14.7 22 12 22c-2.7 0-3 0-4.1-.05-1-.04-1.7-.22-2.3-.47-.7-.26-1.3-.6-1.8-1.2-.6-.5-.9-1.1-1.2-1.8-.3-.7-.4-1.4-.5-2.3C2 15 2 14.7 2 12c0-2.7 0-3 .05-4.1.04-1 .22-1.7.47-2.3.26-.7.6-1.3 1.2-1.8.5-.6 1.1-.9 1.8-1.2.7-.3 1.4-.4 2.3-.5C9 2 9.3 2 12 2zm0 2c-2.66 0-3 0-4 .04-.9.04-1.3.2-1.6.33-.4.15-.7.34-1 .64-.3.3-.5.6-.64 1-.13.3-.29.7-.33 1.6C4.04 9 4 9.3 4 12s0 3 .04 4c.04.9.2 1.3.33 1.6.15.4.34.7.64 1 .3.3.6.5 1 .64.3.13.7.29 1.6.33.9.04 1.3.04 4 .04 2.66 0 3 0 4-.04.9-.04 1.3-.2 1.6-.33.4-.15.7-.34 1-.64.3-.3.5-.6.64-1 .13-.3.29-.7.33-1.6.04-1 .04-1.3.04-4s0-3-.04-4c-.04-.9-.2-1.3-.33-1.6-.15-.4-.34-.7-.64-1-.3-.3-.6-.5-1-.64-.3-.13-.7-.29-1.6-.33-1-.04-1.3-.04-4-.04zm0 3.2a4.8 4.8 0 1 1 0 9.6 4.8 4.8 0 0 1 0-9.6zm0 2a2.8 2.8 0 1 0 0 5.6 2.8 2.8 0 0 0 0-5.6zm5-3.3a1.2 1.2 0 1 1 0 2.4 1.2 1.2 0 0 1 0-2.4z"/></svg>
                  {% when 'facebook'  %}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M13 22v-8h3l.5-4H13V7.5c0-1.2.3-2 2-2H16.5V2h-3C10.8 2 9 3.7 9 6.5V10H6v4h3v8z"/></svg>
                  {% when 'twitter'   %}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M18.244 2H21.5l-7.53 8.625L22.25 22h-6.765l-5.3-6.91L4.09 22H.83l8.04-9.2L.75 2h6.92l4.78 6.33L18.244 2zm-1.184 18h1.87L6.97 4H4.99l12.07 16z"/></svg>
                  {% when 'tiktok'    %}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M19.6 6.3a6.8 6.8 0 0 1-4-1.3v8.9a5.5 5.5 0 1 1-5.5-5.5v2.4a3.1 3.1 0 1 0 3.1 3.1V2h2.4a6.8 6.8 0 0 0 4 3.5v.8z"/></svg>
                  {% when 'youtube'   %}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M23 7.2a3 3 0 0 0-2.1-2.1C19.1 4.7 12 4.7 12 4.7s-7.1 0-8.9.4A3 3 0 0 0 1 7.2C.6 9 .6 12 .6 12s0 3 .4 4.8a3 3 0 0 0 2.1 2.1c1.8.4 8.9.4 8.9.4s7.1 0 8.9-.4a3 3 0 0 0 2.1-2.1c.4-1.8.4-4.8.4-4.8s0-3-.4-4.8zM9.7 15.2V8.8l6 3.2-6 3.2z"/></svg>
                  {% when 'linkedin'  %}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M4.98 3.5c0 1.38-1.12 2.5-2.5 2.5s-2.5-1.12-2.5-2.5S1.1 1 2.48 1s2.5 1.12 2.5 2.5zM.5 8h4V22h-4V8zm7 0h3.8v1.9h.05c.53-1 1.83-2.05 3.76-2.05C19.53 7.85 20.5 10.3 20.5 13.4V22h-4v-7.4c0-1.76-.03-4-2.45-4-2.45 0-2.82 1.9-2.82 3.87V22h-4V8z"/></svg>
                  {% when 'pinterest' %}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 2a10 10 0 0 0-3.64 19.3c-.1-.8-.2-2.1.04-3 .2-.8 1.4-5.1 1.4-5.1s-.36-.72-.36-1.8c0-1.68.97-2.94 2.2-2.94 1.04 0 1.54.78 1.54 1.72 0 1.04-.66 2.6-1 4.04-.28 1.22.6 2.22 1.8 2.22 2.18 0 3.86-2.3 3.86-5.62 0-2.94-2.12-5-5.14-5A5.33 5.33 0 0 0 6.06 11.3c0 1.1.42 2.28.94 2.92.1.12.12.22.1.34-.1.38-.3 1.22-.34 1.4-.06.22-.18.28-.42.16-1.56-.72-2.54-3-2.54-4.82 0-3.92 2.84-7.52 8.2-7.52 4.3 0 7.64 3.06 7.64 7.14 0 4.28-2.7 7.72-6.44 7.72-1.26 0-2.44-.66-2.84-1.44l-.78 2.94c-.28 1.08-1.04 2.44-1.54 3.26A10 10 0 1 0 12 2z"/></svg>
                  {% else %}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/></svg>
                {% endcase %}
              </a>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      {%- comment -%} Link columns {%- endcomment -%}
      {%- assign column_blocks = section.blocks | where: 'type', 'column' -%}
      {% for block in column_blocks %}
        <div class="ft__col" {{ block.fluid_attributes }}>
          {% if block.settings.heading != blank %}
            <h4 class="ft__col-heading">{{ block.settings.heading | escape }}</h4>
          {% endif %}
          <ul class="ft__links">
            {%- assign menu_items = block.settings.menu.menu_items -%}
            {% if menu_items and menu_items.size > 0 %}
              {% for item in menu_items %}
                <li class="ft__link"><a href="{{ item.url | default: item.link | default: '#' }}">{{ item.title | default: item.name | escape }}</a></li>
              {% endfor %}
            {% elsif block.settings.menu and block.settings.menu.links and block.settings.menu.links.size > 0 %}
              {% for link in block.settings.menu.links %}
                <li class="ft__link"><a href="{{ link.url | default: link.link | default: '#' }}">{{ link.title | default: link.name | escape }}</a></li>
              {% endfor %}
            {% elsif block.settings.manual_links != blank %}
              {%- assign lines = block.settings.manual_links | split: "
" -%}
              {% for line in lines %}
                {%- assign _l = line | strip -%}
                {% if _l != '' %}
                  {%- assign parts = _l | split: '|' -%}
                  {% if parts.size > 1 %}
                    <li class="ft__link"><a href="{{ parts[1] | strip }}">{{ parts[0] | strip | escape }}</a></li>
                  {% else %}
                    <li class="ft__link"><span>{{ _l | escape }}</span></li>
                  {% endif %}
                {% endif %}
              {% endfor %}
            {% endif %}
          </ul>
        </div>
      {% endfor %}

    </div>

    {% if section.settings.show_newsletter %}
      <div class="ft__newsletter">
        <div class="ft__newsletter-copy">
          <h3>{{ section.settings.newsletter_heading | default: 'Stay in the loop' | escape }}</h3>
          <p>{{ section.settings.newsletter_subhead | default: 'New drops, guides, and stories — no spam, ever.' | escape }}</p>
        </div>
        {% if section.settings.newsletter_action != blank %}
          <form action="{{ section.settings.newsletter_action }}" method="post" class="ft__newsletter-form" data-ft-newsletter>
            <input type="email" name="email" required placeholder="{{ section.settings.newsletter_placeholder | default: 'you@example.com' | escape }}" aria-label="Email address">
            <button type="submit">{{ section.settings.newsletter_button | default: 'Subscribe' | escape }}</button>
          </form>
        {% else %}
          <form class="ft__newsletter-form" onsubmit="event.preventDefault()" data-ft-newsletter>
            <input type="email" name="email" required placeholder="{{ section.settings.newsletter_placeholder | default: 'you@example.com' | escape }}" aria-label="Email address">
            <button type="submit">{{ section.settings.newsletter_button | default: 'Subscribe' | escape }}</button>
          </form>
        {% endif %}
      </div>
    {% endif %}

    {%- assign legal_blocks = section.blocks | where: 'type', 'legal_link' -%}
    {%- assign payment_blocks = section.blocks | where: 'type', 'payment' -%}
    <div class="ft__bottom">
      <div class="ft__copy">{{ section.settings.copyright | default: '© 2026 Your Company. All rights reserved.' | escape }}</div>
      {% if legal_blocks.size > 0 %}
        <ul class="ft__legal">
          {% for block in legal_blocks %}
            <li {{ block.fluid_attributes }}><a href="{{ block.settings.url | default: '#' }}">{{ block.settings.label | escape }}</a></li>
          {% endfor %}
        </ul>
      {% endif %}
      {% if payment_blocks.size > 0 %}
        <div class="ft__payments">
          {% for block in payment_blocks %}
            <span class="ft__payment" {{ block.fluid_attributes }} aria-label="{{ block.settings.label | escape }}">{{ block.settings.label | upcase | escape }}</span>
          {% endfor %}
        </div>
      {% endif %}
    </div>

  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "section",
  "class": "footer-section",
  "settings": [
    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "link_columns", "label": "Link column count", "min": 1, "max": 4, "step": 1, "default": 3 },

    { "type": "header", "content": "Newsletter" },
    { "type": "checkbox", "id": "show_newsletter", "label": "Show newsletter block", "default": true },
    { "type": "text",     "id": "newsletter_heading",     "label": "Heading",     "default": "Stay in the loop" },
    { "type": "text",     "id": "newsletter_subhead",     "label": "Subhead",     "default": "New drops, guides, and stories — no spam, ever." },
    { "type": "text",     "id": "newsletter_placeholder", "label": "Input placeholder", "default": "you@example.com" },
    { "type": "text",     "id": "newsletter_button",      "label": "Button label",      "default": "Subscribe" },
    { "type": "text",     "id": "newsletter_action",      "label": "Form action URL (optional)",
      "info": "If blank, the form just prevents default (wire it up later)." },

    { "type": "header", "content": "Bottom bar" },
    { "type": "text", "id": "copyright", "label": "Copyright line", "default": "© 2026 Your Company. All rights reserved." },

    { "type": "header", "content": "Colors / Fonts" },
    { "type": "select", "id": "background_color", "label": "Background color", "options": "background_colors", "default": "var(--clr-primary)" },
    { "type": "select", "id": "text_color",       "label": "Text color",       "options": "background_colors", "default": "var(--clr-white)" },
    { "type": "select", "id": "title_font",       "label": "Heading font",     "options": "font_families",     "default": "var(--ff-heading)" },
    { "type": "select", "id": "divider_color",    "label": "Divider color", "default": "rgba(255,255,255,0.12)",
      "options": [
        { "value": "rgba(255,255,255,0.12)", "label": "Subtle white" },
        { "value": "rgba(255,255,255,0.24)", "label": "Medium white" },
        { "value": "rgba(0,0,0,0.12)",       "label": "Subtle black" },
        { "value": "var(--clr-gray)",        "label": "Theme gray" }
      ]
    },
    { "type": "select", "id": "social_background",       "label": "Social icon bg", "default": "rgba(255,255,255,0.12)",
      "options": [
        { "value": "rgba(255,255,255,0.12)", "label": "Glass white" },
        { "value": "rgba(0,0,0,0.12)",       "label": "Glass dark" },
        { "value": "var(--clr-white)",       "label": "Solid white" },
        { "value": "transparent",            "label": "Transparent" }
      ]
    },
    { "type": "select", "id": "social_hover_background", "label": "Social icon bg (hover)", "default": "rgba(255,255,255,0.24)",
      "options": [
        { "value": "rgba(255,255,255,0.24)", "label": "Glass white (stronger)" },
        { "value": "rgba(0,0,0,0.24)",       "label": "Glass dark (stronger)" },
        { "value": "var(--clr-white)",       "label": "Solid white" },
        { "value": "var(--clr-accent)",      "label": "Theme accent" }
      ]
    },
    { "type": "select", "id": "cta_background", "label": "Newsletter CTA bg",   "options": "background_colors", "default": "var(--clr-white)" },
    { "type": "select", "id": "cta_color",      "label": "Newsletter CTA text", "options": "background_colors", "default": "var(--clr-primary)" },

    { "type": "header", "content": "Brand" },
    { "type": "range", "id": "logo_max_width", "label": "Logo max width (px)", "min": 80, "max": 300, "step": 10, "default": 160 },

    { "type": "header", "content": "Container" },
