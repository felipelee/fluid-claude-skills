<style>
.cta-banner3-section {
  position: relative;
}

.cta-banner3-section .cta-banner3-content {
  max-width: 768px;
  margin: 0 auto;
}

.cta-banner3-section .cta-banner3-content h2 {
  margin-bottom: 24px;
}

.cta-banner3-section .cta-banner3-content p {
  margin-bottom: 32px;
  line-height: 1.6;
}

.cta-banner3-section .cta-banner3-buttons {
  display: flex;
  justify-content: center;
  gap: 16px;
  flex-wrap: wrap;
  margin-bottom: 48px;
}

.cta-banner3-section .cta-banner3-buttons .btn {
  padding: 12px 24px;
  text-decoration: none;
  border-radius: 4px;
  font-weight: 500;
  transition: all 0.3s ease;
}

.cta-banner3-section .cta-banner3-buttons .btn:hover {
  opacity: 0.8;
}

.cta-banner3-section .cta-banner3-logos {
  margin-top: 48px;
  padding-top: 32px;
}

.cta-banner3-section .logos-container {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 32px;
  flex-wrap: wrap;
}

.cta-banner3-section .logo-item {
  display: flex;
  align-items: center;
  justify-content: center;
}

.cta-banner3-section .logo-image {
  height: 40px;
  width: auto;
  object-fit: contain;
  opacity: 0.7;
  transition: opacity 0.3s ease;
}

.cta-banner3-section .logo-image:hover {
  opacity: 1;
}

@media (max-width: 767px) {
  .cta-banner3-section .cta-banner3-buttons {
    flex-direction: column;
    align-items: center;
  }
  
  .cta-banner3-section .cta-banner3-buttons .btn {
    text-align: center;
    min-width: 200px;
  }
  
  .cta-banner3-section .logos-container {
    gap: 24px;
  }
}
</style>

