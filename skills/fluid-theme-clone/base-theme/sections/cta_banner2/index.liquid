{%- style -%}
  .section-{{ section.id }} {
    {%- assign p = section.settings.section_padding -%}
    {%- if p -%}
      {%- capture pt -%}{{ p.top }}{%- endcapture -%}
      {%- capture pb -%}{{ p.bottom }}{%- endcapture -%}
      {%- capture pl -%}{{ p.left }}{%- endcapture -%}
      {%- capture pr -%}{{ p.right }}{%- endcapture -%}
      padding-top: {% if pt contains 'var(' %}{{ pt }}{% else %}{{ pt }}px{% endif %};
      padding-bottom: {% if pb contains 'var(' %}{{ pb }}{% else %}{{ pb }}px{% endif %};
      padding-left: {% if pl contains 'var(' %}{{ pl }}{% else %}{{ pl }}px{% endif %};
      padding-right: {% if pr contains 'var(' %}{{ pr }}{% else %}{{ pr }}px{% endif %};
    {%- endif -%}
    {%- assign sr = section.settings.section_border_radius -%}
    {%- if sr -%}
      {%- capture sr_tl -%}{{ sr.tl }}{%- endcapture -%}
      {%- capture sr_tr -%}{{ sr.tr }}{%- endcapture -%}
      {%- capture sr_br -%}{{ sr.br }}{%- endcapture -%}
      {%- capture sr_bl -%}{{ sr.bl }}{%- endcapture -%}
      border-radius: {% if sr_tl contains 'var(' %}{{ sr_tl }}{% else %}{{ sr_tl }}px{% endif %} {% if sr_tr contains 'var(' %}{{ sr_tr }}{% else %}{{ sr_tr }}px{% endif %} {% if sr_br contains 'var(' %}{{ sr_br }}{% else %}{{ sr_br }}px{% endif %} {% if sr_bl contains 'var(' %}{{ sr_bl }}{% else %}{{ sr_bl }}px{% endif %};
    {%- endif -%}
  }
{%- endstyle -%}
<section class="cta-banner2-section section-{{ section.id }}" 
         style="background-color: {{ section.settings.background_color | default: '#f8f8f8' }};
                {% if section.settings.background_image != blank %}
                background-image: url('{{ section.settings.background_image | image_url: width: 1920 }}');
                background-size: cover;
                background-position: center;
                background-repeat: no-repeat;
                {% endif %}">
  
  {%- assign ov = section.settings.overlay -%}
  {%- if ov and ov.enabled -%}
    <div class="overlay-{{ section.id }}"></div>
    {%- style -%}
      .overlay-{{ section.id }} {
        position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1;
        {%- if ov.mode == 'gradient' and ov.colors.size > 1 -%}
          background:
            {%- if ov.gradientType == 'radial' -%}
              radial-gradient(
            {%- else -%}
              linear-gradient({{ ov.angle }}deg,
            {%- endif -%}
            {%- for stop in ov.colors -%}
              {{ stop.color }} {{ stop.position }}%{%- unless forloop.last -%},{%- endunless -%}
            {%- endfor -%}
          );
          opacity: {{ ov.colors.first.opacity | divided_by: 100.0 }};
        {%- else -%}
          {%- assign c = ov.colors | first -%}
          background-color: {{ c.color }};
          opacity: {{ c.opacity | divided_by: 100.0 }};
        {%- endif -%}
      }
    {%- endstyle -%}
  {%- endif -%}
  
  <div class="container" style="position: relative; z-index: 2;">
    <div class="cta-banner2-wrapper grid grid-cols-1 sm-desktop-grid-cols-2 space-x-7xl space-y-4xl py-9xl">
      
      <!-- Content Column -->
      <div class="cta-banner2-content flex flex-col justify-center">
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'heading' -%}
                <div class="rte mb-2xl" {{ block.fluid_attributes }}>{{ block.settings.text }}</div>
              {%- when 'text' -%}
                <div class="rte mb-4xl" {{ block.fluid_attributes }}>{{ block.settings.content }}</div>
              {%- when 'buttons' -%}
                <div class="cta-banner2-buttons flex space-lg" {{ block.fluid_attributes }}>
                  {% if block.settings.show_button_1 and block.settings.button_1_text != blank %}
                    {%- assign cr = block.settings.button_1_border_radius -%}
                    {%- assign _btn1_attr = '' -%}
                    {%- if cr -%}
                      {%- capture cr_tl -%}{{ cr.tl }}{%- endcapture -%}{%- capture cr_tr -%}{{ cr.tr }}{%- endcapture -%}{%- capture cr_br -%}{{ cr.br }}{%- endcapture -%}{%- capture cr_bl -%}{{ cr.bl }}{%- endcapture -%}
                      {%- capture _br_val -%}{% if cr_tl contains 'var(' %}{{ cr_tl }}{% else %}{{ cr_tl }}px{% endif %} {% if cr_tr contains 'var(' %}{{ cr_tr }}{% else %}{{ cr_tr }}px{% endif %} {% if cr_br contains 'var(' %}{{ cr_br }}{% else %}{{ cr_br }}px{% endif %} {% if cr_bl contains 'var(' %}{{ cr_bl }}{% else %}{{ cr_bl }}px{% endif %}{%- endcapture -%}
                      {%- assign _btn1_attr = 'style="border-radius: ' | append: _br_val | append: ';"' -%}
                    {%- endif -%}
                    {% render 'button', href: block.settings.button_1_link | default: '#', text: block.settings.button_1_text, variant: block.settings.button_1_style | default: 'btn-bg-primary', attr: _btn1_attr %}
                  {% endif %}
                  {% if block.settings.show_button_2 and block.settings.button_2_text != blank %}
                    {%- assign cr = block.settings.button_2_border_radius -%}
                    {%- assign _btn2_attr = '' -%}
                    {%- if cr -%}
                      {%- capture cr_tl -%}{{ cr.tl }}{%- endcapture -%}{%- capture cr_tr -%}{{ cr.tr }}{%- endcapture -%}{%- capture cr_br -%}{{ cr.br }}{%- endcapture -%}{%- capture cr_bl -%}{{ cr.bl }}{%- endcapture -%}
                      {%- capture _br_val -%}{% if cr_tl contains 'var(' %}{{ cr_tl }}{% else %}{{ cr_tl }}px{% endif %} {% if cr_tr contains 'var(' %}{{ cr_tr }}{% else %}{{ cr_tr }}px{% endif %} {% if cr_br contains 'var(' %}{{ cr_br }}{% else %}{{ cr_br }}px{% endif %} {% if cr_bl contains 'var(' %}{{ cr_bl }}{% else %}{{ cr_bl }}px{% endif %}{%- endcapture -%}
                      {%- assign _btn2_attr = 'style="border-radius: ' | append: _br_val | append: ';"' -%}
                    {%- endif -%}
                    {% render 'button', href: block.settings.button_2_link | default: '#', text: block.settings.button_2_text, variant: block.settings.button_2_style | default: 'btn-border-black', attr: _btn2_attr %}
                  {% endif %}
                </div>
            {%- when 'link' -%}
              {% if block.settings.text != blank %}
                {% render 'link',
                  href: block.settings.url | default: '#',
                  text: block.settings.text,
                  underline: block.settings.underline_style,
                  icon_position: block.settings.icon_position,
                  color: block.settings.color,
                  font_weight: block.settings.font_weight,
                  attr: block.fluid_attributes
                %}
              {% endif %}
            {%- endcase -%}
          {%- endfor -%}
        {%- endif -%}
      </div>
      
      <!-- Image Column -->
      <div class="cta-banner2-image">
        
        {% assign section_image = section.settings.image %}
        {% assign section_image_fluid_media_id = '' %}
        
        {% if section_image.fluid_media_id %}
          {% assign section_image_fluid_media_id = section_image.fluid_media_id %}
          {% assign section_image_embed_type = section_image.embed_type %}
        {% endif %}

        {% if section_image_fluid_media_id != blank %}
          {% assign use_fluid_image_widget = true %}
        {% endif %}

        {% if use_fluid_image_widget %}
          <div class="image-wrapper">
            <fluid-media-widget class="fluid-media-widget-image" media-id="{{ section_image_fluid_media_id }}" responsive="true" embed-type="{{ section_image_embed_type | default:'inline' }}" data-fluid-widget="true"></fluid-media-widget>
          </div>
        {% else %}
          {% if section_image != blank %}
            <div class="image-wrapper">
              <img src="{{ section_image | image_url }}" 
                alt="{{ section.settings.image_alt | default: section.settings.heading }}" 
                class="image-cover w-full" loading="lazy" width="" height=""/>
              </div>
          {% else %}
            
            <div class="image-placeholder" style="background-color: #e5e5e5; border-radius: 8px; height: 300px; display: flex; align-items: center; justify-content: center;">
              <div class="placeholder-content text-center" style="color: #999;">
                <svg width="64" height="64" fill="currentColor" viewBox="0 0 20 20" style="margin: 0 auto 16px;">
                  <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd"></path>
                </svg>
                <p style="margin: 0; font-size: 14px; font-weight: 500;">Upload an image</p>
              </div>
            </div>
            
          {% endif %}
        {% endif %}
      </div>
      
    </div>
  </div>
</section>

<style>
.cta-banner2-section {
  position: relative;
}

.cta-banner2-section .cta-banner2-content h2 {
  margin-bottom: 24px;
}

.cta-banner2-section .cta-banner2-content p {
  margin-bottom: 32px;
  line-height: 1.6;
}

.cta-banner2-section .cta-banner2-buttons {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
}

.cta-banner2-section .cta-banner2-buttons .btn {
  padding: 12px 24px;
  text-decoration: none;
  border-radius: 4px;
  font-weight: 500;
  transition: all 0.3s ease;
}

.cta-banner2-section .cta-banner2-buttons .btn:hover {
  opacity: 0.8;
}

.cta-banner2-section .image-wrapper {
  border-radius: 8px;
  overflow: hidden;
}

@media (max-width: 767px) {
  .cta-banner2-section .cta-banner2-buttons {
    flex-direction: column;
  }
  
  .cta-banner2-section .cta-banner2-buttons .btn {
    text-align: center;
  }
}
</style>

{% schema %}
{
  "name": "CTA Banner 2",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "padding",
      "id": "section_padding",
      "label": "Section Padding"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "CTA Image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image Alt Text",
      "info": "Describe the image for accessibility"
    },
    {
      "type": "color_background",
      "id": "background_color",
      "default": "#f8f8f8",
      "label": "Background Color"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image",
      "info": "Optional background image (will override background color)"
    },
    {
      "type": "gradient_overlay",
      "id": "overlay",
      "label": "Overlay"
    },
    {
      "type": "corner_radius",
      "id": "section_border_radius",
      "label": "Section Border Radius",
      "info": "Default 0px. Four corners, link/unlink."
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "settings": [
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Medium length heading goes here</p>" }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        { "type": "richtext", "id": "content", "label": "Content", "default": "<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>" }
      ]
    },
    {
      "type": "buttons",
      "name": "Buttons",
      "limit": 1,
      "settings": [
        { "type": "checkbox", "id": "show_button_1", "label": "Show Button 1", "default": true },
        { "type": "text", "id": "button_1_text", "label": "Button 1 Text", "default": "Button" },
        { "type": "url", "id": "button_1_link", "label": "Button 1 Link" },
        { "type": "select", "id": "button_1_style", "label": "Button 1 Style", "options": [
          { "value": "btn-bg-primary", "label": "Primary" }, { "value": "btn-bg-white", "label": "White" }, { "value": "btn-border-black", "label": "Black Border" }
        ], "default": "btn-bg-primary" },
        { "type": "select", "id": "button_1_size", "label": "Button 1 Size", "options": [
          { "value": "btn-xs", "label": "Extra Small" }, { "value": "btn-sm", "label": "Small" }, { "value": "btn-md", "label": "Medium" }, { "value": "btn-lg", "label": "Large" }, { "value": "btn-xl", "label": "Extra Large" }
        ], "default": "btn-md" },
        { "type": "corner_radius", "id": "button_1_border_radius", "label": "Button 1 Border Radius" },
        { "type": "checkbox", "id": "show_button_2", "label": "Show Button 2", "default": false },
        { "type": "text", "id": "button_2_text", "label": "Button 2 Text", "default": "Button" },
        { "type": "url", "id": "button_2_link", "label": "Button 2 Link" },
        { "type": "select", "id": "button_2_style", "label": "Button 2 Style", "options": [
          { "value": "btn-border-black", "label": "Black Border" }, { "value": "btn-bg-primary", "label": "Primary" }, { "value": "btn-border-white", "label": "White Border" }
        ], "default": "btn-border-black" },
        { "type": "select", "id": "button_2_size", "label": "Button 2 Size", "options": [
          { "value": "btn-xs", "label": "Extra Small" }, { "value": "btn-sm", "label": "Small" }, { "value": "btn-md", "label": "Medium" }, { "value": "btn-lg", "label": "Large" }, { "value": "btn-xl", "label": "Extra Large" }
        ], "default": "btn-md" },
        { "type": "corner_radius", "id": "button_2_border_radius", "label": "Button 2 Border Radius" }
      ]
    },
    {
      "type": "link",
      "name": "Link",
      "settings": [
        { "type": "text", "id": "text", "label": "Link Text", "default": "Learn more" },
        { "type": "url", "id": "url", "label": "Link URL" },
        { "type": "select", "id": "underline_style", "label": "Underline Style", "options": [
          { "value": "always", "label": "Always" }, { "value": "hover", "label": "On Hover Only" }, { "value": "never", "label": "Never" }
        ], "default": "hover" },
        { "type": "select", "id": "icon_position", "label": "Icon Position", "options": [
          { "value": "none", "label": "None" }, { "value": "before", "label": "Before Text" }, { "value": "after", "label": "After Text" }
        ], "default": "none" },
        { "type": "color", "id": "color", "label": "Link Color" },
        { "type": "select", "id": "font_weight", "label": "Font Weight", "options": [
          { "value": "400", "label": "Normal" }, { "value": "500", "label": "Medium" }, { "value": "600", "label": "Semi Bold" }, { "value": "700", "label": "Bold" }
        ], "default": "400" }
      ]
    }
  ],
  "presets": [
    { "name": "CTA Banner 2", "blocks": [ { "type": "heading" }, { "type": "text" }, { "type": "buttons" } ] }
  ]
}
{% endschema %} 