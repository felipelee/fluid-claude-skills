          "id": "link",
          "label": "Link"
        },
        {
          "type": "checkbox",
          "id": "open_new_tab",
          "label": "Open in new tab",
          "default": false
        },
        {
          "type": "header",
          "content": "Sizing"
        },
        {
          "type": "select",
          "id": "aspect_ratio",
          "label": "Aspect Ratio",
          "default": "4/3",
          "options": [
            {
              "value": "auto",
              "label": "Auto (natural)"
            },
            {
              "value": "1/1",
              "label": "Square (1:1)"
            },
            {
