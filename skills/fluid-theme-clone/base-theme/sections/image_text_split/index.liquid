          "unit": "px"
        },
        {
          "type": "padding",
          "id": "padding",
          "label": "Padding"
        },
        {
          "type": "select",
          "id": "background_color",
          "label": "Background Color",
          "options": "background_colors",
          "default": "var(--clr-primary)"
        },
        {
          "type": "select",
          "id": "text_color",
          "label": "Text Color",
          "options": "background_colors",
          "default": "var(--clr-white)"
        },
        {
          "type": "header",
          "content": "Shape"
        },
        {
          "type": "range",
          "id": "border_width",
          "label": "Border Width",
          "min": 0,
          "max": 10,
          "step": 1,
          "default": 0,
          "unit": "px"
        },
        {
          "type": "select",
          "id": "border_color",
          "label": "Border Color",
          "options": "background_colors",
          "default": "var(--clr-primary)"
        },
        {
          "type": "corner_radius",
          "id": "border_radius",
          "label": "Border Radius"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image + Text Split",
      "blocks": [
        {
          "type": "eyebrow"
        },
        {
          "type": "heading"
        },
        {
          "type": "text"
        },
        {
          "type": "image",
          "settings": {
            "aspect_ratio": "4/3",
            "fit": "cover"
          }
        },
        {
          "type": "button",
          "settings": {
            "text": "Learn more",
            "style": "filled"
          }
        }
      ]
    }
  ]
}
{% endschema %}
