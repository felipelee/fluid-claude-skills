{%- comment -%}
  enrollment_pack_hero — award-winning MLM enrollment PDP hero.
  Grid gallery (left) + info column (right). Wired to Fluid's enrollment_pack object.
  CTA fires data-fluid-add-enrollment-pack="{id}" for Fluid's enrollment checkout.
  Drop {% section 'enrollment_pack_hero' %} into enrollment_pack/<slug>/index.liquid
{%- endcomment -%}

{%- assign not_purchasable = enrollment_pack.out_of_stock or enrollment_pack.available_for_country == false or enrollment_pack.active == false -%}
{%- assign sel_variant = enrollment_pack.selected_or_first_available_variant -%}

{%- comment -%} Pick image source: variant images (when present) > product images {%- endcomment -%}
{%- assign images_array = enrollment_pack.images -%}
{%- if sel_variant.images and sel_variant.images.size > 0 -%}
  {%- assign images_array = sel_variant.images | parse_json -%}
{%- endif -%}

{%- comment -%} Compute savings if compare-at-price > price {%- endcomment -%}
{%- assign has_compare = false -%}
{%- if enrollment_pack.compare_at_price and enrollment_pack.compare_at_price != blank -%}
  {%- assign cmp = enrollment_pack.compare_at_price | plus: 0.0 -%}
  {%- assign cur = enrollment_pack.price | plus: 0.0 -%}
  {%- if cmp > cur and cur > 0 -%}
    {%- assign has_compare = true -%}
    {%- assign savings_pct = cmp | minus: cur | times: 100.0 | divided_by: cmp | round -%}
  {%- endif -%}
{%- endif -%}

{%- style -%}
  .ph.section-{{ section.id }} {
    {%- assign p = section.settings.section_padding -%}
    {%- if p -%}padding: {{ p.top | default: 48 }}px {{ p.right | default: 0 }}px {{ p.bottom | default: 48 }}px {{ p.left | default: 0 }}px;{%- else -%}padding: 48px 0;{%- endif -%}
    {%- assign r = section.settings.section_border_radius -%}
    {%- if r -%}border-radius: {{ r.tl }}px {{ r.tr }}px {{ r.br }}px {{ r.bl }}px;{%- endif -%}
    {% if section.settings.section_border_width > 0 %}border: {{ section.settings.section_border_width }}px solid {{ section.settings.section_border_color }};{% endif %}
    background-color: {{ section.settings.background_color | default: 'transparent' }};
    {%- if section.settings.background_image != blank -%}
      background-image: url({{ section.settings.background_image | img_url: '2400x' }});
      background-size: cover; background-position: center; background-repeat: no-repeat;
    {%- endif -%}
  }
  .ph.section-{{ section.id }} .ph__container {
    position: relative;
    max-width: {{ section.settings.container_max_width | default: '1280px' }};
    margin: 0 auto;
    {%- assign cp = section.settings.container_padding -%}
    {%- if cp -%}padding: {{ cp.top | default: 0 }}px {{ cp.right | default: 32 }}px {{ cp.bottom | default: 0 }}px {{ cp.left | default: 32 }}px;{%- else -%}padding: 0 32px;{%- endif -%}
    background-color: {{ section.settings.container_background_color | default: 'transparent' }};
    {%- if section.settings.container_background_image != blank -%}
      background-image: url({{ section.settings.container_background_image | img_url: '2400x' }});
      background-size: cover; background-position: center; background-repeat: no-repeat;
    {%- endif -%}
    {%- assign ccr = section.settings.container_border_radius -%}
    {%- if ccr -%}border-radius: {{ ccr.tl }}px {{ ccr.tr }}px {{ ccr.br }}px {{ ccr.bl }}px;{%- endif -%}
    {% if section.settings.container_border_width > 0 %}border: {{ section.settings.container_border_width }}px solid {{ section.settings.container_border_color }};{% endif %}
  }
  {%- if section.settings.container_overlay_color != blank and section.settings.container_overlay_opacity > 0 -%}
    {%- assign _cov = section.settings.container_overlay_opacity | divided_by: 100.0 -%}
    .ph.section-{{ section.id }} .ph__container::before { content: ""; position: absolute; inset: 0; background: {{ section.settings.container_overlay_color }}; opacity: {{ _cov }}; pointer-events: none; }
  {%- endif -%}
  .ph.section-{{ section.id }} .ph__container > * { position: relative; }
  @media (max-width: 991px) { .ph.section-{{ section.id }} .ph__container { padding-left: 16px; padding-right: 16px; } }

  /* ── Layout grid ───────────────────────────────────────────── */
  {%- assign _sr = section.settings.split_ratio | default: '60-40' -%}
  {%- case _sr -%}
    {%- when '50-50' -%}{%- assign _gallery_fr = '1fr' -%}{%- assign _info_fr = '1fr' -%}
    {%- when '60-40' -%}{%- assign _gallery_fr = '3fr' -%}{%- assign _info_fr = '2fr' -%}
    {%- when '65-35' -%}{%- assign _gallery_fr = '13fr' -%}{%- assign _info_fr = '7fr' -%}
    {%- when '40-60' -%}{%- assign _gallery_fr = '2fr' -%}{%- assign _info_fr = '3fr' -%}
    {%- else -%}{%- assign _gallery_fr = '3fr' -%}{%- assign _info_fr = '2fr' -%}
  {%- endcase -%}
  .ph.section-{{ section.id }} .ph__grid {
    display: grid;
    grid-template-columns: {% if section.settings.gallery_position == 'right' %}minmax(0, {{ _info_fr }}) minmax(0, {{ _gallery_fr }}){% else %}minmax(0, {{ _gallery_fr }}) minmax(0, {{ _info_fr }}){% endif %};
    gap: clamp(24px, 4vw, 64px);
    align-items: start;
  }
  @media (max-width: 991px) {
    .ph.section-{{ section.id }} .ph__grid { grid-template-columns: 1fr; gap: 24px; }
  }

  .ph.section-{{ section.id }} .ph__gallery {
    {% if section.settings.gallery_position == 'left' %}order: 1;{% else %}order: 2;{% endif %}
  }
  .ph.section-{{ section.id }} .ph__info {
    {% if section.settings.gallery_position == 'left' %}order: 2;{% else %}order: 1;{% endif %}
    {% if section.settings.sticky_info %}
      position: sticky;
      top: {{ section.settings.sticky_offset | default: 100 }}px;
    {% endif %}
  }
  @media (max-width: 991px) {
    .ph.section-{{ section.id }} .ph__gallery,
    .ph.section-{{ section.id }} .ph__info { order: unset; position: static; }
  }

  /* ── Grid gallery (Seed-style) ────────────────────────────── */
  {%- assign _grid_cols = section.settings.grid_columns | default: 2 -%}
  {%- assign _grid_gap  = section.settings.grid_gap | default: 8 -%}
  .ph.section-{{ section.id }} .ph__grid-gallery {
    display: grid;
    grid-template-columns: repeat({{ _grid_cols }}, minmax(0, 1fr));
    gap: {{ _grid_gap }}px;
  }
  @media (max-width: 767px) {
    .ph.section-{{ section.id }} .ph__grid-gallery {
      grid-template-columns: repeat({{ section.settings.grid_columns_mobile | default: 1 }}, minmax(0, 1fr));
      gap: {{ section.settings.grid_gap_mobile | default: 6 }}px;
    }
  }
  .ph.section-{{ section.id }} .ph__tile {
    appearance: none; -webkit-appearance: none;
    border: 0; padding: 0; margin: 0;
    background: {{ section.settings.image_placeholder_background | default: 'var(--clr-light)' }};
    font: inherit; color: inherit;
    display: block; width: 100%;
    aspect-ratio: {{ section.settings.image_aspect_ratio | default: '1/1' }};
    overflow: hidden;
    cursor: zoom-in;
    position: relative;
    {%- assign ibr = section.settings.image_border_radius -%}
    {%- if ibr -%}border-radius: {{ ibr.tl }}px {{ ibr.tr }}px {{ ibr.br }}px {{ ibr.bl }}px;{%- else -%}border-radius: 12px;{%- endif -%}
    transition: transform .25s ease;
  }
  .ph.section-{{ section.id }} .ph__tile:hover { transform: scale(0.995); }
  .ph.section-{{ section.id }} .ph__tile > img,
  .ph.section-{{ section.id }} .ph__tile > video {
    width: 100%; height: 100%;
    object-fit: cover; object-position: center;
    display: block;
  }
  .ph.section-{{ section.id }} .ph__tile--hero {
    {% if _grid_cols != 1 %}grid-column: span {{ _grid_cols }};{% endif %}
    aspect-ratio: {{ section.settings.hero_aspect_ratio | default: '16/10' }};
  }
  @media (max-width: 767px) {
    .ph.section-{{ section.id }} .ph__tile--hero {
      grid-column: span {{ section.settings.grid_columns_mobile | default: 1 }};
      aspect-ratio: {{ section.settings.image_aspect_ratio | default: '1/1' }};
    }
  }
  .ph.section-{{ section.id }} .ph__tile-placeholder {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    color: var(--clr-muted); opacity: 0.5;
    background: repeating-linear-gradient(45deg, var(--clr-gray) 0 18px, var(--clr-light) 18px 36px);
  }
  .ph.section-{{ section.id }} .ph__badge {
    position: absolute;
    top: 16px; left: 16px;
    z-index: 2;
    padding: 5px 12px;
    font-size: 11px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
    background: {{ section.settings.savings_badge_background | default: 'var(--clr-accent)' }};
    color: {{ section.settings.savings_badge_color | default: 'var(--clr-white)' }};
    border-radius: 999px;
    pointer-events: none;
  }

  /* ── Info column ──────────────────────────────────────────── */
  .ph.section-{{ section.id }} .ph__info-stack {
    display: flex; flex-direction: column;
    gap: 16px;
    color: {{ section.settings.text_color | default: 'var(--clr-primary)' }};
  }

  .ph.section-{{ section.id }} .ph__eyebrow {
    font-size: 12px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase;
    color: {{ section.settings.eyebrow_color | default: 'var(--clr-muted)' }};
    margin: 0;
  }

  .ph.section-{{ section.id }} .ph__title {
    font-size: clamp(28px, 3.5vw, 40px);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0;
    font-family: {{ section.settings.title_font | default: 'var(--ff-heading)' }};
    color: {{ section.settings.title_color | default: 'var(--clr-primary)' }};
  }

  .ph.section-{{ section.id }} .ph__rating-row {
    display: flex; align-items: center; gap: 10px;
    font-size: 13px;
    color: {{ section.settings.rating_text_color | default: 'var(--clr-muted)' }};
  }
  .ph.section-{{ section.id }} .ph__stars { position: relative; display: inline-block; line-height: 0; }
  .ph.section-{{ section.id }} .ph__stars-track,
  .ph.section-{{ section.id }} .ph__stars-fill { display: inline-flex; gap: 1px; }
  .ph.section-{{ section.id }} .ph__stars-track { color: {{ section.settings.star_empty_color | default: 'var(--clr-gray)' }}; }
  .ph.section-{{ section.id }} .ph__stars-fill { position: absolute; inset: 0; overflow: hidden; color: {{ section.settings.star_color | default: 'var(--clr-warning)' }}; }
  .ph.section-{{ section.id }} .ph__stars svg { width: 14px; height: 14px; fill: currentColor; flex-shrink: 0; }
  .ph.section-{{ section.id }} .ph__rating-link {
    color: inherit; text-decoration: underline; text-underline-offset: 3px;
  }

  .ph.section-{{ section.id }} .ph__price-row {
    display: flex; align-items: baseline; gap: 12px; flex-wrap: wrap;
    margin-top: 4px;
  }
  .ph.section-{{ section.id }} .ph__price {
    font-size: clamp(22px, 2.6vw, 32px);
    font-weight: 700; letter-spacing: -0.02em;
    color: {{ section.settings.price_color | default: 'var(--clr-primary)' }};
  }
  .ph.section-{{ section.id }} .ph__compare {
    font-size: 16px;
    color: {{ section.settings.compare_color | default: 'var(--clr-muted)' }};
    text-decoration: line-through;
  }
  .ph.section-{{ section.id }} .ph__savings {
    display: inline-flex; align-items: center;
    padding: 3px 10px;
    font-size: 12px; font-weight: 700; letter-spacing: 0.04em;
    background: {{ section.settings.savings_pill_background | default: 'var(--clr-success)' }};
    color: {{ section.settings.savings_pill_color | default: 'var(--clr-white)' }};
    border-radius: 999px;
  }

  .ph.section-{{ section.id }} .ph__short-desc {
    font-size: 15.5px;
    line-height: 1.6;
    color: {{ section.settings.body_color | default: 'var(--clr-body)' }};
  }
  .ph.section-{{ section.id }} .ph__short-desc p { margin: 0 0 8px; }
  .ph.section-{{ section.id }} .ph__short-desc p:last-child { margin-bottom: 0; }

  .ph.section-{{ section.id }} .ph__divider { height: 1px; background: {{ section.settings.divider_color | default: 'var(--clr-gray)' }}; margin: 8px 0; }

  /* ── Variant pickers ───────────────────────────────────────── */
  .ph.section-{{ section.id }} .ph__variant-group { display: flex; flex-direction: column; gap: 8px; margin: 4px 0; }
  .ph.section-{{ section.id }} .ph__variant-label {
    display: flex; align-items: baseline; gap: 8px;
    font-size: 13px; font-weight: 600; letter-spacing: 0.04em;
    color: {{ section.settings.variant_label_color | default: 'var(--clr-primary)' }};
    text-transform: uppercase;
  }
  .ph.section-{{ section.id }} .ph__variant-selected {
    font-size: 13px; font-weight: 400; letter-spacing: 0; text-transform: none;
    color: {{ section.settings.variant_selected_color | default: 'var(--clr-muted)' }};
  }
  .ph.section-{{ section.id }} .ph__variant-options {
    display: flex; flex-wrap: wrap; gap: 8px;
  }
  .ph.section-{{ section.id }} .ph__variant-pill {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 48px; padding: 9px 16px;
    font-size: 14px; font-weight: 500;
    color: {{ section.settings.variant_pill_color | default: 'var(--clr-primary)' }};
    background: {{ section.settings.variant_pill_background | default: 'var(--clr-white)' }};
    border: 1.5px solid {{ section.settings.variant_pill_border | default: 'var(--clr-gray)' }};
    border-radius: 999px;
    cursor: pointer;
    transition: border-color .15s, background-color .15s, color .15s;
  }
  .ph.section-{{ section.id }} .ph__variant-pill:hover { border-color: {{ section.settings.variant_pill_hover_border | default: 'var(--clr-primary)' }}; }
  .ph.section-{{ section.id }} .ph__variant-pill.is-active {
    background: {{ section.settings.variant_pill_active_bg | default: 'var(--clr-primary)' }};
    color: {{ section.settings.variant_pill_active_color | default: 'var(--clr-white)' }};
    border-color: {{ section.settings.variant_pill_active_bg | default: 'var(--clr-primary)' }};
  }
  .ph.section-{{ section.id }} select.ph__variant-select {
    appearance: none; -webkit-appearance: none;
    width: 100%; max-width: 360px;
    padding: 10px 36px 10px 14px;
    font-size: 14px; font-family: inherit;
    color: {{ section.settings.variant_pill_color | default: 'var(--clr-primary)' }};
    background-color: {{ section.settings.variant_pill_background | default: 'var(--clr-white)' }};
    border: 1.5px solid {{ section.settings.variant_pill_border | default: 'var(--clr-gray)' }};
    border-radius: 10px;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%239CA3AF' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><polyline points='6 9 12 15 18 9'/></svg>");
    background-repeat: no-repeat;
    background-position: right 12px center;
    background-size: 14px;
    cursor: pointer;
  }

  /* ── Quantity stepper ──────────────────────────────────────── */
  .ph.section-{{ section.id }} .ph__qty {
    display: inline-flex; align-items: stretch;
    border: 1.5px solid {{ section.settings.variant_pill_border | default: 'var(--clr-gray)' }};
    border-radius: 999px;
    overflow: hidden;
    width: fit-content;
  }
  .ph.section-{{ section.id }} .ph__qty button {
    width: 40px; height: 40px;
    display: inline-flex; align-items: center; justify-content: center;
    background: transparent; border: none; cursor: pointer;
    color: {{ section.settings.variant_pill_color | default: 'var(--clr-primary)' }};
    font-size: 18px; line-height: 1;
    transition: background-color .15s;
  }
  .ph.section-{{ section.id }} .ph__qty button:hover { background: {{ section.settings.variant_pill_border | default: 'var(--clr-gray)' }}; }
  .ph.section-{{ section.id }} .ph__qty input {
    width: 40px; padding: 0;
    text-align: center;
    background: transparent; border: none;
    font-size: 14px; font-weight: 500;
    color: {{ section.settings.variant_pill_color | default: 'var(--clr-primary)' }};
    -moz-appearance: textfield;
  }
  .ph.section-{{ section.id }} .ph__qty input::-webkit-outer-spin-button,
  .ph.section-{{ section.id }} .ph__qty input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }

  /* ── Add to cart ──────────────────────────────────────────── */
  .ph.section-{{ section.id }} .ph__buy-row {
    display: flex; align-items: stretch; gap: 12px;
    margin-top: 4px;
  }
  .ph.section-{{ section.id }} .ph__buy-row .ph__qty { flex: 0 0 auto; }
  .ph.section-{{ section.id }} .ph__buy-row .ph__qty button { height: auto; align-self: stretch; min-width: 44px; }
  .ph.section-{{ section.id }} .ph__buy-row .ph__qty input { height: auto; min-width: 44px; }
  .ph.section-{{ section.id }} .ph__cta {
    flex: 1 1 auto;
    padding: 18px 28px;
    font-size: 16px; font-weight: 700;
    letter-spacing: 0.04em; text-transform: uppercase;
    color: {{ section.settings.cta_text_color | default: 'var(--clr-white)' }};
    background: {{ section.settings.cta_background | default: 'var(--clr-primary)' }};
    border: none; border-radius: 999px;
    cursor: pointer;
    transition: opacity .15s, transform .1s;
  }
  .ph.section-{{ section.id }} .ph__cta:hover { opacity: 0.92; }
  .ph.section-{{ section.id }} .ph__cta:active { transform: translateY(1px); }
  .ph.section-{{ section.id }} .ph__cta:disabled { opacity: 0.5; cursor: not-allowed; }

  .ph.section-{{ section.id }} .ph__sold-out {
    padding: 12px 16px;
    background: {{ section.settings.divider_color | default: 'var(--clr-gray)' }};
    color: {{ section.settings.body_color | default: 'var(--clr-body)' }};
    border-radius: 10px;
    font-size: 14px; text-align: center;
  }

  .ph.section-{{ section.id }} .ph__commission {
    display: inline-flex; align-items: center; gap: 8px;
    margin-top: 10px;
    padding: 8px 14px;
    font-size: 13px; font-weight: 600; letter-spacing: 0.02em;
    background: {{ section.settings.commission_background | default: 'rgba(16, 185, 129, 0.12)' }};
    color: {{ section.settings.commission_color | default: 'var(--clr-success)' }};
    border-radius: 999px;
    width: fit-content;
  }
  .ph.section-{{ section.id }} .ph__commission svg { width: 14px; height: 14px; }

  /* ── Trust strip ──────────────────────────────────────────── */
  .ph.section-{{ section.id }} .ph__trust {
    display: flex; flex-direction: column; gap: 8px;
    margin-top: 12px;
    padding: 16px 18px;
    background: {{ section.settings.trust_background | default: 'var(--clr-light)' }};
    border-radius: 12px;
  }
  .ph.section-{{ section.id }} .ph__trust-item {
    display: flex; align-items: center; gap: 10px;
    font-size: 13.5px; font-weight: 500;
    color: {{ section.settings.trust_color | default: 'var(--clr-primary)' }};
  }
  .ph.section-{{ section.id }} .ph__trust-item svg {
    width: 16px; height: 16px; flex-shrink: 0;
    color: {{ section.settings.trust_icon_color | default: 'var(--clr-success)' }};
  }

  /* ── Details block (plain product description under price) ── */
  .ph.section-{{ section.id }} .ph__details {
    font-size: 15px; line-height: 1.6;
    color: {{ section.settings.body_color | default: 'var(--clr-body)' }};
  }
  .ph.section-{{ section.id }} .ph__details p { margin: 0 0 10px; }
  .ph.section-{{ section.id }} .ph__details p:last-child { margin-bottom: 0; }

  /* ── Accordion ────────────────────────────────────────────── */
  .ph.section-{{ section.id }} .ph__accordion { margin-top: 18px; }
  .ph.section-{{ section.id }} .ph__acc-item { border-top: 1px solid {{ section.settings.divider_color | default: 'var(--clr-gray)' }}; }
  .ph.section-{{ section.id }} .ph__acc-item:last-child { border-bottom: 1px solid {{ section.settings.divider_color | default: 'var(--clr-gray)' }}; }
  .ph.section-{{ section.id }} .ph__acc-item > summary {
    list-style: none; cursor: pointer;
    padding: 16px 0;
    display: flex; justify-content: space-between; align-items: center; gap: 12px;
    font-size: 14px; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase;
    color: {{ section.settings.accordion_label_color | default: 'var(--clr-primary)' }};
    user-select: none;
  }
  .ph.section-{{ section.id }} .ph__acc-item > summary::-webkit-details-marker { display: none; }
  .ph.section-{{ section.id }} .ph__acc-item > summary::after {
    content: ""; flex-shrink: 0;
    width: 12px; height: 12px;
    background: currentColor;
    -webkit-mask: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='black' stroke-width='3'><path d='M6 9l6 6 6-6'/></svg>") center / contain no-repeat;
            mask: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='black' stroke-width='3'><path d='M6 9l6 6 6-6'/></svg>") center / contain no-repeat;
    transition: transform .2s;
  }
  .ph.section-{{ section.id }} .ph__acc-item[open] > summary::after { transform: rotate(180deg); }
  .ph.section-{{ section.id }} .ph__acc-body {
    padding: 0 0 20px;
    font-size: 14.5px; line-height: 1.6;
    color: {{ section.settings.body_color | default: 'var(--clr-body)' }};
  }
  .ph.section-{{ section.id }} .ph__acc-body p:first-child { margin-top: 0; }
  .ph.section-{{ section.id }} .ph__acc-body p:last-child  { margin-bottom: 0; }

  /* ── Highlights (icon + text bullets) ────────────────────── */
  .ph.section-{{ section.id }} .ph__highlights {
    display: grid; gap: 10px;
    margin: 4px 0;
    padding: 14px 16px;
    background: {{ section.settings.highlights_background | default: 'transparent' }};
    border: 1px solid {{ section.settings.highlights_border | default: 'var(--clr-gray)' }};
    border-radius: 12px;
  }
  .ph.section-{{ section.id }} .ph__highlight {
    display: grid; grid-template-columns: 32px 1fr; align-items: center; gap: 12px;
    font-size: 14px;
    color: {{ section.settings.highlights_text_color | default: 'var(--clr-primary)' }};
  }
  .ph.section-{{ section.id }} .ph__highlight-icon {
    width: 32px; height: 32px; border-radius: 8px;
    display: inline-flex; align-items: center; justify-content: center;
    background: {{ section.settings.highlights_icon_bg | default: 'var(--clr-light)' }};
    color: {{ section.settings.highlights_icon_color | default: 'var(--clr-primary)' }};
    flex-shrink: 0;
  }
  .ph.section-{{ section.id }} .ph__highlight-icon svg { width: 16px; height: 16px; }
  .ph.section-{{ section.id }} .ph__highlight-text strong { font-weight: 600; }
  .ph.section-{{ section.id }} .ph__highlight-text small { display: block; font-size: 12.5px; color: {{ section.settings.body_color | default: 'var(--clr-body)' }}; opacity: 0.85; margin-top: 2px; }

  /* ── Subscription toggle ─────────────────────────────────── */
  .ph.section-{{ section.id }} .ph__sub-toggle {
    display: grid; grid-template-columns: 1fr 1fr; gap: 8px;
    padding: 4px;
    background: {{ section.settings.sub_toggle_background | default: 'var(--clr-light)' }};
    border-radius: 12px;
    margin: 4px 0;
  }
  @media (max-width: 767px) {
    .ph.section-{{ section.id }} .ph__sub-toggle { grid-template-columns: 1fr; gap: 6px; }
  }
  .ph.section-{{ section.id }} .ph__sub-option {
    position: relative;
    padding: 12px 14px;
    border-radius: 9px;
    cursor: pointer;
    transition: background-color .15s, color .15s, box-shadow .15s;
    text-align: left;
    background: transparent;
    color: {{ section.settings.sub_option_text | default: 'var(--clr-primary)' }};
    border: none;
  }
  .ph.section-{{ section.id }} .ph__sub-option.is-active {
    background: {{ section.settings.sub_option_active_bg | default: 'var(--clr-white)' }};
    color: {{ section.settings.sub_option_active_text | default: 'var(--clr-primary)' }};
    box-shadow: 0 2px 8px -2px rgba(17, 24, 39, 0.12);
  }
  .ph.section-{{ section.id }} .ph__sub-option-label {
    display: block;
    font-size: 13px; font-weight: 600; letter-spacing: 0.02em;
  }
  .ph.section-{{ section.id }} .ph__sub-option-detail {
    display: block;
    font-size: 12px; opacity: 0.7;
    margin-top: 2px;
  }
  .ph.section-{{ section.id }} .ph__sub-option-saving {
    display: inline-block;
    margin-left: 6px;
    padding: 1px 7px;
    font-size: 10px; font-weight: 700; letter-spacing: 0.04em;
    background: {{ section.settings.savings_pill_background | default: 'var(--clr-success)' }};
    color: {{ section.settings.savings_pill_color | default: 'var(--clr-white)' }};
    border-radius: 999px;
    vertical-align: middle;
  }

  /* ── Inventory + Delivery ────────────────────────────────── */
  .ph.section-{{ section.id }} .ph__urgency {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 4px 10px;
    font-size: 12px; font-weight: 600; letter-spacing: 0.04em;
    background: {{ section.settings.urgency_background | default: 'rgba(245, 158, 11, 0.12)' }};
    color: {{ section.settings.urgency_color | default: 'var(--clr-warning)' }};
    border-radius: 999px;
    width: fit-content;
  }
  .ph.section-{{ section.id }} .ph__urgency::before {
    content: ""; width: 6px; height: 6px; border-radius: 50%;
    background: currentColor;
    animation: ph-pulse 1.6s infinite ease-in-out;
  }
  @keyframes ph-pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }

  /* Refined Add to Cart sizing */
  .ph.section-{{ section.id }} .ph__cta { padding: 16px 28px; font-size: 14px; }

  /* ── Image lightbox ──────────────────────────────────────── */
  .ph__lightbox {
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.85);
    display: none; align-items: center; justify-content: center;
    z-index: 9999; padding: 24px;
  }
  .ph__lightbox.is-open { display: flex; }
  .ph__lightbox img {
    max-width: 100%; max-height: 100%;
    object-fit: contain;
    border-radius: 4px;
  }
  .ph__lightbox-close,
  .ph__lightbox-prev,
  .ph__lightbox-next {
    position: absolute;
    width: 44px; height: 44px;
    background: rgba(255,255,255,0.95);
    border: none; border-radius: 50%;
    display: inline-flex; align-items: center; justify-content: center;
    cursor: pointer;
    color: #111;
    transition: transform .15s;
  }
  .ph__lightbox-close { top: 24px; right: 24px; }
  .ph__lightbox-prev { left: 24px; top: 50%; transform: translateY(-50%); }
  .ph__lightbox-next { right: 24px; top: 50%; transform: translateY(-50%); }
  .ph__lightbox-close:hover,
  .ph__lightbox-prev:hover,
  .ph__lightbox-next:hover { transform: scale(1.05); }
  .ph__lightbox-prev:hover { transform: translateY(-50%) scale(1.05); }
  .ph__lightbox-next:hover { transform: translateY(-50%) scale(1.05); }
  .ph__lightbox-close svg,
  .ph__lightbox-prev svg,
  .ph__lightbox-next svg { width: 20px; height: 20px; }
  .ph__lightbox-counter {
    position: absolute; bottom: 24px; left: 50%; transform: translateX(-50%);
    background: rgba(0,0,0,0.6); color: #fff;
    padding: 6px 12px; border-radius: 999px;
    font-size: 12px; font-weight: 500;
  }

  /* ── Sticky bottom bar (mobile) ──────────────────────────── */
  .ph__sticky-bar {
    position: fixed; left: 0; right: 0; bottom: 0;
    background: {{ section.settings.sticky_bar_background | default: 'var(--clr-white)' }};
    border-top: 1px solid {{ section.settings.divider_color | default: 'var(--clr-gray)' }};
    padding: 10px 16px env(safe-area-inset-bottom, 12px);
    display: none; align-items: center; gap: 12px;
    z-index: 100;
    box-shadow: 0 -4px 24px -8px rgba(17, 24, 39, 0.15);
    transform: translateY(100%);
    transition: transform .25s ease;
  }
  .ph__sticky-bar.is-visible { transform: translateY(0); }
  @media (max-width: 991px) { .ph__sticky-bar { display: flex; } }
  .ph__sticky-thumb {
    width: 44px; height: 44px; border-radius: 8px;
    background: var(--clr-gray);
    overflow: hidden; flex-shrink: 0;
  }
  .ph__sticky-thumb img { width: 100%; height: 100%; object-fit: cover; }
  .ph__sticky-info { flex: 1; min-width: 0; }
  .ph__sticky-title {
    font-size: 13px; font-weight: 600;
    color: {{ section.settings.text_color | default: 'var(--clr-primary)' }};
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .ph__sticky-price {
    font-size: 14px; font-weight: 700;
    color: {{ section.settings.price_color | default: 'var(--clr-primary)' }};
  }
  .ph__sticky-cta {
    padding: 10px 18px;
    background: {{ section.settings.cta_background | default: 'var(--clr-primary)' }};
    color: {{ section.settings.cta_text_color | default: 'var(--clr-white)' }};
    border: none; border-radius: 999px;
    font-size: 13px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase;
    cursor: pointer;
    flex-shrink: 0;
  }
{%- endstyle -%}

<section class="ph section-{{ section.id }}" {{ section.fluid_attributes }}>
  <div class="ph__container">
    <div class="ph__grid">

      {%- comment -%} ───────── Grid gallery (Seed-style) ───────── {%- endcomment -%}
      <div class="ph__gallery">
        <div class="ph__grid-gallery" data-ph-gallery>
          {% if images_array.size > 0 %}
            {% for image in images_array %}
              {%- assign _hero_class = '' -%}
              {%- if section.settings.feature_first_tile and forloop.first -%}{%- assign _hero_class = ' ph__tile--hero' -%}{%- endif -%}
              <button type="button" class="ph__tile{{ _hero_class }}" data-ph-tile data-image-src="{{ image.src }}" aria-label="Open image {{ forloop.index }} of {{ images_array.size }}">
                {% if forloop.first and has_compare and section.settings.show_savings_badge %}
                  <span class="ph__badge">−{{ savings_pct }}%</span>
                {% endif %}
                <img src="{{ image.src }}" alt="{{ enrollment_pack.title | escape }} — view {{ forloop.index }}" loading="{% if forloop.first %}eager{% else %}lazy{% endif %}">
              </button>
            {% endfor %}
          {% else %}
            <div class="ph__tile ph__tile--hero">
              <div class="ph__tile-placeholder">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" width="64" height="64"><rect x="3" y="4" width="18" height="16" rx="2"/><circle cx="8.5" cy="10" r="1.5"/><path d="M3 16l5-4 4 3 4-5 5 6"/></svg>
              </div>
            </div>
          {% endif %}
        </div>
      </div>

      {%- comment -%} ───────── Info column ───────── {%- endcomment -%}
      <div class="ph__info">
        <div class="ph__form" id="enrollment-form-{{ section.id }}">
          <div class="ph__info-stack">

            {%- assign eyebrow_block = section.blocks | where: 'type', 'eyebrow' | first -%}
            {% if eyebrow_block %}
              <div class="ph__eyebrow" {{ eyebrow_block.fluid_attributes }}>{{ eyebrow_block.settings.text | default: 'Bestseller' | escape }}</div>
            {% elsif section.settings.show_default_eyebrow %}
              <div class="ph__eyebrow">{{ section.settings.default_eyebrow | default: 'Bestseller' | escape }}</div>
            {% endif %}

            <h1 class="ph__title">{{ enrollment_pack.title | escape }}</h1>

            {% if section.settings.show_rating %}
              {%- assign rating = section.settings.rating_value | default: 4.9 | plus: 0 -%}
              {%- assign rating_pct = rating | divided_by: 5.0 | times: 100 -%}
              <div class="ph__rating-row">
                <span class="ph__stars" aria-label="{{ rating }} out of 5 stars">
                  <span class="ph__stars-track">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                  </span>
                  <span class="ph__stars-fill" style="width: {{ rating_pct }}%;">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                  </span>
                </span>
                <span>{{ section.settings.rating_value | default: '4.9' }}</span>
                {% if section.settings.review_count != blank %}
                  <a href="#reviews" class="ph__rating-link">({{ section.settings.review_count | escape }} reviews)</a>
                {% endif %}
              </div>
            {% endif %}

            <div class="ph__price-row">
              <span class="ph__price">{{ enrollment_pack.price }}</span>
              {% if has_compare %}
                <span class="ph__compare">{{ enrollment_pack.compare_at_price }}</span>
                <span class="ph__savings">Save {{ savings_pct }}%</span>
              {% endif %}
            </div>

            {%- assign details_blocks = section.blocks | where: 'type', 'details_block' -%}
            {% for block in details_blocks %}
              <div class="ph__details rte" {{ block.fluid_attributes }}>
                {% if block.settings.use_product_description %}
                  {{ enrollment_pack.description }}
                {% else %}
                  {{ block.settings.body }}
                {% endif %}
              </div>
            {% endfor %}

            {%- assign desc_block = section.blocks | where: 'type', 'description' | first -%}
            {% if desc_block and desc_block.settings.text != blank %}
              <div class="ph__short-desc rte" {{ desc_block.fluid_attributes }}>{{ desc_block.settings.text }}</div>
            {% elsif enrollment_pack.short_description != blank %}
              <div class="ph__short-desc">{{ enrollment_pack.short_description }}</div>
            {% elsif enrollment_pack.feature_text != blank %}
              <div class="ph__short-desc">{{ enrollment_pack.feature_text }}</div>
            {% endif %}

            {%- assign hl_blocks = section.blocks | where: 'type', 'highlight' -%}
            {% if hl_blocks.size > 0 %}
              <div class="ph__highlights">
                {% for block in hl_blocks %}
                  <div class="ph__highlight" {{ block.fluid_attributes }}>
                    <span class="ph__highlight-icon">
                      {% case block.settings.icon %}
                        {% when 'check' %}
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        {% when 'leaf' %}
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19.2 2.96c1.4 9.3-3.7 14.4-8.2 17.04Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6"/></svg>
                        {% when 'sparkle' %}
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l1.9 5.8L20 11l-6.1 2.2L12 19l-1.9-5.8L4 11l6.1-2.2L12 3z"/></svg>
                        {% when 'heart' %}
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                        {% when 'shield' %}
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                        {% when 'flame' %}
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>
                        {% when 'award' %}
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
                        {% when 'truck' %}
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                        {% else %}
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                      {% endcase %}
                    </span>
                    <div class="ph__highlight-text">
                      <strong>{{ block.settings.title | default: 'Highlight' | escape }}</strong>
                      {% if block.settings.text != blank %}<small>{{ block.settings.text | escape }}</small>{% endif %}
                    </div>
                  </div>
                {% endfor %}
              </div>
            {% endif %}

            {% if enrollment_pack.subscription_plans and enrollment_pack.subscription_plans.size > 0 and section.settings.show_subscription_toggle %}
              {%- assign sub_plan = enrollment_pack.subscription_plans | first -%}
              {%- assign sub_save_pct = section.settings.subscription_savings_pct | default: 15 -%}
              <div class="ph__sub-toggle" data-ph-sub-toggle role="radiogroup" aria-label="Purchase type">
                <button type="button" class="ph__sub-option{% unless enrollment_pack.subscription_only %} is-active{% endunless %}" data-ph-sub-option="onetime" role="radio" aria-checked="{% unless enrollment_pack.subscription_only %}true{% else %}false{% endunless %}">
                  <span class="ph__sub-option-label">{{ section.settings.onetime_label | default: 'One-time purchase' | escape }}</span>
                  <span class="ph__sub-option-detail">{{ enrollment_pack.price }}</span>
                </button>
                <button type="button" class="ph__sub-option{% if enrollment_pack.subscription_only %} is-active{% endif %}" data-ph-sub-option="subscribe" role="radio" aria-checked="{% if enrollment_pack.subscription_only %}true{% else %}false{% endif %}">
                  <span class="ph__sub-option-label">
                    {{ section.settings.subscribe_label | default: 'Subscribe & save' | escape }}
                    <span class="ph__sub-option-saving">{{ sub_save_pct }}% off</span>
                  </span>
                  <span class="ph__sub-option-detail">{{ enrollment_pack.subscription_price | default: enrollment_pack.price }} · cancel anytime</span>
                </button>
              </div>
            {% endif %}

            {% if enrollment_pack.options_with_values and enrollment_pack.options_with_values.size > 0 %}
              <div class="ph__divider"></div>
              {% for option in enrollment_pack.options_with_values %}
                <div class="ph__variant-group">
                  <label class="ph__variant-label">
                    {{ option.name | escape }}
                    {% for v in option.values %}{% if v.selected %}<span class="ph__variant-selected">{{ v.name | escape }}</span>{% endif %}{% endfor %}
                  </label>
                  {% if section.settings.variant_style == 'pills' and option.values.size <= 8 %}
                    <div class="ph__variant-options">
                      {% for value in option.values %}
                        <label class="ph__variant-pill{% if value.selected %} is-active{% endif %}">
                          <input type="radio" name="fluid-checkout-option-{{ option.option_id }}" value="{{ value.id }}" {% if value.selected %}checked{% endif %} style="position:absolute;opacity:0;width:1px;height:1px;">
                          {{ value.name | escape }}
                        </label>
                      {% endfor %}
                    </div>
                  {% else %}
                    <select name="fluid-checkout-option-{{ option.option_id }}" class="ph__variant-select custom-select variation-dropdown">
                      {% for value in option.values %}
                        <option value="{{ value.id }}" {% if value.selected %}selected{% endif %}>{{ value.name | escape }}</option>
                      {% endfor %}
                    </select>
                  {% endif %}
                </div>
              {% endfor %}
            {% endif %}

            {% unless not_purchasable %}
              <button type="button" class="ph__cta" data-ph-cta
                data-fluid-add-enrollment-pack="{{ enrollment_pack.id }}"
                {% if enrollment_pack.subscription_only %}data-fluid-subscription-plan-id="{{ enrollment_pack.selected_subscription_plan_id }}"{% endif %}>
                {{ section.settings.cta_label | default: 'Start earning today' | escape }}
              </button>

              {% if section.settings.show_commission_callout %}
                <div class="ph__commission">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                  <span>{{ section.settings.commission_callout | default: 'Commission-eligible from day one' | escape }}</span>
                </div>
              {% endif %}

            {% else %}
              <div class="ph__sold-out">{{ section.settings.sold_out_label | default: 'Currently unavailable' | escape }}</div>
            {% endunless %}

            {%- assign trust_blocks = section.blocks | where: 'type', 'trust_item' -%}
            {% if trust_blocks.size > 0 %}
              <div class="ph__trust">
                {% for block in trust_blocks %}
                  <div class="ph__trust-item" {{ block.fluid_attributes }}>
                    {% case block.settings.icon %}
                      {% when 'check' %}
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                      {% when 'truck' %}
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                      {% when 'shield' %}
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                      {% when 'leaf' %}
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19.2 2.96c1.4 9.3-3.7 14.4-8.2 17.04Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6"/></svg>
                      {% when 'rotate' %}
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
                      {% else %}
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    {% endcase %}
                    <span>{{ block.settings.text | default: 'Free shipping' | escape }}</span>
                  </div>
                {% endfor %}
              </div>
            {% endif %}

            {%- assign acc_blocks = section.blocks | where: 'type', 'accordion_item' -%}
            {% if acc_blocks.size > 0 %}
              <div class="ph__accordion">
                {% for block in acc_blocks %}
                  <details class="ph__acc-item"{% if block.settings.open_by_default %} open{% endif %} {{ block.fluid_attributes }}>
                    <summary>{{ block.settings.title | default: 'Details' | escape }}</summary>
                    <div class="ph__acc-body rte">
                      {% if block.settings.use_product_description %}
                        {{ enrollment_pack.description }}
                      {% else %}
                        {{ block.settings.body }}
                      {% endif %}
                    </div>
                  </details>
                {% endfor %}
              </div>
            {% endif %}

          </div>
        </div>
      </div>

    </div>
  </div>
</section>

