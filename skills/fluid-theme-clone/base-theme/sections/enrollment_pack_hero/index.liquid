    {% if enrollment_pack.subscription_only %}data-fluid-subscription-plan-id="{{ enrollment_pack.selected_subscription_plan_id }}"{% endif %}>
    {{ section.settings.sticky_cta_label | default: 'Add' | escape }}
  </button>
</div>
{% endif %}

<script>
(function () {
  function init(root) {
    /* Grid tiles click to open lightbox at that image index */
    var tiles = root.querySelectorAll('[data-ph-tile]');
    var lightboxImg = root.querySelector('[data-ph-lightbox-img]');
    var lightboxCounter = root.querySelector('[data-ph-lightbox-counter]');
    var lightbox = root.querySelector('[data-ph-lightbox]');
    tiles.forEach(function (t, idx) {
      t.addEventListener('click', function () {
        var src = t.getAttribute('data-image-src');
        if (lightboxImg && src) lightboxImg.setAttribute('src', src);
        if (lightbox) lightbox.classList.add('is-open');
        if (lightboxCounter) lightboxCounter.textContent = (idx + 1) + ' / ' + tiles.length;
        lightbox && lightbox.setAttribute('data-ph-lightbox-index', String(idx));
      });
    });

    var addBtn = root.querySelector('[data-fluid-add-enrollment-pack]');

    /* Variant pill radios — toggle is-active on label */
    root.querySelectorAll('.ph__variant-pill input[type="radio"]').forEach(function (r) {
      r.addEventListener('change', function () {
        var name = r.name;
        root.querySelectorAll('input[type="radio"][name="' + name + '"]').forEach(function (x) {
          x.closest('.ph__variant-pill').classList.toggle('is-active', x.checked);
        });
      });
    });

    /* Subscription toggle */
    var subOptions = root.querySelectorAll('[data-ph-sub-option]');
    subOptions.forEach(function (b) {
      b.addEventListener('click', function () {
        subOptions.forEach(function (x) {
          x.classList.toggle('is-active', x === b);
          x.setAttribute('aria-checked', x === b ? 'true' : 'false');
        });
        var planAttr = b.getAttribute('data-ph-sub-option') === 'subscribe' ? '{{ enrollment_pack.selected_subscription_plan_id }}' : '';
        if (addBtn) {
          if (planAttr) addBtn.setAttribute('data-fluid-subscription-plan-id', planAttr);
          else addBtn.removeAttribute('data-fluid-subscription-plan-id');
        }
      });
    });

    /* Image lightbox — navigates through tile sources */
    if (lightbox) {
      var lbImg     = lightbox.querySelector('[data-ph-lightbox-img]');
      var lbCounter = lightbox.querySelector('[data-ph-lightbox-counter]');
      var lbClose   = lightbox.querySelector('[data-ph-lightbox-close]');
      var lbPrev    = lightbox.querySelector('[data-ph-lightbox-prev]');
      var lbNext    = lightbox.querySelector('[data-ph-lightbox-next]');
      var sources   = Array.prototype.map.call(tiles, function (t) { return t.getAttribute('data-image-src'); });
      var idx = 0;

      function show(i) {
        if (sources.length === 0) return;
        idx = (i + sources.length) % sources.length;
        if (lbImg) lbImg.setAttribute('src', sources[idx]);
        if (lbCounter) lbCounter.textContent = (idx + 1) + ' / ' + sources.length;
      }
      function close() {
        lightbox.classList.remove('is-open');
        lightbox.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      }
      tiles.forEach(function (t, i) {
        t.addEventListener('click', function () {
          idx = i;
          lightbox.setAttribute('aria-hidden', 'false');
          document.body.style.overflow = 'hidden';
        });
      });
      if (lbClose) lbClose.addEventListener('click', close);
      if (lbPrev) lbPrev.addEventListener('click', function () { show(idx - 1); });
      if (lbNext) lbNext.addEventListener('click', function () { show(idx + 1); });
      lightbox.addEventListener('click', function (e) { if (e.target === lightbox) close(); });
      document.addEventListener('keydown', function (e) {
        if (!lightbox.classList.contains('is-open')) return;
        if (e.key === 'Escape') close();
        else if (e.key === 'ArrowLeft')  show(idx - 1);
        else if (e.key === 'ArrowRight') show(idx + 1);
      });
    }

    /* Sticky bottom bar (mobile) — show after scrolling past hero */
    var stickyBar = document.querySelector('[data-ph-sticky-bar]');
    if (stickyBar) {
      var heroBottom = function () { return root.getBoundingClientRect().bottom; };
      function onScroll() {
        if (heroBottom() < 100) stickyBar.classList.add('is-visible');
        else stickyBar.classList.remove('is-visible');
      }
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }

  }
  function boot() {
    document.querySelectorAll('.section-{{ section.id }}').forEach(init);
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot);
  } else {
    boot();
  }
})();
</script>

