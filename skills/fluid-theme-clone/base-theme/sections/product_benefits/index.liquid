{%- style -%}
  .pb.section-{{ section.id }} {
    {%- assign p = section.settings.section_padding -%}
    {%- if p -%}padding: {{ p.top | default: 80 }}px {{ p.right | default: 0 }}px {{ p.bottom | default: 80 }}px {{ p.left | default: 0 }}px;{%- else -%}padding: 80px 0;{%- endif -%}
    {%- assign r = section.settings.section_border_radius -%}
    {%- if r -%}border-radius: {{ r.tl }}px {{ r.tr }}px {{ r.br }}px {{ r.bl }}px;{%- endif -%}
    {% if section.settings.section_border_width > 0 %}border: {{ section.settings.section_border_width }}px solid {{ section.settings.section_border_color }};{% endif %}
    background-color: {{ section.settings.background_color | default: 'transparent' }};
    {%- if section.settings.background_image != blank -%}background-image: url({{ section.settings.background_image | img_url: '2400x' }});background-size:cover;background-position:center;background-repeat:no-repeat;{%- endif -%}
  }
  .pb.section-{{ section.id }} .pb__container {
    position: relative;
    max-width: {{ section.settings.container_max_width | default: '1280px' }};
    margin: 0 auto;
    {%- assign cp = section.settings.container_padding -%}
    {%- if cp -%}padding: {{ cp.top | default: 0 }}px {{ cp.right | default: 64 }}px {{ cp.bottom | default: 0 }}px {{ cp.left | default: 64 }}px;{%- else -%}padding: 0 64px;{%- endif -%}
    background-color: {{ section.settings.container_background_color | default: 'transparent' }};
    {%- if section.settings.container_background_image != blank -%}background-image: url({{ section.settings.container_background_image | img_url: '2400x' }});background-size:cover;background-position:center;background-repeat:no-repeat;{%- endif -%}
    {%- assign ccr = section.settings.container_border_radius -%}
    {%- if ccr -%}border-radius: {{ ccr.tl }}px {{ ccr.tr }}px {{ ccr.br }}px {{ ccr.bl }}px;{%- endif -%}
    {% if section.settings.container_border_width > 0 %}border: {{ section.settings.container_border_width }}px solid {{ section.settings.container_border_color }};{% endif %}
  }
  {%- if section.settings.container_overlay_color != blank and section.settings.container_overlay_opacity > 0 -%}
    {%- assign _cov = section.settings.container_overlay_opacity | divided_by: 100.0 -%}
    .pb.section-{{ section.id }} .pb__container::before { content: ""; position: absolute; inset: 0; background: {{ section.settings.container_overlay_color }}; opacity: {{ _cov }}; pointer-events: none; }
  {%- endif -%}
  .pb.section-{{ section.id }} .pb__container > * { position: relative; }
  @media (max-width: 991px) { .pb.section-{{ section.id }} .pb__container { padding-left: 24px; padding-right: 24px; } }
  @media (max-width: 767px) { .pb.section-{{ section.id }} .pb__container { padding-left: 16px; padding-right: 16px; } }

  .pb.section-{{ section.id }} .pb__intro {
    text-align: {{ section.settings.intro_alignment | default: 'center' }};
    {%- if section.settings.intro_alignment == 'center' -%}margin: 0 auto 56px; max-width: 720px;{%- else -%}margin-bottom: 56px;{%- endif -%}
    display: flex; flex-direction: column; gap: 12px;
  }

  .pb.section-{{ section.id }} .pb__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop | default: 3 }}, minmax(0, 1fr));
    gap: {{ section.settings.gap | default: 32 }}px;
  }
  @media (max-width: 991px) { .pb.section-{{ section.id }} .pb__grid { grid-template-columns: repeat({{ section.settings.columns_tablet | default: 2 }}, minmax(0, 1fr)); } }
  @media (max-width: 767px) { .pb.section-{{ section.id }} .pb__grid { grid-template-columns: repeat({{ section.settings.columns_mobile | default: 1 }}, minmax(0, 1fr)); gap: 20px; } }

  .pb.section-{{ section.id }} .pb__card {
    display: flex; flex-direction: column;
    text-align: {{ section.settings.card_alignment | default: 'left' }};
    align-items: {% case section.settings.card_alignment %}{% when 'center' %}center{% when 'right' %}flex-end{% else %}flex-start{% endcase %};
    gap: 14px;
    padding: {{ section.settings.card_padding | default: 28 }}px;
    background: {{ section.settings.card_background | default: 'var(--clr-white)' }};
    border: 1px solid {{ section.settings.card_border | default: 'var(--clr-gray)' }};
    border-radius: {{ section.settings.card_radius | default: 16 }}px;
    transition: transform .2s, box-shadow .2s;
  }
  .pb.section-{{ section.id }} .pb__card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 30px -12px rgba(17, 24, 39, 0.12);
  }

  .pb.section-{{ section.id }} .pb__icon {
    width: {{ section.settings.icon_size | default: 56 }}px;
    height: {{ section.settings.icon_size | default: 56 }}px;
    border-radius: {{ section.settings.icon_radius | default: 14 }}px;
    background: {{ section.settings.icon_background | default: 'var(--clr-light)' }};
    color: {{ section.settings.icon_color | default: 'var(--clr-primary)' }};
    display: inline-flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .pb.section-{{ section.id }} .pb__icon svg {
    width: {{ section.settings.icon_size | default: 56 | times: 0.5 | round }}px;
    height: {{ section.settings.icon_size | default: 56 | times: 0.5 | round }}px;
  }
  .pb.section-{{ section.id }} .pb__title {
    font-size: {{ section.settings.title_font_size | default: 20 }}px;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: {{ section.settings.title_color | default: 'var(--clr-primary)' }};
    font-family: {{ section.settings.title_font | default: 'var(--ff-heading)' }};
    margin: 0;
  }
  .pb.section-{{ section.id }} .pb__text {
    font-size: {{ section.settings.text_font_size | default: 15 }}px;
    line-height: 1.6;
    color: {{ section.settings.text_color | default: 'var(--clr-body)' }};
    margin: 0;
  }
{%- endstyle -%}

{%- capture icon_svg -%}
{%- comment -%}Icon switch — place inside a case{%- endcomment -%}
{%- endcapture -%}

<section class="pb section-{{ section.id }}" {{ section.fluid_attributes }}>
  <div class="pb__container">
    {%- assign eyebrow_blocks = section.blocks | where: 'type', 'eyebrow' -%}
    {%- assign heading_blocks = section.blocks | where: 'type', 'heading' -%}
    {%- assign subhead_blocks = section.blocks | where: 'type', 'subhead' -%}
    {%- assign benefit_blocks = section.blocks | where: 'type', 'benefit' -%}

    {% if eyebrow_blocks.size > 0 or heading_blocks.size > 0 or subhead_blocks.size > 0 %}
      <div class="pb__intro">
        {% for block in eyebrow_blocks %}<div class="rte" {{ block.fluid_attributes }}>{{ block.settings.text }}</div>{% endfor %}
        {% for block in heading_blocks %}<div class="rte" {{ block.fluid_attributes }}>{{ block.settings.text }}</div>{% endfor %}
        {% for block in subhead_blocks %}<div class="rte" {{ block.fluid_attributes }}>{{ block.settings.text }}</div>{% endfor %}
      </div>
    {% endif %}

    {% if benefit_blocks.size > 0 %}
      <div class="pb__grid">
        {% for block in benefit_blocks %}
          <div class="pb__card" {{ block.fluid_attributes }}>
            <span class="pb__icon">
              {% case block.settings.icon %}
                {% when 'sparkle' %}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l1.9 5.8L20 11l-6.1 2.2L12 19l-1.9-5.8L4 11l6.1-2.2L12 3z"/></svg>
                {% when 'leaf' %}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19.2 2.96c1.4 9.3-3.7 14.4-8.2 17.04Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6"/></svg>
                {% when 'heart' %}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                {% when 'shield' %}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                {% when 'flame' %}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>
                {% when 'award' %}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
                {% when 'rocket' %}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>
                {% when 'droplet' %}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></svg>
                {% when 'sun' %}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
                {% when 'zap' %}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                {% else %}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {% endcase %}
            </span>
            <h3 class="pb__title">{{ block.settings.title | default: 'Benefit' | escape }}</h3>
            {% if block.settings.text != blank %}<p class="pb__text">{{ block.settings.text | escape }}</p>{% endif %}
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Product Benefits",
  "tag": "section",
  "class": "product-benefits-section",
  "settings": [
    { "type": "header", "content": "Layout" },
    { "type": "range",  "id": "columns_desktop", "label": "Columns (desktop)", "min": 2, "max": 4, "step": 1, "default": 3 },
    { "type": "range",  "id": "columns_tablet",  "label": "Columns (tablet)",  "min": 1, "max": 3, "step": 1, "default": 2 },
    { "type": "range",  "id": "columns_mobile",  "label": "Columns (mobile)",  "min": 1, "max": 2, "step": 1, "default": 1 },
    { "type": "range",  "id": "gap", "label": "Gap (px)", "min": 12, "max": 48, "step": 2, "default": 32 },
    { "type": "select", "id": "intro_alignment", "label": "Intro Alignment", "default": "center",
      "options": [ { "value": "left", "label": "Left" }, { "value": "center", "label": "Center" }, { "value": "right", "label": "Right" } ]
    },
    { "type": "radio",  "id": "card_alignment", "label": "Card alignment", "default": "left",
      "options": [ { "value": "left", "label": "Left" }, { "value": "center", "label": "Center" }, { "value": "right", "label": "Right" } ]
    },

    { "type": "header", "content": "Card" },
    { "type": "range",  "id": "card_padding", "label": "Card padding (px)", "min": 16, "max": 48, "step": 2, "default": 28 },
    { "type": "range",  "id": "card_radius",  "label": "Card radius (px)",  "min": 0,  "max": 32, "step": 2, "default": 16 },
    { "type": "select", "id": "card_background", "label": "Card background", "options": "background_colors", "default": "var(--clr-white)" },
    { "type": "select", "id": "card_border",     "label": "Card border",     "options": "background_colors", "default": "var(--clr-gray)" },

    { "type": "header", "content": "Icon" },
    { "type": "range",  "id": "icon_size",   "label": "Icon size (px)",   "min": 32, "max": 88, "step": 4, "default": 56 },
    { "type": "range",  "id": "icon_radius", "label": "Icon radius (px)", "min": 0,  "max": 44, "step": 2, "default": 14 },
    { "type": "select", "id": "icon_background", "label": "Icon background", "options": "background_colors", "default": "var(--clr-light)" },
    { "type": "select", "id": "icon_color",      "label": "Icon color",      "options": "background_colors", "default": "var(--clr-primary)" },

    { "type": "header", "content": "Typography" },
    { "type": "range",  "id": "title_font_size", "label": "Title font size (px)", "min": 14, "max": 28, "step": 1, "default": 20 },
    { "type": "range",  "id": "text_font_size",  "label": "Text font size (px)",  "min": 12, "max": 20, "step": 1, "default": 15 },
    { "type": "select", "id": "title_font",  "label": "Title font",  "options": "font_families",     "default": "var(--ff-heading)" },
    { "type": "select", "id": "title_color", "label": "Title color", "options": "background_colors", "default": "var(--clr-primary)" },
    { "type": "select", "id": "text_color",  "label": "Text color",  "options": "background_colors", "default": "var(--clr-body)" },

    { "type": "header", "content": "Container" },
    { "type": "select", "id": "container_max_width", "label": "Max Width", "default": "1280px",
      "options": [
        { "value": "1080px", "label": "Comfy (1080px)" },
        { "value": "1280px", "label": "Default (1280px)" },
        { "value": "1440px", "label": "Wide (1440px)" },
        { "value": "100%",   "label": "Full (100%)" }
      ]
    },
    { "type": "padding", "id": "container_padding", "label": "Container Padding" },
    { "type": "corner_radius", "id": "container_border_radius", "label": "Container Border Radius" },
    { "type": "select", "id": "container_background_color", "label": "Container Background Color", "options": "background_colors", "default": "transparent" },
    { "type": "image_picker", "id": "container_background_image", "label": "Container Background Image" },
    { "type": "select", "id": "container_overlay_color", "label": "Container Overlay Color", "options": "background_colors", "default": "transparent" },
    { "type": "range", "id": "container_overlay_opacity", "label": "Container Overlay Opacity", "min": 0, "max": 100, "step": 5, "default": 0, "unit": "%" },
    { "type": "range", "id": "container_border_width", "label": "Container Border Width", "min": 0, "max": 10, "step": 1, "default": 0, "unit": "px" },
    { "type": "select", "id": "container_border_color", "label": "Container Border Color", "options": "background_colors", "default": "var(--clr-primary)" },

    { "type": "header", "content": "Section Shell" },
    { "type": "padding", "id": "section_padding", "label": "Section Padding" },
    { "type": "corner_radius", "id": "section_border_radius", "label": "Section Border Radius" },
    { "type": "select", "id": "background_color", "label": "Background Color", "options": "background_colors", "default": "var(--clr-light)" },
    { "type": "image_picker", "id": "background_image", "label": "Background Image" },
    { "type": "range", "id": "section_border_width", "label": "Section Border Width", "min": 0, "max": 10, "step": 1, "default": 0, "unit": "px" },
    { "type": "select", "id": "section_border_color", "label": "Section Border Color", "options": "background_colors", "default": "var(--clr-primary)" }
  ],
  "blocks": [
    { "type": "eyebrow", "name": "Eyebrow",
      "settings": [ { "type": "richtext", "id": "text", "label": "Text", "default": "<h5 style=\"color: var(--clr-primary); text-transform: uppercase; letter-spacing: 0.08em;\">Why you'll love it</h5>" } ]
    },
    { "type": "heading", "name": "Heading",
      "settings": [ { "type": "richtext", "id": "text", "label": "Text", "default": "<h2 style=\"color: var(--clr-primary);\">Built for every day.</h2>" } ]
    },
    { "type": "subhead", "name": "Subhead",
      "settings": [ { "type": "richtext", "id": "text", "label": "Text", "default": "<p style=\"color: var(--clr-body); font-size: 17px;\">The little details that make all the difference.</p>" } ]
    },
    { "type": "benefit", "name": "Benefit Card",
      "settings": [
        { "type": "radio", "id": "icon", "label": "Icon", "default": "sparkle",
          "options": [
            { "value": "sparkle", "label": "Sparkle" },
            { "value": "leaf",    "label": "Leaf" },
            { "value": "heart",   "label": "Heart" },
            { "value": "shield",  "label": "Shield" },
            { "value": "flame",   "label": "Flame" },
            { "value": "award",   "label": "Award" },
            { "value": "rocket",  "label": "Rocket" },
            { "value": "droplet", "label": "Droplet" },
            { "value": "sun",     "label": "Sun" },
            { "value": "zap",     "label": "Zap" },
            { "value": "check",   "label": "Checkmark" }
          ]
        },
        { "type": "text", "id": "title", "label": "Title", "default": "Premium quality" },
        { "type": "text", "id": "text",  "label": "Text", "default": "Made from materials built to last, not just look good on day one." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Benefits",
      "blocks": [
        { "type": "eyebrow" },
        { "type": "heading" },
        { "type": "subhead" },
        { "type": "benefit", "settings": { "icon": "sparkle", "title": "Premium materials",  "text": "Sourced responsibly and built to last for years, not seasons." } },
        { "type": "benefit", "settings": { "icon": "heart",   "title": "Designed with care", "text": "Every detail refined based on feedback from thousands of customers." } },
        { "type": "benefit", "settings": { "icon": "leaf",    "title": "Better for the planet", "text": "Carbon-neutral shipping and recyclable packaging on every order." } },
        { "type": "benefit", "settings": { "icon": "shield",  "title": "Backed by our guarantee", "text": "30-day returns, no questions asked \u2014 and we stand behind it." } },
        { "type": "benefit", "settings": { "icon": "award",   "title": "Award-winning design", "text": "Featured in Wirecutter, Dezeen, and Fast Company's top picks." } },
        { "type": "benefit", "settings": { "icon": "rocket",  "title": "Fast, free delivery", "text": "Standard shipping is on us for all orders over $50." } }
      ]
    }
  ]
}
{% endschema %}
