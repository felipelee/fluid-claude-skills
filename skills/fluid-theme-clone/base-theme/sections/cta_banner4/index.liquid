{% assign bg_url = '' %}
{% assign bg_fluid_media_id = '' %}

{% if section.settings.background_image %}
  {% if section.settings.background_image.url %}
    {% comment %} It's an object with url property {% endcomment %}
    {% assign bg_url = section.settings.background_image.url %}
    {% comment %} Check if it also has fluid_media_id from media picker {% endcomment %}
    {% if section.settings.background_image.fluid_media_id %}
      {% assign bg_fluid_media_id = section.settings.background_image.fluid_media_id %}
      {% assign bg_embed_type = section.settings.background_image.embed_type %}
    {% endif %}
  {% else %}
    {% comment %} It's a string URL {% endcomment %}
    {% assign bg_url = section.settings.background_image %}
  {% endif %}
{% endif %}

{% comment %} Determine whether to use fluid widget - if fluid_media_id exists, use widget {% endcomment %}
{% assign use_fluid_widget = false %}

{% if bg_fluid_media_id != '' %}
  {% assign use_fluid_widget = true %}
{% endif %}
{%- style -%}
  .section-{{ section.id }} {
    {%- assign p = section.settings.section_padding -%}
    {%- if p -%}
      {%- capture pt -%}{{ p.top }}{%- endcapture -%}
      {%- capture pb -%}{{ p.bottom }}{%- endcapture -%}
      {%- capture pl -%}{{ p.left }}{%- endcapture -%}
      {%- capture pr -%}{{ p.right }}{%- endcapture -%}
      padding-top: {% if pt contains 'var(' %}{{ pt }}{% else %}{{ pt }}px{% endif %};
      padding-bottom: {% if pb contains 'var(' %}{{ pb }}{% else %}{{ pb }}px{% endif %};
      padding-left: {% if pl contains 'var(' %}{{ pl }}{% else %}{{ pl }}px{% endif %};
      padding-right: {% if pr contains 'var(' %}{{ pr }}{% else %}{{ pr }}px{% endif %};
    {%- endif -%}
    {%- assign sr = section.settings.section_border_radius -%}
    {%- if sr -%}
      {%- capture sr_tl -%}{{ sr.tl }}{%- endcapture -%}
      {%- capture sr_tr -%}{{ sr.tr }}{%- endcapture -%}
      {%- capture sr_br -%}{{ sr.br }}{%- endcapture -%}
      {%- capture sr_bl -%}{{ sr.bl }}{%- endcapture -%}
      border-radius: {% if sr_tl contains 'var(' %}{{ sr_tl }}{% else %}{{ sr_tl }}px{% endif %} {% if sr_tr contains 'var(' %}{{ sr_tr }}{% else %}{{ sr_tr }}px{% endif %} {% if sr_br contains 'var(' %}{{ sr_br }}{% else %}{{ sr_br }}px{% endif %} {% if sr_bl contains 'var(' %}{{ sr_bl }}{% else %}{{ sr_bl }}px{% endif %};
    {%- endif -%}
    {%- assign sb = section.settings.section_border -%}
    {%- if sb.width -%}
      border: {{ sb.width }} solid {{ sb.color }};
    {%- endif -%}
  }
{%- endstyle -%}
<section class="cta-banner4-section section-{{ section.id }}" 
         style="background-color: {{ section.settings.background_color | default: '#f8f8f8' }};
               
                background-image: url('{% unless use_fluid_widget %}{{ bg_url }}{% endunless %}');
                background-size: cover;
                background-position: center;
                background-repeat: no-repeat;">
               
  {% if use_fluid_widget %}
    <fluid-media-widget class="fluid-media-widget-background" media-id="{{ bg_fluid_media_id }}" responsive="true" embed-type="{{ bg_embed_type | default: 'inline' }}" data-fluid-widget="true"></fluid-media-widget>
  {% endif %}
  {%- assign ov = section.settings.overlay -%}
  {%- if ov and ov.enabled -%}
    <div class="overlay-{{ section.id }}"></div>
    {%- style -%}
      .overlay-{{ section.id }} {
        position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1;
        {%- if ov.mode == 'gradient' and ov.colors.size > 1 -%}
          background:
            {%- if ov.gradientType == 'radial' -%}
              radial-gradient(
            {%- else -%}
              linear-gradient({{ ov.angle }}deg,
            {%- endif -%}
            {%- for stop in ov.colors -%}
              {{ stop.color }} {{ stop.position }}%{%- unless forloop.last -%},{%- endunless -%}
            {%- endfor -%}
          );
          opacity: {{ ov.colors.first.opacity | divided_by: 100.0 }};
        {%- else -%}
          {%- assign c = ov.colors | first -%}
          background-color: {{ c.color }};
          opacity: {{ c.opacity | divided_by: 100.0 }};
        {%- endif -%}
      }
    {%- endstyle -%}
  {%- endif -%}

  
  <div class="container" style="position: relative; z-index: 2;">
    <div class="cta-banner4-card">
      <div class="cta-banner4-wrapper grid grid-cols-1 sm-desktop-grid-cols-2">
        
        <!-- Content Column (Left side - 50%) -->
        <div class="cta-banner4-content flex flex-col justify-center py-7xl px-4xl">
          {%- if section.blocks.size > 0 -%}
            {%- for block in section.blocks -%}
              {%- case block.type -%}
                {%- when 'heading' -%}
                  <div class="rte mb-lg" {{ block.fluid_attributes }}>{{ block.settings.text }}</div>
                {%- when 'text' -%}
                  <div class="rte mb-2xl" {{ block.fluid_attributes }}>{{ block.settings.content }}</div>
                {%- when 'buttons' -%}
                  <div class="cta-banner4-buttons flex space-lg flex-wrap" {{ block.fluid_attributes }}>
                    {% if block.settings.show_button_1 and block.settings.button_1_text != blank %}
                      {%- assign cr = block.settings.button_1_border_radius -%}
                      {%- assign _btn1_attr = '' -%}
                      {%- assign _btn1_size = block.settings.button_1_size | default: 'btn-md' -%}
                      {%- assign _btn1_fw = block.settings.button_1_font_weight | default: '600' -%}
                      {%- assign _btn1_w = block.settings.button_1_width -%}
                      {%- assign _btn1_h = block.settings.button_1_height -%}
                      {%- capture _btn1_extra_style -%}font-weight: {{ _btn1_fw }};{% if _btn1_w != blank %} width: {{ _btn1_w }}px;{% endif %}{% if _btn1_h != blank %} height: {{ _btn1_h }}px;{% endif %}{%- endcapture -%}
                      {%- if cr -%}
                        {%- capture cr_tl -%}{{ cr.tl }}{%- endcapture -%}{%- capture cr_tr -%}{{ cr.tr }}{%- endcapture -%}{%- capture cr_br -%}{{ cr.br }}{%- endcapture -%}{%- capture cr_bl -%}{{ cr.bl }}{%- endcapture -%}
                        {%- capture _br_val -%}{% if cr_tl contains 'var(' %}{{ cr_tl }}{% else %}{{ cr_tl }}px{% endif %} {% if cr_tr contains 'var(' %}{{ cr_tr }}{% else %}{{ cr_tr }}px{% endif %} {% if cr_br contains 'var(' %}{{ cr_br }}{% else %}{{ cr_br }}px{% endif %} {% if cr_bl contains 'var(' %}{{ cr_bl }}{% else %}{{ cr_bl }}px{% endif %}{%- endcapture -%}
                        {%- assign _btn1_attr = 'style="border-radius: ' | append: _br_val | append: ' ' | append: _btn1_extra_style | append: ';"' -%}
                      {%- else -%}
                        {%- assign _btn1_attr = 'style="' | append: _btn1_extra_style | append: ';"' -%}
                      {%- endif -%}
                      {% render 'button', href: block.settings.button_1_link | default: '#', text: block.settings.button_1_text, variant: block.settings.button_1_style | default: 'btn-bg-primary', class: _btn1_size, attr: _btn1_attr %}
                    {% endif %}
                    {% if block.settings.show_button_2 and block.settings.button_2_text != blank %}
                      {%- assign cr = block.settings.button_2_border_radius -%}
                      {%- assign _btn2_attr = '' -%}
                      {%- assign _btn2_size = block.settings.button_2_size | default: 'btn-md' -%}
                      {%- assign _btn2_fw = block.settings.button_2_font_weight | default: '600' -%}
                      {%- assign _btn2_w = block.settings.button_2_width -%}
                      {%- assign _btn2_h = block.settings.button_2_height -%}
                      {%- capture _btn2_extra_style -%}font-weight: {{ _btn2_fw }};{% if _btn2_w != blank %} width: {{ _btn2_w }}px;{% endif %}{% if _btn2_h != blank %} height: {{ _btn2_h }}px;{% endif %}{%- endcapture -%}
                      {%- if cr -%}
                        {%- capture cr_tl -%}{{ cr.tl }}{%- endcapture -%}{%- capture cr_tr -%}{{ cr.tr }}{%- endcapture -%}{%- capture cr_br -%}{{ cr.br }}{%- endcapture -%}{%- capture cr_bl -%}{{ cr.bl }}{%- endcapture -%}
                        {%- capture _br_val -%}{% if cr_tl contains 'var(' %}{{ cr_tl }}{% else %}{{ cr_tl }}px{% endif %} {% if cr_tr contains 'var(' %}{{ cr_tr }}{% else %}{{ cr_tr }}px{% endif %} {% if cr_br contains 'var(' %}{{ cr_br }}{% else %}{{ cr_br }}px{% endif %} {% if cr_bl contains 'var(' %}{{ cr_bl }}{% else %}{{ cr_bl }}px{% endif %}{%- endcapture -%}
                        {%- assign _btn2_attr = 'style="border-radius: ' | append: _br_val | append: ' ' | append: _btn2_extra_style | append: ';"' -%}
                      {%- else -%}
                        {%- assign _btn2_attr = 'style="' | append: _btn2_extra_style | append: ';"' -%}
                      {%- endif -%}
                      {% render 'button', href: block.settings.button_2_link | default: '#', text: block.settings.button_2_text, variant: block.settings.button_2_style | default: 'btn-border-white', class: _btn2_size, attr: _btn2_attr %}
                    {% endif %}
                  </div>
                {%- when 'link' -%}
                  {% if block.settings.text != blank %}
                    {% render 'link',
                      href: block.settings.url | default: '#',
                      text: block.settings.text,
                      underline: block.settings.underline_style,
                      icon_position: block.settings.icon_position,
                      color: block.settings.color,
                      font_weight: block.settings.font_weight,
                      attr: block.fluid_attributes
                    %}
                  {% endif %}
              {%- endcase -%}
            {%- endfor -%}
          {%- endif -%}
        </div>
        
        <!-- Image Column (Right side - 50%, goes to edges) -->
        <div class="cta-banner4-image">
          
            {% assign img_input = section.settings.cta_banner4_image  %}
            {% assign img_fluid_media_id = '' %}
            
            {% if img_input.fluid_media_id %}
              {% assign img_fluid_media_id = img_input.fluid_media_id %}
              {% assign img_embed_type = img_input.embed_type %}
            {% endif %}

            {% assign use_fluid_image_widget = false %}
            
            {% if img_fluid_media_id != blank %}
              {% assign use_fluid_image_widget = true %}
            {% endif %}

            {% if use_fluid_image_widget %}
              <fluid-media-widget class="fluid-media-widget-image" media-id="{{ img_fluid_media_id }}" responsive="true" embed-type="{{ img_embed_type | default:'inline' }}" data-fluid-widget="true"></fluid-media-widget>
            {% else %}
              {% if img_input != blank %}
                <div class="image-wrapper">
                  <img src="{{ img_input | image_url }}" alt="{{ block.settings.image_alt | default: section.settings.heading }}" class="image-cover w-full h-full" loading="lazy" width="" height=""/>
                </div>
              {% else %}
                <div class="image-placeholder">
                  <div class="placeholder-content text-center" style="color: #999;">
                    <svg width="48" height="48" fill="currentColor" viewBox="0 0 20 20" style="margin: 0 auto 12px;">
                      <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd"></path>
                    </svg>
                    <p style="margin: 0; font-size: 14px; font-weight: 500;">Upload an image</p>
                  </div>
                </div>
              {% endif %}
            {% endif %}
          </div>
        
      </div>
    </div>
  </div>
</section>

<style>
.cta-banner4-section {
  position: relative;
}

.cta-banner4-section .cta-banner4-card {
  border: 2px solid #000000;
  border-radius: 8px;
  background-color: #ffffff;
  max-width: 100%;
  margin: 0 auto;
  overflow: hidden;
}

.cta-banner4-section .cta-banner4-wrapper {
  min-height: 300px;
}

.cta-banner4-section .cta-banner4-content h2 {
  margin-bottom: 16px;
  line-height: 1.3;
}

.cta-banner4-section .cta-banner4-content p {
  margin-bottom: 24px;
  line-height: 1.6;
}

.cta-banner4-section .cta-banner4-buttons {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
}

.cta-banner4-section .cta-banner4-buttons .btn {
  padding: 12px 24px;
  text-decoration: none;
  border-radius: 4px;
  font-weight: 500;
  transition: all 0.3s ease;
  display: inline-block;
}

.cta-banner4-section .cta-banner4-buttons .btn:hover {
  opacity: 0.8;
}

.cta-banner4-section .cta-banner4-image {
  height: 100%;
  min-height: 300px;
}

.cta-banner4-section .image-wrapper {
  height: 100%;
  border-top-right-radius: 6px;
  border-bottom-right-radius: 6px;
  overflow: hidden;
}

.cta-banner4-section .image-wrapper img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.cta-banner4-section .image-placeholder {
  background-color: #e5e5e5;
  height: 100%;
  min-height: 300px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-top-right-radius: 6px;
  border-bottom-right-radius: 6px;
}

@media (max-width: 959px) {
  .cta-banner4-section .cta-banner4-wrapper {
    grid-template-columns: 1fr;
    min-height: auto;
  }
  
  .cta-banner4-section .cta-banner4-content {
    text-align: center;
    padding: 32px 24px;
  }
  
  .cta-banner4-section .cta-banner4-buttons {
    justify-content: center;
    flex-direction: column;
    align-items: center;
  }
  
  .cta-banner4-section .cta-banner4-buttons .btn {
    text-align: center;
    min-width: 200px;
  }
  
  .cta-banner4-section .cta-banner4-image {
    order: -1;
    min-height: 200px;
  }
  
  .cta-banner4-section .image-wrapper {
    border-radius: 0;
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
  }
  
  .cta-banner4-section .image-placeholder {
    border-radius: 0;
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
    min-height: 200px;
  }
}
</style>

