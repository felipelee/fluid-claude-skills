    {
      "type": "select",
      "id": "product_list_margin_top_mobile",
      "label": "Product List Margin Top",
      "options": [
        {
          "value": "mt-0",
          "label": "0"
        },
        {
          "value": "mt-xs",
          "label": "XS"
        },
        {
          "value": "mt-sm",
          "label": "SM"
        },
        {
          "value": "mt-md",
          "label": "MD"
        },
        {
          "value": "mt-lg",
          "label": "LG"
        },
        {
          "value": "mt-xl",
          "label": "XL"
        },
        {
          "value": "mt-2xl",
          "label": "2XL"
        },
        {
          "value": "mt-3xl",
          "label": "3XL"
        },
        {
          "value": "mt-4xl",
          "label": "4XL"
        },
        {
          "value": "mt-5xl",
          "label": "5XL"
        }
      ],
      "default": "mt-5xl"
    },
    {
      "type": "select",
      "id": "background_color",
      "label": "Background Color",
