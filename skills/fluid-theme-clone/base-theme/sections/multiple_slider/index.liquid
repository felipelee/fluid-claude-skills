        },
        {
          "type": "product_list",
          "id": "product_list",
          "label": "Product list",
          "limit": 24,
          "visible_if": "{{ block.settings.selection_mode == 'multiple' }}"
        },
        {
          "type": "select",
          "id": "product_title_tag",
          "label": "Product Title Tag",
          "options": [
            {
              "value": "h1",
              "label": "Heading 1"
            },
            {
              "value": "h2",
              "label": "Heading 2"
            },
            {
              "value": "h3",
              "label": "Heading 3"
            },
            {
              "value": "h4",
              "label": "Heading 4"
            },
            {
              "value": "h5",
              "label": "Heading 5"
            },
            {
              "value": "h6",
              "label": "Heading 6"
            }
          ],
          "default": "h6"
        },
        {
          "type": "select",
          "id": "product_price_tag",
          "label": "Product Price Tag",
          "options": [
            {
              "value": "h1",
              "label": "Heading 1"
            },
            {
              "value": "h2",
              "label": "Heading 2"
            },
            {
              "value": "h3",
              "label": "Heading 3"
            },
            {
              "value": "h4",
              "label": "Heading 4"
            },
            {
              "value": "h5",
              "label": "Heading 5"
            },
            {
              "value": "h6",
              "label": "Heading 6"
            }
          ],
          "default": "h5"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Multiple Slider",
      "blocks": [
        {
          "type": "tagline"
