      "label": "Section Border"
    }
  ],
  "blocks": [
    {
      "type": "tagline",
      "name": "Tagline",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "tagline",
          "label": "Tagline",
          "default": "<p>Tagline</p>"
        }
      ]
    },
    {
      "type": "heading",
      "name": "Section heading",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "heading",
          "label": "Heading",
          "default": "<h3 style=\"color: var(--clr-primary);\">Products</h3>"
