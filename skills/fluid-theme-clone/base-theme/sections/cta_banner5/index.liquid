{% comment %} Handle background_image - can be string URL or object with url/fluid_media_id {% endcomment %}
{% assign bg_url = '' %}
{% assign bg_fluid_media_id = '' %}

{% if section.settings.background_image %}
  {% if section.settings.background_image.url %}
    {% comment %} It's an object with url property {% endcomment %}
    {% assign bg_url = section.settings.background_image.url %}
    
    {% comment %} Check if it also has fluid_media_id from media picker {% endcomment %}
    {% if section.settings.background_image.fluid_media_id %}
      {% assign bg_fluid_media_id = section.settings.background_image.fluid_media_id %}
      {% assign bg_embed_type = section.settings.background_image.embed_type %}
    {% endif %}
  {% else %}
    {% comment %} It's a string URL {% endcomment %}
    {% assign bg_url = section.settings.background_image %}
  {% endif %}
{% endif %}

{% comment %} Determine whether to use fluid widget - if fluid_media_id exists, use widget {% endcomment %}
{% assign use_fluid_widget = false %}

{% if bg_fluid_media_id != blank %}
  {% assign use_fluid_widget = true %}
{% endif %}

{%- style -%}
  .section-{{ section.id }} {
    {%- assign p = section.settings.section_padding -%}
    {%- if p -%}
      {%- capture pt -%}{{ p.top }}{%- endcapture -%}
      {%- capture pb -%}{{ p.bottom }}{%- endcapture -%}
      {%- capture pl -%}{{ p.left }}{%- endcapture -%}
      {%- capture pr -%}{{ p.right }}{%- endcapture -%}
      padding-top: {% if pt contains 'var(' %}{{ pt }}{% else %}{{ pt }}px{% endif %};
      padding-bottom: {% if pb contains 'var(' %}{{ pb }}{% else %}{{ pb }}px{% endif %};
      padding-left: {% if pl contains 'var(' %}{{ pl }}{% else %}{{ pl }}px{% endif %};
      padding-right: {% if pr contains 'var(' %}{{ pr }}{% else %}{{ pr }}px{% endif %};
    {%- endif -%}
    {%- assign sr = section.settings.section_border_radius -%}
    {%- if sr -%}
      {%- capture sr_tl -%}{{ sr.tl }}{%- endcapture -%}
      {%- capture sr_tr -%}{{ sr.tr }}{%- endcapture -%}
      {%- capture sr_br -%}{{ sr.br }}{%- endcapture -%}
      {%- capture sr_bl -%}{{ sr.bl }}{%- endcapture -%}
      border-radius: {% if sr_tl contains 'var(' %}{{ sr_tl }}{% else %}{{ sr_tl }}px{% endif %} {% if sr_tr contains 'var(' %}{{ sr_tr }}{% else %}{{ sr_tr }}px{% endif %} {% if sr_br contains 'var(' %}{{ sr_br }}{% else %}{{ sr_br }}px{% endif %} {% if sr_bl contains 'var(' %}{{ sr_bl }}{% else %}{{ sr_bl }}px{% endif %};
    {%- endif -%}
    {%- assign sb = section.settings.section_border -%}
    {%- if sb.width -%}
      border: {{ sb.width }} solid {{ sb.color }};
    {%- endif -%}
  }
{%- endstyle -%}
<!-- Cta section -->
<section class="cta-section section-{{ section.id }}" data-bg="{% unless use_fluid_widget %}{{ bg_url }}{% endunless %}" style="background-color: {{ section.settings.background_color | default: '#444444' }};">
  {% if use_fluid_widget %}
    <fluid-media-widget class="fluid-media-widget-background" media-id="{{ bg_fluid_media_id }}" responsive="true" embed-type="{{ bg_embed_type | default:'inline' }}" data-fluid-widget="true"></fluid-media-widget>
  {% endif %}
  <div class="container">
    <div class="grid grid-cols-1 md-tab-grid-cols-2 {{ section.settings.content_gap_mobile | default: 'space-5xl' }} {{ section.settings.content_gap_desktop | default: 'lg:space-7xl' }}">
      {%- if section.blocks.size > 0 -%}
        {%- assign heading_block = null -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'heading' -%}
            {%- assign heading_block = block -%}
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}
        {%- if heading_block -%}
          <div class="cta-heading rte" {{ heading_block.fluid_attributes }}>{{ heading_block.settings.text }}</div>
        {%- endif -%}
        <div class="cta-content">
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'description' -%}
                <div class="cta-description rte leading-6 {{ section.settings.description_spacing_mobile | default: 'pt-lg' }} {{ section.settings.description_spacing_desktop | default: 'lg:pt-xl' }}" {{ block.fluid_attributes }}>{{ block.settings.text }}</div>
              {%- when 'form' -%}
                {% if block.settings.show_form %}
                  <form class="cta-signup flex-col xl-phone-flex-row flex {{ section.settings.content_spacing_mobile | default: 'mt-md' }} {{ section.settings.content_spacing_desktop | default: 'lg:mt-2xl' }} {{ section.settings.form_gap_mobile | default: 'space-md' }} {{ section.settings.form_gap_desktop | default: 'lg:space-md' }}" action="{{ block.settings.form_action | default: '#' }}" method="POST" {{ block.fluid_attributes }}>
                    <div class="flex-1">
                      <input type="email" name="email" placeholder="{{ block.settings.placeholder | default: 'Enter your email' }}" class="input-border-white" required />
                    </div>
                    {% render 'button', text: block.settings.button_text | default: 'sign up', variant: block.settings.button_style | default: 'btn-bg-white', type: 'submit' %}
                  </form>
                {% endif %}
              {%- when 'terms' -%}
                {% if block.settings.text != blank %}
                  <div class="cta-terms mt-md {{ block.settings.terms_font_size }} {{ block.settings.terms_font_weight }}" {{ block.fluid_attributes }}>
                    {{ block.settings.text }}
                    {% if block.settings.link_url != blank %}
                      <a href="{{ block.settings.link_url }}" class="underline">{{ block.settings.link_text | default: "Terms and Conditions" }}</a>.
                    {% endif %}
                  </div>
                {% endif %}
            {%- endcase -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

