{%- assign logo_block = section.blocks | where: 'type', 'logo' | first -%}
{%- assign nav_block = section.blocks | where: 'type', 'nav' | first -%}
{%- assign locale_block = section.blocks | where: 'type', 'locale_dropdown' | first -%}
{%- if locale_block == blank -%}
  {%- assign locale_block = section.blocks | where: 'type', 'locale' | first -%}
{%- endif -%}
{%- assign mobile_menu_block = section.blocks | where: 'type', 'mobile_menu' | first -%}
{%- assign has_custom_button_blocks = false -%}
{%- for block in section.blocks -%}
  {%- if block.type == 'cart_button' or block.type == 'secondary_button' or block.type == 'primary_button' -%}
    {%- assign has_custom_button_blocks = true -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}

{%- style -%}
  /* NAVBAR/HEADER */
  header.site-header.section-{{ section.id }} {
    {%- assign p = section.settings.section_padding -%}
    {%- if p -%}
      {%- capture pt -%}{{ p.top }}{%- endcapture -%}
      {%- capture pb -%}{{ p.bottom }}{%- endcapture -%}
      {%- capture pl -%}{{ p.left }}{%- endcapture -%}
      {%- capture pr -%}{{ p.right }}{%- endcapture -%}
      padding-top: {% if pt contains 'var(' %}{{ pt }}{% else %}{{ pt }}px{% endif %};
      padding-bottom: {% if pb contains 'var(' %}{{ pb }}{% else %}{{ pb }}px{% endif %};
      padding-left: {% if pl contains 'var(' %}{{ pl }}{% else %}{{ pl }}px{% endif %};
      padding-right: {% if pr contains 'var(' %}{{ pr }}{% else %}{{ pr }}px{% endif %};
    {%- endif -%}
    {%- assign sr = section.settings.section_border_radius -%}
    {%- if sr -%}
      {%- capture sr_tl -%}{{ sr.tl }}{%- endcapture -%}
      {%- capture sr_tr -%}{{ sr.tr }}{%- endcapture -%}
      {%- capture sr_br -%}{{ sr.br }}{%- endcapture -%}
      {%- capture sr_bl -%}{{ sr.bl }}{%- endcapture -%}
      border-radius: {% if sr_tl contains 'var(' %}{{ sr_tl }}{% else %}{{ sr_tl }}px{% endif %} {% if sr_tr contains 'var(' %}{{ sr_tr }}{% else %}{{ sr_tr }}px{% endif %} {% if sr_br contains 'var(' %}{{ sr_br }}{% else %}{{ sr_br }}px{% endif %} {% if sr_bl contains 'var(' %}{{ sr_bl }}{% else %}{{ sr_bl }}px{% endif %};
    {%- endif -%}
  }
  header.site-header:not(.is-floating) {
    background-color: {{ section.settings.navbar_bg_color }};
  }
  header.site-header.is-sticky {
    background-color: {{ section.settings.sticky_navbar_bg_color }};
    {%- assign b = section.settings.navbar_border -%}
    {%- if b -%}border-bottom: {{ b.width }} solid {{ b.color }} !important;{%- endif -%}
  }

  /* Navbar Text Color */
  {%- if section.settings.navbar_text_color != blank -%}
    .site-header:not(.is-floating),
    .site-header .primary-menu a,
    .site-header .primary-menu a:hover {
      color: {{ section.settings.navbar_text_color }};
    }
    .site-header .menu-toggle-button span {
      background-color: {{ section.settings.navbar_text_color }};
    }
  {%- endif -%}

  {%- if section.settings.sticky_navbar_text_color != blank -%}
    .site-header.is-sticky,
    .site-header.is-sticky .primary-menu a,
    .site-header.is-sticky .primary-menu a:hover,
    .media-header .author-content {
      color: {{ section.settings.sticky_navbar_text_color }};
    }
    .site-header.is-sticky .menu-toggle-button span {
      background-color: {{ section.settings.sticky_navbar_text_color }};
    }
  {%- endif -%}

  /* Navbar Font */
  header.site-header {
    font-size: {{ section.settings.navbar_text_size }}px;
    font-weight: {{ section.settings.navbar_font_weight }};
  }

  /* SUB MENU */
  {%- if nav_block -%}
    @media (min-width: 991px) {
      .site-header .primary-menu .menu-has-children .sub-menu {
        {%- assign sub_b = nav_block.settings.sub_menu_border -%}
        {%- if sub_b -%}border: {{ sub_b.width }} solid {{ sub_b.color }};{%- endif -%}
        {%- assign cr = nav_block.settings.sub_menu_border_radius -%}
        {%- if cr -%}
          {%- capture cr_tl -%}{{ cr.tl }}{%- endcapture -%}{%- capture cr_tr -%}{{ cr.tr }}{%- endcapture -%}{%- capture cr_br -%}{{ cr.br }}{%- endcapture -%}{%- capture cr_bl -%}{{ cr.bl }}{%- endcapture -%}
          border-radius: {% if cr_tl contains 'var(' %}{{ cr_tl }}{% else %}{{ cr_tl }}px{% endif %} {% if cr_tr contains 'var(' %}{{ cr_tr }}{% else %}{{ cr_tr }}px{% endif %} {% if cr_br contains 'var(' %}{{ cr_br }}{% else %}{{ cr_br }}px{% endif %} {% if cr_bl contains 'var(' %}{{ cr_bl }}{% else %}{{ cr_bl }}px{% endif %};
        {%- endif -%}
      }
      {%- if nav_block.settings.sub_menu_bg_color != blank -%}
        .site-header .primary-menu .menu-has-children .sub-menu {
          background-color: {{ nav_block.settings.sub_menu_bg_color }};
        }
      {%- endif -%}
      {%- if nav_block.settings.sub_menu_text_color != blank -%}
        .site-header .primary-menu .menu-has-children .sub-menu a {
          color: {{ nav_block.settings.sub_menu_text_color }};
        }
      {%- endif -%}
      .site-header .primary-menu .menu-has-children .sub-menu {
        font-size: {{ nav_block.settings.sub_menu_text_size }}px;
        font-weight: {{ nav_block.settings.sub_menu_font_weight }};
      }
    }
  {%- endif -%}

  /* Locale dropdown owns its own styles — see components/navbar_locale_dropdown/index.liquid */

  /* Cart button */
  .site-header .cart-btn {
    position: relative;
    display: inline-flex; align-items: center; justify-content: center;
    line-height: 1;
    transition: transform .15s, opacity .15s;
    cursor: pointer;
  }
  .site-header .cart-btn:hover { transform: translateY(-1px); }
  .site-header .cart-btn .cart-count {
    position: absolute;
    top: -4px; right: -4px;
    min-width: 18px; height: 18px;
    padding: 0 5px;
    border-radius: 999px;
    display: inline-flex; align-items: center; justify-content: center;
    font-weight: 700; line-height: 1;
    letter-spacing: 0;
  }
{%- endstyle -%}

{%- assign _btn2_label = 'navbar.button_2' | t -%}
{%- assign _btn1_label = 'navbar.button_1' | t -%}

{% capture feature_buttons %}
  {% if has_custom_button_blocks %}
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'cart_button' %}
          {%- assign _icon = block.settings.icon | default: 'bag' -%}
          {%- assign _icon_size = block.settings.icon_size | default: 20 -%}
          {%- assign _btn_style = block.settings.style | default: 'outline' -%}
          {% capture _cart_style %}
            color: {{ block.settings.icon_color | default: 'var(--clr-primary)' }};
            {% if _btn_style == 'filled' %}background-color: {{ block.settings.background_color | default: 'var(--clr-primary)' }};{% elsif _btn_style == 'outline' %}background-color: {{ block.settings.background_color | default: 'transparent' }};{% else %}background-color: transparent;{% endif %}
            {% assign cp = block.settings.padding %}{% if cp %}padding: {{ cp.top }}px {{ cp.right }}px {{ cp.bottom }}px {{ cp.left }}px;{% else %}padding: 8px 12px;{% endif %}
            {% assign cbr = block.settings.border_radius %}{% if cbr %}border-radius: {{ cbr.tl }}px {{ cbr.tr }}px {{ cbr.br }}px {{ cbr.bl }}px;{% else %}border-radius: 999px;{% endif %}
            {% if _btn_style == 'text' %}border: none;{% elsif block.settings.border_width > 0 %}border: {{ block.settings.border_width }}px solid {{ block.settings.border_color | default: 'var(--clr-primary)' }};{% else %}border: 1px solid {{ block.settings.border_color | default: 'var(--clr-primary)' }};{% endif %}
          {% endcapture %}
          <a href="{{ cart_url }}" id="show-cart" class="cart-btn" style="{{ _cart_style | strip_newlines }}" aria-label="Cart" {{ block.fluid_attributes }}>
            {% case _icon %}
              {% when 'bag' %}
                <svg xmlns="http://www.w3.org/2000/svg" width="{{ _icon_size }}" height="{{ _icon_size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
              {% when 'cart' %}
                <svg xmlns="http://www.w3.org/2000/svg" width="{{ _icon_size }}" height="{{ _icon_size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
              {% when 'basket' %}
                <svg xmlns="http://www.w3.org/2000/svg" width="{{ _icon_size }}" height="{{ _icon_size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m5 11 4-7"/><path d="m19 11-4-7"/><path d="M2 11h20"/><path d="m3.5 11 1.6 7.4a2 2 0 0 0 2 1.6h9.8a2 2 0 0 0 2-1.6l1.7-7.4"/><path d="M4.5 15.5h15"/></svg>
              {% when 'minimal' %}
                <svg xmlns="http://www.w3.org/2000/svg" width="{{ _icon_size }}" height="{{ _icon_size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 7h16l-1.5 13a2 2 0 0 1-2 1.7H7.5a2 2 0 0 1-2-1.7L4 7z"/><path d="M8 7a4 4 0 0 1 8 0"/></svg>
            {% endcase %}
            {% if block.settings.show_count %}
              {% capture _count_style %}
                background: {{ block.settings.count_background | default: 'var(--clr-accent)' }};
                color: {{ block.settings.count_text_color | default: 'var(--clr-white)' }};
                font-size: {{ block.settings.count_font_size | default: 11 }}px;
              {% endcapture %}
              <span class="cart-count" id="fluid-cart-count" style="{{ _count_style | strip_newlines }}">0</span>
            {% endif %}
          </a>
        {% when 'secondary_button' %}
          {% capture _sec_style %}
            {% if block.settings.background_color != blank %}background-color: {{ block.settings.background_color }};{% endif %}
            {% if block.settings.text_color != blank %}color: {{ block.settings.text_color }};{% endif %}
            {% if block.settings.font_size != blank %}font-size: {{ block.settings.font_size }}px;{% endif %}
            {% if block.settings.font_family != blank %}font-family: {{ block.settings.font_family }};{% endif %}
            {% assign p = block.settings.padding %}{% if p %}padding: {{ p.top }}px {{ p.right }}px {{ p.bottom }}px {{ p.left }}px;{% else %}padding: 8px 18px;{% endif %}
            {% assign br = block.settings.border_radius %}{% if br %}border-radius: {{ br.tl }}px {{ br.tr }}px {{ br.br }}px {{ br.bl }}px;{% else %}border-radius: 999px;{% endif %}
            {% if block.settings.border_width > 0 %}border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};{% else %}border: 1px solid {{ block.settings.border_color | default: 'var(--clr-primary)' }};{% endif %}
          {% endcapture %}
          <a href="{{ block.settings.link | default: '#' }}"
             class="btn btn--{{ block.settings.style | default: 'outline' }}"
             style="{{ _sec_style | strip_newlines }}"
             {% if block.settings.open_new_tab %}target="_blank" rel="noopener"{% endif %}
             {{ block.fluid_attributes }}>
            {{ block.settings.text | default: _btn2_label | escape }}
          </a>
        {% when 'primary_button' %}
          {% capture _pri_style %}
            {% if block.settings.background_color != blank %}background-color: {{ block.settings.background_color }};{% endif %}
            {% if block.settings.text_color != blank %}color: {{ block.settings.text_color }};{% endif %}
            {% if block.settings.font_size != blank %}font-size: {{ block.settings.font_size }}px;{% endif %}
            {% if block.settings.font_family != blank %}font-family: {{ block.settings.font_family }};{% endif %}
            {% assign p = block.settings.padding %}{% if p %}padding: {{ p.top }}px {{ p.right }}px {{ p.bottom }}px {{ p.left }}px;{% else %}padding: 8px 18px;{% endif %}
            {% assign br = block.settings.border_radius %}{% if br %}border-radius: {{ br.tl }}px {{ br.tr }}px {{ br.br }}px {{ br.bl }}px;{% else %}border-radius: 999px;{% endif %}
            {% if block.settings.border_width > 0 %}border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};{% endif %}
          {% endcapture %}
          <a href="{{ block.settings.link | default: '#' }}"
             class="btn btn--{{ block.settings.style | default: 'filled' }}"
             style="{{ _pri_style | strip_newlines }}"
             {% if block.settings.open_new_tab %}target="_blank" rel="noopener"{% endif %}
             {{ block.fluid_attributes }}>
            {{ block.settings.text | default: _btn1_label | escape }}
          </a>
      {% endcase %}
    {% endfor %}
  {% else %}
    {% render 'button', href: cart_url, text: _cart_inner, variant: 'outline-primary', class: 'button-with-border', attr: 'id="show-cart"' %}
    {% render 'button', href: '#', text: _btn2_label, variant: 'outline-primary', class: 'button-with-border' %}
    {% render 'button', href: '#', text: _btn1_label, variant: 'primary', class: 'button-with-bg' %}
  {% endif %}
{% endcapture %}

{% if request.page_type == 'medium' or request.page_type == 'library' %}
  {% assign header_class = "media-header is-sticky" %}
{% elsif request.page_type == 'home_page' or request.page_type == 'shop_page' or request.page_type == 'collection_page' or request.page_type == 'join_page' %}
  {% assign header_class = "is-floating" %}
{% else %}
  {% assign header_class = "" %}
{% endif %}

<div class='body-overlay' id='body-overlay'></div>
<div class="transparent-overlay" id="transparent-overlay"></div>

<header class="site-header section-{{ section.id }} {{ header_class }}" {{ section.fluid_attributes }}>
  <div class="container">
    <div class="site-header-wrap">
      {% if request.page_type == 'medium' or request.page_type == 'library' %}
        <div class="author-content-wrapper">
          <div class="author-content">
            <a href="{{ affiliate.my_site_url }}" class="author-profile">
              {% if affiliate.avatar != blank %}
                <img src="{{ affiliate.avatar }}" alt="logo" />
              {% elsif affiliate.initials != blank %}
                <div class="logo">{{ affiliate.initials }}</div>
              {% else %}
                <div class="author-placeholder h-full bg-gray"></div>
              {% endif %}
            </a>
            <div class="author-name">
              <h6>by {{ affiliate.name }}</h6>
              <a href="{{ affiliate.my_site_url }}">{{ 'navbar.view_my_site' | t }}</a>
            </div>
          </div>
          <a href="{{ company.home_page_url }}" class="site-logo" {% if logo_block %}{{ logo_block.fluid_attributes }}{% endif %}>
            {% if company.logo_url != blank %}
              <img src="{{ company.logo_url }}" alt="logo" />
            {% else %}
              <div class="logo">LOGO</div>
            {% endif %}
          </a>
        </div>
      {% else %}
        <a href="{{ company.home_page_url }}" class="site-logo" {% if logo_block %}{{ logo_block.fluid_attributes }}{% endif %}>
          {% if company.logo_url != blank %}
            <img src="{{ company.logo_url }}" alt="logo" />
          {% else %}
            <div class="logo">LOGO</div>
          {% endif %}
        </a>
      {% endif %}
      <div class="menu-toggle">
        <div class="menu-toggle-icon">
          <span></span>
          <span></span>
          <span></span>
        </div>
      </div>
      <div class="menu-wrapper">
        {% render 'navbar_primary_nav', section: section, block: nav_block %}
        <div class="header-right">
          {% render 'navbar_locale_dropdown', block: locale_block %}
          {{ feature_buttons }}
        </div>
      </div>
    </div>
  </div>
</header>

{% render 'navbar_mobile_menu', feature_buttons: feature_buttons, block: mobile_menu_block %}

<script src='https://code.jquery.com/jquery-3.7.1.min.js' integrity='sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=' crossorigin='anonymous'></script>
<script src='https://cdn.jsdelivr.net/npm/tom-select/dist/js/tom-select.complete.min.js'></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-cookie/1.4.1/jquery.cookie.min.js"></script>
<script src="{{ 'header.js' | asset_url }}"></script>

{% schema %}
{
  "name": "main_navbar",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "padding",
      "id": "section_padding",
      "label": "Section Padding"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color_background",
      "id": "navbar_bg_color",
      "label": "Navbar Background Color",
      "default": "#fff"
    },
    {
      "type": "color_background",
      "id": "sticky_navbar_bg_color",
      "label": "Sticky Navbar Background Color",
      "default": "#fff"
    },
    {
      "type": "range",
      "id": "navbar_border_width",
      "label": "Navbar Border Width",
      "min": 0,
      "max": 10,
      "step": 1,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "navbar_border_color",
      "label": "Navbar Border Color",
      "options": "background_colors",
      "default": "var(--clr-primary)"
    },
    {
      "type": "color_background",
      "id": "navbar_text_color",
      "label": "Navbar Text Color",
      "default": ""
    },
    {
      "type": "color_background",
      "id": "sticky_navbar_text_color",
      "label": "Sticky Navbar Text Color",
      "default": ""
    },
    {
      "type": "range",
      "id": "navbar_text_size",
      "min": 10,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Navbar Font Size",
      "default": 14
    },
    {
      "type": "select",
      "id": "navbar_font_weight",
      "label": "Navbar Font Weight",
      "options": [
        {
          "value": "300",
          "label": "Light"
        },
        {
          "value": "400",
          "label": "Regular"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi Bold"
        },
        {
          "value": "700",
          "label": "Bold"
        },
        {
          "value": "800",
          "label": "Extra Bold"
        }
      ],
      "default": "400"
    },
    {
      "type": "corner_radius",
      "id": "section_border_radius",
      "label": "Section Border Radius",
      "info": "Default 0px. Four corners, link/unlink."
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "limit": 1,
      "settings": []
    },
    {
      "type": "nav",
      "name": "Navigation",
      "limit": 1,
      "settings": [
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "default": "main-menu"
        },
        {
          "type": "header",
          "content": "Sub Menu"
        },
        {
          "type": "color_background",
          "id": "sub_menu_bg_color",
          "label": "Background Color",
          "default": ""
        },
        {
          "type": "range",
          "id": "sub_menu_border_width",
          "label": "Sub Menu Border Width",
          "min": 0,
          "max": 10,
          "step": 1,
          "default": 0,
          "unit": "px"
        },
        {
          "type": "select",
          "id": "sub_menu_border_color",
          "label": "Sub Menu Border Color",
          "options": "background_colors",
          "default": "var(--clr-primary)"
        },
        {
          "type": "corner_radius",
          "id": "sub_menu_border_radius",
          "label": "Border Radius"
        },
        {
          "type": "color_background",
          "id": "sub_menu_text_color",
          "label": "Text Color",
          "default": ""
        },
        {
          "type": "range",
          "id": "sub_menu_text_size",
          "min": 10,
          "max": 30,
          "step": 2,
          "unit": "px",
          "label": "Font Size",
          "default": 14
        },
        {
          "type": "select",
          "id": "sub_menu_font_weight",
          "label": "Font Weight",
          "options": [
            {
              "value": "300",
              "label": "Light"
            },
            {
              "value": "400",
              "label": "Regular"
            },
            {
              "value": "500",
              "label": "Medium"
            },
            {
              "value": "600",
              "label": "Semi Bold"
            },
            {
              "value": "700",
              "label": "Bold"
            },
            {
              "value": "800",
              "label": "Extra Bold"
            }
          ],
          "default": "300"
        }
      ]
    },
    {
      "type": "locale_dropdown",
      "name": "Locale Dropdown",
      "limit": 1,
      "settings": [
        { "type": "header", "content": "Trigger" },
        { "type": "select", "id": "display_mode", "label": "Trigger display", "default": "flag_code",
          "options": [
            { "value": "flag_code", "label": "Flag + country code" },
            { "value": "flag_only", "label": "Flag only" },
            { "value": "code_only", "label": "Country code only" },
            { "value": "flag_name", "label": "Flag + country name" }
          ]
        },
        { "type": "checkbox", "id": "show_language",  "label": "Show language code", "default": true },
        { "type": "checkbox", "id": "show_separator", "label": "Show separator between country and language", "default": true },
        { "type": "checkbox", "id": "show_arrow",     "label": "Show dropdown arrow", "default": true },
        { "type": "range",    "id": "trigger_font_size",    "label": "Font size (px)",     "min": 11, "max": 18, "step": 1, "default": 13 },
        { "type": "range",    "id": "trigger_border_width", "label": "Border width (px)",  "min": 0,  "max": 3,  "step": 1, "default": 1 },
        { "type": "range",    "id": "trigger_radius",       "label": "Corner radius (px)", "min": 0,  "max": 999,"step": 1, "default": 999 },
        { "type": "select",   "id": "trigger_color",         "label": "Text color",         "options": "background_colors", "default": "var(--clr-body)" },
        { "type": "select",   "id": "trigger_border_color",  "label": "Border color",       "options": "background_colors", "default": "var(--clr-gray)" },
        { "type": "select",   "id": "separator_color",       "label": "Separator color",    "options": "background_colors", "default": "var(--clr-gray)" },

        { "type": "header", "content": "Dropdown Panel" },
        { "type": "text",   "id": "header_label",  "label": "Mobile header label", "default": "Country & language" },
        { "type": "text",   "id": "save_label",    "label": "Save button label",   "default": "Save & close" },
        { "type": "range",  "id": "panel_width",   "label": "Panel width (desktop px)", "min": 240, "max": 420, "step": 10, "default": 320 },
