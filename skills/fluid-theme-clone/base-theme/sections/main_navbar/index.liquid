    { "type": "select", "id": "text_color",       "label": "Text / icons",  "options": "background_colors", "default": "var(--clr-primary)" },
    { "type": "select", "id": "link_color",       "label": "Nav link color","options": "background_colors", "default": "var(--clr-primary)" },
