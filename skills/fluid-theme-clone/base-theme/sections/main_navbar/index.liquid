{% schema %}
{
  "name": "main_navbar",
  "settings": [
    { "type": "header", "content": "Behavior" },
    { "type": "checkbox", "id": "sticky",            "label": "Stick to top on scroll", "default": true },
    { "type": "checkbox", "id": "scrolled_shadow",   "label": "Add shadow when scrolled", "default": true },
    { "type": "select",   "id": "scrolled_background","label": "Scrolled background",
      "options": "background_colors", "default": "transparent",
      "info": "Background the navbar switches to once the user scrolls past the top. Leave on 'transparent' to keep the idle background." },
    { "type": "checkbox", "id": "bottom_border",     "label": "Show bottom border at rest", "default": true },

    { "type": "header", "content": "Layout" },
    { "type": "select", "id": "container_max_width", "label": "Container max width", "default": "1440px",
      "options": [
        { "value": "1080px", "label": "Comfy (1080px)" },
        { "value": "1280px", "label": "Default (1280px)" },
        { "value": "1440px", "label": "Wide (1440px)" },
        { "value": "1600px", "label": "Extra wide (1600px)" },
        { "value": "100%",   "label": "Full width" }
      ]
    },
    { "type": "range", "id": "container_vertical_padding",   "label": "Vertical padding (px)",   "min": 6,  "max": 40, "step": 2, "default": 16 },
    { "type": "range", "id": "container_horizontal_padding", "label": "Horizontal padding (px)", "min": 12, "max": 80, "step": 4, "default": 32 },
    { "type": "range", "id": "column_gap",                   "label": "Column gap (px)",         "min": 12, "max": 64, "step": 4, "default": 32 },
    { "type": "range", "id": "link_gap",                     "label": "Link spacing (px)",        "min": 12, "max": 48, "step": 2, "default": 28 },
    { "type": "range", "id": "logo_max_height",              "label": "Logo max height (px)",     "min": 20, "max": 96, "step": 2, "default": 48 },
    { "type": "range", "id": "logo_min_width",               "label": "Logo min width (px)",      "min": 60, "max": 240, "step": 10, "default": 120,
      "info": "Reserves a clickable area even when the logo is empty \u2014 keeps the slot selectable in the editor." },
    { "type": "select", "id": "nav_alignment", "label": "Nav alignment", "default": "flex-start",
      "options": [
