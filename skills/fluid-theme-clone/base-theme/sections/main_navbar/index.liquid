    { "type": "select", "id": "secondary_btn_border",   "label": "Secondary button border", "options": "background_colors", "default": "var(--clr-primary)" },
    { "type": "select", "id": "primary_btn_background", "label": "Primary button background", "options": "background_colors", "default": "var(--clr-primary)" },
    { "type": "select", "id": "primary_btn_color",      "label": "Primary button text",     "options": "background_colors", "default": "var(--clr-white)" },

    { "type": "header", "content": "Container" },
    { "type": "padding",       "id": "container_padding",       "label": "Container padding" },
