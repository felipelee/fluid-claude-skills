{% comment %}
  sections/enrollment_pack_list/index.liquid

  Enrollment pack product listing page with block-driven structure.
  Blocks:
    section_header → tagline, heading, description + their typography settings
    product_list   → grid spacing, product content spacing, product title/price typography
{% endcomment %}

{% comment %} ── Defaults ──────────────────────────────────────────────────── {% endcomment %}
{%- assign tagline_text                    = '<p>Our Collection</p>' -%}

{%- assign heading_text                    = '<p>Enrollments</p>' -%}
{%- assign heading_spacing_mobile          = 'py-md' -%}
{%- assign heading_spacing_desktop         = 'lg:py-lg' -%}

{%- assign description_text                = '<p>Discover our handpicked selection of premium enrollment products that combine quality, style, and functionality.</p>' -%}

{%- assign product_list_spacing_mobile     = 'mt-5xl' -%}
{%- assign product_list_spacing_desktop    = 'lg:mt-7xl' -%}
{%- assign grid_gap_x_mobile               = 'space-x-4xl' -%}
{%- assign grid_gap_x_desktop              = 'lg:space-x-7xl' -%}
{%- assign grid_gap_y_mobile               = 'space-y-7xl' -%}
{%- assign grid_gap_y_desktop              = 'lg:space-y-9xl' -%}
{%- assign product_content_spacing_mobile  = 'pt-lg' -%}
{%- assign product_content_spacing_desktop = 'lg:pt-lg' -%}

{%- assign product_title_font_size         = 'text-base' -%}
{%- assign product_title_font_size_desktop = 'lg:text-lg' -%}
{%- assign product_title_font_weight       = 'font-semibold' -%}
{%- assign product_title_color             = '' -%}

{%- assign product_price_font_size         = 'text-base' -%}
{%- assign product_price_font_size_desktop = 'lg:text-xl' -%}
{%- assign product_price_font_weight       = 'font-normal' -%}
{%- assign product_price_color             = '' -%}

{% comment %} ── Extract block settings ───────────────────────────────────── {% endcomment %}
{%- for block in section.blocks -%}
  {%- if block.type == 'section_header' -%}
    {%- assign section_header_block          = block -%}
    {%- if block.settings.tagline != blank -%}{%- assign tagline_text = block.settings.tagline -%}{%- endif -%}

    {%- if block.settings.heading != blank -%}{%- assign heading_text = block.settings.heading -%}{%- endif -%}
    {%- assign heading_spacing_mobile        = block.settings.heading_spacing_mobile | default: 'py-md' -%}
    {%- assign heading_spacing_desktop       = block.settings.heading_spacing_desktop | default: 'lg:py-lg' -%}

    {%- if block.settings.description != blank -%}{%- assign description_text = block.settings.description -%}{%- endif -%}

  {%- elsif block.type == 'product_list' -%}
    {%- assign product_list_block              = block -%}
    {%- assign product_list_spacing_mobile     = block.settings.product_list_spacing_mobile | default: 'mt-5xl' -%}
    {%- assign product_list_spacing_desktop    = block.settings.product_list_spacing_desktop | default: 'lg:mt-7xl' -%}
    {%- assign grid_gap_x_mobile               = block.settings.grid_gap_x_mobile | default: 'space-x-4xl' -%}
    {%- assign grid_gap_x_desktop              = block.settings.grid_gap_x_desktop | default: 'lg:space-x-7xl' -%}
    {%- assign grid_gap_y_mobile               = block.settings.grid_gap_y_mobile | default: 'space-y-7xl' -%}
    {%- assign grid_gap_y_desktop              = block.settings.grid_gap_y_desktop | default: 'lg:space-y-9xl' -%}
    {%- assign product_content_spacing_mobile  = block.settings.product_content_spacing_mobile | default: 'pt-lg' -%}
    {%- assign product_content_spacing_desktop = block.settings.product_content_spacing_desktop | default: 'lg:pt-lg' -%}

    {%- assign product_title_font_size         = block.settings.product_title_font_size | default: 'text-base' -%}
    {%- assign product_title_font_size_desktop = block.settings.product_title_font_size_desktop | default: 'lg:text-lg' -%}
    {%- assign product_title_font_weight       = block.settings.product_title_font_weight | default: 'font-semibold' -%}
    {%- assign product_title_color             = block.settings.product_title_color | default: '' -%}

    {%- assign product_price_font_size         = block.settings.product_price_font_size | default: 'text-base' -%}
    {%- assign product_price_font_size_desktop = block.settings.product_price_font_size_desktop | default: 'lg:text-xl' -%}
    {%- assign product_price_font_weight       = block.settings.product_price_font_weight | default: 'font-normal' -%}
    {%- assign product_price_color             = block.settings.product_price_color | default: '' -%}
  {%- endif -%}
{%- endfor -%}

{%- style -%}
  .section-{{ section.id }} {
    {%- assign p = section.settings.section_padding -%}
    {%- if p -%}
      {%- capture pt -%}{{ p.top }}{%- endcapture -%}
      {%- capture pb -%}{{ p.bottom }}{%- endcapture -%}
      {%- capture pl -%}{{ p.left }}{%- endcapture -%}
      {%- capture pr -%}{{ p.right }}{%- endcapture -%}
      padding-top: {% if pt contains 'var(' %}{{ pt }}{% else %}{{ pt }}px{% endif %};
      padding-bottom: {% if pb contains 'var(' %}{{ pb }}{% else %}{{ pb }}px{% endif %};
      padding-left: {% if pl contains 'var(' %}{{ pl }}{% else %}{{ pl }}px{% endif %};
      padding-right: {% if pr contains 'var(' %}{{ pr }}{% else %}{{ pr }}px{% endif %};
    {%- endif -%}
    {%- assign sr = section.settings.section_border_radius -%}
    {%- if sr -%}
      {%- capture sr_tl -%}{{ sr.tl }}{%- endcapture -%}
      {%- capture sr_tr -%}{{ sr.tr }}{%- endcapture -%}
      {%- capture sr_br -%}{{ sr.br }}{%- endcapture -%}
      {%- capture sr_bl -%}{{ sr.bl }}{%- endcapture -%}
      border-radius: {% if sr_tl contains 'var(' %}{{ sr_tl }}{% else %}{{ sr_tl }}px{% endif %} {% if sr_tr contains 'var(' %}{{ sr_tr }}{% else %}{{ sr_tr }}px{% endif %} {% if sr_br contains 'var(' %}{{ sr_br }}{% else %}{{ sr_br }}px{% endif %} {% if sr_bl contains 'var(' %}{{ sr_bl }}{% else %}{{ sr_bl }}px{% endif %};
    {%- endif -%}
  }

  {% if product_list_block and product_title_color != blank %}
  .section-{{ section.id }} .product-title {
    color: {{ product_title_color }};
  }
  {% endif %}

  {% if product_list_block and product_price_color != blank %}
  .section-{{ section.id }} .product-price {
    color: {{ product_price_color }};
  }
  {% endif %}
{%- endstyle -%}

<section class="product-collection-section section-{{ section.id }}" style="background-color: {{ section.settings.background_color | default: '#ffffff' }};">
  <div class="container">
    {%- if section_header_block -%}
      <div class="header-section" {{ section_header_block.fluid_attributes }}>
        <div class="wrapper lg:flex flex-wrap align-end">
          <div class="desc">
            {% if tagline_text != blank %}
              <div class="section-tagline rte">
                {{ tagline_text }}
              </div>
            {% endif %}

            <div class="section-heading rte {{ heading_spacing_mobile }} {{ heading_spacing_desktop }}">
              {{ heading_text }}
            </div>

            {% if description_text != blank %}
              <div class="section-description rte">
                {{ description_text }}
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    {%- endif -%}

    {%- paginate collection.enrollment_packs by 10 -%}
      {%- if product_list_block -%}
        <div class="product-list-section {{ product_list_spacing_mobile }} {{ product_list_spacing_desktop }}" {{ product_list_block.fluid_attributes }}>
          <ul class="grid grid-cols-1 xl-phone-grid-cols-2 lg-tab-grid-cols-3 {{ grid_gap_x_mobile }} {{ grid_gap_x_desktop }} {{ grid_gap_y_mobile }} {{ grid_gap_y_desktop }}">
            {% assign enrollment_packs_array = collection.enrollment_packs | parse_json %}
            {% for enrollment_pack in enrollment_packs_array %}
              {% if enrollment_pack.images_array.size > 0 %}
                {% assign image_url = enrollment_pack.images_array[0] %}
              {% elsif enrollment_pack.subscription_products and enrollment_pack.subscription_products[0].image %}
                {% assign image_url = enrollment_pack.subscription_products[0].image %}
              {% else %}
                {% assign image_url = '' %}
              {% endif %}

              <li>
                <a href="{{ enrollment_pack.url }}" class="product">
                  <div class="image-section product-image-height image-hover-effect">
                    <img
                      src="{{ image_url }}"
                      alt="{{ enrollment_pack.title }}"
                      class="image-cover"
                    />
                  </div>
                  <div class="desc {{ product_content_spacing_mobile }} {{ product_content_spacing_desktop }}">
                    <div class="product-title text-hover-effect {{ product_title_font_size }} {{ product_title_font_size_desktop }} {{ product_title_font_weight }}">
                      {{ enrollment_pack.title }}
                    </div>
                    <div class="product-price {{ product_price_font_size }} {{ product_price_font_size_desktop }} {{ product_price_font_weight }} pt-md">
                      {{ enrollment_pack.price }}
                    </div>
                  </div>
                </a>
              </li>
            {% endfor %}
          </ul>
        </div>
      {%- endif -%}
      {%- if paginate.pages > 1 -%}
        {% render 'pagination', paginate: paginate, anchor: '' %}
      {%- endif -%}
    {% endpaginate %}
  </div>
</section>

