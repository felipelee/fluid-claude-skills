{%- assign breadcrumb_block = section.blocks | where: 'type', 'breadcrumb' | first -%}
{%- assign membership_packs_block = section.blocks | where: 'type', 'membership_packs' | first -%}
{%- assign subscription_packs_block = section.blocks | where: 'type', 'subscription_packs' | first -%}
{%- style -%}

  {% if breadcrumb_block and breadcrumb_block.settings.color != blank %}
  .enrollment-pack-section-{{ section.id }} .breadcrumb {
    color: {{ breadcrumb_block.settings.color }};
  }
  {% endif %}

  {% if breadcrumb_block and breadcrumb_block.settings.active_color != blank %}
  .enrollment-pack-section-{{ section.id }} .breadcrumb .active {
    color: {{ breadcrumb_block.settings.active_color }};
  }
  {% endif %}

  {% if section.settings.product_title_color != blank %}
  .enrollment-pack-{{ section.id }} .product-title {
    color: {{ section.settings.product_title_color }};
  }
  {% endif %}

  {% if section.settings.product_price_color != blank %}
  .enrollment-pack-{{ section.id }} .product-price {
    color: {{ section.settings.product_price_color }};
  }
  {% endif %}

  {% if subscription_packs_block and subscription_packs_block.settings.info_text_color != blank %}
  .enrollment-pack-{{ section.id }} .enrollment-pack .desc .info {
    color: {{ subscription_packs_block.settings.info_text_color }};
  }
  {% endif %}

  {% if subscription_packs_block and subscription_packs_block.settings.learn_more_color != blank %}
  .enrollment-pack-{{ section.id }} .enrollment-pack .desc .learn-more-section a {
    color: {{ subscription_packs_block.settings.learn_more_color }};
  }
  {% endif %}

  {%- if subscription_packs_block -%}
  .enrollment-pack-{{ section.id }} .subscription-product {
    background-color: var(--{{ subscription_packs_block.settings.background_color | default: 'clr-white' }});
    {%- assign b = subscription_packs_block.settings.border -%}
    {%- if b -%}border: {{ b.width }} solid {{ b.color }};{%- endif -%}
  }
  {%- endif -%}
  /* Membership Product */
  {%- if membership_packs_block -%}
  .enrollment-pack-{{ section.id }} .membership-product {
    background-color: var(--{{ membership_packs_block.settings.background_color | default: 'clr-white' }});
    {%- assign b = membership_packs_block.settings.border -%}
    {%- if b -%}border: {{ b.width }} solid {{ b.color }};{%- endif -%}
  }
  {%- endif -%}

{%- assign p = section.settings.section_padding -%}
  {%- if p -%}
    .section-{{ section.id }} {
      {%- capture pt -%}{{ p.top }}{%- endcapture -%}
      {%- capture pb -%}{{ p.bottom }}{%- endcapture -%}
      {%- capture pl -%}{{ p.left }}{%- endcapture -%}
      {%- capture pr -%}{{ p.right }}{%- endcapture -%}
      padding-top: {% if pt contains 'var(' %}{{ pt }}{% else %}{{ pt }}px{% endif %};
      padding-bottom: {% if pb contains 'var(' %}{{ pb }}{% else %}{{ pb }}px{% endif %};
      padding-left: {% if pl contains 'var(' %}{{ pl }}{% else %}{{ pl }}px{% endif %};
      padding-right: {% if pr contains 'var(' %}{{ pr }}{% else %}{{ pr }}px{% endif %};
    }
  {%- endif -%}
  .section-{{ section.id }} {
    {%- assign sr = section.settings.section_border_radius -%}
    {%- if sr -%}
      {%- capture sr_tl -%}{{ sr.tl }}{%- endcapture -%}
      {%- capture sr_tr -%}{{ sr.tr }}{%- endcapture -%}
      {%- capture sr_br -%}{{ sr.br }}{%- endcapture -%}
      {%- capture sr_bl -%}{{ sr.bl }}{%- endcapture -%}
      border-radius: {% if sr_tl contains 'var(' %}{{ sr_tl }}{% else %}{{ sr_tl }}px{% endif %} {% if sr_tr contains 'var(' %}{{ sr_tr }}{% else %}{{ sr_tr }}px{% endif %} {% if sr_br contains 'var(' %}{{ sr_br }}{% else %}{{ sr_br }}px{% endif %} {% if sr_bl contains 'var(' %}{{ sr_bl }}{% else %}{{ sr_bl }}px{% endif %};
    {%- endif -%}
  }
{%- endstyle -%}
<main class="enrollment-page-section content-min-height enrollment-pack-section-{{ section.id }} section-{{ section.id }}" style="background-color: {{ section.settings.background_color | default: '#ffffff' }};">
  {% if breadcrumb_block %}
  <div class="breadcrumb {{ breadcrumb_block.settings.font_size | default: 'text-sm' }}" {{ breadcrumb_block.fluid_attributes }}>
      <div class="container">
        <ul class="flex flex-wrap align-center space-sm leading-none">
          <li class="flex space-sm align-center">
            <a href="{{ company.join_page_url }}">{{ 'enrollment_pack.all_products' | t }}</a>
              <span class="seperator">
                  <svg width="9" height="16" viewBox="0 0 9 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M8.56641 7.70703C8.88281 8.05859 8.88281 8.58594 8.56641 8.90234L1.81641 15.6523C1.46484 16.0039 0.9375 16.0039 0.621094 15.6523C0.269531 15.3359 0.269531 14.8086 0.621094 14.4922L6.77344 8.33984L0.621094 2.15234C0.269531 1.83594 0.269531 1.30859 0.621094 0.992188C0.9375 0.640625 1.46484 0.640625 1.78125 0.992188L8.56641 7.70703Z" fill="currentColor"/>
                  </svg>
              </span>
          </li>
          <li>
            <a href="#" class="active font-semibold">{{ enrollment_pack.title }}</a>
          </li>
        </ul>
      </div>
  </div>
  {% endif %}
  <section class="product-details-section enrollment-pack-{{ section.id }} mt-xl">
      <div class="container">
           <div class="grid {{ section.settings.grid_layout | default: 'grid-cols-1 xl-tab-grid-cols-2' }} {{ section.settings.grid_gap_x | default: 'space-x-4xl' }} {{ section.settings.grid_gap_y | default: 'space-y-4xl' }}">
              {%- if section.blocks.size > 0 -%}
                  {%- assign slider_block = section.blocks | where: 'type', 'slider' | first -%}
                  {%- comment -%} Left column: image slider (always show when using blocks; fluid_attributes from slider block if present) {%- endcomment -%}
                  <div class="slider-section" {% if slider_block %}{{ slider_block.fluid_attributes }}{% endif %}>
                      <div class="splide main-slider-section" id="enrollment-slider">
                          <div class="splide__track">
                              <ul class="splide__list">
                              {% for image in images_array %}
                                  <li class="splide__slide">
                                      <img src="{{ image }}" alt="product" data-zoom-image="{{ image }}">
                                  </li>
                              {% endfor %}
                              </ul>
                          </div>
                      </div>
                      <div class="splide thumbnail-carousel-section mt-2xl" id="enrollment-thumbnail-carousel">
                          <div class="splide__track">
                              <ul class="splide__list splide-list">
                              {% for image in images_array %}
                                  <li class="splide__slide">
                                      <img src="{{ image }}" alt="product">
                                  </li>
                              {% endfor %}
                              </ul>
                          </div>
                      </div>
                  </div>

                  {%- comment -%} Right column: heading, price, rating, description, membership_packs, subscription_packs, buttons (in block order) {%- endcomment -%}
                  <div class="product-details">
                    {%- assign top_opened = false -%}
                    {%- assign details_opened = false -%}
                    {%- for block in section.blocks -%}
                      {%- case block.type -%}
                        {%- when 'heading' -%}
                          {%- unless top_opened -%}<div class="flex flex-col space-y-sm">{%- assign top_opened = true -%}{%- endunless -%}
                          {% assign enrollment_title_tag = block.settings.heading_tag | default: 'h1' %}
                          <{{ enrollment_title_tag }} class="product-title {{ section.settings.product_title_font_size | default: 'text-2xl' }} {{ section.settings.product_title_font_size_desktop | default: 'text-h3' }} {{ section.settings.product_title_font_weight | default: 'font-bold' }}" {{ block.fluid_attributes }}>{{ enrollment_pack.title }}</{{ enrollment_title_tag }}>

                        {%- when 'price' -%}
                          {%- unless top_opened -%}<div class="flex flex-col space-y-sm">{%- assign top_opened = true -%}{%- endunless -%}
                          <div class="flex gap-1 align-center" {{ block.fluid_attributes }}>
                            <div class="product-price {{ section.settings.product_price_font_size | default: 'text-lg' }} {{ section.settings.product_price_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.product_price_font_weight | default: 'font-medium' }}">
                              {{ enrollment_pack.price }}
                            </div>
                            <div class="enrollment-fee text-sm font-medium text-secondary">
                              {{ block.settings.fee_label | default: 'enrollment fee' }}
                            </div>
                          </div>

                        {%- when 'rating' -%}
                          {%- unless top_opened -%}<div class="flex flex-col space-y-sm">{%- assign top_opened = true -%}{%- endunless -%}
                          <div class="rating" {{ block.fluid_attributes }}>
                              <svg width="101" height="21" viewBox="0 0 101 21" fill="none" xmlns="http://www.w3.org/2000/svg">
                              <path fill-rule="evenodd" clip-rule="evenodd" d="M11.0207 2.88369C10.6997 2.11169 9.60575 2.11169 9.28475 2.88369L7.45475 7.28469L2.70175 7.66569C1.86875 7.73269 1.53075 8.77269 2.16575 9.31669L5.78575 12.4187L4.67975 17.0557C4.48575 17.8687 5.37075 18.5117 6.08475 18.0757L10.1527 15.5907L14.2217 18.0757C14.9347 18.5117 15.8197 17.8687 15.6257 17.0557L14.5197 12.4187L18.1397 9.31669C18.7747 8.77269 18.4367 7.73269 17.6037 7.66669L12.8517 7.28469L11.0207 2.88369Z" fill="#FFAE00"/>
                              <path fill-rule="evenodd" clip-rule="evenodd" d="M31.0207 2.88369C30.6997 2.11169 29.6057 2.11169 29.2847 2.88369L27.4547 7.28469L22.7017 7.66569C21.8687 7.73269 21.5307 8.77269 22.1657 9.31669L25.7857 12.4187L24.6797 17.0557C24.4857 17.8687 25.3707 18.5117 26.0847 18.0757L30.1527 15.5907L34.2217 18.0757C34.9347 18.5117 35.8197 17.8687 35.6257 17.0557L34.5197 12.4187L38.1397 9.31669C38.7747 8.77269 38.4367 7.73269 37.6037 7.66669L32.8517 7.28469L31.0207 2.88369Z" fill="#FFAE00"/>
                              <path fill-rule="evenodd" clip-rule="evenodd" d="M51.0207 2.88369C50.6997 2.11169 49.6057 2.11169 49.2847 2.88369L47.4547 7.28469L42.7017 7.66569C41.8687 7.73269 41.5307 8.77269 42.1657 9.31669L45.7857 12.4187L44.6797 17.0557C44.4857 17.8687 45.3707 18.5117 46.0847 18.0757L50.1527 15.5907L54.2217 18.0757C54.9347 18.5117 55.8197 17.8687 55.6257 17.0557L54.5197 12.4187L58.1397 9.31669C58.7747 8.77269 58.4367 7.73269 57.6037 7.66669L52.8517 7.28469L51.0207 2.88369Z" fill="#FFAE00"/>
                              <path fill-rule="evenodd" clip-rule="evenodd" d="M71.0207 2.88369C70.6997 2.11169 69.6057 2.11169 69.2847 2.88369L67.4547 7.28469L62.7017 7.66569C61.8687 7.73269 61.5307 8.77269 62.1657 9.31669L65.7857 12.4187L64.6797 17.0557C64.4857 17.8687 65.3707 18.5117 66.0847 18.0757L70.1527 15.5907L74.2217 18.0757C74.9347 18.5117 75.8197 17.8687 75.6257 17.0557L74.5197 12.4187L78.1397 9.31669C78.7747 8.77269 78.4367 7.73269 77.6037 7.66669L72.8517 7.28469L71.0207 2.88369Z" fill="#FFAE00"/>
                              <path fill-rule="evenodd" clip-rule="evenodd" d="M91.0207 2.88369C90.6997 2.11169 89.6057 2.11169 89.2847 2.88369L87.4547 7.28469L82.7017 7.66569C81.8687 7.73269 81.5307 8.77269 82.1657 9.31669L85.7857 12.4187L84.6797 17.0557C84.4857 17.8687 85.3707 18.5117 86.0847 18.0757L90.1527 15.5907L94.2217 18.0757C94.9347 18.5117 95.8197 17.8687 95.6257 17.0557L94.5197 12.4187L98.1397 9.31669C98.7747 8.77269 98.4367 7.73269 97.6037 7.66669L92.8517 7.28469L91.0207 2.88369Z" fill="#D0D5DD"/>
                              </svg>
                          </div>

                        {%- when 'description' -%}
                          {%- unless top_opened -%}<div class="flex flex-col space-y-sm">{%- assign top_opened = true -%}{%- endunless -%}
                          <div class="rte" {{ block.fluid_attributes }}>{{ block.settings.text | default: description | raw }}</div>

                        {%- when 'membership_packs' -%}
                          {%- if top_opened -%}</div>{%- assign top_opened = false -%}{%- endif -%}
                          {%- unless details_opened -%}<div class="details flex flex-col space-y-2xl pt-2xl">{%- assign details_opened = true -%}{%- endunless -%}
                          <div class="membership-packs-block" {{ block.fluid_attributes }}>
                            {% for product in membership_products %}
                              {%- assign cr = block.settings.border_radius -%}
                              {%- assign _card_cr_style = '' -%}
                              {%- if cr -%}
                                {%- capture cr_tl -%}{{ cr.tl }}{%- endcapture -%}{%- capture cr_tr -%}{{ cr.tr }}{%- endcapture -%}{%- capture cr_br -%}{{ cr.br }}{%- endcapture -%}{%- capture cr_bl -%}{{ cr.bl }}{%- endcapture -%}
                                {%- capture _card_cr_style -%}border-radius: {% if cr_tl contains 'var(' %}{{ cr_tl }}{% else %}{{ cr_tl }}px{% endif %} {% if cr_tr contains 'var(' %}{{ cr_tr }}{% else %}{{ cr_tr }}px{% endif %} {% if cr_br contains 'var(' %}{{ cr_br }}{% else %}{{ cr_br }}px{% endif %} {% if cr_bl contains 'var(' %}{{ cr_bl }}{% else %}{{ cr_bl }}px{% endif %};{%- endcapture -%}
                              {%- endif -%}
                              <div class="enrollment-pack membership-product md-tab-flex flex-wrap align-center border-0 {{ block.settings.padding | default: 'p-0' }}" {% if _card_cr_style != '' %}style="{{ _card_cr_style }}"{% endif %}>
                                <div class="image-section md-tab-order-2">
                                  <div class="wrapper">
                                    <img src="{{ product.image_url }}" alt="enrollment pack" class="image-cover rounded">
                                  </div>
                                </div>
                                <div class="desc md-tab-order-1 mt-2xl md-tab-m-0">
                                  <div class="pr-md">
                                    {% if block.settings.show_heading != false %}
                                      <p class="text-secondary">{{ block.settings.heading_text | default: 'One Time Purchase' }}</p>
                                    {% endif %}
                                    <div class="product-title subscription-product-title leading-8 {{ block.settings.product_title_font_size | default: 'text-lg' }} {{ block.settings.product_title_font_size_desktop | default: 'lg:text-xl' }} {{ block.settings.product_title_font_weight | default: 'font-bold' }}" style="color: {{ block.settings.product_title_color | default: '#000000' }};">{{ product.title }}</div>
                                    <div class="price subscription-product-price leading-8 {{ block.settings.product_price_font_size | default: 'text-lg' }} {{ block.settings.product_price_font_size_desktop | default: 'lg:text-xl' }} {{ block.settings.product_price_font_weight | default: 'font-medium' }}" style="color: {{ block.settings.product_price_color | default: '#000000' }};">{{ product.price }}</div>
                                  </div>
                                </div>
                              </div>
                            {% endfor %}
                          </div>

                        {%- when 'subscription_packs' -%}
                          {%- if top_opened -%}</div>{%- assign top_opened = false -%}{%- endif -%}
                          {%- unless details_opened -%}<div class="details flex flex-col space-y-2xl pt-2xl">{%- assign details_opened = true -%}{%- endunless -%}
                          <div class="subscription-packs-block" {{ block.fluid_attributes }}>
                            {% for product in subscription_products %}
                              {%- assign cr = block.settings.border_radius -%}
                              {%- assign _card_cr_style = '' -%}
                              {%- if cr -%}
                                {%- capture cr_tl -%}{{ cr.tl }}{%- endcapture -%}{%- capture cr_tr -%}{{ cr.tr }}{%- endcapture -%}{%- capture cr_br -%}{{ cr.br }}{%- endcapture -%}{%- capture cr_bl -%}{{ cr.bl }}{%- endcapture -%}
                                {%- capture _card_cr_style -%}border-radius: {% if cr_tl contains 'var(' %}{{ cr_tl }}{% else %}{{ cr_tl }}px{% endif %} {% if cr_tr contains 'var(' %}{{ cr_tr }}{% else %}{{ cr_tr }}px{% endif %} {% if cr_br contains 'var(' %}{{ cr_br }}{% else %}{{ cr_br }}px{% endif %} {% if cr_bl contains 'var(' %}{{ cr_bl }}{% else %}{{ cr_bl }}px{% endif %};{%- endcapture -%}
                              {%- endif -%}
                              <div class="enrollment-pack subscription-product border {{ block.settings.padding | default: 'p-lg' }} md-tab-flex flex-wrap align-center" {% if _card_cr_style != '' %}style="{{ _card_cr_style }}"{% endif %}>
                                <div class="image-section md-tab-order-2">
                                  <div class="wrapper">
                                    <img src="{{ product.image }}" alt="enrollment pack" class="image-cover rounded">
                                  </div>
                                </div>
                                <div class="desc md-tab-order-1 mt-2xl md-tab-m-0">
                                  <div class="pr-md">
                                    <div class="product-title subscription-product-title leading-8 {{ block.settings.product_title_font_size | default: 'text-lg' }} {{ block.settings.product_title_font_size_desktop | default: 'lg:text-xl' }} {{ block.settings.product_title_font_weight | default: 'font-bold' }}" style="color: {{ block.settings.product_title_color | default: '#000000' }};">{{ product.title }}</div>
                                    <div class="price subscription-product-price leading-8 {{ block.settings.product_price_font_size | default: 'text-lg' }} {{ block.settings.product_price_font_size_desktop | default: 'lg:text-xl' }} {{ block.settings.product_price_font_weight | default: 'font-medium' }}" style="color: {{ block.settings.product_price_color | default: '#000000' }};">{{ product.price }}</div>
                                    <ul class="info text-secondary flex flex-col space-y-xs pt-md {{ block.settings.info_text_font_size | default: 'text-sm' }}">
                                      <li>{{ 'enrollment_pack.monthly_subscription' | t }}</li>
                                      <li>{{ 'enrollment_pack.first_payment' | t: date: first_payment_date }}</li>
                                    </ul>
                                  </div>
                                  <div class="learn-more-section pt-4xl md-tab-text-left">
                                    <a href="{{ product.learn_more_path }}" class="{{ block.settings.learn_more_font_size | default: 'text-base' }}">{{ 'enrollment_pack.learn_more' | t }}</a>
                                  </div>
                                </div>
                              </div>
                            {% endfor %}
                          </div>

                        {%- when 'buttons' -%}
                          {%- if top_opened -%}</div>{%- assign top_opened = false -%}{%- endif -%}
                          {%- unless details_opened -%}<div class="details flex flex-col space-y-2xl pt-2xl">{%- assign details_opened = true -%}{%- endunless -%}
                          <div class="btn-section" {{ block.fluid_attributes }}>
                            <div class="w-full" data-fluid-checkout-group data-enrollment-pack="{{ enrollment_pack.id }}">
                              {%- assign cr = block.settings.button_border_radius | default: section.settings.button_border_radius -%}
                              {%- assign _btn_cr_style = '' -%}
                              {%- if cr -%}
                                {%- capture cr_tl -%}{{ cr.tl }}{%- endcapture -%}{%- capture cr_tr -%}{{ cr.tr }}{%- endcapture -%}{%- capture cr_br -%}{{ cr.br }}{%- endcapture -%}{%- capture cr_bl -%}{{ cr.bl }}{%- endcapture -%}
                                {%- capture _btn_cr_style -%}border-radius: {% if cr_tl contains 'var(' %}{{ cr_tl }}{% else %}{{ cr_tl }}px{% endif %} {% if cr_tr contains 'var(' %}{{ cr_tr }}{% else %}{{ cr_tr }}px{% endif %} {% if cr_br contains 'var(' %}{{ cr_br }}{% else %}{{ cr_br }}px{% endif %} {% if cr_bl contains 'var(' %}{{ cr_bl }}{% else %}{{ cr_bl }}px{% endif %}; {%- endcapture -%}
                              {%- endif -%}
                              <button
                                type="button"
                                class="btn w-full checkout-button {{ block.settings.button_padding_y | default: section.settings.button_padding_y | default: 'py-md' }} {{ block.settings.button_padding_x | default: section.settings.button_padding_x | default: 'px-4xl' }} {{ block.settings.button_font_size | default: section.settings.button_font_size | default: 'text-base' }} {{ block.settings.button_font_weight | default: section.settings.button_font_weight | default: 'font-medium' }}"
                                style="{{ _btn_cr_style }}background-color: {{ block.settings.button_background_color | default: section.settings.button_background_color | default: '#000000' }}; color: {{ block.settings.button_text_color | default: section.settings.button_text_color | default: '#ffffff' }};"
                                data-fluid-add-enrollment-pack="{{ enrollment_pack.id }}"
                              >
                                {{ 'enrollment_pack.checkout' | t }}
                              </button>
                            </div>
                          </div>
                      {%- endcase -%}
                    {%- endfor -%}
                    {%- if top_opened -%}</div>{%- endif -%}
                    {%- if details_opened -%}</div>{%- endif -%}
                  </div>
              {%- endif -%}
          </div>
      </div>
  </section>
</main>
<script src="{{ 'enrollment.js' | asset_url }}"></script>

{% schema %}
{
  "name": "Enrollment Pack",
  "tag": "section",
  "class": "enrollment-pack-section",
  "enabled_on": {
    "templates": ["enrollment_pack"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "padding",
      "id": "section_padding",
      "label": "Section Padding"
    },
    {
      "type": "color_background",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Main Product Typography"
    },
    {
      "type": "select",
      "id": "product_title_font_size",
      "label": "Product Title Font Size (Mobile)",
      "options": [
        { "value": "text-xs", "label": "XS" },
        { "value": "text-sm", "label": "SM" },
        { "value": "text-base", "label": "Base" },
        { "value": "text-lg", "label": "LG" },
        { "value": "text-xl", "label": "XL" },
        { "value": "text-2xl", "label": "2XL" },
        { "value": "text-3xl", "label": "3XL" },
        { "value": "text-h1", "label": "H1" },
        { "value": "text-h2", "label": "H2" },
        { "value": "text-h3", "label": "H3" },
        { "value": "text-h4", "label": "H4" },
        { "value": "text-h5", "label": "H5" },
        { "value": "text-h6", "label": "H6" }
      ],
      "default": "text-2xl"
    },
    {
      "type": "select",
      "id": "product_title_font_size_desktop",
      "label": "Product Title Font Size (Desktop)",
      "options": [
        { "value": "text-h1", "label": "H1" },
        { "value": "text-h2", "label": "H2" },
        { "value": "text-h3", "label": "H3" },
        { "value": "text-h4", "label": "H4" },
        { "value": "text-h5", "label": "H5" },
        { "value": "text-h6", "label": "H6" },
        { "value": "lg:text-2xl", "label": "2XL" },
        { "value": "lg:text-3xl", "label": "3XL" },
        { "value": "lg:text-4xl", "label": "4XL" },
        { "value": "lg:text-5xl", "label": "5XL" },
        { "value": "lg:text-6xl", "label": "6XL" }
      ],
      "default": "text-h3"
