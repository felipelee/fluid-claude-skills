          <a href="#pattern-hero-overlay"><span>Hero Overlay</span><span class="sr-nav-tag">pattern</span></a>
          <a href="#pattern-scroll-indicator"><span>Scroll Indicator</span><span class="sr-nav-tag">pattern</span></a>
