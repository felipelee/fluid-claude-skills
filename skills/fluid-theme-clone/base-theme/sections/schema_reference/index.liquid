          <a href="#html"><span><code>html</code></span></a>
          <a href="#url"><span><code>url</code></span></a>
        </div>
        <div class="sr-nav-group">
          <div class="sr-nav-h">Number &amp; Selection</div>
          <a href="#range"><span><code>range</code></span></a>
          <a href="#select"><span><code>select</code></span></a>
          <a href="#radio"><span><code>radio</code></span></a>
          <a href="#checkbox"><span><code>checkbox</code></span></a>
        </div>
        <div class="sr-nav-group">
          <div class="sr-nav-h">Visual &amp; Media</div>
          <a href="#color"><span><code>color</code></span></a>
          <a href="#color_background"><span><code>color_background</code></span></a>
          <a href="#theme-color-dropdown" class="is-pattern"><span>Theme Color Dropdown</span><span class="sr-nav-tag">pattern</span></a>
          <a href="#font_picker"><span><code>font_picker</code></span></a>
          <a href="#image_picker"><span><code>image_picker</code></span></a>
          <a href="#video_picker"><span><code>video_picker</code></span></a>
          <a href="#media_picker"><span><code>media_picker</code></span></a>
          <a href="#text_alignment"><span><code>text_alignment</code></span></a>
        </div>
        <div class="sr-nav-group">
          <div class="sr-nav-h">Layout</div>
          <a href="#padding"><span><code>padding</code></span></a>
          <a href="#corner_radius"><span><code>corner_radius</code></span></a>
          <a href="#border"><span><code>border</code></span></a>
          <a href="#gradient_overlay"><span><code>gradient_overlay</code></span></a>
          <a href="#media_fit"><span><code>media_fit</code></span></a>
        </div>
        <div class="sr-nav-group">
          <div class="sr-nav-h">Organization</div>
          <a href="#header"><span><code>header</code></span></a>
        </div>
        <div class="sr-nav-group">
          <div class="sr-nav-h">Resource (Single)</div>
          <a href="#product"><span><code>product</code></span></a>
          <a href="#collection"><span><code>collection</code></span></a>
          <a href="#category"><span><code>category</code></span></a>
          <a href="#post"><span><code>post</code></span></a>
          <a href="#enrollment_pack"><span><code>enrollment_pack</code></span></a>
          <a href="#forms"><span><code>forms</code></span></a>
          <a href="#link_list"><span><code>link_list</code></span></a>
        </div>
        <div class="sr-nav-group">
          <div class="sr-nav-h">Resource (List)</div>
          <a href="#product_list"><span><code>product_list</code></span></a>
          <a href="#collection_list"><span><code>collection_list</code></span></a>
          <a href="#category_list"><span><code>category_list</code></span></a>
          <a href="#posts_list"><span><code>posts_list</code></span></a>
          <a href="#enrollment_list"><span><code>enrollment_list</code></span></a>
        </div>
      </nav>
    </aside>

    <main class="sr-main">

      <header class="sr-hero">
        <h1>{{ section.settings.page_title | default: 'Schema Controls Reference' }}</h1>
        <div class="sr-hero-sub">{{ section.settings.page_intro | default: '<p>Every schema control available in Fluid themes — how each one renders in the builder, how to invoke it, and how to access its value in Liquid. The shared vocabulary for everyone building on Fluid.</p>' }}</div>

        <aside class="sr-agent" aria-label="How agents should use this page">
          <div class="sr-agent-head">
            <span class="sr-agent-badge">For agents &amp; devs</span>
            <span class="sr-agent-title">How to use this reference</span>
          </div>
          <ol>
            <li><strong>Find the category</strong> for the value you need (text, number, color, media, resource, layout) in the left nav.</li>
            <li><strong>Match the builder preview</strong> to what you want editors to see. Fluid's UI is often different from convention — <code>radio</code> renders as pills, <code>checkbox</code> as a toggle.</li>
            <li><strong>Expand "Schema"</strong> and copy the snippet into your section schema block.</li>
            <li><strong>Expand "Liquid"</strong> and copy the accessor into your section body — do not invent accessor shapes.</li>
            <li>For theme-aware colors, use the <a href="#theme-color-dropdown"><strong>Theme Color Dropdown</strong></a> pattern — not raw <code>color</code>.</li>
          </ol>
          <div class="sr-agent-foot">
            <strong>When unsure — stop and ask.</strong> Do not guess control names. Unsupported types (<code>number</code>, <code>article</code>, <code>video_url</code>, <code>inline_richtext</code>) break the editor silently.
          </div>
        </aside>
      </header>

      {% assign current_category = '' %}
      {% for block in section.blocks %}
        {% if block.settings.category != current_category %}
          <div class="sr-cat-head">
            <div class="sr-cat-eyebrow">Category</div>
            {% case block.settings.category %}
              {% when 'patterns' %}
                <h2>Patterns</h2>
                <p>How controls combine for common section shapes. Copy the full recipe, then tune — these are the defaults every section should start from.</p>
              {% when 'input' %}
                <h2>Input</h2>
                <p>Text content controls. Use <code>richtext</code> for anything visible to visitors.</p>
              {% when 'number' %}
                <h2>Number &amp; Selection</h2>
                <p><code>number</code> is not supported — always use <code>range</code>. <code>radio</code> renders as pills, <code>checkbox</code> as a toggle switch.</p>
              {% when 'visual' %}
                <h2>Visual &amp; Media</h2>
                <p>Colors, fonts, and uploads. For theme-aware colors prefer the <strong>Theme Color Dropdown</strong> pattern over raw <code>color</code>.</p>
              {% when 'layout' %}
                <h2>Layout</h2>
                <p>Structured objects — every section should ship with <code>padding</code> + <code>corner_radius</code>.</p>
              {% when 'organization' %}
                <h2>Organization</h2>
                <p>Visual-only — purely UI. Renders no value in Liquid.</p>
              {% when 'resource_single' %}
                <h2>Resource (Single)</h2>
                <p>Chip-style pickers. Singular and plural aliases both work. <code>link_list</code> renders as a dropdown.</p>
              {% when 'resource_list' %}
                <h2>Resource (List)</h2>
                <p>Multi-resource pickers. Hard cap of 24. Iterate directly — return the full object array.</p>
            {% endcase %}
          </div>
          {% assign current_category = block.settings.category %}
        {% endif %}
        {% case block.type %}
          {% when 'schema_entry' %}
            {% assign pt = block.settings.preview_type | default: 'text' %}
            {% assign pl = block.settings.preview_label | default: block.settings.control_name %}
            {% assign pv = block.settings.preview_value | default: 'Welcome' %}
            {% assign feat = block.settings.is_featured %}
            <article class="sr-entry{% if feat %} sr-entry--feature{% endif %}"
                     id="{{ block.settings.anchor_id | default: block.id }}"
                     {{ block.fluid_attributes }}>
              <div class="sr-entry-head">
                <h3><code>{{ block.settings.control_name | default: 'control' }}</code></h3>
                {% if block.settings.returns_label != blank %}
                  <span class="sr-returns-pill">{{ block.settings.returns_label }}</span>
                {% endif %}
              </div>
              <div class="sr-entry-desc rte">{{ block.settings.description }}</div>
              <div class="sr-preview-label">Fluid builder renders</div>
              <div class="sr-builder">
                {% case pt %}
                  {% when 'text' %}
                    <div class="sr-field-label">{{ pl }}</div>
                    <span class="sr-db-var">Database Variable</span>
                    <div class="sr-preset-row"><div class="sr-preset">Text Presets</div><div class="sr-preset">Primary Color</div></div>
                    <div class="sr-toolbar">
                      <span class="sr-tb-btn">B</span><span class="sr-tb-btn sr-i">I</span><span class="sr-tb-btn sr-u">U</span><span class="sr-tb-btn sr-s">S</span>
                      <span class="sr-tb-sep"></span>
                      <span class="sr-tb-btn">🔗</span><span class="sr-tb-btn">x²</span>
                    </div>
                    <div class="sr-input">{{ pv }}</div>
                  {% when 'textarea' %}
                    <div class="sr-field-label">{{ pl }}</div>
                    <div class="sr-input sr-input--multi">{{ pv }}</div>
                  {% when 'richtext' %}
                    <div class="sr-field-label">{{ pl }}</div>
                    <div class="sr-input sr-input--multi">{{ pv }}</div>
                  {% when 'html' %}
                    <div class="sr-field-label">{{ pl }}</div>
                    <div class="sr-input sr-input--code">{{ pv | escape }}</div>
                  {% when 'url' %}
                    <div class="sr-field-label">{{ pl }}</div>
                    <div class="sr-input">{{ pv }}</div>
                  {% when 'range' %}
                    <div class="sr-field-label">{{ pl }}</div>
                    <div class="sr-range-wrap">
                      <div class="sr-range"><div class="sr-range-fill"></div><div class="sr-range-knob"></div></div>
                      <div class="sr-range-val">{{ pv }}</div>
                    </div>
                  {% when 'select' %}
                    <div class="sr-field-label">{{ pl }}</div>
                    <div class="sr-select">{{ pv }}</div>
                  {% when 'radio' %}
                    <div class="sr-field-label">{{ pl }}</div>
                    <div class="sr-radio"><span class="sr-radio-opt">Small</span><span class="sr-radio-opt is-selected">Medium</span><span class="sr-radio-opt">Large</span></div>
                  {% when 'checkbox' %}
                    <div class="sr-toggle-row"><div class="sr-field-label">{{ pl }}</div><div class="sr-toggle{% if pv == 'off' %} sr-toggle--off{% endif %}"></div></div>
                  {% when 'color' %}
                    <div class="sr-field-label">{{ pl }}</div>
                    <div class="sr-color-row"><div class="sr-swatch" style="background:{{ pv }};"></div><div class="sr-hex">{{ pv }}</div></div>
                  {% when 'color_background' %}
                    <div class="sr-field-label">{{ pl }}</div>
                    <div class="sr-gradient">
                      <div class="sr-bg-tabs"><span class="sr-bg-tab">Solid</span><span class="sr-bg-tab is-selected">Gradient</span></div>
                      <div class="sr-gr-row"><div class="sr-gr-label">Angle</div><div class="sr-input">135</div></div>
                      <div class="sr-gr-row"><div class="sr-gr-label">Color 1</div><div class="sr-color-row"><div class="sr-swatch" style="background:#6366f1"></div><div class="sr-hex">#6366f1</div></div></div>
                      <div class="sr-add-color">+ Add Color</div>
                    </div>
                  {% when 'font_picker' %}
                    <div class="sr-field-label">{{ pl }}</div>
                    <div class="sr-select">{{ pv }}</div>
                  {% when 'image_picker' %}
                    <div class="sr-field-label">{{ pl }}</div>
                    <div class="sr-upload"><div class="sr-upload-icon">📁</div><div class="sr-upload-title">Select or Upload image</div></div>
                  {% when 'video_picker' %}
                    <div class="sr-field-label">{{ pl }}</div>
                    <div class="sr-upload"><div class="sr-upload-icon">📁</div><div class="sr-upload-title">Select or Upload video</div></div>
                  {% when 'media_picker' %}
                    <div class="sr-field-label">{{ pl }}</div>
                    <div class="sr-media-link">Select media</div>
                  {% when 'text_alignment' %}
                    <div class="sr-field-label">{{ pl }}</div>
                    <div class="sr-align"><span class="sr-align-opt">Left</span><span class="sr-align-opt is-selected">Center</span><span class="sr-align-opt">Right</span></div>
                  {% when 'padding' %}
                    <div class="sr-field-label">{{ pl }}</div>
                    <div class="sr-box4">
                      <div class="sr-box4-icon sr-pi-t"></div><div class="sr-box4-input">0</div>
                      <div class="sr-box4-icon sr-pi-r"></div><div class="sr-box4-input">0</div>
                      <div class="sr-box4-icon sr-pi-b"></div><div class="sr-box4-input">0</div>
                      <div class="sr-box4-icon sr-pi-l"></div><div class="sr-box4-input">0</div>
                    </div>
                  {% when 'corner_radius' %}
                    <div class="sr-field-label">{{ pl }}</div>
                    <div class="sr-box4">
                      <div class="sr-box4-icon sr-cr-tl"></div><div class="sr-box4-input">0</div>
                      <div class="sr-box4-icon sr-cr-tr"></div><div class="sr-box4-input">0</div>
                      <div class="sr-box4-icon sr-cr-bl"></div><div class="sr-box4-input">0</div>
                      <div class="sr-box4-icon sr-cr-br"></div><div class="sr-box4-input">0</div>
                    </div>
                  {% when 'border' %}
                    <div class="sr-field-label">{{ pl }}</div>
                    <div class="sr-border-row">
                      <div class="sr-box4-input">0</div>
                      <div class="sr-select">Color Presets</div>
                      <div class="sr-swatch" style="background:#000"></div>
                      <div class="sr-hex">#000000</div>
                    </div>
                  {% when 'resource_chip' %}
                    <div class="sr-field-label">{{ pl }}</div>
                    <div class="sr-chip"><div class="sr-chip-icon"></div>{{ pv }}</div>
                  {% when 'resource_chip_list' %}
                    <div class="sr-field-label">{{ pl }}</div>
                    <div class="sr-chip-list">
                      <span class="sr-chip"><span class="sr-chip-icon"></span>{{ pv }} #0</span>
                      <span class="sr-chip"><span class="sr-chip-icon"></span>{{ pv }} #1</span>
                    </div>
                  {% when 'header_group' %}
                    <div class="sr-collapsible">{{ pv }}</div>
                  {% when 'custom' %}
                    {{ block.settings.preview_custom_html }}
                {% endcase %}
              </div>
              <div class="sr-disclosures">
                {% if block.settings.schema_snippet != blank %}
                  <details class="sr-disclose"{% if feat %} open{% endif %}>
                    <summary>{{ block.settings.schema_label | default: 'Schema' }} <span class="sr-dk">json</span></summary>
                    <div class="sr-dc"><pre><code>{{ block.settings.schema_snippet }}</code></pre></div>
                  </details>
                {% endif %}
                {% if block.settings.schema_snippet_2 != blank %}
                  <details class="sr-disclose"{% if feat %} open{% endif %}>
                    <summary>{{ block.settings.schema_snippet_2_label | default: 'Schema (2)' }} <span class="sr-dk">json</span></summary>
                    <div class="sr-dc"><pre><code>{{ block.settings.schema_snippet_2 }}</code></pre></div>
                  </details>
                {% endif %}
                {% if block.settings.liquid_snippet != blank %}
                  <details class="sr-disclose">
                    <summary>{{ block.settings.liquid_label | default: 'Liquid' }} <span class="sr-dk">liquid</span></summary>
                    <div class="sr-dc"><pre><code>{{ block.settings.liquid_snippet }}</code></pre></div>
                  </details>
                {% endif %}
                {% if block.settings.tip != blank %}
                  <details class="sr-disclose sr-disclose--tip">
                    <summary>{{ block.settings.tip_label | default: 'Tip' }} <span class="sr-dk">{{ block.settings.tip_kind | default: 'tip' }}</span></summary>
                    <div class="sr-dc"><div class="sr-tip-body">{{ block.settings.tip }}</div></div>
                  </details>
                {% endif %}
              </div>
            </article>
        {% endcase %}
      {% endfor %}

    </main>
  </div>
</section>

{% schema %}
{
  "name": "Schema Controls Reference",
  "settings": [
    {
      "type": "header",
      "content": "Page Intro"
    },
    {
      "type": "text",
      "id": "page_title",
      "label": "Page Title",
      "default": "Schema Controls Reference"
    },
    {
      "type": "richtext",
      "id": "page_intro",
      "label": "Page Intro",
      "default": "<p>Every schema control available in Fluid themes.</p>"
    }
  ],
  "blocks": [
    {
      "type": "schema_entry",
      "name": "Schema Entry",
      "settings": [
        {
          "type": "header",
          "content": "Taxonomy"
        },
        {
          "type": "select",
          "id": "category",
          "label": "Category",
          "default": "input",
          "options": [
            {
              "value": "patterns",
              "label": "Patterns (recipe)"
            },
            {
              "value": "input",
              "label": "Input"
            },
            {
              "value": "number",
              "label": "Number & Selection"
            },
            {
              "value": "visual",
              "label": "Visual & Media"
            },
            {
              "value": "layout",
              "label": "Layout"
            },
            {
              "value": "organization",
              "label": "Organization"
            },
            {
              "value": "resource_single",
              "label": "Resource (Single)"
            },
            {
              "value": "resource_list",
              "label": "Resource (List)"
            }
          ]
        },
        {
          "type": "text",
          "id": "anchor_id",
          "label": "Anchor ID",
          "info": "Used in the URL hash. e.g. 'text', 'theme-color-dropdown'."
        },
        {
          "type": "checkbox",
          "id": "is_featured",
          "label": "Feature this entry (purple border, auto-open code)",
          "default": false
        },
        {
          "type": "header",
          "content": "Header"
        },
        {
          "type": "text",
          "id": "control_name",
          "label": "Control name",
          "info": "Shown in the entry heading. e.g. 'text' or 'select + option_group'."
        },
        {
          "type": "text",
          "id": "returns_label",
          "label": "Returns pill",
          "info": "Short label \u2014 e.g. 'String', 'Hex string', '{ top, bottom, left, right }'."
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>What this control does and when to use it.</p>"
        },
        {
          "type": "header",
          "content": "Fluid builder preview"
        },
        {
          "type": "select",
          "id": "preview_type",
          "label": "Preview shape",
          "default": "text",
          "info": "Pick the builder control this entry demonstrates. For multi-control patterns, use 'custom' and supply markup below.",
          "options": [
            {
              "value": "text",
              "label": "text (single line + toolbar)"
            },
            {
              "value": "textarea",
              "label": "textarea (multi line + toolbar)"
            },
            {
              "value": "richtext",
              "label": "richtext (WYSIWYG)"
            },
            {
              "value": "html",
              "label": "html (raw monospace)"
            },
            {
              "value": "url",
              "label": "url (plain input)"
            },
            {
              "value": "range",
              "label": "range (slider)"
            },
            {
              "value": "select",
              "label": "select (dropdown)"
            },
            {
              "value": "radio",
              "label": "radio (pill buttons)"
            },
            {
              "value": "checkbox",
              "label": "checkbox / toggle (switch)"
            },
            {
              "value": "color",
              "label": "color (swatch + hex)"
            },
            {
              "value": "color_background",
              "label": "color_background (gradient UI)"
            },
            {
              "value": "font_picker",
              "label": "font_picker (dropdown)"
            },
            {
              "value": "image_picker",
              "label": "image_picker (upload card)"
            },
            {
              "value": "video_picker",
              "label": "video_picker (upload card)"
            },
            {
              "value": "media_picker",
              "label": "media_picker (select-media link)"
            },
            {
              "value": "text_alignment",
              "label": "text_alignment (align pills)"
            },
            {
              "value": "padding",
              "label": "padding (4-side grid)"
            },
            {
              "value": "corner_radius",
              "label": "corner_radius (4-corner grid)"
            },
            {
              "value": "border",
              "label": "border (width + color)"
            },
            {
              "value": "resource_chip",
              "label": "resource chip (single)"
            },
            {
              "value": "resource_chip_list",
              "label": "resource chip list"
            },
            {
              "value": "header_group",
              "label": "header (collapsible group)"
            },
            {
              "value": "custom",
              "label": "custom (inject your own HTML)"
            }
          ]
        },
        {
          "type": "text",
          "id": "preview_label",
          "label": "Field label",
          "info": "Label shown above the mock control. Defaults to the control name."
        },
        {
          "type": "text",
          "id": "preview_value",
          "label": "Sample value",
          "info": "What's shown inside the control (value of the mock input, swatch hex, radio selection, etc.)."
        },
        {
          "type": "html",
          "id": "preview_custom_html",
          "label": "Custom preview HTML",
          "info": "Used only when Preview shape is 'custom'. Compose multiple sr-* building blocks."
        },
        {
          "type": "header",
          "content": "Code snippets"
        },
        {
          "type": "text",
          "id": "schema_label",
          "label": "Schema disclosure label",
          "default": "Schema"
        },
        {
          "type": "html",
          "id": "schema_snippet",
          "label": "Schema snippet",
          "info": "JSON, no surrounding raw/code tags. This is shown verbatim inside a <pre><code> block."
        },
        {
          "type": "text",
          "id": "schema_snippet_2_label",
          "label": "Second schema disclosure label",
          "info": "Optional. For patterns that need two JSON snippets (e.g. section schema + theme option_group)."
        },
        {
          "type": "html",
          "id": "schema_snippet_2",
          "label": "Second schema snippet",
          "info": "Optional."
        },
        {
          "type": "text",
          "id": "liquid_label",
          "label": "Liquid disclosure label",
          "default": "Liquid"
        },
        {
          "type": "html",
          "id": "liquid_snippet",
          "label": "Liquid snippet",
          "info": "Liquid, shown verbatim inside a <pre><code> block."
        },
        {
          "type": "header",
          "content": "Tip / warning"
        },
        {
          "type": "text",
          "id": "tip_label",
          "label": "Tip disclosure label",
          "default": "Tip"
        },
        {
          "type": "text",
          "id": "tip_kind",
          "label": "Tip tag",
          "info": "Short label shown on the disclosure button \u2014 e.g. 'tip', 'warning'."
        },
        {
          "type": "richtext",
          "id": "tip",
          "label": "Tip / warning body",
          "info": "Optional callout. Appears in yellow disclosure."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Schema Controls Reference",
      "blocks": [
        {
          "type": "schema_entry",
          "settings": {
            "category": "patterns",
            "anchor_id": "pattern-section-shell",
            "is_featured": true,
            "control_name": "Section Shell + Container",
            "returns_label": "17 settings \u00b7 Container (9) + Section Shell (6) + two composition groups",
            "description": "<p>The baseline every section ships with. <strong>Container</strong> (9 settings) is a nested shell with its own max-width, padding, radius, background color/image, overlay, and border. <strong>Section Shell</strong> (6 settings) wraps it with outer padding, radius, background, and border. Two nested shells give editors full control \u2014 outer can be full-bleed with a colored bg, inner can be a bounded card with its own styling.</p>",
            "preview_type": "custom",
            "preview_custom_html": "<div class=\"sr-collapsible\">Container</div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Max Width</div><div class=\"sr-select\" style=\"margin-left:8px;\">Default (1280px)</div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Container Padding</div><div class=\"sr-box4\" style=\"padding-left:8px;\"><div class=\"sr-box4-icon sr-pi-t\"></div><div class=\"sr-box4-input\">0</div><div class=\"sr-box4-icon sr-pi-r\"></div><div class=\"sr-box4-input\">64</div><div class=\"sr-box4-icon sr-pi-b\"></div><div class=\"sr-box4-input\">0</div><div class=\"sr-box4-icon sr-pi-l\"></div><div class=\"sr-box4-input\">64</div></div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Container Border Radius</div><div class=\"sr-box4\" style=\"padding-left:8px;\"><div class=\"sr-box4-icon sr-cr-tl\"></div><div class=\"sr-box4-input\">0</div><div class=\"sr-box4-icon sr-cr-tr\"></div><div class=\"sr-box4-input\">0</div><div class=\"sr-box4-icon sr-cr-bl\"></div><div class=\"sr-box4-input\">0</div><div class=\"sr-box4-icon sr-cr-br\"></div><div class=\"sr-box4-input\">0</div></div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Container Background Color</div><div class=\"sr-select\" style=\"margin-left:8px;\">Transparent</div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Container Background Image</div><div class=\"sr-upload\" style=\"margin-left:8px;\"><div class=\"sr-upload-icon\">\ud83d\udcc1</div><div class=\"sr-upload-title\">Select or Upload image</div></div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Container Overlay Color</div><div class=\"sr-select\" style=\"margin-left:8px;\">Transparent</div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Container Overlay Opacity</div><div class=\"sr-range-wrap\" style=\"margin-left:8px;\"><div class=\"sr-range\"><div class=\"sr-range-fill\" style=\"width:0%;\"></div><div class=\"sr-range-knob\" style=\"left:0%;\"></div></div><div class=\"sr-range-val\">0</div></div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Container Border Width</div><div class=\"sr-range-wrap\" style=\"margin-left:8px;\"><div class=\"sr-range\"><div class=\"sr-range-fill\" style=\"width:0%;\"></div><div class=\"sr-range-knob\" style=\"left:0%;\"></div></div><div class=\"sr-range-val\">0</div></div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Container Border Color</div><div class=\"sr-select\" style=\"margin-left:8px;\">Primary</div><div class=\"sr-collapsible\" style=\"margin-top:8px;\">Section Shell</div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Section Padding</div><div class=\"sr-box4\" style=\"padding-left:8px;\"><div class=\"sr-box4-icon sr-pi-t\"></div><div class=\"sr-box4-input\">80</div><div class=\"sr-box4-icon sr-pi-r\"></div><div class=\"sr-box4-input\">0</div><div class=\"sr-box4-icon sr-pi-b\"></div><div class=\"sr-box4-input\">80</div><div class=\"sr-box4-icon sr-pi-l\"></div><div class=\"sr-box4-input\">0</div></div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Section Border Radius</div><div class=\"sr-box4\" style=\"padding-left:8px;\"><div class=\"sr-box4-icon sr-cr-tl\"></div><div class=\"sr-box4-input\">0</div><div class=\"sr-box4-icon sr-cr-tr\"></div><div class=\"sr-box4-input\">0</div><div class=\"sr-box4-icon sr-cr-bl\"></div><div class=\"sr-box4-input\">0</div><div class=\"sr-box4-icon sr-cr-br\"></div><div class=\"sr-box4-input\">0</div></div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Background Color</div><div class=\"sr-select\" style=\"margin-left:8px;\">Primary</div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Background Image</div><div class=\"sr-upload\" style=\"margin-left:8px;\"><div class=\"sr-upload-icon\">\ud83d\udcc1</div><div class=\"sr-upload-title\">Select or Upload image</div></div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Section Border Width</div><div class=\"sr-range-wrap\" style=\"margin-left:8px;\"><div class=\"sr-range\"><div class=\"sr-range-fill\" style=\"width:0%;\"></div><div class=\"sr-range-knob\" style=\"left:0%;\"></div></div><div class=\"sr-range-val\">0</div></div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Section Border Color</div><div class=\"sr-select\" style=\"margin-left:8px;\">Primary</div>",
            "schema_snippet": "{\n  \"settings\": [\n    { \"type\": \"header\", \"content\": \"Container\" },\n    { \"type\": \"select\", \"id\": \"container_max_width\", \"label\": \"Max Width\", \"default\": \"1280px\",\n      \"options\": [\n        { \"value\": \"960px\",  \"label\": \"Narrow (960px)\" },\n        { \"value\": \"1280px\", \"label\": \"Default (1280px)\" },\n        { \"value\": \"1440px\", \"label\": \"Wide (1440px)\" },\n        { \"value\": \"100%\",   \"label\": \"Full (100%)\" }\n      ] },\n    { \"type\": \"padding\", \"id\": \"container_padding\", \"label\": \"Container Padding\" },\n    { \"type\": \"corner_radius\", \"id\": \"container_border_radius\", \"label\": \"Container Border Radius\" },\n    { \"type\": \"select\", \"id\": \"container_background_color\", \"label\": \"Container Background Color\",\n      \"options\": \"background_colors\", \"default\": \"transparent\" },\n    { \"type\": \"image_picker\", \"id\": \"container_background_image\", \"label\": \"Container Background Image\" },\n    { \"type\": \"select\", \"id\": \"container_overlay_color\", \"label\": \"Container Overlay Color\",\n      \"options\": \"background_colors\", \"default\": \"transparent\" },\n    { \"type\": \"range\", \"id\": \"container_overlay_opacity\", \"label\": \"Container Overlay Opacity\",\n      \"min\": 0, \"max\": 100, \"step\": 5, \"default\": 0, \"unit\": \"%\" },\n    { \"type\": \"range\", \"id\": \"container_border_width\", \"label\": \"Container Border Width\",\n      \"min\": 0, \"max\": 10, \"step\": 1, \"default\": 0, \"unit\": \"px\" },\n    { \"type\": \"select\", \"id\": \"container_border_color\", \"label\": \"Container Border Color\",\n      \"options\": \"background_colors\", \"default\": \"var(--clr-primary)\" },\n\n    { \"type\": \"header\", \"content\": \"Section Shell\" },\n    { \"type\": \"padding\", \"id\": \"section_padding\", \"label\": \"Section Padding\" },\n    { \"type\": \"corner_radius\", \"id\": \"section_border_radius\", \"label\": \"Section Border Radius\" },\n    { \"type\": \"select\", \"id\": \"background_color\", \"label\": \"Background Color\",\n      \"options\": \"background_colors\", \"default\": \"transparent\" },\n    { \"type\": \"image_picker\", \"id\": \"background_image\", \"label\": \"Background Image\" },\n    { \"type\": \"range\", \"id\": \"section_border_width\", \"label\": \"Section Border Width\",\n      \"min\": 0, \"max\": 10, \"step\": 1, \"default\": 0, \"unit\": \"px\" },\n    { \"type\": \"select\", \"id\": \"section_border_color\", \"label\": \"Section Border Color\",\n      \"options\": \"background_colors\", \"default\": \"var(--clr-primary)\" }\n  ]\n}",
            "liquid_label": "Liquid wire-up",
            "liquid_snippet": "{%- style -%}\n  .my-section.section-{{ section.id }} {\n    {%- assign p = section.settings.section_padding -%}\n    {%- if p -%}padding: {{ p.top }}px {{ p.right }}px {{ p.bottom }}px {{ p.left }}px;{%- endif -%}\n    {%- assign r = section.settings.section_border_radius -%}\n    {%- if r -%}border-radius: {{ r.tl }}px {{ r.tr }}px {{ r.br }}px {{ r.bl }}px;{%- endif -%}\n    {% if section.settings.section_border_width > 0 %}\n      border: {{ section.settings.section_border_width }}px solid {{ section.settings.section_border_color }};\n    {% endif %}\n    background-color: {{ section.settings.background_color | default: 'transparent' }};\n    {%- if section.settings.background_image != blank -%}\n      background-image: url({{ section.settings.background_image | img_url: '2400x' }});\n      background-size: cover; background-position: center; background-repeat: no-repeat;\n    {%- endif -%}\n  }\n  .my-section.section-{{ section.id }} .my-section__container {\n    max-width: {{ section.settings.container_max_width | default: '1280px' }};\n    margin: 0 auto;\n    {%- assign cp = section.settings.container_padding -%}\n    {%- if cp -%}\n      padding: {{ cp.top | default: 0 }}px {{ cp.right | default: 64 }}px {{ cp.bottom | default: 0 }}px {{ cp.left | default: 64 }}px;\n    {%- else -%}\n      padding: 0 64px;\n    {%- endif -%}\n  }\n  @media (max-width: 991px) { .my-section.section-{{ section.id }} .my-section__container { padding-left: 24px; padding-right: 24px; } }\n  @media (max-width: 767px) { .my-section.section-{{ section.id }} .my-section__container { padding-left: 16px; padding-right: 16px; } }\n{%- endstyle -%}\n\n<section class=\"my-section section-{{ section.id }}\" {{ section.fluid_attributes }}>\n  <div class=\"my-section__container\">\n    \u2026\n  </div>\n</section>",
            "tip_label": "Why split Container from Section Shell",
            "tip_kind": "tip",
            "tip": "<p>Think of it as two nested boxes. <strong>Section Shell</strong> is the outer box \u2014 full-width colored area, section-to-section separator. <strong>Container</strong> is the inner box \u2014 bounded content area, optionally styled as a standalone card. Stack them for hero sections with image backgrounds + bordered content containers, or keep the container transparent for a clean centered layout.</p>"
          }
        },
        {
          "type": "schema_entry",
          "settings": {
            "category": "patterns",
            "anchor_id": "pattern-button",
            "is_featured": true,
            "control_name": "Button",
            "returns_label": "11 settings \u00b7 text \u00b7 link \u00b7 font \u00b7 checkbox \u00b7 radio \u00b7 range \u00b7 padding \u00b7 select \u00d72 \u00b7 border \u00b7 corner_radius",
            "description": "<p>The canonical Button block. 11 settings \u2014 use the standalone <code>blocks/button</code> or copy inline. <strong>Font Size</strong> + <strong>Padding</strong> together determine visual size (no t-shirt preset). Style sets the base CSS class; everything else is inline-style override.</p>",
            "preview_type": "custom",
            "preview_custom_html": "<div class=\"sr-collapsible\">Content</div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Text</div><div class=\"sr-input\" style=\"margin-left:8px;\">Shop now</div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Link</div><div class=\"sr-input\" style=\"margin-left:8px;\">/shop</div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Font Family</div><div class=\"sr-select\" style=\"margin-left:8px;\">Inter</div><div class=\"sr-toggle-row\" style=\"padding-left:8px;margin-top:4px;\"><div class=\"sr-field-label\">Open in new tab</div><div class=\"sr-toggle sr-toggle--off\"></div></div><div class=\"sr-collapsible\" style=\"margin-top:8px;\">Style</div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Style</div><div class=\"sr-radio\" style=\"margin-left:8px;\"><span class=\"sr-radio-opt is-selected\">Filled</span><span class=\"sr-radio-opt\">Outline</span><span class=\"sr-radio-opt\">Text only</span></div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Font Size</div><div class=\"sr-range-wrap\" style=\"margin-left:8px;\"><div class=\"sr-range\"><div class=\"sr-range-fill\" style=\"width:33%;\"></div><div class=\"sr-range-knob\" style=\"left:33%;\"></div></div><div class=\"sr-range-val\">16</div></div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Padding</div><div class=\"sr-box4\" style=\"padding-left:8px;\"><div class=\"sr-box4-icon sr-pi-t\"></div><div class=\"sr-box4-input\">12</div><div class=\"sr-box4-icon sr-pi-r\"></div><div class=\"sr-box4-input\">24</div><div class=\"sr-box4-icon sr-pi-b\"></div><div class=\"sr-box4-input\">12</div><div class=\"sr-box4-icon sr-pi-l\"></div><div class=\"sr-box4-input\">24</div></div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Background Color</div><div class=\"sr-select\" style=\"margin-left:8px;\">Primary</div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Text Color</div><div class=\"sr-select\" style=\"margin-left:8px;\">White</div><div class=\"sr-collapsible\" style=\"margin-top:8px;\">Shape</div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Border</div><div class=\"sr-border-row\" style=\"margin-left:8px;\"><div class=\"sr-box4-input\">0</div><div class=\"sr-select\">Color Presets</div><div class=\"sr-swatch\" style=\"background:#000\"></div><div class=\"sr-hex\">#000000</div></div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Border Radius</div><div class=\"sr-box4\" style=\"padding-left:8px;\"><div class=\"sr-box4-icon sr-cr-tl\"></div><div class=\"sr-box4-input\">8</div><div class=\"sr-box4-icon sr-cr-tr\"></div><div class=\"sr-box4-input\">8</div><div class=\"sr-box4-icon sr-cr-bl\"></div><div class=\"sr-box4-input\">8</div><div class=\"sr-box4-icon sr-cr-br\"></div><div class=\"sr-box4-input\">8</div></div>",
            "schema_label": "Schema (inline in section's blocks)",
            "schema_snippet": "{\n  \"type\": \"button\",\n  \"name\": \"Button\",\n  \"settings\": [\n    { \"type\": \"header\", \"content\": \"Content\" },\n    { \"type\": \"text\", \"id\": \"text\", \"label\": \"Text\", \"default\": \"Shop now\" },\n    { \"type\": \"url\", \"id\": \"link\", \"label\": \"Link\" },\n    { \"type\": \"font_picker\", \"id\": \"font_family\", \"label\": \"Font Family\", \"default\": \"Inter\" },\n    { \"type\": \"checkbox\", \"id\": \"open_new_tab\", \"label\": \"Open in new tab\", \"default\": false },\n    { \"type\": \"header\", \"content\": \"Style\" },\n    { \"type\": \"radio\", \"id\": \"style\", \"label\": \"Style\", \"default\": \"filled\",\n      \"options\": [\n        { \"value\": \"filled\",  \"label\": \"Filled\" },\n        { \"value\": \"outline\", \"label\": \"Outline\" },\n        { \"value\": \"text\",    \"label\": \"Text only\" }\n      ] },\n    { \"type\": \"range\", \"id\": \"font_size\", \"label\": \"Font Size\",\n      \"min\": 10, \"max\": 32, \"step\": 1, \"default\": 16, \"unit\": \"px\" },\n    { \"type\": \"padding\", \"id\": \"padding\", \"label\": \"Padding\" },\n    { \"type\": \"select\", \"id\": \"background_color\", \"label\": \"Background Color\",\n      \"options\": \"background_colors\", \"default\": \"var(--clr-primary)\" },\n    { \"type\": \"select\", \"id\": \"text_color\", \"label\": \"Text Color\",\n      \"options\": \"background_colors\", \"default\": \"var(--clr-white)\" },\n    { \"type\": \"header\", \"content\": \"Shape\" },\n    { \"type\": \"border\", \"id\": \"border\", \"label\": \"Border\" },\n    { \"type\": \"corner_radius\", \"id\": \"border_radius\", \"label\": \"Border Radius\" }\n  ]\n}",
            "liquid_label": "Liquid (render inside a section's case/when)",
            "liquid_snippet": "<a href=\"{{ block.settings.link | default: '#' }}\"\n   class=\"btn btn--{{ block.settings.style | default: 'filled' }}\"\n   style=\"\n     background-color: {{ block.settings.background_color }};\n     color: {{ block.settings.text_color }};\n     font-size: {{ block.settings.font_size }}px;\n     font-family: {{ block.settings.font_family | font_family }};\n     {%- assign p = block.settings.padding -%}\n     {%- if p -%}padding: {{ p.top }}px {{ p.right }}px {{ p.bottom }}px {{ p.left }}px;{%- endif -%}\n     {%- assign br = block.settings.border_radius -%}\n     {%- if br -%}border-radius: {{ br.tl }}px {{ br.tr }}px {{ br.br }}px {{ br.bl }}px;{%- endif -%}\n     {%- assign bd = block.settings.border -%}\n     {%- if bd.width -%}border: {{ bd.width }} solid {{ bd.color }};{%- endif -%}\n   \"\n   {% if block.settings.open_new_tab %}target=\"_blank\" rel=\"noopener\"{% endif %}\n   {{ block.fluid_attributes }}>\n  {{ block.settings.text | escape }}\n</a>",
            "tip_label": "Why Font Size + Padding instead of Size presets",
            "tip_kind": "tip",
            "tip": "<p>T-shirt sizes (sm/md/lg) are opinionated \u2014 they bake in a specific relationship between font-size and padding. Font Size + Padding as independent controls let you dial in the exact button dimensions for the design, without being stuck with three preset shapes.</p>"
          }
        },
        {
          "type": "schema_entry",
          "settings": {
            "category": "patterns",
            "anchor_id": "pattern-image",
            "is_featured": true,
            "control_name": "Image",
            "returns_label": "11 settings \u00b7 image_picker \u00b7 text \u00b7 url \u00b7 checkbox \u00b7 select \u00d73 \u00b7 radio \u00b7 range \u00b7 border \u00b7 corner_radius",
            "description": "<p>The canonical Image block. Handles the image, link/clickability, aspect + fit + object-position (the three controls that actually frame a photo), an optional overlay (color + opacity), border, and radius. Always explicit <strong>alt text</strong> for accessibility.</p>",
            "preview_type": "custom",
            "preview_custom_html": "<div class=\"sr-collapsible\">Content</div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Image</div><div class=\"sr-upload\" style=\"margin-left:8px;\"><div class=\"sr-upload-icon\">\ud83d\udcc1</div><div class=\"sr-upload-title\">Select or Upload image</div></div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Alt Text</div><div class=\"sr-input\" style=\"margin-left:8px;color:#94a3b8;\">Describe the image\u2026</div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Link</div><div class=\"sr-input\" style=\"margin-left:8px;\">/product</div><div class=\"sr-toggle-row\" style=\"padding-left:8px;margin-top:4px;\"><div class=\"sr-field-label\">Open in new tab</div><div class=\"sr-toggle sr-toggle--off\"></div></div><div class=\"sr-collapsible\" style=\"margin-top:8px;\">Sizing</div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Aspect Ratio</div><div class=\"sr-select\" style=\"margin-left:8px;\">Square (1:1)</div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Fit</div><div class=\"sr-radio\" style=\"margin-left:8px;\"><span class=\"sr-radio-opt is-selected\">Cover</span><span class=\"sr-radio-opt\">Contain</span><span class=\"sr-radio-opt\">Fill</span></div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Object Position</div><div class=\"sr-select\" style=\"margin-left:8px;\">Center</div><div class=\"sr-collapsible\" style=\"margin-top:8px;\">Overlay</div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Overlay Color</div><div class=\"sr-select\" style=\"margin-left:8px;\">Primary</div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Overlay Opacity</div><div class=\"sr-range-wrap\" style=\"margin-left:8px;\"><div class=\"sr-range\"><div class=\"sr-range-fill\" style=\"width:25%;\"></div><div class=\"sr-range-knob\" style=\"left:25%;\"></div></div><div class=\"sr-range-val\">25</div></div><div class=\"sr-collapsible\" style=\"margin-top:8px;\">Shape</div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Border</div><div class=\"sr-border-row\" style=\"margin-left:8px;\"><div class=\"sr-box4-input\">0</div><div class=\"sr-select\">Color Presets</div><div class=\"sr-swatch\" style=\"background:#000\"></div><div class=\"sr-hex\">#000000</div></div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Border Radius</div><div class=\"sr-box4\" style=\"padding-left:8px;\"><div class=\"sr-box4-icon sr-cr-tl\"></div><div class=\"sr-box4-input\">12</div><div class=\"sr-box4-icon sr-cr-tr\"></div><div class=\"sr-box4-input\">12</div><div class=\"sr-box4-icon sr-cr-bl\"></div><div class=\"sr-box4-input\">12</div><div class=\"sr-box4-icon sr-cr-br\"></div><div class=\"sr-box4-input\">12</div></div>",
            "schema_label": "Schema (inline in section's blocks)",
            "schema_snippet": "{\n  \"type\": \"image\",\n  \"name\": \"Image\",\n  \"settings\": [\n    { \"type\": \"header\", \"content\": \"Content\" },\n    { \"type\": \"image_picker\", \"id\": \"image\", \"label\": \"Image\" },\n    { \"type\": \"text\", \"id\": \"alt\", \"label\": \"Alt Text\",\n      \"info\": \"Leave blank to use the image's own alt.\" },\n    { \"type\": \"url\", \"id\": \"link\", \"label\": \"Link\" },\n    { \"type\": \"checkbox\", \"id\": \"open_new_tab\", \"label\": \"Open in new tab\", \"default\": false },\n    { \"type\": \"header\", \"content\": \"Sizing\" },\n    { \"type\": \"select\", \"id\": \"aspect_ratio\", \"label\": \"Aspect Ratio\", \"default\": \"auto\",\n      \"options\": [\n        { \"value\": \"auto\",  \"label\": \"Auto (natural)\" },\n        { \"value\": \"1/1\",   \"label\": \"Square (1:1)\" },\n        { \"value\": \"4/3\",   \"label\": \"Standard (4:3)\" },\n        { \"value\": \"16/9\",  \"label\": \"Widescreen (16:9)\" },\n        { \"value\": \"3/2\",   \"label\": \"Classic (3:2)\" },\n        { \"value\": \"3/4\",   \"label\": \"Portrait (3:4)\" },\n        { \"value\": \"9/16\",  \"label\": \"Portrait mobile (9:16)\" },\n        { \"value\": \"21/9\",  \"label\": \"Ultrawide (21:9)\" }\n      ] },\n    { \"type\": \"radio\", \"id\": \"fit\", \"label\": \"Fit\", \"default\": \"cover\",\n      \"options\": [\n        { \"value\": \"cover\",   \"label\": \"Cover\" },\n        { \"value\": \"contain\", \"label\": \"Contain\" },\n        { \"value\": \"fill\",    \"label\": \"Fill\" }\n      ] },\n    { \"type\": \"select\", \"id\": \"object_position\", \"label\": \"Object Position\", \"default\": \"center\",\n      \"info\": \"Only affects Fit = Cover.\",\n      \"options\": [\n        { \"value\": \"center\", \"label\": \"Center\" },\n        { \"value\": \"top\",    \"label\": \"Top\" },\n        { \"value\": \"bottom\", \"label\": \"Bottom\" },\n        { \"value\": \"left\",   \"label\": \"Left\" },\n        { \"value\": \"right\",  \"label\": \"Right\" }\n      ] },\n    { \"type\": \"header\", \"content\": \"Overlay\" },\n    { \"type\": \"select\", \"id\": \"overlay_color\", \"label\": \"Overlay Color\",\n      \"options\": \"background_colors\", \"default\": \"transparent\" },\n    { \"type\": \"range\", \"id\": \"overlay_opacity\", \"label\": \"Overlay Opacity\",\n      \"min\": 0, \"max\": 100, \"step\": 5, \"default\": 0, \"unit\": \"%\" },\n    { \"type\": \"header\", \"content\": \"Shape\" },\n    { \"type\": \"border\", \"id\": \"border\", \"label\": \"Border\" },\n    { \"type\": \"corner_radius\", \"id\": \"border_radius\", \"label\": \"Border Radius\" }\n  ]\n}",
            "liquid_label": "Liquid (render inside a section's case/when)",
            "liquid_snippet": "{% assign _img = block.settings.image %}\n{% assign _alt = block.settings.alt | default: _img.alt | default: '' %}\n{% capture _wrap %}\n  {% if block.settings.aspect_ratio != 'auto' %}aspect-ratio: {{ block.settings.aspect_ratio }};{% endif %}\n  {% assign br = block.settings.border_radius %}{% if br %}border-radius: {{ br.tl }}px {{ br.tr }}px {{ br.br }}px {{ br.bl }}px;{% endif %}\n  {% assign bd = block.settings.border %}{% if bd.width %}border: {{ bd.width }} solid {{ bd.color }};{% endif %}\n{% endcapture %}\n<div class=\"media-wrap\" style=\"{{ _wrap | strip_newlines }}\" {{ block.fluid_attributes }}>\n  {% if _img %}\n    <img src=\"{{ _img | img_url: '1600x' }}\"\n         alt=\"{{ _alt | escape }}\" loading=\"lazy\"\n         style=\"object-fit: {{ block.settings.fit }}; object-position: {{ block.settings.object_position }}; {% if block.settings.aspect_ratio != 'auto' %}width:100%;height:100%;{% endif %}\">\n  {% endif %}\n  {% if block.settings.overlay_color != blank and block.settings.overlay_opacity > 0 %}\n    {% assign _a = block.settings.overlay_opacity | divided_by: 100.0 %}\n    <div class=\"media-wrap__overlay\" style=\"background: {{ block.settings.overlay_color }}; opacity: {{ _a }};\"></div>\n  {% endif %}\n</div>",
            "tip_label": "Alt text vs image_picker's built-in alt",
            "tip_kind": "tip",
            "tip": "<p>The <code>image_picker</code> object carries its own <code>.alt</code> (set when the image was uploaded to the DAM). The explicit Alt Text field here <strong>overrides</strong> that when filled \u2014 useful when the image has a generic DAM alt but needs context-specific copy here. If left blank, the render falls back to <code>image.alt</code>.</p>"
          }
        },
        {
          "type": "schema_entry",
          "settings": {
            "category": "patterns",
            "anchor_id": "pattern-fluid-media",
            "is_featured": true,
            "control_name": "Fluid Media",
            "returns_label": "8 settings \u00b7 media \u00b7 select \u00d73 \u00b7 checkbox \u00b7 range \u00b7 corner_radius",
            "description": "<p>The canonical way to embed a Fluid DAM media asset (video, audio, PDF, etc.) using the <code>&lt;fluid-media-widget&gt;</code> web component. Picks from your media library, supports inline / popover / modal embed types, with theme-compliant border and radius.</p>",
            "preview_type": "custom",
            "preview_custom_html": "<div class=\"sr-collapsible\">Media</div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Media</div><div class=\"sr-media-link\" style=\"margin-left:8px;\">Select media</div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Embed Type</div><div class=\"sr-select\" style=\"margin-left:8px;\">Inline (plays in place)</div><div class=\"sr-toggle-row\" style=\"padding-left:8px;margin-top:4px;\"><div class=\"sr-field-label\">Responsive</div><div class=\"sr-toggle\"></div></div><div class=\"sr-collapsible\" style=\"margin-top:8px;\">Layout</div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Aspect Ratio</div><div class=\"sr-select\" style=\"margin-left:8px;\">Widescreen (16:9)</div><div class=\"sr-collapsible\" style=\"margin-top:8px;\">Shape</div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Background Color</div><div class=\"sr-select\" style=\"margin-left:8px;\">Transparent</div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Border Width</div><div class=\"sr-range-wrap\" style=\"margin-left:8px;\"><div class=\"sr-range\"><div class=\"sr-range-fill\" style=\"width:0%;\"></div><div class=\"sr-range-knob\" style=\"left:0%;\"></div></div><div class=\"sr-range-val\">0</div></div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Border Color</div><div class=\"sr-select\" style=\"margin-left:8px;\">Primary</div><div class=\"sr-field-label\" style=\"padding-left:8px;\">Border Radius</div><div class=\"sr-box4\" style=\"padding-left:8px;\"><div class=\"sr-box4-icon sr-cr-tl\"></div><div class=\"sr-box4-input\">12</div><div class=\"sr-box4-icon sr-cr-tr\"></div><div class=\"sr-box4-input\">12</div><div class=\"sr-box4-icon sr-cr-bl\"></div><div class=\"sr-box4-input\">12</div><div class=\"sr-box4-icon sr-cr-br\"></div><div class=\"sr-box4-input\">12</div></div>",
            "schema_label": "Schema (inline in section's blocks)",
            "schema_snippet": "{\n  \"type\": \"fluid_media\",\n  \"name\": \"Fluid Media\",\n  \"settings\": [\n    { \"type\": \"header\", \"content\": \"Media\" },\n    { \"type\": \"media\", \"id\": \"media\", \"label\": \"Media\" },\n    { \"type\": \"select\", \"id\": \"embed_type\", \"label\": \"Embed Type\", \"default\": \"auto\",\n      \"options\": [\n        { \"value\": \"auto\",    \"label\": \"Use media's default\" },\n        { \"value\": \"inline\",  \"label\": \"Inline (plays in place)\" },\n        { \"value\": \"popover\", \"label\": \"Popover (opens in overlay)\" },\n        { \"value\": \"modal\",   \"label\": \"Modal (full-screen)\" }\n      ] },\n    { \"type\": \"checkbox\", \"id\": \"responsive\", \"label\": \"Responsive\", \"default\": true },\n    { \"type\": \"header\", \"content\": \"Layout\" },\n    { \"type\": \"select\", \"id\": \"aspect_ratio\", \"label\": \"Aspect Ratio\", \"default\": \"16/9\",\n      \"options\": [\n        { \"value\": \"auto\", \"label\": \"Auto (media's natural)\" },\n        { \"value\": \"16/9\", \"label\": \"Widescreen (16:9)\" },\n        { \"value\": \"1/1\",  \"label\": \"Square (1:1)\" },\n        { \"value\": \"4/3\",  \"label\": \"Standard (4:3)\" },\n        { \"value\": \"4/5\",  \"label\": \"Portrait (4:5)\" },\n        { \"value\": \"9/16\", \"label\": \"Portrait mobile (9:16)\" },\n        { \"value\": \"21/9\", \"label\": \"Ultrawide (21:9)\" }\n      ] },\n    { \"type\": \"header\", \"content\": \"Shape\" },\n    { \"type\": \"select\", \"id\": \"background_color\", \"label\": \"Background Color\",\n      \"options\": \"background_colors\", \"default\": \"transparent\" },\n    { \"type\": \"range\", \"id\": \"border_width\", \"label\": \"Border Width\",\n      \"min\": 0, \"max\": 10, \"step\": 1, \"default\": 0, \"unit\": \"px\" },\n    { \"type\": \"select\", \"id\": \"border_color\", \"label\": \"Border Color\",\n      \"options\": \"background_colors\", \"default\": \"var(--clr-primary)\" },\n    { \"type\": \"corner_radius\", \"id\": \"border_radius\", \"label\": \"Border Radius\" }\n  ]\n}",
            "liquid_label": "Liquid (render inside a section's case/when)",
            "liquid_snippet": "{% assign _m = block.settings.media %}\n{% assign _fmid = _m.fluid_media_id | default: _m.id %}\n{% assign _embed = block.settings.embed_type %}\n{% if _embed == 'auto' %}{% assign _embed = _m.embed_type | default: 'inline' %}{% endif %}\n{% assign _ar = block.settings.aspect_ratio | default: 'auto' %}\n{% capture _wrap %}\n  {% if _ar != 'auto' and _embed == 'inline' %}aspect-ratio: {{ _ar }};{% endif %}\n  background-color: {{ block.settings.background_color | default: 'transparent' }};\n  {% assign br = block.settings.border_radius %}{% if br %}border-radius: {{ br.tl }}px {{ br.tr }}px {{ br.br }}px {{ br.bl }}px;{% endif %}\n  {% if block.settings.border_width > 0 %}border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};{% endif %}\n{% endcapture %}\n<div class=\"fluid-media\" style=\"{{ _wrap | strip_newlines }}\" {{ block.fluid_attributes }}>\n  {% if _fmid != blank %}\n    <fluid-media-widget media-id=\"{{ _fmid }}\"\n      responsive=\"{% if block.settings.responsive %}true{% else %}false{% endif %}\"\n      embed-type=\"{{ _embed }}\"\n      data-fluid-widget=\"true\"></fluid-media-widget>\n  {% endif %}\n</div>",
            "tip_label": "Embed types explained",
            "tip_kind": "tip",
            "tip": "<p><strong>Inline</strong> \u2014 the media renders in place and plays within its container. Needs an aspect ratio for videos to prevent layout shift.</p><p><strong>Popover</strong> \u2014 the widget renders a thumbnail/trigger; clicking opens the media in an overlay panel. Good for video galleries.</p><p><strong>Modal</strong> \u2014 similar to popover but full-screen. Good for long-form content.</p><p><strong>Use media's default</strong> \u2014 defers to whatever <code>embed_type</code> was set when the media was uploaded to the DAM. Usually a safe default.</p>"
          }
        },
