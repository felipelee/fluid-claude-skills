        <div class="sr-nav-group">
          <div class="sr-nav-h">Patterns &mdash; Foundation</div>
          <a href="#pattern-divider-block"><span>Divider Block</span><span class="sr-nav-tag">pattern</span></a>
          <a href="#theme-color-dropdown" class="is-pattern"><span>Theme-Driven Colors</span><span class="sr-nav-tag">pattern</span></a>
          <a href="#pattern-theme-fonts"><span>Theme-Driven Fonts</span><span class="sr-nav-tag">pattern</span></a>
          <a href="#pattern-split-border"><span>Split Border</span><span class="sr-nav-tag">pattern</span></a>
          <a href="#pattern-canonical-block-primacy"><span>Canonical Block Primacy</span><span class="sr-nav-tag">pattern</span></a>
          <a href="#pattern-loop-not-first"><span>Loop, don't <code>| first</code></span><span class="sr-nav-tag">pattern</span></a>
          <a href="#pattern-phantom-default"><span>Phantom Default Antipattern</span><span class="sr-nav-tag">pattern</span></a>
        </div>
        <div class="sr-nav-group">
          <div class="sr-nav-h">Patterns &mdash; Composition</div>
          <a href="#pattern-stat"><span>Stat</span><span class="sr-nav-tag">pattern</span></a>
          <a href="#pattern-rating-stars"><span>Rating Stars</span><span class="sr-nav-tag">pattern</span></a>
          <a href="#pattern-trust-bar"><span>Trust Bar</span><span class="sr-nav-tag">pattern</span></a>
          <a href="#pattern-tag-pill"><span>Tag Pill</span><span class="sr-nav-tag">pattern</span></a>
          <a href="#pattern-card-grid"><span>Card Grid</span><span class="sr-nav-tag">pattern</span></a>
          <a href="#pattern-css-carousel"><span>CSS Scroll Carousel</span><span class="sr-nav-tag">pattern</span></a>
          <a href="#pattern-native-accordion"><span>Native Accordion</span><span class="sr-nav-tag">pattern</span></a>
          <a href="#pattern-drag-slider"><span>Drag Slider</span><span class="sr-nav-tag">pattern</span></a>
        </div>
        <div class="sr-nav-group">
