{%- style -%}
  /* ==================================================================
     SCHEMA REFERENCE — documentation-style layout
     ================================================================== */
  .sr-doc {
    --sr-bg: #ffffff;
    --sr-fg: #0a2540;
    --sr-fg-muted: #425466;
    --sr-fg-dim: #6b7c93;
    --sr-border: #e6ebf1;
    --sr-border-strong: #d9dfe6;
    --sr-surface: #f6f9fc;
    --sr-surface-2: #fafbfd;
    --sr-accent: #635bff;
    --sr-accent-fg: #fff;
    --sr-accent-soft: #e8ebff;
    --sr-code-bg: #0a2540;
    --sr-code-fg: #f6f9fc;
    --sr-radius: 10px;
    --sr-radius-sm: 6px;
    --sr-sidebar-w: 244px;

    background: var(--sr-bg);
    color: var(--sr-fg);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Inter", Roboto, sans-serif;
    font-size: 15px;
    line-height: 1.55;
    min-height: 100vh;
  }
  .sr-doc * { box-sizing: border-box; }
  .sr-doc h1, .sr-doc h2, .sr-doc h3, .sr-doc h4 {
    color: var(--sr-fg); margin: 0; font-weight: 600; letter-spacing: -0.015em;
  }
  .sr-doc a { color: var(--sr-accent); text-decoration: none; }
  .sr-doc a:hover { text-decoration: underline; }
  .sr-doc code {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.88em; background: var(--sr-surface); padding: 1px 6px; border-radius: 4px;
    color: #0a2540; border: 1px solid var(--sr-border);
  }

  .sr-shell {
    display: grid; grid-template-columns: var(--sr-sidebar-w) 1fr;
    max-width: 1400px; margin: 0 auto; min-height: 100vh;
  }
  @media (max-width: 900px) { .sr-shell { grid-template-columns: 1fr; } }

  /* SIDEBAR */
  .sr-aside {
    border-right: 1px solid var(--sr-border); background: var(--sr-surface-2);
    padding: 32px 20px 64px 32px;
    position: sticky; top: 0; align-self: start;
    max-height: 100vh; overflow-y: auto;
  }
  @media (max-width: 900px) {
    .sr-aside { position: relative; max-height: none; padding: 24px 20px; border-right: 0; border-bottom: 1px solid var(--sr-border); }
  }
  .sr-aside-brand { display: flex; flex-direction: column; gap: 2px; padding-bottom: 18px; margin-bottom: 18px; border-bottom: 1px solid var(--sr-border); }
  .sr-aside-eyebrow { font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--sr-accent); font-weight: 600; }
  .sr-aside-title { font-size: 17px; font-weight: 600; color: var(--sr-fg); }
  .sr-nav { display: flex; flex-direction: column; gap: 18px; }
  .sr-nav-group { display: flex; flex-direction: column; gap: 2px; }
  .sr-nav-h { font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--sr-fg-dim); font-weight: 600; padding: 6px 8px; }
  .sr-nav a {
    display: flex; align-items: center; justify-content: space-between; gap: 8px;
    padding: 5px 10px; font-size: 13.5px; color: var(--sr-fg-muted);
    border-radius: 6px; text-decoration: none;
    transition: background .12s, color .12s;
  }
  .sr-nav a:hover { background: var(--sr-surface); color: var(--sr-fg); text-decoration: none; }
  .sr-nav a code { background: transparent; border: 0; padding: 0; color: inherit; font-size: 12.5px; }
  .sr-nav-tag { font-size: 10px; padding: 1px 6px; border-radius: 999px; background: var(--sr-accent-soft); color: var(--sr-accent); font-weight: 600; }

  /* MAIN */
  .sr-main { padding: 56px 64px 120px; max-width: 880px; width: 100%; }
  @media (max-width: 1100px) { .sr-main { padding: 48px 40px 96px; } }
  @media (max-width: 767px)  { .sr-main { padding: 32px 20px 80px; } }

  .sr-hero { margin-bottom: 40px; padding-bottom: 32px; border-bottom: 1px solid var(--sr-border); }
  .sr-hero h1 { font-size: 44px; line-height: 1.05; letter-spacing: -0.025em; margin-bottom: 14px; }
  @media (max-width: 767px) { .sr-hero h1 { font-size: 34px; } }
  .sr-hero-sub { font-size: 18px; color: var(--sr-fg-muted); margin: 0; line-height: 1.55; }

  .sr-agent { margin-top: 28px; background: linear-gradient(180deg, #f5f8ff 0%, #fafbff 100%); border: 1px solid #d3dcff; border-radius: var(--sr-radius); padding: 22px 24px; }
  .sr-agent-head { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
  .sr-agent-badge { display: inline-flex; align-items: center; gap: 5px; background: var(--sr-accent); color: #fff; padding: 3px 9px; border-radius: 999px; font-size: 11px; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; }
  .sr-agent-title { font-size: 14.5px; font-weight: 600; color: var(--sr-fg); }
  .sr-agent ol { margin: 0; padding-left: 20px; font-size: 14px; line-height: 1.6; color: var(--sr-fg-muted); }
  .sr-agent ol li { margin-bottom: 5px; }
  .sr-agent ol li strong { color: var(--sr-fg); font-weight: 600; }
  .sr-agent-foot { margin-top: 14px; padding-top: 14px; border-top: 1px dashed #d3dcff; font-size: 13px; color: var(--sr-fg-muted); }

  .sr-cat-head { margin: 56px 0 8px; }
  .sr-cat-eyebrow { font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--sr-accent); font-weight: 600; margin-bottom: 6px; }
  .sr-cat-head h2 { font-size: 28px; letter-spacing: -0.02em; }
  .sr-cat-head p { font-size: 15.5px; color: var(--sr-fg-muted); margin: 6px 0 0; max-width: 640px; }

  /* ENTRIES — rendered by blocks/schema_entry */
  .sr-entry { padding: 36px 0; border-bottom: 1px solid var(--sr-border); }
  .sr-entry--feature { margin: 32px 0; padding: 28px 28px; background: linear-gradient(180deg, #f5f8ff 0%, #fafbff 100%); border: 1px solid #d3dcff; border-radius: 12px; }
  .sr-entry-head { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; margin-bottom: 6px; }
  .sr-entry-head h3 { font-size: 22px; line-height: 1.2; letter-spacing: -0.02em; display: inline-flex; align-items: center; gap: 10px; }
  .sr-entry-head h3 code { background: var(--sr-accent-soft); color: var(--sr-accent); padding: 3px 10px; border-radius: 6px; font-size: 15px; font-weight: 600; border: 0; }
  .sr-returns-pill { font-family: ui-monospace, Menlo, monospace; font-size: 12px; color: var(--sr-fg-dim); background: var(--sr-surface); border: 1px solid var(--sr-border); padding: 2px 8px; border-radius: 999px; }
  .sr-entry-desc { color: var(--sr-fg-muted); font-size: 15px; line-height: 1.6; margin: 6px 0 18px; max-width: 640px; }
  .sr-entry-desc strong { color: var(--sr-fg); font-weight: 600; }
  .sr-preview-label { font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--sr-fg-dim); font-weight: 600; margin-bottom: 8px; }

  /* BUILDER REPLICA */
  .sr-builder { background: #fff; border: 1px solid var(--sr-border); border-radius: var(--sr-radius); padding: 16px; display: flex; flex-direction: column; gap: 9px; max-width: 420px; box-shadow: 0 1px 3px rgba(10, 37, 64, 0.05); }
  .sr-field-label { font-size: 13px; color: var(--sr-fg); font-weight: 500; }
  .sr-db-var { display: inline-flex; align-items: center; gap: 4px; align-self: flex-end; font-size: 11px; color: var(--sr-fg-dim); }
  .sr-db-var::before { content: "🗄"; font-size: 11px; }

  .sr-preset-row { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
  .sr-preset { display: flex; align-items: center; justify-content: space-between; padding: 6px 10px; background: #fff; border: 1px solid var(--sr-border); border-radius: var(--sr-radius-sm); font-size: 12px; color: var(--sr-fg-muted); }
  .sr-preset::after { content: "▾"; font-size: 10px; color: var(--sr-fg-dim); }

  .sr-toolbar { display: flex; align-items: center; gap: 2px; flex-wrap: wrap; background: #fff; border: 1px solid var(--sr-border); border-radius: var(--sr-radius-sm); padding: 4px; }
  .sr-tb-btn { width: 24px; height: 24px; display: inline-flex; align-items: center; justify-content: center; font-size: 12px; color: var(--sr-fg-muted); border-radius: 4px; font-weight: 600; }
  .sr-tb-btn.sr-i { font-style: italic; }
  .sr-tb-btn.sr-u { text-decoration: underline; }
  .sr-tb-btn.sr-s { text-decoration: line-through; color: var(--sr-fg-dim); }
  .sr-tb-sep { width: 1px; height: 16px; background: var(--sr-border); margin: 0 2px; }

  .sr-input { background: #fff; border: 1px solid var(--sr-border); border-radius: var(--sr-radius-sm); padding: 8px 10px; font-size: 13px; color: var(--sr-fg); }
  .sr-input--multi { min-height: 60px; }
  .sr-input--code { font-family: ui-monospace, Menlo, monospace; font-size: 12px; background: var(--sr-surface); white-space: pre-wrap; line-height: 1.4; }
  .sr-helper { font-size: 11.5px; color: var(--sr-fg-dim); }

  .sr-range-wrap { display: flex; align-items: center; gap: 12px; }
  .sr-range { flex: 1; height: 6px; background: var(--sr-border); border-radius: 999px; position: relative; }
  .sr-range-fill { position: absolute; left: 0; top: 0; bottom: 0; width: 25%; background: var(--sr-fg); border-radius: 999px; }
  .sr-range-knob { position: absolute; left: 25%; top: 50%; transform: translate(-50%, -50%); width: 18px; height: 18px; border-radius: 50%; background: #fff; border: 2px solid var(--sr-fg); }
  .sr-range-val { font-size: 13px; color: var(--sr-fg); min-width: 18px; text-align: right; }

  .sr-select { background: #fff; border: 1px solid var(--sr-border); border-radius: var(--sr-radius-sm); padding: 8px 28px 8px 10px; font-size: 13px; color: var(--sr-fg); position: relative; }
  .sr-select::after { content: "▾"; position: absolute; right: 10px; top: 50%; transform: translateY(-50%); color: var(--sr-fg-dim); font-size: 10px; }

  .sr-radio { display: inline-flex; border: 1px solid var(--sr-border); border-radius: var(--sr-radius-sm); background: #fff; overflow: hidden; align-self: flex-start; }
  .sr-radio-opt { padding: 6px 14px; font-size: 12.5px; color: var(--sr-fg-muted); border-right: 1px solid var(--sr-border); }
  .sr-radio-opt:last-child { border-right: none; }
  .sr-radio-opt.is-selected { background: var(--sr-surface); color: var(--sr-fg); font-weight: 500; }

  .sr-toggle-row { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
  .sr-toggle { display: inline-flex; width: 34px; height: 20px; background: var(--sr-accent); border-radius: 999px; position: relative; flex-shrink: 0; }
  .sr-toggle::after { content: ""; position: absolute; top: 2px; left: 16px; width: 16px; height: 16px; background: #fff; border-radius: 50%; }
  .sr-toggle--off { background: var(--sr-border-strong); }
  .sr-toggle--off::after { left: 2px; }

  .sr-color-row { display: flex; align-items: center; gap: 8px; border: 1px solid var(--sr-border); border-radius: var(--sr-radius-sm); background: #fff; padding: 4px 8px 4px 4px; }
  .sr-swatch { width: 24px; height: 24px; border-radius: 4px; border: 1px solid rgba(10, 37, 64, 0.08); flex-shrink: 0; }
  .sr-hex { font-family: ui-monospace, Menlo, monospace; font-size: 12.5px; color: var(--sr-fg); flex: 1; }

  .sr-gradient { display: flex; flex-direction: column; gap: 8px; }
  .sr-bg-tabs { display: inline-flex; border: 1px solid var(--sr-border); border-radius: var(--sr-radius-sm); background: #fff; overflow: hidden; align-self: flex-start; }
  .sr-bg-tab { padding: 5px 12px; font-size: 12px; color: var(--sr-fg-muted); }
  .sr-bg-tab.is-selected { background: var(--sr-surface); color: var(--sr-fg); font-weight: 500; }
  .sr-gr-row { display: grid; grid-template-columns: 80px 1fr; gap: 8px; align-items: center; }
  .sr-gr-label { font-size: 11.5px; color: var(--sr-fg-dim); }
  .sr-add-color { font-size: 12px; color: var(--sr-accent); font-weight: 500; padding: 4px 0; display: inline-flex; align-items: center; gap: 4px; }

  .sr-upload { border: 1.5px dashed var(--sr-border-strong); border-radius: var(--sr-radius-sm); background: var(--sr-surface); padding: 26px 16px; text-align: center; display: flex; flex-direction: column; align-items: center; gap: 4px; }
  .sr-upload-icon { width: 32px; height: 32px; background: var(--sr-border); border-radius: var(--sr-radius-sm); display: inline-flex; align-items: center; justify-content: center; font-size: 18px; color: var(--sr-fg-muted); margin-bottom: 6px; }
  .sr-upload-title { font-size: 13px; color: var(--sr-fg); font-weight: 500; }
  .sr-upload-sub { font-size: 11.5px; color: var(--sr-fg-dim); }
  .sr-media-link { font-size: 13px; color: var(--sr-fg); padding: 6px 10px; background: #fff; border: 1px solid var(--sr-border); border-radius: var(--sr-radius-sm); }

  .sr-box4 { display: grid; grid-template-columns: auto 1fr auto 1fr; gap: 6px; align-items: center; }
  .sr-box4-icon { width: 24px; height: 24px; border: 1.5px solid var(--sr-border-strong); border-radius: 3px; background: #fff; position: relative; }
  .sr-box4-icon::after { content: ""; position: absolute; background: var(--sr-fg); }
  .sr-pi-t::after { top: 0; left: 0; right: 0; height: 2px; }
  .sr-pi-r::after { top: 0; right: 0; bottom: 0; width: 2px; }
  .sr-pi-b::after { left: 0; right: 0; bottom: 0; height: 2px; }
  .sr-pi-l::after { top: 0; left: 0; bottom: 0; width: 2px; }
  .sr-cr-tl::after { top: 0; left: 0; width: 10px; height: 10px; border-top: 2px solid var(--sr-fg); border-left: 2px solid var(--sr-fg); background: transparent; border-radius: 4px 0 0 0; }
  .sr-cr-tr::after { top: 0; right: 0; width: 10px; height: 10px; border-top: 2px solid var(--sr-fg); border-right: 2px solid var(--sr-fg); background: transparent; border-radius: 0 4px 0 0; }
  .sr-cr-bl::after { bottom: 0; left: 0; width: 10px; height: 10px; border-bottom: 2px solid var(--sr-fg); border-left: 2px solid var(--sr-fg); background: transparent; border-radius: 0 0 0 4px; }
  .sr-cr-br::after { bottom: 0; right: 0; width: 10px; height: 10px; border-bottom: 2px solid var(--sr-fg); border-right: 2px solid var(--sr-fg); background: transparent; border-radius: 0 0 4px 0; }
  .sr-box4-input { background: #fff; border: 1px solid var(--sr-border); border-radius: var(--sr-radius-sm); padding: 6px 26px 6px 8px; font-size: 12px; color: var(--sr-fg); position: relative; }
  .sr-box4-input::after { content: "px"; position: absolute; right: 8px; top: 50%; transform: translateY(-50%); font-size: 10.5px; color: var(--sr-fg-dim); }

  .sr-border-row { display: grid; grid-template-columns: 64px 1fr 36px 1fr; gap: 6px; align-items: center; }

  .sr-chip { display: inline-flex; align-items: center; gap: 8px; padding: 8px 12px; border: 1px solid var(--sr-border); background: #fff; border-radius: var(--sr-radius-sm); font-size: 12.5px; color: var(--sr-fg-muted); align-self: stretch; }
  .sr-chip-icon { width: 16px; height: 16px; background: var(--sr-border); border-radius: 3px; flex-shrink: 0; }
  .sr-chip-list { display: flex; flex-wrap: wrap; gap: 6px; }

  .sr-align { display: inline-flex; border: 1px solid var(--sr-border); border-radius: var(--sr-radius-sm); background: #fff; overflow: hidden; align-self: flex-start; }
  .sr-align-opt { padding: 6px 12px; font-size: 12px; color: var(--sr-fg-muted); display: inline-flex; align-items: center; gap: 4px; border-right: 1px solid var(--sr-border); }
  .sr-align-opt:last-child { border-right: none; }
  .sr-align-opt.is-selected { background: var(--sr-surface); color: var(--sr-fg); font-weight: 500; }
  .sr-align-ico { display: inline-block; width: 12px; height: 10px; position: relative; }
  .sr-align-ico::before, .sr-align-ico::after, .sr-align-ico i { content: ""; position: absolute; height: 1.5px; background: currentColor; border-radius: 1px; }
  .sr-align-ico::before { top: 0; left: 0; right: 0; }
  .sr-align-ico i { top: 4px; display: block; }
  .sr-align-ico::after { bottom: 0; left: 0; right: 0; }
  .sr-align--l i { left: 0; width: 70%; }
  .sr-align--c i { left: 15%; width: 70%; }
  .sr-align--r i { right: 0; width: 70%; }

  .sr-collapsible { background: #fff; border: 1px solid var(--sr-border); border-radius: var(--sr-radius-sm); padding: 10px 12px; display: flex; align-items: center; justify-content: space-between; font-size: 13px; color: var(--sr-fg); font-weight: 500; }
  .sr-collapsible::after { content: "▾"; font-size: 10px; color: var(--sr-fg-dim); }

  /* DISCLOSURES */
  .sr-disclosures { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 16px; }
  .sr-disclose { border: 1px solid var(--sr-border); border-radius: var(--sr-radius-sm); background: #fff; overflow: hidden; flex: 1 1 280px; min-width: 0; }
  .sr-disclose[open] { background: var(--sr-surface-2); }
  .sr-disclose > summary {
    padding: 9px 14px; cursor: pointer; user-select: none;
    display: flex; align-items: center; gap: 8px;
    font-size: 12.5px; font-weight: 500; color: var(--sr-fg);
    list-style: none;
  }
  .sr-disclose > summary::-webkit-details-marker { display: none; }
  .sr-disclose > summary::before { content: "▸"; display: inline-block; font-size: 10px; color: var(--sr-fg-dim); width: 10px; transition: transform .15s; }
  .sr-disclose[open] > summary::before { transform: rotate(90deg); }
  .sr-disclose > summary .sr-dk { font-family: ui-monospace, Menlo, monospace; font-size: 10px; padding: 1px 6px; border-radius: 3px; font-weight: 600; background: var(--sr-surface); color: var(--sr-fg-muted); border: 1px solid var(--sr-border); margin-left: auto; }
  .sr-disclose[open] > summary .sr-dk { background: var(--sr-accent-soft); color: var(--sr-accent); border-color: var(--sr-accent-soft); }
  .sr-disclose > .sr-dc { padding: 0; border-top: 1px solid var(--sr-border); }
  .sr-disclose pre { margin: 0; padding: 14px 16px; background: var(--sr-code-bg); color: var(--sr-code-fg); font-family: ui-monospace, Menlo, monospace; font-size: 12.5px; line-height: 1.55; overflow-x: auto; white-space: pre; }
  .sr-disclose pre code { background: transparent; border: 0; padding: 0; color: inherit; font-size: inherit; }
  .sr-disclose--tip > summary { color: #7a4a00; }
  .sr-disclose--tip { border-color: #fde68a; background: #fffbeb; }
  .sr-disclose--tip[open] { background: #fffbeb; }
  .sr-disclose--tip .sr-dc { background: #fffbeb; }
  .sr-disclose--tip .sr-tip-body { padding: 12px 16px; font-size: 13px; color: #78350f; line-height: 1.55; }
  .sr-disclose--tip .sr-tip-body code { background: rgba(146, 64, 14, 0.1); border-color: rgba(146, 64, 14, 0.2); color: #78350f; }

  .sr-nav .is-pattern { color: var(--sr-accent); font-weight: 600; }
{%- endstyle -%}

{% comment %}
  Schema Controls Reference — blocks-based content.
  Each entry is a schema_entry block. Settings defined inline in section schema.
  Preset provides 40 initial entries.
{% endcomment %}

