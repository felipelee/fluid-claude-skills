{%- style -%}
  .featured-products.section-{{ section.id }} {
    {%- assign p = section.settings.section_padding -%}
    {%- if p -%}padding: {{ p.top | default: 80 }}px {{ p.right | default: 0 }}px {{ p.bottom | default: 80 }}px {{ p.left | default: 0 }}px;{%- else -%}padding: 80px 0;{%- endif -%}
    {%- assign r = section.settings.section_border_radius -%}
    {%- if r -%}border-radius: {{ r.tl }}px {{ r.tr }}px {{ r.br }}px {{ r.bl }}px;{%- endif -%}
    {% if section.settings.section_border_width > 0 %}border: {{ section.settings.section_border_width }}px solid {{ section.settings.section_border_color }};{% endif %}
    background-color: {{ section.settings.background_color | default: 'transparent' }};
    {%- if section.settings.background_image != blank -%}
      background-image: url({{ section.settings.background_image | img_url: '2400x' }});
      background-size: cover; background-position: center; background-repeat: no-repeat;
    {%- endif -%}
  }
  .featured-products.section-{{ section.id }} .featured-products__container {
    position: relative;
    max-width: {{ section.settings.container_max_width | default: '1280px' }};
    margin: 0 auto;
    {%- assign cp = section.settings.container_padding -%}
    {%- if cp -%}padding: {{ cp.top | default: 0 }}px {{ cp.right | default: 64 }}px {{ cp.bottom | default: 0 }}px {{ cp.left | default: 64 }}px;{%- else -%}padding: 0 64px;{%- endif -%}
    background-color: {{ section.settings.container_background_color | default: 'transparent' }};
    {%- if section.settings.container_background_image != blank -%}
      background-image: url({{ section.settings.container_background_image | img_url: '2400x' }});
      background-size: cover; background-position: center; background-repeat: no-repeat;
    {%- endif -%}
    {%- assign ccr = section.settings.container_border_radius -%}
    {%- if ccr -%}border-radius: {{ ccr.tl }}px {{ ccr.tr }}px {{ ccr.br }}px {{ ccr.bl }}px;{%- endif -%}
    {% if section.settings.container_border_width > 0 %}border: {{ section.settings.container_border_width }}px solid {{ section.settings.container_border_color }};{% endif %}
    overflow: hidden;
  }
  {%- if section.settings.container_overlay_color != blank and section.settings.container_overlay_opacity > 0 -%}
    {%- assign _cov = section.settings.container_overlay_opacity | divided_by: 100.0 -%}
    .featured-products.section-{{ section.id }} .featured-products__container::before {
      content: ""; position: absolute; inset: 0;
      background: {{ section.settings.container_overlay_color }};
      opacity: {{ _cov }};
      pointer-events: none;
    }
  {%- endif -%}
  .featured-products.section-{{ section.id }} .featured-products__container > * { position: relative; }
  @media (max-width: 991px) { .featured-products.section-{{ section.id }} .featured-products__container { padding-left: 24px; padding-right: 24px; } }
  @media (max-width: 767px) { .featured-products.section-{{ section.id }} .featured-products__container { padding-left: 16px; padding-right: 16px; } }

  .featured-products.section-{{ section.id }} .featured-products__intro {
    text-align: {{ section.settings.intro_alignment | default: 'center' }};
    {%- if section.settings.intro_alignment == 'center' -%}margin: 0 auto 56px; max-width: 720px;{%- else -%}margin-bottom: 56px;{%- endif -%}
    display: flex; flex-direction: column; gap: 12px;
  }
  .featured-products.section-{{ section.id }} .featured-products__intro-buttons {
    display: flex; flex-wrap: wrap; gap: 12px; margin-top: 8px;
    justify-content: {% case section.settings.intro_alignment %}{% when 'center' %}center{% when 'right' %}flex-end{% else %}flex-start{% endcase %};
  }
  @media (max-width: 767px) { .featured-products.section-{{ section.id }} .featured-products__intro { margin-bottom: 32px; } }

  .featured-products.section-{{ section.id }} .featured-products__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop | default: 4 }}, minmax(0, 1fr));
    gap: {{ section.settings.gap | default: 24 }}px;
  }
  @media (max-width: 991px) { .featured-products.section-{{ section.id }} .featured-products__grid { grid-template-columns: repeat({{ section.settings.columns_tablet | default: 3 }}, minmax(0, 1fr)); } }
  @media (max-width: 767px) { .featured-products.section-{{ section.id }} .featured-products__grid { grid-template-columns: repeat({{ section.settings.columns_mobile | default: 2 }}, minmax(0, 1fr)); gap: 16px; } }

  .featured-products.section-{{ section.id }} .product-card {
    display: flex; flex-direction: column; gap: 8px;
    text-decoration: none; color: inherit;
    transition: transform .2s ease;
  }
  .featured-products.section-{{ section.id }} .product-card:hover { transform: translateY(-2px); }
  .featured-products.section-{{ section.id }} .product-card .media-wrap {
    aspect-ratio: {{ section.settings.card_aspect_ratio | default: '1/1' }};
    margin-bottom: 8px;
    {%- assign cbr = section.settings.card_border_radius -%}
    {%- if cbr -%}border-radius: {{ cbr.tl }}px {{ cbr.tr }}px {{ cbr.br }}px {{ cbr.bl }}px;{%- endif -%}
  }
  .featured-products.section-{{ section.id }} .product-card .media-wrap img {
    width: 100%; height: 100%; object-fit: cover; object-position: center;
  }
  .featured-products.section-{{ section.id }} .product-card__title {
    font-size: {{ section.settings.title_font_size | default: 15 }}px;
    font-weight: 500; line-height: 1.4; color: {{ section.settings.title_color | default: 'var(--clr-primary)' }};
    margin: 0;
  }
  .featured-products.section-{{ section.id }} .product-card__price {
    font-size: {{ section.settings.price_font_size | default: 14 }}px;
    color: {{ section.settings.price_color | default: 'var(--clr-body)' }};
    margin: 0;
  }
  .featured-products.section-{{ section.id }} .product-card__compare {
    text-decoration: line-through; opacity: 0.6; margin-right: 6px;
  }
{%- endstyle -%}

<section class="featured-products section-{{ section.id }}" {{ section.fluid_attributes }}>
  <div class="featured-products__container">

    {%- assign eyebrow_block = section.blocks | where: 'type', 'eyebrow' | first -%}
    {%- assign heading_block = section.blocks | where: 'type', 'heading' | first -%}
    {%- assign subhead_block = section.blocks | where: 'type', 'subhead' | first -%}
    {%- assign button_blocks = section.blocks | where: 'type', 'button' -%}

    {% if eyebrow_block or heading_block or subhead_block or button_blocks.size > 0 %}
      <div class="featured-products__intro">
        {% if eyebrow_block %}<div class="rte" {{ eyebrow_block.fluid_attributes }}>{{ eyebrow_block.settings.text }}</div>{% endif %}
        {% if heading_block %}<div class="rte" {{ heading_block.fluid_attributes }}>{{ heading_block.settings.text }}</div>{% endif %}
        {% if subhead_block %}<div class="rte" {{ subhead_block.fluid_attributes }}>{{ subhead_block.settings.text }}</div>{% endif %}
        {% if button_blocks.size > 0 %}
          <div class="featured-products__intro-buttons">
            {% for block in button_blocks %}
              {% capture _btn_style %}
                {% if block.settings.background_color != blank %}background-color: {{ block.settings.background_color }};{% endif %}
                {% if block.settings.text_color != blank %}color: {{ block.settings.text_color }};{% endif %}
                {% if block.settings.font_size != blank %}font-size: {{ block.settings.font_size }}px;{% endif %}
                {% if block.settings.font_family != blank %}font-family: {{ block.settings.font_family }};{% endif %}
                {% assign bp = block.settings.padding %}{% if bp %}padding: {{ bp.top }}px {{ bp.right }}px {{ bp.bottom }}px {{ bp.left }}px;{% endif %}
                {% assign bbr = block.settings.border_radius %}{% if bbr %}border-radius: {{ bbr.tl }}px {{ bbr.tr }}px {{ bbr.br }}px {{ bbr.bl }}px;{% endif %}
                {% if block.settings.border_width > 0 %}border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};{% endif %}
              {% endcapture %}
              <a href="{{ block.settings.link | default: '#' }}"
                 class="btn btn--{{ block.settings.style | default: 'filled' }}"
                 style="{{ _btn_style | strip_newlines }}"
                 {% if block.settings.open_new_tab %}target="_blank" rel="noopener"{% endif %}
                 {{ block.fluid_attributes }}>
                {{ block.settings.text | escape }}
              </a>
            {% endfor %}
          </div>
        {% endif %}
      </div>
    {% endif %}

    {%- assign src_collection = section.settings.collection -%}
    {%- assign curated_products = src_collection.products -%}
    {%- assign limit = section.settings.products_to_show | default: 8 -%}
    {%- if curated_products and curated_products.size > 0 -%}
      <div class="featured-products__grid">
        {%- for product in curated_products limit: limit -%}
          {%- assign _pimg_url = '' -%}
          {%- if product.images and product.images.size > 0 -%}
            {%- assign _pimg_url = product.images[0].src -%}
          {%- elsif product.image_url != blank -%}
            {%- assign _pimg_url = product.image_url -%}
          {%- elsif product.image -%}
            {%- assign _pimg_url = product.image | image_url -%}
          {%- endif -%}
          <a class="product-card" href="{{ product.url | default: '#' }}">
            <div class="media-wrap">
              {% if _pimg_url != blank %}
                <img src="{{ _pimg_url }}" alt="{{ product.title | escape }}" loading="lazy">
              {% else %}
                <div class="media-wrap__placeholder">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="16" rx="2"/><circle cx="8.5" cy="10" r="1.5"/><path d="M3 16l5-4 4 3 4-5 5 6"/></svg>
                </div>
              {% endif %}
            </div>
            {% if section.settings.show_title %}
              <h3 class="product-card__title">{{ product.title | escape }}</h3>
            {% endif %}
            {% if section.settings.show_price %}
              <p class="product-card__price">
                {% if product.compare_at_price and product.compare_at_price > product.price %}
                  <span class="product-card__compare">{{ product.compare_at_price | money }}</span>
                {% endif %}
                {{ product.price | money }}
              </p>
            {% endif %}
          </a>
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="featured-products__grid">
        {% for i in (1..4) %}
          <div class="product-card">
            <div class="media-wrap">
              <div class="media-wrap__placeholder">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="16" rx="2"/><circle cx="8.5" cy="10" r="1.5"/><path d="M3 16l5-4 4 3 4-5 5 6"/></svg>
              </div>
            </div>
            {% if section.settings.show_title %}<h3 class="product-card__title">Product {{ i }}</h3>{% endif %}
            {% if section.settings.show_price %}<p class="product-card__price">$—</p>{% endif %}
          </div>
        {% endfor %}
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "tag": "section",
  "class": "featured-products-section",
  "settings": [
    { "type": "header", "content": "Products" },
    { "type": "collection", "id": "collection", "label": "Collection",
      "info": "Pick a Fluid collection — the section displays its products in order." },
    { "type": "range", "id": "products_to_show", "label": "Products to show",
      "min": 2, "max": 24, "step": 1, "default": 8 },
    { "type": "checkbox", "id": "show_title", "label": "Show product title", "default": true },
    { "type": "checkbox", "id": "show_price", "label": "Show price", "default": true },

    { "type": "header", "content": "Layout" },
    {
      "type": "select", "id": "intro_alignment", "label": "Intro Alignment", "default": "center",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ]
    },
    { "type": "range", "id": "columns_desktop", "label": "Columns (desktop)", "min": 2, "max": 6, "step": 1, "default": 4 },
    { "type": "range", "id": "columns_tablet",  "label": "Columns (tablet)",  "min": 2, "max": 4, "step": 1, "default": 3 },
    { "type": "range", "id": "columns_mobile",  "label": "Columns (mobile)",  "min": 1, "max": 3, "step": 1, "default": 2 },
    { "type": "range", "id": "gap", "label": "Grid Gap (px)", "min": 8, "max": 48, "step": 2, "default": 24 },

    { "type": "header", "content": "Card" },
    {
      "type": "select", "id": "card_aspect_ratio", "label": "Image Aspect Ratio", "default": "1/1",
      "options": [
        { "value": "1/1",  "label": "Square (1:1)" },
        { "value": "4/3",  "label": "Standard (4:3)" },
        { "value": "4/5",  "label": "Portrait (4:5)" },
        { "value": "3/4",  "label": "Portrait (3:4)" },
        { "value": "3/2",  "label": "Classic (3:2)" }
      ]
    },
    { "type": "corner_radius", "id": "card_border_radius", "label": "Image Border Radius" },
    { "type": "range", "id": "title_font_size", "label": "Title Font Size (px)", "min": 12, "max": 24, "step": 1, "default": 15 },
    { "type": "select", "id": "title_color", "label": "Title Color", "options": "background_colors", "default": "var(--clr-primary)" },
    { "type": "range", "id": "price_font_size", "label": "Price Font Size (px)", "min": 11, "max": 22, "step": 1, "default": 14 },
    { "type": "select", "id": "price_color", "label": "Price Color", "options": "background_colors", "default": "var(--clr-body)" },

    { "type": "header", "content": "Container" },
    { "type": "select", "id": "container_max_width", "label": "Max Width", "default": "1280px",
      "options": [
        { "value": "960px",  "label": "Narrow (960px)" },
        { "value": "1280px", "label": "Default (1280px)" },
        { "value": "1440px", "label": "Wide (1440px)" },
        { "value": "100%",   "label": "Full (100%)" }
      ]
    },
    { "type": "padding", "id": "container_padding", "label": "Container Padding" },
    { "type": "corner_radius", "id": "container_border_radius", "label": "Container Border Radius" },
    { "type": "select", "id": "container_background_color", "label": "Container Background Color", "options": "background_colors", "default": "transparent" },
    { "type": "image_picker", "id": "container_background_image", "label": "Container Background Image" },
    { "type": "select", "id": "container_overlay_color", "label": "Container Overlay Color", "options": "background_colors", "default": "transparent" },
    { "type": "range", "id": "container_overlay_opacity", "label": "Container Overlay Opacity", "min": 0, "max": 100, "step": 5, "default": 0, "unit": "%" },
    { "type": "range", "id": "container_border_width", "label": "Container Border Width", "min": 0, "max": 10, "step": 1, "default": 0, "unit": "px" },
    { "type": "select", "id": "container_border_color", "label": "Container Border Color", "options": "background_colors", "default": "var(--clr-primary)" },

    { "type": "header", "content": "Section Shell" },
    { "type": "padding", "id": "section_padding", "label": "Section Padding" },
    { "type": "corner_radius", "id": "section_border_radius", "label": "Section Border Radius" },
    { "type": "select", "id": "background_color", "label": "Background Color", "options": "background_colors", "default": "transparent" },
    { "type": "image_picker", "id": "background_image", "label": "Background Image" },
    { "type": "range", "id": "section_border_width", "label": "Section Border Width", "min": 0, "max": 10, "step": 1, "default": 0, "unit": "px" },
    { "type": "select", "id": "section_border_color", "label": "Section Border Color", "options": "background_colors", "default": "var(--clr-primary)" }
  ],
  "blocks": [
    {
      "type": "eyebrow",
      "name": "Eyebrow",
      "limit": 1,
      "settings": [
        { "type": "richtext", "id": "text", "label": "Text",
          "default": "<h5 style=\"color: var(--clr-primary); text-transform: uppercase; letter-spacing: 0.08em;\">Shop</h5>" }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        { "type": "richtext", "id": "text", "label": "Text",
          "default": "<h2 style=\"color: var(--clr-primary);\">Featured picks</h2>" }
      ]
    },
    {
      "type": "subhead",
      "name": "Subhead",
      "limit": 1,
      "settings": [
        { "type": "richtext", "id": "text", "label": "Text",
          "default": "<p style=\"color: var(--clr-body); font-size: 17px;\">Curated products our customers love most.</p>" }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "settings": [
        { "type": "header", "content": "Content" },
        { "type": "text", "id": "text", "label": "Text", "default": "Shop all" },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "select", "id": "font_family", "label": "Font Family", "options": "font_families", "default": "var(--ff-body)" },
        { "type": "checkbox", "id": "open_new_tab", "label": "Open in new tab", "default": false },
        { "type": "header", "content": "Style" },
        {
          "type": "radio", "id": "style", "label": "Style", "default": "outline",
          "options": [
            { "value": "filled",  "label": "Filled" },
            { "value": "outline", "label": "Outline" },
            { "value": "text",    "label": "Text only" }
          ]
        },
        { "type": "range", "id": "font_size", "label": "Font Size", "min": 10, "max": 32, "step": 1, "default": 14, "unit": "px" },
        { "type": "padding", "id": "padding", "label": "Padding" },
        { "type": "select", "id": "background_color", "label": "Background Color", "options": "background_colors", "default": "transparent" },
        { "type": "select", "id": "text_color",       "label": "Text Color",       "options": "background_colors", "default": "var(--clr-primary)" },
        { "type": "header", "content": "Shape" },
        { "type": "range", "id": "border_width", "label": "Border Width", "min": 0, "max": 10, "step": 1, "default": 1, "unit": "px" },
        { "type": "select", "id": "border_color", "label": "Border Color", "options": "background_colors", "default": "var(--clr-primary)" },
        { "type": "corner_radius", "id": "border_radius", "label": "Border Radius" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Products",
      "blocks": [
        { "type": "eyebrow" },
        { "type": "heading" },
        { "type": "subhead" },
        { "type": "button" }
      ]
    }
  ]
}
{% endschema %}
