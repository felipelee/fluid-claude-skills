            {
              "value": "1/1",
              "label": "Square (1:1)"
            },
            {
              "value": "4/3",
              "label": "Standard (4:3)"
            },
            {
              "value": "16/9",
              "label": "Widescreen (16:9)"
            },
            {
              "value": "3/2",
              "label": "Classic (3:2)"
            },
            {
              "value": "3/4",
              "label": "Portrait (3:4)"
            },
            {
              "value": "9/16",
              "label": "Portrait mobile (9:16)"
            },
            {
              "value": "21/9",
              "label": "Ultrawide (21:9)"
            }
          ]
        },
        {
