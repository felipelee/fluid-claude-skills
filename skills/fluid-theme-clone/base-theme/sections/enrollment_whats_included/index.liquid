{%- comment -%}
  enrollment_whats_included — high-conversion "what you get" section.
  - Eyebrow / heading / subhead hero blocks
  - 2x2 grid of categories (Products / Tools / Training / Support), each a card
  - Each category has: icon, title, feature list, value amount
  - Big "total value" banner below the grid
{%- endcomment -%}

{%- style -%}
  .ewi.section-{{ section.id }} {
    {%- assign p = section.settings.section_padding -%}
    {%- if p -%}padding: {{ p.top | default: 100 }}px {{ p.right | default: 0 }}px {{ p.bottom | default: 100 }}px {{ p.left | default: 0 }}px;{%- else -%}padding: 100px 0;{%- endif -%}
    {%- assign r = section.settings.section_border_radius -%}
    {%- if r -%}border-radius: {{ r.tl }}px {{ r.tr }}px {{ r.br }}px {{ r.bl }}px;{%- endif -%}
    background-color: {{ section.settings.background_color | default: 'transparent' }};
    {%- if section.settings.background_image != blank -%}background-image: url({{ section.settings.background_image | img_url: '2400x' }});background-size:cover;background-position:center;{%- endif -%}
    {% if section.settings.section_border_width > 0 %}border: {{ section.settings.section_border_width }}px solid {{ section.settings.section_border_color }};{% endif %}
  }
  .ewi.section-{{ section.id }} .ewi__container {
    max-width: {{ section.settings.container_max_width | default: '1280px' }};
    margin: 0 auto; padding: 0 64px;
  }
  @media (max-width: 991px) { .ewi.section-{{ section.id }} .ewi__container { padding: 0 24px; } }
  @media (max-width: 767px) { .ewi.section-{{ section.id }} .ewi__container { padding: 0 16px; } }

  .ewi.section-{{ section.id }} .ewi__intro {
    text-align: {{ section.settings.intro_alignment | default: 'center' }};
    display: flex; flex-direction: column; gap: 12px;
    margin-bottom: 48px;
    {% if section.settings.intro_alignment == 'center' %}max-width: 720px; margin-left: auto; margin-right: auto;{% endif %}
  }
  .ewi.section-{{ section.id }} .ewi__intro > * { margin: 0; }

  .ewi.section-{{ section.id }} .ewi__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop | default: 2 }}, minmax(0, 1fr));
    gap: {{ section.settings.gap | default: 20 }}px;
  }
  @media (max-width: 767px) { .ewi.section-{{ section.id }} .ewi__grid { grid-template-columns: 1fr; } }

  .ewi.section-{{ section.id }} .ewi__card {
    display: flex; flex-direction: column;
    padding: 36px 32px;
    background: {{ section.settings.card_background | default: 'var(--clr-white)' }};
    border: 1.5px solid {{ section.settings.card_border | default: 'var(--clr-gray)' }};
    border-radius: 20px;
    transition: transform .25s ease, box-shadow .25s ease;
  }
  .ewi.section-{{ section.id }} .ewi__card:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 32px -14px rgba(0,0,0,0.18);
  }
  .ewi.section-{{ section.id }} .ewi__card-head {
    display: flex; align-items: center; justify-content: space-between; gap: 12px;
  }
  .ewi.section-{{ section.id }} .ewi__icon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 52px; height: 52px;
    background: {{ section.settings.icon_background | default: 'var(--clr-light)' }};
    color: {{ section.settings.icon_color | default: 'var(--clr-primary)' }};
    border-radius: 14px;
  }
  .ewi.section-{{ section.id }} .ewi__icon svg { width: 22px; height: 22px; }
  .ewi.section-{{ section.id }} .ewi__value {
    font-size: 13px; font-weight: 700;
    color: {{ section.settings.accent_color | default: 'var(--clr-primary)' }};
    background: {{ section.settings.accent_background | default: 'rgba(17, 24, 39, 0.06)' }};
    padding: 6px 12px;
    border-radius: 999px;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }
  .ewi.section-{{ section.id }} .ewi__title {
    margin: 18px 0 0;
    font-size: clamp(20px, 2vw, 26px);
    font-weight: 700; letter-spacing: -0.01em; line-height: 1.2;
    color: {{ section.settings.title_color | default: 'var(--clr-primary)' }};
    font-family: {{ section.settings.title_font | default: 'var(--ff-heading)' }};
  }
  .ewi.section-{{ section.id }} .ewi__subtitle {
    margin: 6px 0 0;
    font-size: 14.5px; line-height: 1.55;
    color: {{ section.settings.body_color | default: 'var(--clr-body)' }};
  }

  .ewi.section-{{ section.id }} .ewi__features {
    margin: 20px 0 0;
    padding: 0;
    list-style: none;
    display: flex; flex-direction: column; gap: 10px;
  }
  .ewi.section-{{ section.id }} .ewi__feature {
    display: grid; grid-template-columns: 18px 1fr; gap: 10px; align-items: start;
    font-size: 14px;
    color: {{ section.settings.body_color | default: 'var(--clr-body)' }};
  }
  .ewi.section-{{ section.id }} .ewi__feature svg {
    width: 18px; height: 18px; margin-top: 2px;
    color: {{ section.settings.check_color | default: 'var(--clr-success)' }};
  }

  .ewi.section-{{ section.id }} .ewi__total {
    margin-top: 48px;
    padding: 36px 40px;
    background: {{ section.settings.total_background | default: 'var(--clr-primary)' }};
    color: {{ section.settings.total_color | default: 'var(--clr-white)' }};
    border-radius: 20px;
    display: flex; align-items: center; justify-content: space-between; gap: 24px;
    flex-wrap: wrap;
  }
  .ewi.section-{{ section.id }} .ewi__total-label {
    font-size: 12px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase;
    opacity: 0.75;
  }
  .ewi.section-{{ section.id }} .ewi__total-row {
    display: flex; align-items: baseline; gap: 14px; margin-top: 4px;
    flex-wrap: wrap;
  }
  .ewi.section-{{ section.id }} .ewi__total-strike {
    font-size: clamp(22px, 2.2vw, 28px);
    text-decoration: line-through; opacity: 0.55;
    font-family: {{ section.settings.title_font | default: 'var(--ff-heading)' }};
  }
  .ewi.section-{{ section.id }} .ewi__total-amount {
    font-size: clamp(36px, 4.4vw, 56px); font-weight: 700; letter-spacing: -0.02em; line-height: 1;
    font-family: {{ section.settings.title_font | default: 'var(--ff-heading)' }};
  }
  .ewi.section-{{ section.id }} .ewi__total-copy {
    max-width: 440px; font-size: 14.5px; line-height: 1.5; opacity: 0.88;
  }
{%- endstyle -%}

{%- capture check_svg -%}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>{%- endcapture -%}

<section class="ewi section-{{ section.id }}" {{ section.fluid_attributes }}>
  <div class="ewi__container">

    {%- assign eyebrow_blocks = section.blocks | where: 'type', 'eyebrow' -%}
    {%- assign heading_blocks = section.blocks | where: 'type', 'heading' -%}
    {%- assign subhead_blocks = section.blocks | where: 'type', 'subhead' -%}
    {% if eyebrow_blocks.size > 0 or heading_blocks.size > 0 or subhead_blocks.size > 0 %}
      <div class="ewi__intro">
        {% for b in eyebrow_blocks %}<div class="rte" {{ b.fluid_attributes }}>{{ b.settings.text }}</div>{% endfor %}
        {% for b in heading_blocks %}<div class="rte" {{ b.fluid_attributes }}>{{ b.settings.text }}</div>{% endfor %}
        {% for b in subhead_blocks %}<div class="rte" {{ b.fluid_attributes }}>{{ b.settings.text }}</div>{% endfor %}
      </div>
    {% endif %}

    {%- assign category_blocks = section.blocks | where: 'type', 'category' -%}
    {% if category_blocks.size > 0 %}
      <div class="ewi__grid">
        {% for block in category_blocks %}
          <article class="ewi__card" {{ block.fluid_attributes }}>
            <div class="ewi__card-head">
              <span class="ewi__icon">
                {% case block.settings.icon %}
                  {% when 'box'      %}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8V21H3V8"/><path d="M1 3h22v5H1z"/><path d="M10 12h4"/></svg>
                  {% when 'tool'     %}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                  {% when 'graduate' %}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
                  {% when 'chat'     %}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                  {% when 'users'    %}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                  {% when 'dashboard'%}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                  {% else %}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                {% endcase %}
              </span>
              {% if block.settings.value != blank %}<span class="ewi__value">{{ block.settings.value | escape }}</span>{% endif %}
            </div>
            <h3 class="ewi__title">{{ block.settings.title | default: 'Category' | escape }}</h3>
            {% if block.settings.subtitle != blank %}<p class="ewi__subtitle">{{ block.settings.subtitle | escape }}</p>{% endif %}
            {% if block.settings.features != blank %}
              <ul class="ewi__features">
                {% assign lines = block.settings.features | split: "\n" %}
                {% for line in lines %}
                  {%- assign _l = line | strip -%}
                  {% if _l != '' %}
                    <li class="ewi__feature">{{ check_svg }}<span>{{ _l | escape }}</span></li>
                  {% endif %}
                {% endfor %}
              </ul>
            {% endif %}
          </article>
        {% endfor %}
      </div>
    {% endif %}

    {% if section.settings.show_total %}
      <div class="ewi__total">
        <div>
          <div class="ewi__total-label">{{ section.settings.total_label | default: 'Everything included, total value' | escape }}</div>
          <div class="ewi__total-row">
            <span class="ewi__total-amount">{{ section.settings.total_amount | default: '$1,400' | escape }}</span>
            {% if section.settings.total_strike != blank %}<span class="ewi__total-strike">{{ section.settings.total_strike | escape }}</span>{% endif %}
          </div>
        </div>
        {% if section.settings.total_copy != blank %}
          <div class="ewi__total-copy">{{ section.settings.total_copy | escape }}</div>
        {% endif %}
      </div>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "Enrollment What's Included",
  "tag": "section",
  "class": "enrollment-whats-included-section",
  "settings": [
    { "type": "header", "content": "Intro" },
    { "type": "radio", "id": "intro_alignment", "label": "Intro alignment", "default": "center",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" }
      ]
    },

    { "type": "header", "content": "Grid" },
    { "type": "range", "id": "columns_desktop", "label": "Columns (desktop)", "min": 1, "max": 4, "step": 1, "default": 2 },
    { "type": "range", "id": "gap",             "label": "Gap (px)",          "min": 12, "max": 40, "step": 4, "default": 20 },

    { "type": "header", "content": "Card colors" },
    { "type": "select", "id": "card_background",    "label": "Card background",    "options": "background_colors", "default": "var(--clr-white)" },
    { "type": "select", "id": "card_border",        "label": "Card border",        "options": "background_colors", "default": "var(--clr-gray)" },
    { "type": "select", "id": "icon_background",    "label": "Icon chip bg",       "options": "background_colors", "default": "var(--clr-light)" },
    { "type": "select", "id": "icon_color",         "label": "Icon color",         "options": "background_colors", "default": "var(--clr-primary)" },
    { "type": "select", "id": "accent_color",       "label": "Value chip text",    "options": "background_colors", "default": "var(--clr-primary)" },
    { "type": "select", "id": "accent_background",  "label": "Value chip bg",      "default": "rgba(17, 24, 39, 0.06)",
      "options": [
        { "value": "rgba(17, 24, 39, 0.06)", "label": "Soft gray" },
        { "value": "rgba(16, 185, 129, 0.12)", "label": "Soft green" },
        { "value": "rgba(245, 158, 11, 0.12)", "label": "Soft amber" },
        { "value": "var(--clr-light)", "label": "Theme light" }
      ]
    },
    { "type": "select", "id": "title_color",        "label": "Title color",        "options": "background_colors", "default": "var(--clr-primary)" },
    { "type": "select", "id": "title_font",         "label": "Title font",         "options": "font_families",     "default": "var(--ff-heading)" },
    { "type": "select", "id": "body_color",         "label": "Body text",          "options": "background_colors", "default": "var(--clr-body)" },
    { "type": "select", "id": "check_color",        "label": "Checkmark color",    "options": "background_colors", "default": "var(--clr-success)" },

    { "type": "header", "content": "Total value banner" },
    { "type": "checkbox", "id": "show_total",     "label": "Show total value banner", "default": true },
    { "type": "text",     "id": "total_label",    "label": "Label",        "default": "Everything included, total value" },
    { "type": "text",     "id": "total_amount",   "label": "Main amount",  "default": "$1,400" },
    { "type": "text",     "id": "total_strike",   "label": "Struck-through compare amount (optional)", "default": "$2,100" },
    { "type": "textarea", "id": "total_copy",     "label": "Supporting copy",
      "default": "You get everything above for a single one-time fee \u2014 plus commission eligibility from day one." },
    { "type": "select",   "id": "total_background", "label": "Banner background", "options": "background_colors", "default": "var(--clr-primary)" },
    { "type": "select",   "id": "total_color",      "label": "Banner text",       "options": "background_colors", "default": "var(--clr-white)" },

    { "type": "header", "content": "Container" },
    { "type": "select", "id": "container_max_width", "label": "Max Width", "default": "1280px",
      "options": [
        { "value": "1080px", "label": "Comfy (1080px)" },
        { "value": "1280px", "label": "Default (1280px)" },
        { "value": "1440px", "label": "Wide (1440px)" }
      ]
    },

    { "type": "header", "content": "Section Shell" },
    { "type": "padding", "id": "section_padding", "label": "Section Padding" },
    { "type": "corner_radius", "id": "section_border_radius", "label": "Section Border Radius" },
    { "type": "select", "id": "background_color", "label": "Background Color", "options": "background_colors", "default": "transparent" },
    { "type": "image_picker", "id": "background_image", "label": "Background Image" },
    { "type": "range", "id": "section_border_width", "label": "Section Border Width", "min": 0, "max": 10, "step": 1, "default": 0, "unit": "px" },
    { "type": "select", "id": "section_border_color", "label": "Section Border Color", "options": "background_colors", "default": "var(--clr-primary)" }
  ],
  "blocks": [
    { "type": "eyebrow", "name": "Eyebrow",
      "settings": [
        { "type": "richtext", "id": "text", "label": "Text",
          "default": "<h5 style=\"color: var(--clr-primary); text-transform: uppercase; letter-spacing: 0.14em; font-size: 12px; font-weight: 600;\">What's included</h5>" }
      ]
    },
    { "type": "heading", "name": "Heading",
      "settings": [
        { "type": "richtext", "id": "text", "label": "Text",
          "default": "<h2 style=\"color: var(--clr-primary); font-size: clamp(32px, 4.5vw, 56px); font-weight: 700; letter-spacing: -0.02em; line-height: 1.05;\">Everything you need to earn from day one.</h2>" }
      ]
    },
    { "type": "subhead", "name": "Subhead",
      "settings": [
        { "type": "richtext", "id": "text", "label": "Text",
          "default": "<p style=\"color: var(--clr-body); font-size: clamp(15px, 1.3vw, 17px); line-height: 1.55;\">Products, tools, training, and support \u2014 hand-picked to get you profitable fast.</p>" }
      ]
    },
    { "type": "category", "name": "Category card",
      "settings": [
        { "type": "radio", "id": "icon", "label": "Icon", "default": "box",
          "options": [
            { "value": "box",       "label": "Box (products)" },
            { "value": "tool",      "label": "Tool (tools)" },
            { "value": "graduate",  "label": "Graduate (training)" },
            { "value": "chat",      "label": "Chat (support)" },
            { "value": "users",     "label": "Users (community)" },
            { "value": "dashboard", "label": "Dashboard (software)" }
          ]
        },
        { "type": "text",     "id": "title",    "label": "Title",    "default": "Full starter kit" },
        { "type": "text",     "id": "value",    "label": "Value chip (e.g. $300 value)", "default": "$300 value" },
        { "type": "text",     "id": "subtitle", "label": "Subtitle",
          "default": "Everything you need to share, sample, and sell." },
        { "type": "textarea", "id": "features", "label": "Features (one per line)",
          "default": "Bestselling products\nProduct samples for sharing\nBranded packaging\nGetting-started guide" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Enrollment What's Included",
      "blocks": [
        { "type": "eyebrow" },
        { "type": "heading" },
        { "type": "subhead" },
        { "type": "category", "settings": { "icon": "box",       "title": "Full starter kit",     "value": "$300 value", "subtitle": "Everything you need to share, sample, and sell.", "features": "Bestselling products\nProduct samples for sharing\nBranded packaging\nGetting-started guide" } },
        { "type": "category", "settings": { "icon": "dashboard", "title": "Personal dashboard",   "value": "$240 / yr value", "subtitle": "Your always-on business cockpit.", "features": "Personal website\nOrder + commission tracker\nTeam-view analytics\nCRM to manage leads" } },
        { "type": "category", "settings": { "icon": "graduate",  "title": "Training & playbooks", "value": "$500 value", "subtitle": "Learn the exact systems top earners use.", "features": "Weekly live training\nOn-demand video library\nSales + social-selling playbooks\nCertification path" } },
        { "type": "category", "settings": { "icon": "chat",      "title": "Ongoing support",      "value": "Priceless", "subtitle": "We're with you every step.", "features": "Dedicated onboarding coach\n24/7 chat support\nPrivate member community\nMonthly leadership calls" } }
      ]
    }
  ]
}
{% endschema %}
