{% comment %} Handle background_image - can be string URL or object with url/fluid_media_id {% endcomment %}
{% assign bg_url = '' %}
{% assign bg_fluid_media_id = '' %}

{% if section.settings.background_image %}
  {% if section.settings.background_image.url %}
    {% assign bg_url = section.settings.background_image.url %}
    {% if section.settings.background_image.fluid_media_id %}
      {% assign bg_fluid_media_id = section.settings.background_image.fluid_media_id %}
      {% assign bg_embed_type = section.settings.background_image.embed_type %}
    {% endif %}
  {% else %}
    {% assign bg_url = section.settings.background_image %}
  {% endif %}
{% endif %}

{% assign use_fluid_widget = false %}
{% if bg_fluid_media_id != '' %}
  {% assign use_fluid_widget = true %}
{% endif %}

<!-- Blog section  -->
{%- style -%}
  .section-{{ section.id }} {
    background-color: {{ section.settings.background_color | default: '#ffffff' }};
    {%- assign p = section.settings.section_padding -%}
    {%- if p -%}
      {%- capture pt -%}{{ p.top }}{%- endcapture -%}
      {%- capture pb -%}{{ p.bottom }}{%- endcapture -%}
      {%- capture pl -%}{{ p.left }}{%- endcapture -%}
      {%- capture pr -%}{{ p.right }}{%- endcapture -%}
      padding-top: {% if pt contains 'var(' %}{{ pt }}{% else %}{{ pt }}px{% endif %};
      padding-bottom: {% if pb contains 'var(' %}{{ pb }}{% else %}{{ pb }}px{% endif %};
      padding-left: {% if pl contains 'var(' %}{{ pl }}{% else %}{{ pl }}px{% endif %};
      padding-right: {% if pr contains 'var(' %}{{ pr }}{% else %}{{ pr }}px{% endif %};
    {%- endif -%}
    {%- assign sr = section.settings.section_border_radius -%}
    {%- if sr -%}
      {%- capture sr_tl -%}{{ sr.tl }}{%- endcapture -%}
      {%- capture sr_tr -%}{{ sr.tr }}{%- endcapture -%}
      {%- capture sr_br -%}{{ sr.br }}{%- endcapture -%}
      {%- capture sr_bl -%}{{ sr.bl }}{%- endcapture -%}
      border-radius: {% if sr_tl contains 'var(' %}{{ sr_tl }}{% else %}{{ sr_tl }}px{% endif %} {% if sr_tr contains 'var(' %}{{ sr_tr }}{% else %}{{ sr_tr }}px{% endif %} {% if sr_br contains 'var(' %}{{ sr_br }}{% else %}{{ sr_br }}px{% endif %} {% if sr_bl contains 'var(' %}{{ sr_bl }}{% else %}{{ sr_bl }}px{% endif %};
    {%- endif -%}
    {%- assign sb = section.settings.section_border -%}
    {%- if sb.width -%}
      border: {{ sb.width }} solid {{ sb.color }};
    {%- endif -%}
  }
{%- endstyle -%}

<section class="blog-section section-{{ section.id }}" data-bg="{% unless use_fluid_widget %}{{ bg_url }}{% endunless %}">
  {% if use_fluid_widget %}
    <fluid-media-widget class="fluid-media-widget-background" media-id="{{ bg_fluid_media_id }}" responsive="true" embed-type="{{ bg_embed_type | default: 'inline' }}" data-fluid-widget="true"></fluid-media-widget>
  {% endif %}
  <div class="container">
    {%- assign section_title_block = section.blocks | where: 'type', 'section_title' | first -%}
    {%- assign section_description_block = section.blocks | where: 'type', 'section_description' | first -%}
    <div class="header text-center flex flex-col {{ section.settings.title_spacing_mobile | default: 'space-xl' }} {{ section.settings.title_spacing_desktop | default: 'lg:space-2xl' }}">
      {%- if section_title_block and section_title_block.settings.text != blank -%}
        <div class="rte" {{ section_title_block.fluid_attributes }}>{{ section_title_block.settings.text }}</div>
      {%- endif -%}
      {%- if section_description_block and section_description_block.settings.text != blank -%}
        <div class="rte" {{ section_description_block.fluid_attributes }}>{{ section_description_block.settings.text }}</div>
      {%- endif -%}
    </div>

    <div class="blog-grid-section {{ section.settings.content_spacing_mobile | default: 'pt-5xl' }} {{ section.settings.content_spacing_desktop | default: 'lg:pt-5xl' }}">
      <div class="grid grid-cols-1 {{ section.settings.grid_columns_tablet | default: 'lg-tab-grid-cols-2' }} {{ section.settings.grid_columns_desktop | default: 'xl-desktop-grid-cols-3' }} {{ section.settings.grid_gap_mobile | default: 'space-5xl' }} {{ section.settings.grid_gap_desktop | default: 'lg:space-5xl' }} blog-grid">
        {%- assign posts_per_page = section.settings.posts_per_page | default: 12 -%}
        {%- assign blog_image_block = section.blocks | where: 'type', 'blog_image' | first -%}
        {%- assign blog_category_block = section.blocks | where: 'type', 'blog_category' | first -%}
        {%- assign blog_title_block = section.blocks | where: 'type', 'blog_title' | first -%}
        {%- assign blog_excerpt_block = section.blocks | where: 'type', 'blog_excerpt' | first -%}
        {%- assign blog_author_block = section.blocks | where: 'type', 'blog_author' | first -%}
        {%- assign blog_button_block = section.blocks | where: 'type', 'blog_button' | first -%}

        {%- if posts.size > 0 -%}
          {%- for post in posts limit: posts_per_page -%}
            {%- assign post_url = post.url | default: post.preview_url | default: '#' -%}
            <div class="blog-col flex flex-col {{ section.settings.blog_item_spacing_mobile | default: 'space-xl' }} {{ section.settings.blog_item_spacing_desktop | default: 'lg:space-2xl' }}">
              {%- if section.settings.show_image -%}
                {%- assign post_image_url = '' -%}
                {%- assign post_image_obj = null -%}
                {%- if post.image_url != blank -%}
                  {%- assign post_image_url = post.image_url -%}
                {%- elsif post.image != blank -%}
                  {%- assign post_image_obj = post.image -%}
                  {%- assign post_image_url = post.image | image_url: width: 600 -%}
                {%- endif -%}
                {%- assign cr = blog_image_block.settings.image_border_radius | default: section.settings.image_border_radius -%}
                {%- assign _img_cr_style = '' -%}
                {%- if cr -%}
                  {%- capture cr_tl -%}{{ cr.tl }}{%- endcapture -%}{%- capture cr_tr -%}{{ cr.tr }}{%- endcapture -%}{%- capture cr_br -%}{{ cr.br }}{%- endcapture -%}{%- capture cr_bl -%}{{ cr.bl }}{%- endcapture -%}
                  {%- capture _img_cr_style -%}border-radius: {% if cr_tl contains 'var(' %}{{ cr_tl }}{% else %}{{ cr_tl }}px{% endif %} {% if cr_tr contains 'var(' %}{{ cr_tr }}{% else %}{{ cr_tr }}px{% endif %} {% if cr_br contains 'var(' %}{{ cr_br }}{% else %}{{ cr_br }}px{% endif %} {% if cr_bl contains 'var(' %}{{ cr_bl }}{% else %}{{ cr_bl }}px{% endif %}; {%- endcapture -%}
                {%- endif -%}
                <figure class="blog-image relative overflow-hidden" style="{{ _img_cr_style }}height: {{ blog_image_block.settings.image_height | default: section.settings.image_height | default: 'auto' }};" {% if blog_image_block %}{{ blog_image_block.fluid_attributes }}{% endif %}>
                  {%- assign img_input = post_image_obj -%}
                  {%- assign img_fluid_media_id = '' -%}
                  {%- if img_input and img_input.fluid_media_id -%}
                    {%- assign img_fluid_media_id = img_input.fluid_media_id -%}
                    {%- assign img_embed_type = img_input.embed_type -%}
                  {%- endif -%}
                  {%- assign use_fluid_image_widget = false -%}
                  {%- if img_fluid_media_id != '' -%}
                    {%- assign use_fluid_image_widget = true -%}
                  {%- endif -%}
                  {%- assign _fit_class = 'image-cover' -%}
                  {%- case blog_image_block.settings.media_fit -%}
                    {%- when 'contain' -%}{%- assign _fit_class = 'image-contain' -%}
                    {%- when 'fit-width' -%}{%- assign _fit_class = 'image-cover' -%}
                    {%- when 'fit-height' -%}{%- assign _fit_class = 'image-contain' -%}
                  {%- endcase -%}
                  {%- capture _media_style -%}
                    {% if blog_image_block.settings.max_width != blank %}max-width: {{ blog_image_block.settings.max_width }}px;{% endif %}
                    {% if blog_image_block.settings.max_height != blank %}max-height: {{ blog_image_block.settings.max_height }}px;{% endif %}
                  {%- endcapture -%}
                  {%- if use_fluid_image_widget -%}
                    <fluid-media-widget class="fluid-media-widget-image" media-id="{{ img_fluid_media_id }}" responsive="true" embed-type="{{ img_embed_type | default: 'inline' }}" data-fluid-widget="true"></fluid-media-widget>
                  {%- elsif post_image_url != blank -%}
                    <div class="media-container" style="{{ _media_style }}">
                    <img src="{{ post_image_url }}" alt="{{ post.title | escape }}" class="{{ _fit_class }} media-container" style="{{ _media_style }}" loading="lazy" width="" height=""/>
                    </div>
                  {%- else -%}
                    <div class="media-container" style="{{ _media_style }}">
                    <img src="{{ 'blog-placeholder.png' | asset_url }}" alt="blog" class="{{ _fit_class }} media-container" style="{{ _media_style }}" width="" height=""/>
                    </div>
                  {%- endif -%}
                </figure>
              {%- endif -%}

              <div class="blog-content flex flex-col {{ section.settings.blog_content_spacing_mobile | default: 'space-md' }} {{ section.settings.blog_content_spacing_desktop | default: 'lg:space-lg' }}">
                {%- if section.settings.show_category and post.category -%}
                  <div class="blog-category" {% if blog_category_block %}{{ blog_category_block.fluid_attributes }}{% endif %}>
                    <span>
                      {{ post.category.title | default: post.category }}
                    </span>
                  </div>
                {%- endif -%}

                {%- if section.settings.show_title -%}
                  <div class="rte" {% if blog_title_block %}{{ blog_title_block.fluid_attributes }}{% endif %}>
                    <a href="{{ post_url }}" class="text-inherit hover:opacity-80 transition-opacity">{{ post.title }}</a>
                  </div>
                {%- endif -%}

                {%- if section.settings.show_excerpt -%}
                  {%- assign post_excerpt = post.excerpt | default: post.summary -%}
                  {%- if post_excerpt != blank -%}
                    <p {% if blog_excerpt_block %}{{ blog_excerpt_block.fluid_attributes }}{% endif %}>
                      {{ post_excerpt | strip_html | truncate: 150 }}
                    </p>
                  {%- endif -%}
                {%- endif -%}

                {%- if section.settings.show_author or section.settings.show_date -%}
                  <div class="blog-author flex align-center {{ section.settings.author_gap | default: 'space-sm' }}" {% if blog_author_block %}{{ blog_author_block.fluid_attributes }}{% endif %}>
                    {%- if section.settings.show_author -%}
                      {%- assign post_author = post.author | default: post.post_author -%}
                      {%- if post_author != blank -%}
                        {%- if section.settings.show_author_image -%}
                          <img src="{{ 'avatar.png' | asset_url }}" alt="{{ post_author }}" class="rounded-full w-10 h-10 object-cover" loading="lazy" width="" height=""/>
                        {%- endif -%}
                        <div class="flex flex-col {{ section.settings.author_info_spacing | default: 'space-xs' }}">
                          <p>
                            {{ post_author }}
                          </p>
                          {%- if section.settings.show_date -%}
                            {%- assign post_date = post.published_at | default: post.post_date -%}
                            {%- if post_date != blank -%}
                              <p class="text-xs">
                                {{ post_date | date: '%b %d, %Y' }}
                              </p>
                            {%- endif -%}
                          {%- endif -%}
                        </div>
                      {%- elsif section.settings.show_date -%}
                        {%- assign post_date = post.published_at | default: post.post_date -%}
                        {%- if post_date != blank -%}
                          <p>
                            {{ post_date | date: '%b %d, %Y' }}
                          </p>
                        {%- endif -%}
                      {%- endif -%}
                    {%- elsif section.settings.show_date -%}
                      {%- assign post_date = post.published_at | default: post.post_date -%}
                      {%- if post_date != blank -%}
                        <p>
                          {{ post_date | date: '%b %d, %Y' }}
                        </p>
                      {%- endif -%}
                    {%- endif -%}
                  </div>
                {%- endif -%}

                {%- if section.settings.show_read_more -%}
                  <div class="blog-btn {{ blog_button_block.settings.margin_top | default: section.settings.read_more_margin_top | default: 'mt-md' }}" {% if blog_button_block %}{{ blog_button_block.fluid_attributes }}{% endif %}>
                    <a href="{{ post_url }}" class="btn {{ blog_button_block.settings.button_style | default: section.settings.read_more_button_style | default: 'btn-link' }}" style="color: {{ blog_button_block.settings.color | default: section.settings.read_more_button_color | default: '#000000' }};">
                      <span>{{ blog_button_block.settings.text | default: section.settings.read_more_button_text | default: "Read more" }}</span>
                      {%- assign _show_icon = blog_button_block.settings.show_icon | default: section.settings.show_read_more_icon | default: true -%}
                      {%- if _show_icon -%}
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="25" viewBox="0 0 24 25" fill="none" class="mt-1">
                          <path d="M9.70697 17.3491L15.414 11.6421L9.70697 5.93506L8.29297 7.34906L12.586 11.6421L8.29297 15.9351L9.70697 17.3491Z" fill="currentColor" />
                        </svg>
                      {%- endif -%}
                    </a>
                  </div>
                {%- endif -%}
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

