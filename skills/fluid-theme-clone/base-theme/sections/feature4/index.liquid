{%- style -%}
  .section-{{ section.id }} {
    {%- assign p = section.settings.section_padding -%}
    {%- if p -%}
      {%- capture pt -%}{{ p.top }}{%- endcapture -%}
      {%- capture pb -%}{{ p.bottom }}{%- endcapture -%}
      {%- capture pl -%}{{ p.left }}{%- endcapture -%}
      {%- capture pr -%}{{ p.right }}{%- endcapture -%}
      padding-top: {% if pt contains 'var(' %}{{ pt }}{% else %}{{ pt }}px{% endif %};
      padding-bottom: {% if pb contains 'var(' %}{{ pb }}{% else %}{{ pb }}px{% endif %};
      padding-left: {% if pl contains 'var(' %}{{ pl }}{% else %}{{ pl }}px{% endif %};
      padding-right: {% if pr contains 'var(' %}{{ pr }}{% else %}{{ pr }}px{% endif %};
    {%- endif -%}
    {%- assign sr = section.settings.section_border_radius -%}
    {%- if sr -%}
      {%- capture sr_tl -%}{{ sr.tl }}{%- endcapture -%}
      {%- capture sr_tr -%}{{ sr.tr }}{%- endcapture -%}
      {%- capture sr_br -%}{{ sr.br }}{%- endcapture -%}
      {%- capture sr_bl -%}{{ sr.bl }}{%- endcapture -%}
      border-radius: {% if sr_tl contains 'var(' %}{{ sr_tl }}{% else %}{{ sr_tl }}px{% endif %} {% if sr_tr contains 'var(' %}{{ sr_tr }}{% else %}{{ sr_tr }}px{% endif %} {% if sr_br contains 'var(' %}{{ sr_br }}{% else %}{{ sr_br }}px{% endif %} {% if sr_bl contains 'var(' %}{{ sr_bl }}{% else %}{{ sr_bl }}px{% endif %};
    {%- endif -%}
    {%- assign sb = section.settings.section_border -%}
    {%- if sb.width -%}
      border: {{ sb.width }} solid {{ sb.color }};
    {%- endif -%}
  }
{%- endstyle -%}

<section class="feature4-section section-{{ section.id }}" 
         style="background-color: {{ section.settings.background_color | default: '#ffffff' }};
                {% if section.settings.background_image != blank %}
                background-image: url('{{ section.settings.background_image | image_url: width: 1920 }}');
                background-size: cover;
                background-position: center;
                background-repeat: no-repeat;
                {% endif %}
                position: relative;">
  
  {%- assign ov = section.settings.overlay -%}
  {%- if ov and ov.enabled -%}
    <div class="overlay-{{ section.id }}"></div>
    {%- style -%}
      .overlay-{{ section.id }} {
        position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1;
        {%- if ov.mode == 'gradient' and ov.colors.size > 1 -%}
          background:
            {%- if ov.gradientType == 'radial' -%}
              radial-gradient(
            {%- else -%}
              linear-gradient({{ ov.angle }}deg,
            {%- endif -%}
            {%- for stop in ov.colors -%}
              {{ stop.color }} {{ stop.position }}%{%- unless forloop.last -%},{%- endunless -%}
            {%- endfor -%}
          );
          opacity: {{ ov.colors.first.opacity | divided_by: 100.0 }};
        {%- else -%}
          {%- assign c = ov.colors | first -%}
          background-color: {{ c.color }};
          opacity: {{ c.opacity | divided_by: 100.0 }};
        {%- endif -%}
      }
    {%- endstyle -%}
  {%- endif -%}
  
  <div class="container" style="position: relative; z-index: 2;">
    
    <!-- Header Section -->
    <div class="feature4-header text-center mb-10xl">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'tagline' %}
            <div class="feature4-tagline rte mb-lg" {{ block.fluid_attributes }}>{{ block.settings.text }}</div>
          {% when 'heading' %}
            <div class="feature4__heading rte mb-2xl" {{ block.fluid_attributes }}>{{ block.settings.text }}</div>
          {% when 'description' %}
            <div class="feature4-description rte max-w-3xl mx-auto" {{ block.fluid_attributes }}>{{ block.settings.text }}</div>
        {% endcase %}
      {% endfor %}
    </div>

    <!-- Main Content Section -->
    <div class="feature4-main-content grid grid-cols-1 sm-desktop-grid-cols-3 space-7xl align-center mb-10xl">
      
      <!-- Left Feature Points (Column 1) -->
      <div class="feature4-left-points">
        <!-- Feature Point 1 -->
        <div class="feature4-point text-center mb-7xl">
          <div class="feature4-icon mb-lg flex justify-center">
              {% assign img_input = section.settings.point_1_image %}
              {% assign img_fluid_media_id = '' %}
              
              {% if img_input.fluid_media_id %}
                {% assign img_fluid_media_id = img_input.fluid_media_id %}
                {% assign img_embed_type = img_input.embed_type %}
              {% endif %}

              {% assign use_fluid_image_widget = false %}
              
              {% if img_fluid_media_id != blank %}
                {% assign use_fluid_image_widget = true %}
              {% endif %}

              {% if use_fluid_image_widget %}
                <fluid-media-widget class="fluid-media-widget-image" media-id="{{ img_fluid_media_id }}" responsive="true" embed-type="{{ img_embed_type | default:'inline' }}" data-fluid-widget="true"></fluid-media-widget>
              {% else %}
                {% if img_input != blank %}
                    <img src="{{ img_input | image_url }}" 
                      alt="{{ section.settings.point_1_image_alt | default: section.settings.point_1_heading }}" 
                      class="feature4-point-image" loading="lazy" width="" height=""/>
                {% else %}
                  <div class="feature4-icon-placeholder">
                    <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                    </svg>
                  </div>
                {% endif %}
              {% endif %}
          </div>
          <div class="rte mb-md">
            {{ section.settings.point_1_heading | default: '<p>Short heading goes here</p>' }}
          </div>
          <div class="rte">
            {{ section.settings.point_1_description | default: '<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique.</p>' }}
          </div>
        </div>

        <!-- Feature Point 2 -->
        <div class="feature4-point text-center">
          <div class="feature4-icon mb-lg flex justify-center">
            {% assign point_2_image = section.settings.point_2_image %}
              {% assign point_2_fluid_media_id = '' %}
              
              {% if point_2_image.fluid_media_id %}
                {% assign point_2_fluid_media_id = point_2_image.fluid_media_id %}
                {% assign point_2_embed_type = point_2_image.embed_type %}
              {% endif %}

              {% assign use_point_2_fluid_image_widget = false %}
              
              {% if point_2_fluid_media_id != blank %}
                {% assign use_point_2_fluid_image_widget = true %}
              {% endif %}

              {% if use_point_2_fluid_image_widget %}
                <fluid-media-widget class="fluid-media-widget-image" media-id="{{ point_2_fluid_media_id }}" responsive="true" embed-type="{{ point_2_embed_type | default:'inline' }}" data-fluid-widget="true"></fluid-media-widget>
              {% else %}
                {% if point_2_image != blank %}
                    <img src="{{ point_2_image | image_url }}" alt="{{ section.settings.point_2_image_alt | default: section.settings.point_2_heading }}" class="feature4-point-image" loading="lazy" width="" height=""/>
                {% else %}
                  <div class="feature4-icon-placeholder">
                    <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                    </svg>
                  </div>
                {% endif %}
              {% endif %}
          </div>
          <div class="rte mb-md">
            {{ section.settings.point_2_heading | default: '<p>Short heading goes here</p>' }}
          </div>
          <div class="rte">
            {{ section.settings.point_2_description | default: '<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique.</p>' }}
          </div>
        </div>
      </div>

      <!-- Central Image (Column 2) -->
      <div class="feature4-image-wrapper flex justify-center">
        {% assign feature_image_input = section.settings.feature_image %}
          {% assign feature_image_input_fluid_media_id = '' %}
          
          {% if feature_image_input.fluid_media_id %}
            {% assign feature_image_input_fluid_media_id = feature_image_input.fluid_media_id %}
            {% assign feature_image_input_embed_type = feature_image_input.embed_type %}
          {% endif %}

          {% assign use_feature_image_fluid_image_widget = false %}
          
          {% if feature_image_input_fluid_media_id != blank %}
            {% assign use_feature_image_fluid_image_widget = true %}
          {% endif %}

          {% if use_feature_image_fluid_image_widget %}
            <fluid-media-widget class="fluid-media-widget-image" media-id="{{ feature_image_input_fluid_media_id }}" responsive="true" embed-type="{{ feature_image_input_embed_type | default:'inline' }}" data-fluid-widget="true"></fluid-media-widget>
          {% else %}
            {% if feature_image_input != blank %}
                <img src="{{ feature_image_input | image_url }}" alt="{{ section.settings.image_alt | default: 'Feature image' }}" class="feature4-image image-cover" loading="lazy" width="" height=""/>
            {% else %}
              <div class="feature4-image-placeholder">
                <svg width="80" height="80" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                </svg>
                <p class="text-sm mt-md" style=" color: #9ca3af;">Upload feature image</p>
              </div>
            {% endif %}
          {% endif %}
      </div>

      <!-- Right Feature Points (Column 3) -->
      <div class="feature4-right-points">
        <!-- Feature Point 3 -->
        <div class="feature4-point text-center mb-7xl">
          <div class="feature4-icon mb-lg flex justify-center">
            {% assign point_3_image = section.settings.point_3_image %}
              {% assign point_3_fluid_media_id = '' %}
              
              {% if point_3_image.fluid_media_id %}
                {% assign point_3_fluid_media_id = point_3_image.fluid_media_id %}
                {% assign point_3_embed_type = point_3_image.embed_type %}
              {% endif %}

              {% assign use_point_3_fluid_image_widget = false %}
              
              {% if point_3_fluid_media_id != blank %}
                {% assign use_point_3_fluid_image_widget = true %}
              {% endif %}

              {% if use_point_3_fluid_image_widget %}
                <fluid-media-widget class="fluid-media-widget-image" media-id="{{ point_3_fluid_media_id }}" responsive="true" embed-type="{{ point_3_embed_type | default:'inline' }}" data-fluid-widget="true"></fluid-media-widget>
              {% else %}
                {% if point_3_image != blank %}
                    <img src="{{ point_3_image | image_url }}" 
                      alt="{{ section.settings.point_3_image_alt | default: section.settings.point_3_heading }}" 
                      class="feature4-point-image" loading="lazy" width="" height=""/>
                {% else %}
                  <div class="feature4-icon-placeholder">
                    <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                    </svg>
                  </div>
                {% endif %}
              {% endif %}
          </div>
          <div class="rte mb-md">
            {{ section.settings.point_3_heading | default: '<p>Short heading goes here</p>' }}
          </div>
          <div class="rte">
            {{ section.settings.point_3_description | default: '<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique.</p>' }}
          </div>
        </div>

        <!-- Feature Point 4 -->
        <div class="feature4-point text-center">
          <div class="feature4-icon mb-lg flex justify-center">
            {% assign point_4_image = section.settings.point_4_image %}
              {% assign point_4_fluid_media_id = '' %}
              
              {% if point_4_image.fluid_media_id %}
                {% assign point_4_fluid_media_id = point_4_image.fluid_media_id %}
                {% assign point_4_embed_type = point_4_image.embed_type %}
              {% endif %}

              {% assign use_point_4_fluid_image_widget = false %}
              
              {% if point_4_fluid_media_id != blank %}
                {% assign use_point_4_fluid_image_widget = true %}
              {% endif %}

              {% if use_point_4_fluid_image_widget %}
                <fluid-media-widget class="fluid-media-widget-image" media-id="{{ point_4_fluid_media_id }}" responsive="true" embed-type="{{ point_4_embed_type | default:'inline' }}" data-fluid-widget="true"></fluid-media-widget>
              {% else %}
                {% if point_4_image != blank %}
                    <img src="{{ point_4_image | image_url }}" 
                      alt="{{ section.settings.point_4_image_alt | default: section.settings.point_4_heading }}" 
                      class="feature4-point-image" loading="lazy" width="" height=""/>
                {% else %}
                  <div class="feature4-icon-placeholder">
                    <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                    </svg>
                  </div>
                {% endif %}
              {% endif %}
          </div>
          <div class="rte mb-md">
            {{ section.settings.point_4_heading | default: '<p>Short heading goes here</p>' }}
          </div>
          <div class="rte">
            {{ section.settings.point_4_description | default: '<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique.</p>' }}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.feature4-section .feature4-image {
  width: 100%;
  max-width: 400px;
  height: 400px;
  border-radius: 8px;
  object-fit: cover;
}

.feature4-section .feature4-image-placeholder {
  width: 100%;
  max-width: 400px;
  height: 400px;
  background-color: #f3f4f6;
  border: 2px dashed #d1d5db;
  border-radius: 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #9ca3af;
}

.feature4-section .feature4-point-image {
  width: 48px;
  height: 48px;
  object-fit: cover;
  border-radius: 4px;
}

.feature4-section .feature4-icon-placeholder {
  width: 48px;
  height: 48px;
  background-color: #f3f4f6;
  border: 2px dashed #d1d5db;
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9ca3af;
}

.feature4-section .feature4-main-content {
  min-height: 500px;
}

@media (max-width: 767px) {
  .feature4-section .feature4-main-content {
    grid-template-columns: 1fr !important;
    gap: 32px;
  }
  
  .feature4-section .feature4-left-points,
  .feature4-section .feature4-right-points {
    display: block;
  }
  
  .feature4-section .feature4-point {
    margin-bottom: 48px;
  }

  .feature4-section .feature4-image,
  .feature4-section .feature4-image-placeholder {
    height: 300px;
  }
  
  .feature4-section .feature4-header {
    margin-bottom: 48px;
  }
  
  .feature4-section .feature4-main-content {
    margin-bottom: 48px;
  }
}
</style>

