{%- style -%}
  .section-{{ section.id }} {
    {%- assign p = section.settings.section_padding -%}
    {%- if p -%}
      {%- capture pt -%}{{ p.top }}{%- endcapture -%}
      {%- capture pb -%}{{ p.bottom }}{%- endcapture -%}
      {%- capture pl -%}{{ p.left }}{%- endcapture -%}
      {%- capture pr -%}{{ p.right }}{%- endcapture -%}
      padding-top: {% if pt contains 'var(' %}{{ pt }}{% else %}{{ pt }}px{% endif %};
      padding-bottom: {% if pb contains 'var(' %}{{ pb }}{% else %}{{ pb }}px{% endif %};
      padding-left: {% if pl contains 'var(' %}{{ pl }}{% else %}{{ pl }}px{% endif %};
      padding-right: {% if pr contains 'var(' %}{{ pr }}{% else %}{{ pr }}px{% endif %};
    {%- endif -%}
    {%- assign sr = section.settings.section_border_radius -%}
    {%- if sr -%}
      {%- capture sr_tl -%}{{ sr.tl }}{%- endcapture -%}
      {%- capture sr_tr -%}{{ sr.tr }}{%- endcapture -%}
      {%- capture sr_br -%}{{ sr.br }}{%- endcapture -%}
      {%- capture sr_bl -%}{{ sr.bl }}{%- endcapture -%}
      border-radius: {% if sr_tl contains 'var(' %}{{ sr_tl }}{% else %}{{ sr_tl }}px{% endif %} {% if sr_tr contains 'var(' %}{{ sr_tr }}{% else %}{{ sr_tr }}px{% endif %} {% if sr_br contains 'var(' %}{{ sr_br }}{% else %}{{ sr_br }}px{% endif %} {% if sr_bl contains 'var(' %}{{ sr_bl }}{% else %}{{ sr_bl }}px{% endif %};
    {%- endif -%}
  }
{%- endstyle -%}

{% assign bg_url = '' %}
{% assign bg_fluid_media_id = '' %}

{% if section.settings.background_image %}
  {% if section.settings.background_image.url %}
    {% assign bg_url = section.settings.background_image.url %}
    {% if section.settings.background_image.fluid_media_id %}
      {% assign bg_fluid_media_id = section.settings.background_image.fluid_media_id %}
      {% assign bg_embed_type = section.settings.background_image.embed_type %}
    {% endif %}
  {% else %}
    {% assign bg_url = section.settings.background_image %}
  {% endif %}
{% endif %}

{% assign use_fluid_widget = false %}

{% if bg_fluid_media_id != '' %}
  {% assign use_fluid_widget = true %}
{% endif %}

<section class="feature6-section section-{{ section.id }}" 
         style="background-color: {{ section.settings.background_color | default: '#ffffff' }};
                {% if section.settings.background_image != blank %}
                background-image: url('{% unless use_fluid_widget %}{{ bg_url }}{% endunless %}');
                background-size: cover;
                background-position: center;
                background-repeat: no-repeat;
                {% endif %}
                position: relative;">
  
  {% if use_fluid_widget %}
    <fluid-media-widget class="fluid-media-widget-background" media-id="{{ bg_fluid_media_id }}" responsive="true" embed-type="{{ bg_embed_type | default: 'inline' }}" data-fluid-widget="true"></fluid-media-widget>
  {% endif %}
  {%- assign ov = section.settings.overlay -%}
  {%- if ov and ov.enabled -%}
    <div class="overlay-{{ section.id }}"></div>
    {%- style -%}
      .overlay-{{ section.id }} {
        position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1;
        {%- if ov.mode == 'gradient' and ov.colors.size > 1 -%}
          background:
            {%- if ov.gradientType == 'radial' -%}
              radial-gradient(
            {%- else -%}
              linear-gradient({{ ov.angle }}deg,
            {%- endif -%}
            {%- for stop in ov.colors -%}
              {{ stop.color }} {{ stop.position }}%{%- unless forloop.last -%},{%- endunless -%}
            {%- endfor -%}
          );
          opacity: {{ ov.colors.first.opacity | divided_by: 100.0 }};
        {%- else -%}
          {%- assign c = ov.colors | first -%}
          background-color: {{ c.color }};
          opacity: {{ c.opacity | divided_by: 100.0 }};
        {%- endif -%}
      }
    {%- endstyle -%}
  {%- endif -%}
  
  <div class="container" style="position: relative; z-index: 2;">
    <div class="feature6-content text-center mx-auto">
      
      <!-- Feature Image -->
      <div class="feature6-image-wrapper mb-2xl flex justify-center">
       
        {% assign feature_image = section.settings.feature_image %}
        {% assign feature_image_fluid_media_id = '' %}
        
        {% if feature_image.fluid_media_id %}
          {% assign feature_image_fluid_media_id = feature_image.fluid_media_id %}
          {% assign feature_image_embed_type = feature_image.embed_type %}
        {% endif %}

        {% assign use_feature_image_fluid_image_widget = false %}
        
        {% if feature_image_fluid_media_id != blank %}
          {% assign use_feature_image_fluid_image_widget = true %}
        {% endif %}

        {% if use_feature_image_fluid_image_widget %}
          <fluid-media-widget class="fluid-media-widget-image" media-id="{{ feature_image_fluid_media_id }}" responsive="true" embed-type="{{ feature_image_embed_type | default:'inline' }}" data-fluid-widget="true"></fluid-media-widget>
        {% else %}
          {% if feature_image != blank %}
              <img src="{{ feature_image | image_url }}" 
                alt="{{ section.settings.image_alt | default: 'Feature image' }}" 
                class="feature6-image" loading="lazy" width="" height=""/>
          {% else %}
            <div class="feature6-image-placeholder">
              <svg width="80" height="80" fill="currentColor" viewBox="0 0 24 24">
                <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
              </svg>
              <p class="text-sm" style="margin-top: 12px; color: #9ca3af;">Upload feature image</p>
            </div>
          {% endif %}
        {% endif %}
      </div>
      
      <!-- Heading -->
      {% if section.settings.heading != blank %}
        <div class="feature6__heading rte mb-2xl">{{ section.settings.heading }}</div>
      {% endif %}
      {% if section.settings.description != blank %}
        <div class="feature6-description rte">{{ section.settings.description }}</div>
      {% endif %}
      
      <!-- Buttons -->
      <div class="feature6-buttons flex flex-wrap gap-lg justify-center mt-4xl">
        {% if section.settings.primary_button_text != blank %}
          {%- assign cr = section.settings.button_border_radius -%}{%- assign _cr_attr = '' -%}{%- if cr -%}{%- capture cr_tl -%}{{ cr.tl }}{%- endcapture -%}{%- capture cr_tr -%}{{ cr.tr }}{%- endcapture -%}{%- capture cr_br -%}{{ cr.br }}{%- endcapture -%}{%- capture cr_bl -%}{{ cr.bl }}{%- endcapture -%}{%- capture _br_val -%}{% if cr_tl contains 'var(' %}{{ cr_tl }}{% else %}{{ cr_tl }}px{% endif %} {% if cr_tr contains 'var(' %}{{ cr_tr }}{% else %}{{ cr_tr }}px{% endif %} {% if cr_br contains 'var(' %}{{ cr_br }}{% else %}{{ cr_br }}px{% endif %} {% if cr_bl contains 'var(' %}{{ cr_bl }}{% else %}{{ cr_bl }}px{% endif %}{%- endcapture -%}{%- assign _cr_attr = 'style="border-radius: ' | append: _br_val | append: ';"' -%}{%- endif -%}
          {% render 'button', href: section.settings.primary_button_link | default: '#', text: section.settings.primary_button_text, variant: section.settings.button_style | default: 'btn-bg-primary', attr: _cr_attr %}
        {% endif %}

        {% if section.settings.secondary_button_text != blank %}
          {%- assign cr = section.settings.button_secondary_border_radius -%}{%- assign _cr_attr = '' -%}{%- if cr -%}{%- capture cr_tl -%}{{ cr.tl }}{%- endcapture -%}{%- capture cr_tr -%}{{ cr.tr }}{%- endcapture -%}{%- capture cr_br -%}{{ cr.br }}{%- endcapture -%}{%- capture cr_bl -%}{{ cr.bl }}{%- endcapture -%}{%- capture _br_val -%}{% if cr_tl contains 'var(' %}{{ cr_tl }}{% else %}{{ cr_tl }}px{% endif %} {% if cr_tr contains 'var(' %}{{ cr_tr }}{% else %}{{ cr_tr }}px{% endif %} {% if cr_br contains 'var(' %}{{ cr_br }}{% else %}{{ cr_br }}px{% endif %} {% if cr_bl contains 'var(' %}{{ cr_bl }}{% else %}{{ cr_bl }}px{% endif %}{%- endcapture -%}{%- assign _cr_attr = 'style="border-radius: ' | append: _br_val | append: ';"' -%}{%- endif -%}
          {% render 'button', href: section.settings.secondary_button_link | default: '#', text: section.settings.secondary_button_text, variant: section.settings.button_secondary_style | default: 'btn-border-black', attr: _cr_attr %}
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
.feature6-section .feature6-image {
  width: 100%;
  max-width: 300px;
  height: 200px;
  object-fit: cover;
  border-radius: 12px;
}

.feature6-section .feature6-image-placeholder {
  width: 100%;
  max-width: 300px;
  height: 200px;
  background-color: #f3f4f6;
  border: 2px dashed #d1d5db;
  border-radius: 12px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #9ca3af;
}

@media (max-width: 767px) {
  .feature6-section .feature6-content {
    max-width: 100%;
  }
  
  .feature6-section .feature6-image-wrapper {
    margin-bottom: 32px;
  }
  
  .feature6-section .feature6-image,
  .feature6-section .feature6-image-placeholder {
    height: 160px;
  }
  
  .feature6-section .feature6__heading {
    margin-bottom: 24px;
  }
}
</style>

{% schema %}
{
  "name": "Feature 6",
  "settings": [
    {
      "type": "image_picker",
      "id": "feature_image",
      "label": "Feature Image"
    },
    {
      "type": "select",
      "id": "media_fit",
      "label": "Image Fit",
      "options": [
        { "value": "cover", "label": "Cover (Fill Container)" },
        { "value": "contain", "label": "Contain (Fit Inside)" },
        { "value": "fit-width", "label": "Fit to Width" },
        { "value": "fit-height", "label": "Fit to Height" }
      ],
      "default": "cover"
    },

    {

      "type": "range",

      "id": "max_width",

      "min": 0,

      "max": 2000,

      "step": 1,

      "label": "Max Width (px)",

      "info": "Leave empty for no limit"

    },

    {

      "type": "range",

      "id": "max_height",

      "min": 0,

      "max": 2000,

      "step": 1,

      "label": "Max Height (px)",

      "info": "Leave empty for no limit"

    },
    {
      "type": "corner_radius",
      "id": "media_border_radius",
      "label": "Image Border Radius",
      "info": "Override theme default media radius"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image Alt Text",
      "info": "Describe the image for accessibility"
    },
    {
      "type": "richtext",
      "id": "heading",
      "default": "<p>Long heading is what you see here in this feature section</p>",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "description",
      "default": "<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique. Duis cursus, mi quis viverra ornare, eros dolor interdum nulla, ut commodo diam libero vitae erat.</p>",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "primary_button_text",
      "default": "Button",
      "label": "Primary Button Text"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "default": "#",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "secondary_button_text",
      "default": "Button",
      "label": "Secondary Button Text"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "default": "#",
      "label": "Secondary Button Link"
    },
    {
      "type": "color_background",
      "id": "background_color",
      "default": "#ffffff",
      "label": "Background Color"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image",
      "info": "Optional background image (will override background color)"
    },
    {
      "type": "gradient_overlay",
      "id": "overlay",
      "label": "Overlay"
    },
    {
      "type": "padding",
      "id": "section_padding",
      "label": "Section Padding"
    },
    {
      "type": "header",
      "content": "Button Styles"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button Style",
      "options": [
        { "value": "btn-bg-white", "label": "White" },
        { "value": "btn-bg-primary", "label": "Primary" },
        { "value": "btn-border-white", "label": "White Border" },
        { "value": "btn-border-black", "label": "Black Border" },
        { "value": "btn-border-primary", "label": "Primary Border" }
      ],
      "default": "btn-bg-primary"
    },
    {
      "type": "corner_radius",
      "id": "button_border_radius",
      "label": "Button Border Radius"
    },
    {
      "type": "select",
      "id": "button_secondary_style",
      "label": "Secondary Button Style",
      "options": [
        { "value": "btn-bg-white", "label": "White" },
        { "value": "btn-bg-primary", "label": "Primary" },
        { "value": "btn-border-white", "label": "White Border" },
        { "value": "btn-border-black", "label": "Black Border" },
        { "value": "btn-border-primary", "label": "Primary Border" }
      ],
      "default": "btn-border-black"
    },
    {
      "type": "corner_radius",
      "id": "button_secondary_border_radius",
      "label": "Secondary Button Border Radius"
    },
    {
      "type": "corner_radius",
      "id": "section_border_radius",
      "label": "Section Border Radius",
      "info": "Default 0px. Four corners, link/unlink."
    }
  ]
}
{% endschema %}