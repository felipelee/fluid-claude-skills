{%- style -%}
  .section-{{ section.id }} {
    background-color: {{ section.settings.background_color | default: '#444444' }};
    {%- assign p = section.settings.section_padding -%}
    {%- if p -%}
      {%- capture pt -%}{{ p.top }}{%- endcapture -%}
      {%- capture pb -%}{{ p.bottom }}{%- endcapture -%}
      {%- capture pl -%}{{ p.left }}{%- endcapture -%}
      {%- capture pr -%}{{ p.right }}{%- endcapture -%}
      padding-top: {% if pt contains 'var(' %}{{ pt }}{% else %}{{ pt }}px{% endif %};
      padding-bottom: {% if pb contains 'var(' %}{{ pb }}{% else %}{{ pb }}px{% endif %};
      padding-left: {% if pl contains 'var(' %}{{ pl }}{% else %}{{ pl }}px{% endif %};
      padding-right: {% if pr contains 'var(' %}{{ pr }}{% else %}{{ pr }}px{% endif %};
    {%- endif -%}
    {%- assign sr = section.settings.section_border_radius -%}
    {%- if sr -%}
      {%- capture sr_tl -%}{{ sr.tl }}{%- endcapture -%}
      {%- capture sr_tr -%}{{ sr.tr }}{%- endcapture -%}
      {%- capture sr_br -%}{{ sr.br }}{%- endcapture -%}
      {%- capture sr_bl -%}{{ sr.bl }}{%- endcapture -%}
      border-radius: {% if sr_tl contains 'var(' %}{{ sr_tl }}{% else %}{{ sr_tl }}px{% endif %} {% if sr_tr contains 'var(' %}{{ sr_tr }}{% else %}{{ sr_tr }}px{% endif %} {% if sr_br contains 'var(' %}{{ sr_br }}{% else %}{{ sr_br }}px{% endif %} {% if sr_bl contains 'var(' %}{{ sr_bl }}{% else %}{{ sr_bl }}px{% endif %};
    {%- endif -%}
  }
{%- endstyle -%}

<section class="cta-section section-{{ section.id }} relative placeholde-bg-color">
  <!-- <div class="overlay-red absolute top-0 left-0 w-full h-full z-1"></div> -->
  <!-- <img src="images/cta-desktop.png" alt="cta-image" class="absolute top-0 left-0 image-cover variation image-position-top hidden xl-phone-block"> -->
  <!-- <img src="images/cta.jpeg" alt="cta-image" class="absolute top-0 left-0 image-cover variation xl-phone-hidden"> -->
  <div class="container relative z-2">
    <div class="wrapper text-white">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'heading' -%}
              <div class="rte title" {{ block.fluid_attributes }}>{{ block.settings.text }}</div>
            {%- when 'text' -%}
              <div class="rte xl-phone-text-lg leading-6 pt-2xl" {{ block.fluid_attributes }}>{{ block.settings.content }}</div>
            {%- when 'buttons' -%}
              <div class="btn-section flex flex-wrap space-lg pt-lg" {{ block.fluid_attributes }}>
                {% if block.settings.show_button_1 and block.settings.button_1_text != blank %}
                  {% render 'button', href: block.settings.button_1_link | default: '#', text: block.settings.button_1_text, variant: 'white' %}
                {% endif %}
                {% if block.settings.show_button_2 and block.settings.button_2_text != blank %}
                  {% render 'button', href: block.settings.button_2_link | default: '#', text: block.settings.button_2_text, variant: 'outline-white' %}
                {% endif %}
              </div>
          {%- when 'link' -%}
            {% if block.settings.text != blank %}
              {% render 'link',
                href: block.settings.url | default: '#',
                text: block.settings.text,
                underline: block.settings.underline_style,
                icon_position: block.settings.icon_position,
                color: block.settings.color,
                font_weight: block.settings.font_weight,
                attr: block.fluid_attributes
              %}
            {% endif %}
          {%- endcase -%}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CTA Banner",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "padding",
      "id": "section_padding",
      "label": "Section Padding"
    },
    {
      "type": "color_background",
      "id": "background_color",
      "default": "#444444",
      "label": "Background Color"
    },
    {
      "type": "corner_radius",
      "id": "section_border_radius",
      "label": "Section Border Radius",
      "info": "Default 0px. Four corners, link/unlink."
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Medium length heading goes here</p>"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique.</p>"
        }
      ]
    },
    {
      "type": "buttons",
      "name": "Buttons",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_button_1",
          "label": "Show Button 1",
          "default": true
        },
        {
          "type": "text",
          "id": "button_1_text",
          "label": "Button 1 Text",
          "default": "Button"
        },
        {
          "type": "url",
          "id": "button_1_link",
          "label": "Button 1 Link"
        },
        {
          "type": "select",
          "id": "button_1_size",
          "label": "Button 1 Size",
          "options": [
            { "value": "btn-xs", "label": "Extra Small" },
            { "value": "btn-sm", "label": "Small" },
            { "value": "btn-md", "label": "Medium" },
            { "value": "btn-lg", "label": "Large" },
            { "value": "btn-xl", "label": "Extra Large" }
          ],
          "default": "btn-md"
        },
        {
          "type": "checkbox",
          "id": "show_button_2",
          "label": "Show Button 2",
          "default": true
        },
        {
          "type": "text",
          "id": "button_2_text",
          "label": "Button 2 Text",
          "default": "Button"
        },
        {
          "type": "url",
          "id": "button_2_link",
          "label": "Button 2 Link"
        },
        {
          "type": "select",
          "id": "button_2_size",
          "label": "Button 2 Size",
          "options": [
            { "value": "btn-xs", "label": "Extra Small" },
            { "value": "btn-sm", "label": "Small" },
            { "value": "btn-md", "label": "Medium" },
            { "value": "btn-lg", "label": "Large" },
            { "value": "btn-xl", "label": "Extra Large" }
          ],
          "default": "btn-md"
        }
      ]
    },
    {
      "type": "link",
      "name": "Link",
      "settings": [
        { "type": "text", "id": "text", "label": "Link Text", "default": "Learn more" },
        { "type": "url", "id": "url", "label": "Link URL" },
        { "type": "select", "id": "underline_style", "label": "Underline Style", "options": [
          { "value": "always", "label": "Always" },
          { "value": "hover", "label": "On Hover Only" },
          { "value": "never", "label": "Never" }
        ], "default": "hover" },
        { "type": "select", "id": "icon_position", "label": "Icon Position", "options": [
          { "value": "none", "label": "None" },
          { "value": "before", "label": "Before Text" },
          { "value": "after", "label": "After Text" }
        ], "default": "none" },
        { "type": "color", "id": "color", "label": "Link Color" },
        { "type": "select", "id": "font_weight", "label": "Font Weight", "options": [
          { "value": "400", "label": "Normal" },
          { "value": "500", "label": "Medium" },
          { "value": "600", "label": "Semi Bold" },
          { "value": "700", "label": "Bold" }
        ], "default": "400" }
      ]
    }
  ],
  "presets": [
    {
      "name": "CTA Banner",
      "blocks": [
        { "type": "heading" },
        { "type": "text" },
        { "type": "buttons" }
      ]
    }
  ]
}
{% endschema %}