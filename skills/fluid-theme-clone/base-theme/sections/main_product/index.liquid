                      <h5 class="{{ accordion_block.settings.header_font_size | default: 'text-lg' }} {{ accordion_block.settings.header_font_weight | default: 'font-semibold' }}">{{ 'product.shipping' | t }}</h5>
                    </div>
                    <div class="icon flex align-center justify-center">
                      <svg width="24" height="25" viewBox="0 0 24 25" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path fill-rule="evenodd" clip-rule="evenodd" d="M11.6018 9.36784C11.8215 9.14817 12.1776 9.14817 12.3973 9.36784L18.1321 15.1027C18.3518 15.3224 18.3518 15.6785 18.1321 15.8982L17.867 16.1634C17.6473 16.383 17.2911 16.383 17.0715 16.1634L11.9995 11.0914L6.92759 16.1634C6.70791 16.383 6.35181 16.383 6.13214 16.1634L5.86694 15.8982C5.64726 15.6785 5.64726 15.3224 5.86694 15.1027L11.6018 9.36784Z" fill="black"/>
                      </svg>
                    </div><!-- .icon -->
                  </div>
                  <div class="accordion-content pb-xl lg:pb-2xl hidden {{ accordion_block.settings.content_font_size | default: 'text-base' }} {{ accordion_block.settings.content_font_weight | default: 'font-normal' }}">
                    <p>{{ 'product.shipping_content' | t }}</p>
                  </div>
                </li>
                <li class="accordion-item">
