{%- style -%}
  .section-{{ section.id }} {
    {%- assign p = section.settings.section_padding -%}
    {%- if p -%}
      {%- capture pt -%}{{ p.top }}{%- endcapture -%}
      {%- capture pb -%}{{ p.bottom }}{%- endcapture -%}
      {%- capture pl -%}{{ p.left }}{%- endcapture -%}
      {%- capture pr -%}{{ p.right }}{%- endcapture -%}
      padding-top: {% if pt contains 'var(' %}{{ pt }}{% else %}{{ pt }}px{% endif %};
      padding-bottom: {% if pb contains 'var(' %}{{ pb }}{% else %}{{ pb }}px{% endif %};
      padding-left: {% if pl contains 'var(' %}{{ pl }}{% else %}{{ pl }}px{% endif %};
      padding-right: {% if pr contains 'var(' %}{{ pr }}{% else %}{{ pr }}px{% endif %};
    {%- endif -%}
    {%- assign sr = section.settings.section_border_radius -%}
    {%- if sr -%}
      {%- capture sr_tl -%}{{ sr.tl }}{%- endcapture -%}
      {%- capture sr_tr -%}{{ sr.tr }}{%- endcapture -%}
      {%- capture sr_br -%}{{ sr.br }}{%- endcapture -%}
      {%- capture sr_bl -%}{{ sr.bl }}{%- endcapture -%}
      border-radius: {% if sr_tl contains 'var(' %}{{ sr_tl }}{% else %}{{ sr_tl }}px{% endif %} {% if sr_tr contains 'var(' %}{{ sr_tr }}{% else %}{{ sr_tr }}px{% endif %} {% if sr_br contains 'var(' %}{{ sr_br }}{% else %}{{ sr_br }}px{% endif %} {% if sr_bl contains 'var(' %}{{ sr_bl }}{% else %}{{ sr_bl }}px{% endif %};
    {%- endif -%}
    {%- assign sb = section.settings.section_border -%}
    {%- if sb.width -%}
      border: {{ sb.width }} solid {{ sb.color }};
    {%- endif -%}
  }
{%- endstyle -%}

<section class="feature2-section section-{{ section.id }}" 
         style="background-color: {{ section.settings.background_color | default: '#ffffff' }};
                {% if section.settings.background_image != blank %}
                background-image: url('{{ section.settings.background_image | image_url: width: 1920 }}');
                background-size: cover;
                background-position: center;
                background-repeat: no-repeat;
                {% endif %}
                position: relative;">
  
  {%- assign ov = section.settings.overlay -%}
  {%- if ov and ov.enabled -%}
    <div class="overlay-{{ section.id }}"></div>
    {%- style -%}
      .overlay-{{ section.id }} {
        position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1;
        {%- if ov.mode == 'gradient' and ov.colors.size > 1 -%}
          background:
            {%- if ov.gradientType == 'radial' -%}
              radial-gradient(
            {%- else -%}
              linear-gradient({{ ov.angle }}deg,
            {%- endif -%}
            {%- for stop in ov.colors -%}
              {{ stop.color }} {{ stop.position }}%{%- unless forloop.last -%},{%- endunless -%}
            {%- endfor -%}
          );
          opacity: {{ ov.colors.first.opacity | divided_by: 100.0 }};
        {%- else -%}
          {%- assign c = ov.colors | first -%}
          background-color: {{ c.color }};
          opacity: {{ c.opacity | divided_by: 100.0 }};
        {%- endif -%}
      }
    {%- endstyle -%}
  {%- endif -%}
  
  <div class="container" style="position: relative; z-index: 2;">
    <div class="feature2-wrapper grid grid-cols-1 sm-desktop-grid-cols-2 gap-7xl align-center {% if section.settings.image_on_left %}feature2-flipped{% endif %}">
      
      <!-- Content Column -->
      <div class="feature2-content">
        <!-- Main Heading and Description -->
        <div class="feature2-header mb-4xl">
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'heading' %}
                <div class="feature2__heading rte mb-2xl" {{ block.fluid_attributes }}>{{ block.settings.text }}</div>
              {% when 'description' %}
                <div class="rte mb-4xl" {{ block.fluid_attributes }}>{{ block.settings.text }}</div>
            {% endcase %}
          {% endfor %}
        </div>

        <!-- Feature Points -->
        <div class="feature2-points grid grid-cols-1 sm-desktop-grid-cols-2 gap-4xl">
          
          <!-- Feature Point 1 -->
          <div class="feature2-point">
            <div class="feature2-icon mb-lg">
              
              {% assign img_input = section.settings.point_1_image %}
              {% assign img_fluid_media_id = '' %}
              
              {% if img_input.fluid_media_id %}
                {% assign img_fluid_media_id = img_input.fluid_media_id %}
                {% assign img_embed_type = img_input.embed_type %}
              {% endif %}

              {% assign use_fluid_image_widget = false %}
              
              {% if img_fluid_media_id != blank %}
                {% assign use_fluid_image_widget = true %}
              {% endif %}

              {% if use_fluid_image_widget %}
                <fluid-media-widget class="fluid-media-widget-image" media-id="{{ img_fluid_media_id }}" responsive="true" embed-type="{{ img_embed_type | default:'inline' }}" data-fluid-widget="true"></fluid-media-widget>
              {% else %}
                {% if img_input != blank %}
                  
                    <img src="{{ img_input | image_url }}" alt="{{ section.settings.point_1_image_alt | default: section.settings.point_1_heading }}" class="feature2-point-image" loading="lazy" width="" height=""/>
                  
                {% else %}
                  <div class="feature2-icon-placeholder">
                    <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                    </svg>
                  </div>
                {% endif %}
              {% endif %}
            </div>
            <div class="rte mb-md">
              {{ section.settings.point_1_heading | default: '<p>Subheading one</p>' }}
            </div>
            <div class="rte">
              {{ section.settings.point_1_description | default: '<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros.</p>' }}
            </div>
          </div>

          <!-- Feature Point 2 -->
          <div class="feature2-point">
            <div class="feature2-icon mb-lg">
              
              {% assign point_2_image = section.settings.point_2_image %}
              {% assign point_2_fluid_media_id = '' %}
              
              {% if point_2_image.fluid_media_id %}
                {% assign point_2_fluid_media_id = point_2_image.fluid_media_id %}
                {% assign point_2_embed_type = point_2_image.embed_type %}
              {% endif %}

              {% assign use_point_2_fluid_image_widget = false %}
              
              {% if point_2_fluid_media_id != blank %}
                {% assign use_point_2_fluid_image_widget = true %}
              {% endif %}

              {% if use_point_2_fluid_image_widget %}
                <fluid-media-widget class="fluid-media-widget-image" media-id="{{ point_2_fluid_media_id }}" responsive="true" embed-type="{{ point_2_embed_type | default:'inline' }}" data-fluid-widget="true"></fluid-media-widget>
              {% else %}
                {% if point_2_image != blank %}
                  
                    <img src="{{ point_2_image | image_url }}" alt="{{ section.settings.point_2_image_alt | default: section.settings.point_2_heading }}" class="feature2-point-image" loading="lazy" width="" height=""/>
                  
                {% else %}
                  
                  <div class="feature2-icon-placeholder">
                    <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                    </svg>
                  </div>
                  
                {% endif %}
              {% endif %}
            </div>
            <div class="rte mb-md">
              {{ section.settings.point_2_heading | default: '<p>Subheading two</p>' }}
            </div>
            <div class="rte">
              {{ section.settings.point_2_description | default: '<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros.</p>' }}
            </div>
          </div>
        </div>
      </div>

      <!-- Image Column -->
      <div class="feature2-image-wrapper">
        
          {% assign feature_image_input = section.settings.feature_image %}
          {% assign feature_image_input_fluid_media_id = '' %}
          
          {% if feature_image_input.fluid_media_id %}
            {% assign feature_image_input_fluid_media_id = feature_image_input.fluid_media_id %}
            {% assign feature_image_input_embed_type = feature_image_input.embed_type %}
          {% endif %}

          {% assign use_feature_image_fluid_image_widget = false %}
          
          {% if feature_image_input_fluid_media_id != blank %}
            {% assign use_feature_image_fluid_image_widget = true %}
          {% endif %}

          {% if use_feature_image_fluid_image_widget %}
            <fluid-media-widget class="fluid-media-widget-image" media-id="{{ feature_image_input_fluid_media_id }}" responsive="true" embed-type="{{ feature_image_input_embed_type | default:'inline' }}" data-fluid-widget="true"></fluid-media-widget>
          {% else %}
            {% if feature_image_input != blank %}
              
                <img src="{{ feature_image_input | image_url }}" alt="{{ section.settings.image_alt | default: 'Feature image' }}" class="feature2-image image-cover" loading="lazy" width="" height=""/>
              
            {% else %}
              
              <div class="feature2-image-placeholder">
                <svg width="80" height="80" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                </svg>
                <p class="text-sm mt-md" style=" color: #9ca3af;">Upload feature image</p>
              </div>
              
            {% endif %}
          {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
.feature2-section .feature2-wrapper {
  min-height: 400px;
}

.feature2-section .feature2-content {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

/* Flipped layout - image on left, content on right */
.feature2-section .feature2-flipped .feature2-content {
  order: 2;
}

.feature2-section .feature2-flipped .feature2-image-wrapper {
  order: 1;
}

.feature2-section .feature2-image-wrapper {
  position: relative;
  min-height: 300px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.feature2-section .feature2-image {
  width: 100%;
  height: 400px;
  border-radius: 8px;
  object-fit: cover;
}

.feature2-section .feature2-image-placeholder {
  width: 100%;
  height: 400px;
  background-color: #f3f4f6;
  border: 2px dashed #d1d5db;
  border-radius: 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #9ca3af;
}

.feature2-section .feature2-point-image {
  width: 48px;
  height: 48px;
  object-fit: cover;
  border-radius: 4px;
}

.feature2-section .feature2-icon-placeholder {
  width: 48px;
  height: 48px;
  background-color: #f3f4f6;
  border: 2px dashed #d1d5db;
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9ca3af;
}

@media (max-width: 959px) {
  .feature2-section .feature2-wrapper {
    min-height: auto;
    gap: 32px;
  }
  
  .feature2-section .feature2-image,
  .feature2-section .feature2-image-placeholder {
    height: 300px;
  }

  .feature2-section .feature2-points {
    gap: 24px;
  }

  /* Reset order on mobile - always show content first, then image */
  .feature2-section .feature2-flipped .feature2-content,
  .feature2-section .feature2-flipped .feature2-image-wrapper {
    order: initial;
  }
}

@media (max-width: 767px) {
  .feature2-section .feature2-wrapper {
    gap: 24px;
  }
  
  .feature2-section .feature2-image,
  .feature2-section .feature2-image-placeholder {
    height: 250px;
  }

  .feature2-section .feature2-points {
    grid-template-columns: 1fr;
    gap: 20px;
  }
}
</style>

{% schema %}
{
  "name": "Feature 2",
  "settings": [
    {
      "type": "image_picker",
      "id": "feature_image",
      "label": "Feature Image"
    },
    {
      "type": "select",
      "id": "media_fit",
      "label": "Image Fit",
      "options": [
        {
          "value": "cover",
          "label": "Cover (Fill Container)"
        },
        {
          "value": "contain",
          "label": "Contain (Fit Inside)"
        },
        {
          "value": "fit-width",
          "label": "Fit to Width"
        },
        {
          "value": "fit-height",
          "label": "Fit to Height"
        }
      ],
      "default": "cover"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 0,
      "max": 2000,
      "step": 1,
      "label": "Max Width (px)",
      "info": "Leave empty for no limit"
    },
    {
      "type": "range",
      "id": "max_height",
      "min": 0,
      "max": 2000,
      "step": 1,
      "label": "Max Height (px)",
      "info": "Leave empty for no limit"
    },
    {
      "type": "corner_radius",
      "id": "media_border_radius",
      "label": "Image Border Radius",
      "info": "Override theme default media radius"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image Alt Text",
      "info": "Describe the image for accessibility"
    },
    {
      "type": "checkbox",
      "id": "image_on_left",
      "default": false,
      "label": "Image on Left",
      "info": "Check to place image on left side and content on right"
    },
    {
      "type": "image_picker",
      "id": "point_1_image",
      "label": "Feature Point 1 - Image"
    },
    {
      "type": "text",
      "id": "point_1_image_alt",
      "label": "Feature Point 1 - Image Alt Text",
      "info": "Describe the image for accessibility"
    },
    {
      "type": "richtext",
      "id": "point_1_heading",
      "default": "<p>Subheading one</p>",
      "label": "Feature Point 1 - Heading"
    },
    {
      "type": "richtext",
      "id": "point_1_description",
      "default": "<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros.</p>",
      "label": "Feature Point 1 - Description"
    },
    {
      "type": "image_picker",
      "id": "point_2_image",
      "label": "Feature Point 2 - Image"
    },
    {
      "type": "text",
      "id": "point_2_image_alt",
      "label": "Feature Point 2 - Image Alt Text",
      "info": "Describe the image for accessibility"
    },
    {
      "type": "richtext",
      "id": "point_2_heading",
      "default": "<p>Subheading two</p>",
      "label": "Feature Point 2 - Heading"
    },
    {
      "type": "richtext",
      "id": "point_2_description",
      "default": "<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros.</p>",
      "label": "Feature Point 2 - Description"
    },
    {
      "type": "select",
      "id": "background_color",
      "label": "Background Color",
      "options": "background_colors",
      "default": "var(--clr-white)"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image",
      "info": "Optional background image (will override background color)"
    },
    {
      "type": "gradient_overlay",
      "id": "overlay",
      "label": "Overlay"
    },
    {
      "type": "padding",
      "id": "section_padding",
      "label": "Section Padding"
    },
    {
      "type": "corner_radius",
      "id": "section_border_radius",
      "label": "Section Border Radius",
      "info": "Default 0px. Four corners, link/unlink."
    },
    {
      "type": "border",
      "id": "section_border",
      "label": "Section Border"
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Long heading goes here</p>"
        }
      ]
    },
    {
      "type": "description",
      "name": "Description",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Lorem ipsum dolor sit amet.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Feature 2",
      "blocks": [
        {
          "type": "heading"
        },
        {
          "type": "description"
        }
      ]
    }
  ]
}
{% endschema %}