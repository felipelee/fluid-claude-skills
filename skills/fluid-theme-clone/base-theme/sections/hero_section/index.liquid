<!-- Hero section -->
{%- style -%}
  .section-{{ section.id }} {
    background-color: {{ section.settings.background_color | default: '#000000' }};
    {%- assign p = section.settings.section_padding -%}
    {%- if p -%}
      {%- capture pt -%}{{ p.top }}{%- endcapture -%}
      {%- capture pb -%}{{ p.bottom }}{%- endcapture -%}
      {%- capture pl -%}{{ p.left }}{%- endcapture -%}
      {%- capture pr -%}{{ p.right }}{%- endcapture -%}
      padding-top: {% if pt contains 'var(' %}{{ pt }}{% else %}{{ pt }}px{% endif %};
      padding-bottom: {% if pb contains 'var(' %}{{ pb }}{% else %}{{ pb }}px{% endif %};
      padding-left: {% if pl contains 'var(' %}{{ pl }}{% else %}{{ pl }}px{% endif %};
      padding-right: {% if pr contains 'var(' %}{{ pr }}{% else %}{{ pr }}px{% endif %};
    {%- endif -%}
    {%- assign sr = section.settings.section_border_radius -%}
    {%- if sr -%}
      {%- capture sr_tl -%}{{ sr.tl }}{%- endcapture -%}
      {%- capture sr_tr -%}{{ sr.tr }}{%- endcapture -%}
      {%- capture sr_br -%}{{ sr.br }}{%- endcapture -%}
      {%- capture sr_bl -%}{{ sr.bl }}{%- endcapture -%}
      border-radius: {% if sr_tl contains 'var(' %}{{ sr_tl }}{% else %}{{ sr_tl }}px{% endif %} {% if sr_tr contains 'var(' %}{{ sr_tr }}{% else %}{{ sr_tr }}px{% endif %} {% if sr_br contains 'var(' %}{{ sr_br }}{% else %}{{ sr_br }}px{% endif %} {% if sr_bl contains 'var(' %}{{ sr_bl }}{% else %}{{ sr_bl }}px{% endif %};
    {%- endif -%}
    {%- assign sb = section.settings.section_border -%}
    {%- if sb.width -%}
      border: {{ sb.width }} solid {{ sb.color }};
    {%- endif -%}
  }
{%- endstyle -%}
{% comment %} Handle background_image - can be string URL or object with url/fluid_media_id {% endcomment %}
{% assign bg_url = '' %}
{% assign bg_fluid_media_id = '' %}

{% if section.settings.background_image %}
  {% if section.settings.background_image.url %}
    {% assign bg_url = section.settings.background_image.url %}
    {% if section.settings.background_image.fluid_media_id %}
      {% assign bg_fluid_media_id = section.settings.background_image.fluid_media_id %}
      {% assign bg_embed_type = section.settings.background_image.embed_type %}
    {% endif %}
  {% else %}
    {% assign bg_url = section.settings.background_image %}
  {% endif %}
{% endif %}

{% assign use_fluid_widget = false %}
{% if bg_fluid_media_id != '' %}
  {% assign use_fluid_widget = true %}
{% endif %}

<section class="heading-section hero-section section-{{ section.id }}" data-bg="{% unless use_fluid_widget %}{{ bg_url }}{% endunless %}" style="background-color: {{ section.settings.background_color | default: '#000000' }};">
  {% if use_fluid_widget %}
    <fluid-media-widget media-id="{{ bg_fluid_media_id }}" responsive="true" embed-type="{{ bg_embed_type | default: 'inline' }}" data-fluid-widget="true"></fluid-media-widget>
  {% endif %}
  <div class="container">
    <div class="hero-content flex flex-col justify-{{ section.settings.text_alignment }} {{ section.settings.content_gap_mobile | default: 'space-2xl' }} {{ section.settings.content_gap_desktop | default: 'lg:space-3xl' }}">
      {%- assign button_blocks = section.blocks | where: 'type', 'button' -%}
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'subheading' -%}
            <div class="subheading uppercase tracking-widest rte" {{ block.fluid_attributes }}>{{ block.settings.text }}</div>
          {%- when 'heading' -%}
            <div class="hero-header-text-h1 rte" {{ block.fluid_attributes }}>
              {{ block.settings.text }}
            </div>
          {%- when 'description' -%}
            <p class="rte" {{ block.fluid_attributes }}>
              {{ block.settings.text }}
            </p>
          {%- when 'link' -%}
            {% if block.settings.text != blank %}
              {% render 'link',
                href: block.settings.url | default: '#',
                text: block.settings.text,
                underline: block.settings.underline_style,
                icon_position: block.settings.icon_position,
                color: block.settings.color,
                font_weight: block.settings.font_weight,
                attr: block.fluid_attributes
              %}
            {% endif %}
        {%- endcase -%}
      {%- endfor -%}
      {%- if button_blocks.size > 0 -%}
        <div class="flex justify-{{ section.settings.text_alignment }} align-center {{ section.settings.button_gap | default: 'space-lg' }}">
          {% for button_block in button_blocks %}
            {% if button_block.settings.text != blank %}
              {% capture _btn_style %}
                {% if button_block.settings.background_color != blank %}background-color: {{ button_block.settings.background_color }};{% endif %}
                {% if button_block.settings.text_color != blank %}color: {{ button_block.settings.text_color }};{% endif %}
                {% if button_block.settings.font_size != blank %}font-size: {{ button_block.settings.font_size }}px;{% endif %}
                {% if button_block.settings.font_family != blank %}font-family: {{ button_block.settings.font_family | font_family }};{% endif %}
                {% assign p = button_block.settings.padding %}{% if p %}padding: {{ p.top }}px {{ p.right }}px {{ p.bottom }}px {{ p.left }}px;{% endif %}
                {% assign br = button_block.settings.border_radius %}{% if br %}border-radius: {{ br.tl }}px {{ br.tr }}px {{ br.br }}px {{ br.bl }}px;{% endif %}
                {% assign bd = button_block.settings.border %}{% if bd.width %}border: {{ bd.width }} solid {{ bd.color }};{% endif %}
              {% endcapture %}
              <a href="{{ button_block.settings.link | default: '#' }}"
                 class="btn btn--{{ button_block.settings.style | default: 'filled' }}"
                 style="{{ _btn_style | strip_newlines }}"
                 {% if button_block.settings.open_new_tab %}target="_blank" rel="noopener"{% endif %}
                 {{ button_block.fluid_attributes }}>
                {{ button_block.settings.text | escape }}
              </a>
            {% endif %}
          {% endfor %}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
