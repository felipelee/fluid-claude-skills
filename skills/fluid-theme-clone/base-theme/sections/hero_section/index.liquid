<!-- Hero section -->
{%- style -%}
  .section-{{ section.id }} {
    background-color: {{ section.settings.background_color | default: '#000000' }};
    {%- assign p = section.settings.section_padding -%}
    {%- if p -%}
      {%- capture pt -%}{{ p.top }}{%- endcapture -%}
      {%- capture pb -%}{{ p.bottom }}{%- endcapture -%}
      {%- capture pl -%}{{ p.left }}{%- endcapture -%}
      {%- capture pr -%}{{ p.right }}{%- endcapture -%}
      padding-top: {% if pt contains 'var(' %}{{ pt }}{% else %}{{ pt }}px{% endif %};
      padding-bottom: {% if pb contains 'var(' %}{{ pb }}{% else %}{{ pb }}px{% endif %};
      padding-left: {% if pl contains 'var(' %}{{ pl }}{% else %}{{ pl }}px{% endif %};
      padding-right: {% if pr contains 'var(' %}{{ pr }}{% else %}{{ pr }}px{% endif %};
    {%- endif -%}
    {%- assign sr = section.settings.section_border_radius -%}
    {%- if sr -%}
      {%- capture sr_tl -%}{{ sr.tl }}{%- endcapture -%}
      {%- capture sr_tr -%}{{ sr.tr }}{%- endcapture -%}
      {%- capture sr_br -%}{{ sr.br }}{%- endcapture -%}
      {%- capture sr_bl -%}{{ sr.bl }}{%- endcapture -%}
      border-radius: {% if sr_tl contains 'var(' %}{{ sr_tl }}{% else %}{{ sr_tl }}px{% endif %} {% if sr_tr contains 'var(' %}{{ sr_tr }}{% else %}{{ sr_tr }}px{% endif %} {% if sr_br contains 'var(' %}{{ sr_br }}{% else %}{{ sr_br }}px{% endif %} {% if sr_bl contains 'var(' %}{{ sr_bl }}{% else %}{{ sr_bl }}px{% endif %};
    {%- endif -%}
  }
{%- endstyle -%}
{% comment %} Handle background_image - can be string URL or object with url/fluid_media_id {% endcomment %}
{% assign bg_url = '' %}
{% assign bg_fluid_media_id = '' %}

{% if section.settings.background_image %}
  {% if section.settings.background_image.url %}
    {% assign bg_url = section.settings.background_image.url %}
    {% if section.settings.background_image.fluid_media_id %}
      {% assign bg_fluid_media_id = section.settings.background_image.fluid_media_id %}
      {% assign bg_embed_type = section.settings.background_image.embed_type %}
    {% endif %}
  {% else %}
    {% assign bg_url = section.settings.background_image %}
  {% endif %}
{% endif %}

{% assign use_fluid_widget = false %}
{% if bg_fluid_media_id != '' %}
  {% assign use_fluid_widget = true %}
{% endif %}

<section class="heading-section hero-section section-{{ section.id }}" data-bg="{% unless use_fluid_widget %}{{ bg_url }}{% endunless %}" style="background-color: {{ section.settings.background_color | default: '#000000' }};">
  {% if use_fluid_widget %}
    <fluid-media-widget media-id="{{ bg_fluid_media_id }}" responsive="true" embed-type="{{ bg_embed_type | default: 'inline' }}" data-fluid-widget="true"></fluid-media-widget>
  {% endif %}
  <div class="container">
    <div class="hero-content flex flex-col justify-{{ section.settings.text_alignment }} {{ section.settings.content_gap_mobile | default: 'space-2xl' }} {{ section.settings.content_gap_desktop | default: 'lg:space-3xl' }}">
      {%- assign button_blocks = section.blocks | where: 'type', 'button' -%}
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'subheading' -%}
            <div class="subheading uppercase tracking-widest rte" {{ block.fluid_attributes }}>{{ block.settings.text }}</div>
          {%- when 'heading' -%}
            <div class="hero-header-text-h1 rte" {{ block.fluid_attributes }}>
              {{ block.settings.text }}
            </div>
          {%- when 'description' -%}
            <p class="rte" {{ block.fluid_attributes }}>
              {{ block.settings.text }}
            </p>
          {%- when 'link' -%}
            {% if block.settings.text != blank %}
              {% render 'link',
                href: block.settings.url | default: '#',
                text: block.settings.text,
                underline: block.settings.underline_style,
                icon_position: block.settings.icon_position,
                color: block.settings.color,
                font_weight: block.settings.font_weight,
                attr: block.fluid_attributes
              %}
            {% endif %}
        {%- endcase -%}
      {%- endfor -%}
      {%- if button_blocks.size > 0 -%}
        <div class="flex justify-{{ section.settings.text_alignment }} align-center {{ section.settings.button_gap | default: 'space-lg' }}">
          {%- for button_block in button_blocks -%}
            {% if button_block.settings.text != blank %}
              {%- assign cr = button_block.settings.border_radius -%}
              {%- assign _btn_attr = button_block.fluid_attributes -%}
              {%- assign _btn_size = button_block.settings.size | default: 'btn-md' -%}
              {%- assign _btn_fw = button_block.settings.font_weight | default: '600' -%}
              {%- assign _btn_w = button_block.settings.width -%}
              {%- assign _btn_h = button_block.settings.height -%}
              {%- capture _btn_extra_style -%}font-weight: {{ _btn_fw }};{% if _btn_w != blank %} width: {{ _btn_w }}px;{% endif %}{% if _btn_h != blank %} height: {{ _btn_h }}px;{% endif %}{%- endcapture -%}
              {%- if cr -%}
                {%- capture cr_tl -%}{{ cr.tl }}{%- endcapture -%}
                {%- capture cr_tr -%}{{ cr.tr }}{%- endcapture -%}
                {%- capture cr_br -%}{{ cr.br }}{%- endcapture -%}
                {%- capture cr_bl -%}{{ cr.bl }}{%- endcapture -%}
                {%- capture _br_val -%}{% if cr_tl contains 'var(' %}{{ cr_tl }}{% else %}{{ cr_tl }}px{% endif %} {% if cr_tr contains 'var(' %}{{ cr_tr }}{% else %}{{ cr_tr }}px{% endif %} {% if cr_br contains 'var(' %}{{ cr_br }}{% else %}{{ cr_br }}px{% endif %} {% if cr_bl contains 'var(' %}{{ cr_bl }}{% else %}{{ cr_bl }}px{% endif %}{%- endcapture -%}
                {%- assign _btn_attr = 'style="border-radius: ' | append: _br_val | append: ' ' | append: _btn_extra_style | append: ';" ' | append: _btn_attr -%}
              {%- else -%}
                {%- assign _btn_attr = 'style="' | append: _btn_extra_style | append: ';" ' | append: _btn_attr -%}
              {%- endif -%}
              {% render 'button',
                href: button_block.settings.link | default: '#',
                text: button_block.settings.text,
                variant: button_block.settings.style | default: 'btn-bg-white',
                class: _btn_size,
                attr: _btn_attr
              %}
            {% endif %}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Section",
  "tag": "section",
  "class": "hero-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image",
      "info": "Recommended size: 1920x1080px or larger"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        { "value": "start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "end", "label": "Right" }
      ],
      "default": "start"
    },
    {
      "type": "header",
      "content": "Content Spacing"
    },
    {
      "type": "select",
      "id": "content_gap_mobile",
      "label": "Content Gap (Mobile)",
      "options": [
        { "value": "space-xs", "label": "XS" },
        { "value": "space-sm", "label": "SM" },
        { "value": "space-md", "label": "MD" },
        { "value": "space-lg", "label": "LG" },
        { "value": "space-xl", "label": "XL" },
        { "value": "space-2xl", "label": "2XL" },
        { "value": "space-3xl", "label": "3XL" },
        { "value": "space-4xl", "label": "4XL" },
        { "value": "space-5xl", "label": "5XL" }
      ],
      "default": "space-2xl"
    },
    {
      "type": "select",
      "id": "content_gap_desktop",
      "label": "Content Gap (Desktop)",
      "options": [
        { "value": "lg:space-xs", "label": "XS" },
        { "value": "lg:space-sm", "label": "SM" },
        { "value": "lg:space-md", "label": "MD" },
        { "value": "lg:space-lg", "label": "LG" },
        { "value": "lg:space-xl", "label": "XL" },
        { "value": "lg:space-2xl", "label": "2XL" },
        { "value": "lg:space-3xl", "label": "3XL" },
        { "value": "lg:space-4xl", "label": "4XL" },
        { "value": "lg:space-5xl", "label": "5XL" }
      ],
      "default": "lg:space-3xl"
    },
    {
      "type": "select",
      "id": "button_gap",
      "label": "Button Gap",
      "options": [
        { "value": "space-xs", "label": "XS" },
        { "value": "space-sm", "label": "SM" },
        { "value": "space-md", "label": "MD" },
        { "value": "space-lg", "label": "LG" },
        { "value": "space-xl", "label": "XL" },
        { "value": "space-2xl", "label": "2XL" },
        { "value": "space-3xl", "label": "3XL" },
        { "value": "space-4xl", "label": "4XL" },
        { "value": "space-5xl", "label": "5XL" }
      ],
      "default": "space-lg"
    },
    {
      "type": "header",
      "content": "Layout & Colors"
    },
    {
      "type": "color_background",
      "id": "background_color",
      "label": "Background Color",
      "default": "#000000"
    },
    {
      "type": "padding",
      "id": "section_padding",
      "label": "Section Padding"
    },
    {
      "type": "corner_radius",
      "id": "section_border_radius",
      "label": "Section Border Radius",
      "info": "Default 0px. Four corners, link/unlink."
    }
  ],
  "blocks": [
    {
      "type": "subheading",
      "name": "Subheading",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Welcome</p>"
        }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Medium length hero headline goes here</p>"
        }
      ]
    },
    {
      "type": "description",
      "name": "Description",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique. Duis cursus, mi quis viverra ornare, eros dolor interdum nulla, ut commodo diam libero vitae erat.</p>"
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Button"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "select",
          "id": "style",
          "label": "Style",
          "options": [
            { "value": "btn-bg-white", "label": "White" },
            { "value": "btn-bg-primary", "label": "Primary" },
            { "value": "btn-border-white", "label": "White Border" },
            { "value": "btn-border-black", "label": "Black Border" },
            { "value": "btn-border-primary", "label": "Primary Border" }
          ],
          "default": "btn-bg-white"
        },
        {
          "type": "select",
          "id": "size",
          "label": "Button Size",
          "options": [
            { "value": "btn-xs", "label": "Extra Small" },
            { "value": "btn-sm", "label": "Small" },
            { "value": "btn-md", "label": "Medium" },
            { "value": "btn-lg", "label": "Large" },
            { "value": "btn-xl", "label": "Extra Large" }
          ],
          "default": "btn-md"
        },
        {
          "type": "select",
          "id": "font_weight",
          "label": "Font Weight",
          "options": [
            { "value": "400", "label": "Normal" },
            { "value": "500", "label": "Medium" },
            { "value": "600", "label": "Semi Bold" },
            { "value": "700", "label": "Bold" }
          ],
          "default": "600"
        },

        {

          "type": "range",

          "id": "width",

          "min": 0,

          "max": 500,

          "step": 1,

          "label": "Button Width (px)",

          "info": "Leave empty for auto width"

        },

        {

          "type": "range",

          "id": "height",

          "min": 0,

          "max": 500,

          "step": 1,

          "label": "Button Height (px)",

          "info": "Leave empty for auto height"

        },
        {
          "type": "corner_radius",
          "id": "border_radius",
          "label": "Border Radius"
        }
      ]
    },
    {
      "type": "link",
      "name": "Link",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Link Text",
          "default": "Learn more"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link URL"
        },
        {
          "type": "select",
          "id": "underline_style",
          "label": "Underline Style",
          "options": [
            { "value": "always", "label": "Always" },
            { "value": "hover", "label": "On Hover Only" },
            { "value": "never", "label": "Never" }
          ],
          "default": "hover"
        },
        {
          "type": "select",
          "id": "icon_position",
          "label": "Icon Position",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "before", "label": "Before Text" },
            { "value": "after", "label": "After Text" }
          ],
          "default": "none"
        },
        {
          "type": "color",
          "id": "color",
          "label": "Link Color"
        },
        {
          "type": "select",
          "id": "font_weight",
          "label": "Font Weight",
          "options": [
            { "value": "400", "label": "Normal" },
            { "value": "500", "label": "Medium" },
            { "value": "600", "label": "Semi Bold" },
            { "value": "700", "label": "Bold" }
          ],
          "default": "400"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Section",
      "blocks": [
        { "type": "heading" },
        { "type": "description" },
        { "type": "button", "settings": { "text": "Button 1", "style": "btn-bg-white" } },
        { "type": "button", "settings": { "text": "Button 2", "style": "btn-border-white" } }
      ]
    }
  ]
}
{% endschema %}
