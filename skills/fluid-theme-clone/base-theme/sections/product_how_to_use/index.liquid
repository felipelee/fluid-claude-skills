{%- style -%}
  .phu.section-{{ section.id }} {
    {%- assign p = section.settings.section_padding -%}
    {%- if p -%}padding: {{ p.top | default: 80 }}px {{ p.right | default: 0 }}px {{ p.bottom | default: 80 }}px {{ p.left | default: 0 }}px;{%- else -%}padding: 80px 0;{%- endif -%}
    {%- assign r = section.settings.section_border_radius -%}
    {%- if r -%}border-radius: {{ r.tl }}px {{ r.tr }}px {{ r.br }}px {{ r.bl }}px;{%- endif -%}
    {% if section.settings.section_border_width > 0 %}border: {{ section.settings.section_border_width }}px solid {{ section.settings.section_border_color }};{% endif %}
    background-color: {{ section.settings.background_color | default: 'transparent' }};
    {%- if section.settings.background_image != blank -%}background-image: url({{ section.settings.background_image | img_url: '2400x' }});background-size:cover;background-position:center;background-repeat:no-repeat;{%- endif -%}
  }
  .phu.section-{{ section.id }} .phu__container {
    position: relative;
    max-width: {{ section.settings.container_max_width | default: '1280px' }};
    margin: 0 auto;
    {%- assign cp = section.settings.container_padding -%}
    {%- if cp -%}padding: {{ cp.top | default: 0 }}px {{ cp.right | default: 64 }}px {{ cp.bottom | default: 0 }}px {{ cp.left | default: 64 }}px;{%- else -%}padding: 0 64px;{%- endif -%}
    background-color: {{ section.settings.container_background_color | default: 'transparent' }};
    {%- if section.settings.container_background_image != blank -%}background-image: url({{ section.settings.container_background_image | img_url: '2400x' }});background-size:cover;background-position:center;background-repeat:no-repeat;{%- endif -%}
    {%- assign ccr = section.settings.container_border_radius -%}
    {%- if ccr -%}border-radius: {{ ccr.tl }}px {{ ccr.tr }}px {{ ccr.br }}px {{ ccr.bl }}px;{%- endif -%}
    {% if section.settings.container_border_width > 0 %}border: {{ section.settings.container_border_width }}px solid {{ section.settings.container_border_color }};{% endif %}
  }
  {%- if section.settings.container_overlay_color != blank and section.settings.container_overlay_opacity > 0 -%}
    {%- assign _cov = section.settings.container_overlay_opacity | divided_by: 100.0 -%}
    .phu.section-{{ section.id }} .phu__container::before { content: ""; position: absolute; inset: 0; background: {{ section.settings.container_overlay_color }}; opacity: {{ _cov }}; pointer-events: none; }
  {%- endif -%}
  .phu.section-{{ section.id }} .phu__container > * { position: relative; }
  @media (max-width: 991px) { .phu.section-{{ section.id }} .phu__container { padding-left: 24px; padding-right: 24px; } }
  @media (max-width: 767px) { .phu.section-{{ section.id }} .phu__container { padding-left: 16px; padding-right: 16px; } }

  .phu.section-{{ section.id }} .phu__intro {
    text-align: {{ section.settings.intro_alignment | default: 'center' }};
    {%- if section.settings.intro_alignment == 'center' -%}margin: 0 auto 64px; max-width: 720px;{%- else -%}margin-bottom: 64px;{%- endif -%}
    display: flex; flex-direction: column; gap: 12px;
  }

  {%- assign step_dividers = section.blocks | where: 'type', 'step' -%}
  {%- assign cols = step_dividers.size -%}
  {%- if cols > 4 -%}{%- assign cols = 4 -%}{%- endif -%}
  {%- if cols < 1 -%}{%- assign cols = 1 -%}{%- endif -%}

  .phu.section-{{ section.id }} .phu__grid {
    display: grid;
    grid-template-columns: repeat({{ cols }}, minmax(0, 1fr));
    gap: {{ section.settings.gap | default: 32 }}px;
  }
  @media (max-width: 991px) { .phu.section-{{ section.id }} .phu__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (max-width: 767px) { .phu.section-{{ section.id }} .phu__grid { grid-template-columns: 1fr; gap: 24px; } }

  .phu.section-{{ section.id }} .phu__step {
    display: flex; flex-direction: column; gap: 16px;
    text-align: {{ section.settings.step_alignment | default: 'center' }};
    align-items: {% case section.settings.step_alignment %}{% when 'center' %}center{% when 'right' %}flex-end{% else %}flex-start{% endcase %};
  }

  /* Canonical image block inside a step — wraps .media-wrap */
  .phu.section-{{ section.id }} .phu__step .media-wrap {
    width: 100%;
    position: relative;
    overflow: hidden;
    background: {{ section.settings.image_placeholder_background | default: 'var(--clr-light)' }};
  }
  .phu.section-{{ section.id }} .phu__step .media-wrap img {
    width: 100%; height: 100%;
    display: block;
  }
  .phu.section-{{ section.id }} .phu__media-placeholder {
    width: 100%; aspect-ratio: 1/1;
    background: repeating-linear-gradient(45deg, var(--clr-gray) 0 16px, var(--clr-light) 16px 32px);
    display: flex; align-items: center; justify-content: center;
    color: var(--clr-muted); opacity: 0.5;
    border-radius: 16px;
  }

  /* Number block */
  .phu.section-{{ section.id }} .phu__number {
    display: inline-flex; align-items: center; justify-content: center;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  /* Title / text blocks */
  .phu.section-{{ section.id }} .phu__title,
  .phu.section-{{ section.id }} .phu__title * {
    font-size: {{ section.settings.title_font_size | default: 18 }}px;
    font-weight: 600; line-height: 1.3;
    font-family: {{ section.settings.title_font | default: 'var(--ff-heading)' }};
    color: {{ section.settings.title_color | default: 'var(--clr-primary)' }};
    margin: 0;
  }
  .phu.section-{{ section.id }} .phu__text,
  .phu.section-{{ section.id }} .phu__text * {
    font-size: {{ section.settings.text_font_size | default: 14.5 }}px;
    line-height: 1.6;
    color: {{ section.settings.text_color | default: 'var(--clr-body)' }};
    margin: 0;
  }
{%- endstyle -%}

<section class="phu section-{{ section.id }}" {{ section.fluid_attributes }}>
  <div class="phu__container">

    {%- assign eyebrow_blocks = section.blocks | where: 'type', 'eyebrow' -%}
    {%- assign heading_blocks = section.blocks | where: 'type', 'heading' -%}
    {%- assign subhead_blocks = section.blocks | where: 'type', 'subhead' -%}

    {% if eyebrow_blocks.size > 0 or heading_blocks.size > 0 or subhead_blocks.size > 0 %}
      <div class="phu__intro">
        {% for block in eyebrow_blocks %}<div class="rte" {{ block.fluid_attributes }}>{{ block.settings.text }}</div>{% endfor %}
        {% for block in heading_blocks %}<div class="rte" {{ block.fluid_attributes }}>{{ block.settings.text }}</div>{% endfor %}
        {% for block in subhead_blocks %}<div class="rte" {{ block.fluid_attributes }}>{{ block.settings.text }}</div>{% endfor %}
      </div>
    {% endif %}

    {% if step_dividers.size > 0 %}
      <div class="phu__grid">
        {%- assign in_step = false -%}
        {%- assign step_index = 0 -%}
        {% for block in section.blocks %}
          {% case block.type %}

            {% when 'step' %}
              {% if in_step %}</div>{% endif %}
              {% assign step_index = step_index | plus: 1 %}
              <div class="phu__step" {{ block.fluid_attributes }}>
              {% assign in_step = true %}

            {% when 'number' %}
              {% if in_step %}
                {%- assign size   = block.settings.size | default: 40 -%}
                {%- assign shape  = block.settings.shape | default: 'circle' -%}
                {%- assign radius = block.settings.border_radius -%}
                {%- assign label  = block.settings.number_override -%}
                {% if label == blank %}{% assign label = step_index %}{% endif %}
                {%- capture num_style -%}
                  width: {{ size }}px;
                  height: {{ size }}px;
                  font-size: {{ block.settings.font_size | default: 16 }}px;
                  font-family: {{ block.settings.font_family | default: 'var(--ff-heading)' }};
                  background: {{ block.settings.background | default: 'var(--clr-primary)' }};
                  color: {{ block.settings.color | default: 'var(--clr-white)' }};
                  border-radius: {% if shape == 'square' %}{% if radius %}{{ radius.tl }}px {{ radius.tr }}px {{ radius.br }}px {{ radius.bl }}px{% else %}10px{% endif %}{% else %}50%{% endif %};
                  {% if block.settings.border_width > 0 %}border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};{% endif %}
                {%- endcapture -%}
                <div class="phu__number" style="{{ num_style | strip_newlines }}" {{ block.fluid_attributes }}>{{ label }}</div>
              {% endif %}

            {% when 'image' %}
              {% if in_step %}
                {%- assign _img = block.settings.image -%}
                {%- assign _ar = block.settings.aspect_ratio | default: '1/1' -%}
                {%- assign _alt = block.settings.alt | default: _img.alt | default: '' -%}
                {%- capture _wrap_style -%}
                  {% if _ar != 'auto' %}aspect-ratio: {{ _ar }};{% endif %}
                  {%- assign br = block.settings.border_radius -%}{% if br %}border-radius: {{ br.tl }}px {{ br.tr }}px {{ br.br }}px {{ br.bl }}px;{% else %}border-radius: 16px;{% endif %}
                  {% if block.settings.border_width > 0 %}border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};{% endif %}
                {%- endcapture -%}
                {%- capture _img_style -%}
                  object-fit: {{ block.settings.fit | default: 'cover' }};
                  object-position: {{ block.settings.object_position | default: 'center' }};
                {%- endcapture -%}
                {% if _img %}
                  <div class="media-wrap" style="{{ _wrap_style | strip_newlines }}" {{ block.fluid_attributes }}>
                    <img src="{{ _img | img_url: '1200x' }}" alt="{{ _alt | escape }}" loading="lazy" style="{{ _img_style | strip_newlines }}">
                    {% if block.settings.overlay_color != blank and block.settings.overlay_opacity > 0 %}
                      {%- assign _ov = block.settings.overlay_opacity | divided_by: 100.0 -%}
                      <div style="position:absolute;inset:0;background:{{ block.settings.overlay_color }};opacity:{{ _ov }};pointer-events:none;"></div>
                    {% endif %}
                  </div>
                {% else %}
                  <div class="phu__media-placeholder" {{ block.fluid_attributes }}>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" width="48" height="48"><rect x="3" y="4" width="18" height="16" rx="2"/><circle cx="8.5" cy="10" r="1.5"/><path d="M3 16l5-4 4 3 4-5 5 6"/></svg>
                  </div>
                {% endif %}
              {% endif %}

            {% when 'step_heading' %}
              {% if in_step %}
                <div class="phu__title rte" {{ block.fluid_attributes }}>{{ block.settings.text }}</div>
              {% endif %}

            {% when 'step_text' %}
              {% if in_step %}
                <div class="phu__text rte" {{ block.fluid_attributes }}>{{ block.settings.text }}</div>
              {% endif %}

          {% endcase %}
        {% endfor %}
        {% if in_step %}</div>{% endif %}
      </div>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "Product How To Use",
  "tag": "section",
  "class": "product-how-to-use-section",
  "settings": [
    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "gap", "label": "Gap between steps (px)", "min": 16, "max": 64, "step": 4, "default": 32 },
    { "type": "select", "id": "intro_alignment", "label": "Intro Alignment", "default": "center",
      "options": [ { "value": "left", "label": "Left" }, { "value": "center", "label": "Center" }, { "value": "right", "label": "Right" } ]
    },
    { "type": "radio", "id": "step_alignment", "label": "Step alignment", "default": "center",
      "options": [ { "value": "left", "label": "Left" }, { "value": "center", "label": "Center" }, { "value": "right", "label": "Right" } ]
    },

    { "type": "header", "content": "Step Image (defaults)" },
    { "type": "select", "id": "image_placeholder_background", "label": "Placeholder background", "options": "background_colors", "default": "var(--clr-light)" },

    { "type": "header", "content": "Typography (defaults)" },
    { "type": "range",  "id": "title_font_size", "label": "Title font size (px)", "min": 14, "max": 28, "step": 1, "default": 18 },
    { "type": "range",  "id": "text_font_size",  "label": "Text font size (px)",  "min": 12, "max": 20, "step": 1, "default": 14 },
    { "type": "select", "id": "title_font",  "label": "Title font",  "options": "font_families",     "default": "var(--ff-heading)" },
    { "type": "select", "id": "title_color", "label": "Title color", "options": "background_colors", "default": "var(--clr-primary)" },
    { "type": "select", "id": "text_color",  "label": "Text color",  "options": "background_colors", "default": "var(--clr-body)" },

    { "type": "header", "content": "Container" },
    { "type": "select", "id": "container_max_width", "label": "Max Width", "default": "1280px",
      "options": [
        { "value": "1080px", "label": "Comfy (1080px)" },
        { "value": "1280px", "label": "Default (1280px)" },
        { "value": "1440px", "label": "Wide (1440px)" },
        { "value": "100%",   "label": "Full (100%)" }
      ]
    },
    { "type": "padding", "id": "container_padding", "label": "Container Padding" },
    { "type": "corner_radius", "id": "container_border_radius", "label": "Container Border Radius" },
    { "type": "select", "id": "container_background_color", "label": "Container Background Color", "options": "background_colors", "default": "transparent" },
    { "type": "image_picker", "id": "container_background_image", "label": "Container Background Image" },
    { "type": "select", "id": "container_overlay_color", "label": "Container Overlay Color", "options": "background_colors", "default": "transparent" },
    { "type": "range", "id": "container_overlay_opacity", "label": "Container Overlay Opacity", "min": 0, "max": 100, "step": 5, "default": 0, "unit": "%" },
    { "type": "range", "id": "container_border_width", "label": "Container Border Width", "min": 0, "max": 10, "step": 1, "default": 0, "unit": "px" },
    { "type": "select", "id": "container_border_color", "label": "Container Border Color", "options": "background_colors", "default": "var(--clr-primary)" },

    { "type": "header", "content": "Section Shell" },
    { "type": "padding", "id": "section_padding", "label": "Section Padding" },
    { "type": "corner_radius", "id": "section_border_radius", "label": "Section Border Radius" },
    { "type": "select", "id": "background_color", "label": "Background Color", "options": "background_colors", "default": "transparent" },
    { "type": "image_picker", "id": "background_image", "label": "Background Image" },
    { "type": "range", "id": "section_border_width", "label": "Section Border Width", "min": 0, "max": 10, "step": 1, "default": 0, "unit": "px" },
    { "type": "select", "id": "section_border_color", "label": "Section Border Color", "options": "background_colors", "default": "var(--clr-primary)" }
  ],
  "blocks": [
    { "type": "eyebrow", "name": "Eyebrow",
      "settings": [ { "type": "richtext", "id": "text", "label": "Text", "default": "<h5 style=\"color: var(--clr-primary); text-transform: uppercase; letter-spacing: 0.08em;\">How to use</h5>" } ]
    },
    { "type": "heading", "name": "Heading",
      "settings": [ { "type": "richtext", "id": "text", "label": "Text", "default": "<h2 style=\"color: var(--clr-primary);\">Three steps to great results.</h2>" } ]
    },
    { "type": "subhead", "name": "Subhead",
      "settings": [ { "type": "richtext", "id": "text", "label": "Text", "default": "<p style=\"color: var(--clr-body); font-size: 17px;\">Simple to use, easy to love.</p>" } ]
    },

    { "type": "step", "name": "+ New Step",
      "settings": [
        { "type": "paragraph", "content": "Divider block. Marks the start of a new step. Add number / image / title / text blocks AFTER this block." }
      ]
    },

    { "type": "number", "name": "Step Number",
      "settings": [
        { "type": "text",  "id": "number_override", "label": "Number override (leave blank for auto)" },
        { "type": "radio", "id": "shape", "label": "Shape", "default": "circle",
          "options": [ { "value": "circle", "label": "Circle" }, { "value": "square", "label": "Square / rounded" } ]
        },
        { "type": "range", "id": "size",      "label": "Size (px)",      "min": 24, "max": 72, "step": 4, "default": 40 },
        { "type": "range", "id": "font_size", "label": "Font size (px)", "min": 12, "max": 28, "step": 1, "default": 16 },
        { "type": "corner_radius", "id": "border_radius", "label": "Border Radius (square shape only)" },
        { "type": "select", "id": "font_family", "label": "Font Family", "options": "font_families", "default": "var(--ff-heading)" },
        { "type": "select", "id": "background",  "label": "Background",  "options": "background_colors", "default": "var(--clr-primary)" },
        { "type": "select", "id": "color",       "label": "Text color",  "options": "background_colors", "default": "var(--clr-white)" },
        { "type": "range",  "id": "border_width","label": "Border Width", "min": 0, "max": 10, "step": 1, "default": 0, "unit": "px" },
        { "type": "select", "id": "border_color","label": "Border Color", "options": "background_colors", "default": "var(--clr-primary)" }
      ]
    },

    { "type": "image", "name": "Step Image",
      "settings": [
        { "type": "header", "content": "Content" },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "alt", "label": "Alt Text" },
        { "type": "header", "content": "Sizing" },
        { "type": "select", "id": "aspect_ratio", "label": "Aspect Ratio", "default": "1/1",
          "options": [
            { "value": "auto", "label": "Auto (natural)" },
            { "value": "1/1",  "label": "Square (1:1)" },
            { "value": "4/3",  "label": "Standard (4:3)" },
            { "value": "16/9", "label": "Widescreen (16:9)" },
            { "value": "4/5",  "label": "Portrait (4:5)" },
            { "value": "3/4",  "label": "Portrait (3:4)" }
          ]
        },
        { "type": "radio", "id": "fit", "label": "Fit", "default": "cover",
          "options": [ { "value": "cover", "label": "Cover" }, { "value": "contain", "label": "Contain" } ]
        },
        { "type": "select", "id": "object_position", "label": "Focal point", "default": "center",
          "options": [ { "value": "center", "label": "Center" }, { "value": "top", "label": "Top" }, { "value": "bottom", "label": "Bottom" }, { "value": "left", "label": "Left" }, { "value": "right", "label": "Right" } ]
        },
        { "type": "header", "content": "Overlay" },
        { "type": "select", "id": "overlay_color",   "label": "Overlay Color",   "options": "background_colors", "default": "transparent" },
        { "type": "range",  "id": "overlay_opacity", "label": "Overlay Opacity", "min": 0, "max": 100, "step": 5, "default": 0, "unit": "%" },
        { "type": "header", "content": "Shape" },
        { "type": "corner_radius", "id": "border_radius", "label": "Border Radius" },
        { "type": "range",  "id": "border_width", "label": "Border Width", "min": 0, "max": 10, "step": 1, "default": 0, "unit": "px" },
        { "type": "select", "id": "border_color", "label": "Border Color", "options": "background_colors", "default": "var(--clr-primary)" }
      ]
    },

    { "type": "step_heading", "name": "Step Title",
      "settings": [
        { "type": "richtext", "id": "text", "label": "Title",
          "default": "<h3 style=\"color: var(--clr-primary); font-size: 18px;\">Step title</h3>" }
      ]
    },

    { "type": "step_text", "name": "Step Text",
      "settings": [
        { "type": "richtext", "id": "text", "label": "Text",
          "default": "<p style=\"color: var(--clr-body); font-size: 14.5px;\">Short description of what happens in this step.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product How To Use",
      "blocks": [
        { "type": "eyebrow" },
        { "type": "heading" },
        { "type": "subhead" },

        { "type": "step" },
        { "type": "number" },
        { "type": "step_heading", "settings": { "text": "<h3 style=\"color: var(--clr-primary); font-size: 18px;\">Unbox</h3>" } },
        { "type": "step_text",    "settings": { "text": "<p style=\"color: var(--clr-body); font-size: 14.5px;\">Twist the cap to open and remove the safety seal.</p>" } },

        { "type": "step" },
        { "type": "number" },
        { "type": "step_heading", "settings": { "text": "<h3 style=\"color: var(--clr-primary); font-size: 18px;\">Take your serving</h3>" } },
        { "type": "step_text",    "settings": { "text": "<p style=\"color: var(--clr-body); font-size: 14.5px;\">One scoop per day, any time that works for you.</p>" } },

        { "type": "step" },
        { "type": "number" },
        { "type": "step_heading", "settings": { "text": "<h3 style=\"color: var(--clr-primary); font-size: 18px;\">Mix & enjoy</h3>" } },
        { "type": "step_text",    "settings": { "text": "<p style=\"color: var(--clr-body); font-size: 14.5px;\">Stir into 8oz of cold water or your favorite drink.</p>" } }
      ]
    }
  ]
}
{% endschema %}
