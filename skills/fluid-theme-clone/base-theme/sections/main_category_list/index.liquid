{% comment %}
  sections/main_category_list/index.liquid

  Category list carousel section with block-driven structure.
  Loops over `categories` and shows each category as a carousel slide.
  Blocks:
    section_header    → optional section title + view-all button
    category_carousel → category carousel display with typography controls
{% endcomment %}

{% assign carousel_id = section.id | append: '-carousel-categories' %}
<div class="container" id="dummy-category-container"></div>

{% comment %} ── Defaults ──────────────────────────────────────────────────── {% endcomment %}
{%- assign show_section_title       = true -%}
{%- assign section_title            = 'Categories' -%}
{%- assign title_heading_tag        = 'h2' -%}
{%- assign title_font_weight        = 'font-bold' -%}
{%- assign title_color              = '#000000' -%}

{%- assign show_view_all_button     = true -%}
{%- assign view_all_button_text     = 'View All' -%}
{%- assign view_all_button_url      = '#' -%}
{%- assign button_style             = 'btn-border-black' -%}
{%- assign button_background_color  = 'transparent' -%}
{%- assign button_text_color        = '#000000' -%}
{%- assign button_border             = nil -%}

{%- assign categories_limit         = 12 -%}
{%- assign show_carousel_arrows     = true -%}
{%- assign arrow_color              = '#000000' -%}
{%- assign arrow_size               = 48 -%}

{%- assign category_title_tag       = 'h5' -%}
{%- assign category_title_font_weight = 'font-semibold' -%}
{%- assign category_title_color     = '#000000' -%}

{% comment %} ── Extract block settings ───────────────────────────────────── {% endcomment %}
{%- for block in section.blocks -%}
  {%- if block.type == 'section_header' -%}
    {%- assign section_header_block     = block -%}
    {%- assign show_section_title       = block.settings.show_section_title -%}
    {%- if block.settings.section_title != blank -%}{%- assign section_title = block.settings.section_title -%}{%- endif -%}
    {%- assign title_heading_tag        = block.settings.title_heading_tag | default: 'h2' -%}
    {%- assign title_font_weight        = block.settings.title_font_weight | default: 'font-bold' -%}
    {%- assign title_color              = block.settings.title_color | default: '#000000' -%}
    {%- assign show_view_all_button     = block.settings.show_view_all_button -%}
    {%- if block.settings.view_all_button_text != blank -%}{%- assign view_all_button_text = block.settings.view_all_button_text -%}{%- endif -%}
    {%- if block.settings.view_all_button_url != blank -%}{%- assign view_all_button_url = block.settings.view_all_button_url -%}{%- endif -%}
    {%- assign button_style             = block.settings.button_style | default: 'btn-border-black' -%}
    {%- assign button_background_color  = block.settings.button_background_color | default: 'transparent' -%}
    {%- assign button_text_color        = block.settings.button_text_color | default: '#000000' -%}
    {%- assign button_border             = block.settings.button_border -%}

  {%- elsif block.type == 'category_carousel' -%}
    {%- assign category_carousel_block      = block -%}
    {%- assign categories_limit             = block.settings.categories_limit | default: 12 -%}
    {%- assign show_carousel_arrows         = block.settings.show_carousel_arrows -%}
    {%- assign arrow_color                  = block.settings.arrow_color | default: '#000000' -%}
    {%- assign arrow_size                   = block.settings.arrow_size | default: 48 -%}
    {%- assign category_title_tag           = block.settings.category_title_tag | default: 'h5' -%}
    {%- assign category_title_font_weight   = block.settings.category_title_font_weight | default: 'font-semibold' -%}
    {%- assign category_title_color         = block.settings.category_title_color | default: '#000000' -%}
  {%- endif -%}
{%- endfor -%}

{%- style -%}
  .section-{{ section.id }} {
    {%- assign p = section.settings.section_padding -%}
    {%- if p -%}
      {%- capture pt -%}{{ p.top }}{%- endcapture -%}
      {%- capture pb -%}{{ p.bottom }}{%- endcapture -%}
      {%- capture pl -%}{{ p.left }}{%- endcapture -%}
      {%- capture pr -%}{{ p.right }}{%- endcapture -%}
      padding-top: {% if pt contains 'var(' %}{{ pt }}{% else %}{{ pt }}px{% endif %};
      padding-bottom: {% if pb contains 'var(' %}{{ pb }}{% else %}{{ pb }}px{% endif %};
      padding-left: {% if pl contains 'var(' %}{{ pl }}{% else %}{{ pl }}px{% endif %};
      padding-right: {% if pr contains 'var(' %}{{ pr }}{% else %}{{ pr }}px{% endif %};
    {%- endif -%}
    background-color: {{ section.settings.background_color | default: 'transparent' }};
    {%- assign sr = section.settings.section_border_radius -%}
    {%- if sr -%}
      {%- capture sr_tl -%}{{ sr.tl }}{%- endcapture -%}
      {%- capture sr_tr -%}{{ sr.tr }}{%- endcapture -%}
      {%- capture sr_br -%}{{ sr.br }}{%- endcapture -%}
      {%- capture sr_bl -%}{{ sr.bl }}{%- endcapture -%}
      border-radius: {% if sr_tl contains 'var(' %}{{ sr_tl }}{% else %}{{ sr_tl }}px{% endif %} {% if sr_tr contains 'var(' %}{{ sr_tr }}{% else %}{{ sr_tr }}px{% endif %} {% if sr_br contains 'var(' %}{{ sr_br }}{% else %}{{ sr_br }}px{% endif %} {% if sr_bl contains 'var(' %}{{ sr_bl }}{% else %}{{ sr_bl }}px{% endif %};
    {%- endif -%}
  }
{%- endstyle -%}

<section class="category-list-section section-{{ section.id }}">

  {%- if section_header_block -%}
    <div class="header-section" {{ section_header_block.fluid_attributes }}>
      <div class="container">
        <div class="wrapper flex flex-wrap align-end">
          {%- if show_section_title -%}
            <div class="desc">
              <{{ title_heading_tag }}
                class="{{ title_font_weight }}"
                style="color: {{ title_color }};">
                {{ section_title }}
              </{{ title_heading_tag }}>
            </div>
          {%- endif -%}
          {%- if show_view_all_button -%}
            <div class="btn-section text-right hidden sm-desktop-block">
              <a href="{{ view_all_button_url }}"
                class="btn text-center {{ button_style }}"
                style="
                  background-color: {{ button_background_color }};
                  color: {{ button_text_color }};
                  {%- if button_border -%}border: {{ button_border.width }} solid {{ button_border.color }};{%- endif -%}
                ">
                {{ view_all_button_text }}
              </a>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  {%- endif -%}

  {%- if category_carousel_block -%}
    <div class="product-list-section carousel-container mt-12" {{ category_carousel_block.fluid_attributes }}>
      <div class="container">
        <div class="product-carousel {{ carousel_id }} splide" data-carousel-id="{{ carousel_id }}">
          <div class="splide__track">
            <ul class="splide__list">
              {% for category in categories limit: categories_limit %}
                <li class="splide__slide">
                  <a href="{{ category.url }}" class="category-card block">
                    <div class="image-section">
                      {% if category.image %}
                        <img
                          src="{{ category.image }}"
                          alt="{{ category.title }}"
                          class="image-cover"
                        />
                      {% elsif category.image_url %}
                        <img
                          src="{{ category.image_url }}"
                          alt="{{ category.title }}"
                          class="image-cover"
                        />
                      {% else %}
                        <div class="h-full w-full flex items-center justify-center bg-gray-100">
                          <span class="text-gray-400">{{ category.title }}</span>
                        </div>
                      {% endif %}
                    </div>
                    <div class="desc pt-4">
                      <{{ category_title_tag }}
                        class="{{ category_title_font_weight }}"
                        style="color: {{ category_title_color }};">
                        {{ category.title }}
                      </{{ category_title_tag }}>
                    </div>
                  </a>
                </li>
              {% endfor %}
            </ul>
          </div>

          {% if show_carousel_arrows %}
          <div class="splide__arrows splide-arrow-section mt-12">
            <button class="slide-arrow splide__arrow splide__arrow--prev arrow-prev-btn"
                    style="color: {{ arrow_color }}; width: {{ arrow_size }}px; height: {{ arrow_size }}px;">
              <svg width="{{ arrow_size | default: 24 }}" height="{{ arrow_size | default: 25 }}" viewBox="0 0 24 25" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M20 11.4004H7.83L13.42 5.81039L12 4.40039L4 12.4004L12 20.4004L13.41 18.9904L7.83 13.4004H20V11.4004Z" fill="{{ arrow_color }}"/>
              </svg>
            </button>
            <button class="slide-arrow splide__arrow splide__arrow--next arrow-next-btn"
                    style="color: {{ arrow_color }}; width: {{ arrow_size }}px; height: {{ arrow_size }}px;">
              <svg width="{{ arrow_size | default: 24 }}" height="{{ arrow_size | default: 25 }}" viewBox="0 0 24 25" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M20 11.4004H7.83L13.42 5.81039L12 4.40039L4 12.4004L12 20.4004L13.41 18.9904L7.83 13.4004H20V11.4004Z" fill="{{ arrow_color }}"/>
              </svg>
            </button>
          </div>
          {% endif %}

        </div>
        <!-- .product-carousel -->
      </div>
    </div>
    <!-- .carousel-container -->
  {%- endif -%}

</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    function initializeCategoryCarousel() {
      const carousels = document.querySelectorAll('.section-{{ section.id }} .product-carousel');
      carousels.forEach((carousel) => {
        const carouselId = carousel.getAttribute('data-carousel-id');
        if (carouselId) {
          const splide = new Splide(carousel, {
            perPage: 1,
            perMove: 1,
            speed: 500,
            mediaQuery: "min",
            padding: { right: "64px" },
            gap: "24px",
            breakpoints: {
              576: { perPage: 2 },
              768: { perPage: 3 },
              1200: {
                perPage: 4,
                gap: "48px",
                padding: { right: "80px" },
              },
            },
          });
          splide.mount();
        }
      });
    }

    function setCategoryCarouselSpacing() {
      const dummyContainer = document.getElementById('dummy-category-container');
      if (!dummyContainer) return;
      const paddingLeft = dummyContainer.getBoundingClientRect().left;
      document.querySelectorAll('.section-{{ section.id }} .carousel-container').forEach(function(el) {
        el.style.paddingLeft = paddingLeft + 'px';
      });
    }

    initializeCategoryCarousel();
    setCategoryCarouselSpacing();

    window.addEventListener('resize', setCategoryCarouselSpacing);
  });
</script>

{% schema %}
{
  "name": "Category List",
  "tag": "section",
  "class": "category-list-section",
  "settings": [
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "color_background",
      "id": "background_color",
      "label": "Background Color",
      "default": "transparent"
    },
    {
      "type": "padding",
      "id": "section_padding",
      "label": "Section Padding"
    },
    {
      "type": "corner_radius",
      "id": "section_border_radius",
      "label": "Section Border Radius",
      "info": "Default 0px. Four corners, link/unlink."
    }
  ],
  "blocks": [
    {
      "type": "section_header",
      "name": "Section Header",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_section_title",
          "label": "Show Section Title",
          "default": true
        },
        {
          "type": "text",
          "id": "section_title",
          "label": "Section Title",
          "default": "Categories"
        },
        {
          "type": "select",
          "id": "title_heading_tag",
          "label": "Title Heading Tag",
          "options": [
            { "value": "h1", "label": "Heading 1" },
            { "value": "h2", "label": "Heading 2" },
            { "value": "h3", "label": "Heading 3" },
            { "value": "h4", "label": "Heading 4" },
            { "value": "h5", "label": "Heading 5" },
            { "value": "h6", "label": "Heading 6" }
          ],
          "default": "h2"
        },
        {
          "type": "select",
          "id": "title_font_weight",
          "label": "Title Font Weight",
          "options": [
            { "value": "font-light", "label": "Light" },
            { "value": "font-normal", "label": "Normal" },
            { "value": "font-medium", "label": "Medium" },
            { "value": "font-semibold", "label": "Semi Bold" },
            { "value": "font-bold", "label": "Bold" },
            { "value": "font-extrabold", "label": "Extra Bold" }
          ],
          "default": "font-bold"
        },
        {
          "type": "color_background",
          "id": "title_color",
          "label": "Title Color",
          "default": "#000000"
        },
        {
          "type": "header",
          "content": "View All Button"
        },
        {
          "type": "checkbox",
          "id": "show_view_all_button",
          "label": "Show View All Button",
          "default": true
        },
        {
          "type": "text",
          "id": "view_all_button_text",
          "label": "Button Text",
          "default": "View All"
        },
        {
          "type": "url",
          "id": "view_all_button_url",
          "label": "Button URL",
          "default": "#"
        },
        {
          "type": "select",
          "id": "button_style",
          "label": "Button Style",
          "options": [
            { "value": "btn-border-primary", "label": "Primary Border" },
            { "value": "btn-bg-primary", "label": "Primary Background" },
            { "value": "btn-border-black", "label": "Black Border" },
            { "value": "btn-bg-black", "label": "Black Background" }
          ],
          "default": "btn-border-black"
        },
        {
          "type": "color_background",
          "id": "button_background_color",
          "label": "Button Background Color",
          "default": "transparent"
        },
        {
          "type": "color_background",
          "id": "button_text_color",
          "label": "Button Text Color",
          "default": "#000000"
        },
        {
          "type": "border",
          "id": "button_border",
          "label": "Button Border"
        }
      ]
    },
    {
      "type": "category_carousel",
      "name": "Category Carousel",
      "limit": 1,
      "settings": [
        {
          "type": "range",
          "id": "categories_limit",
          "min": 3,
          "max": 24,
          "step": 3,
          "label": "Number of Categories to Show",
          "default": 12
        },
        {
          "type": "checkbox",
          "id": "show_carousel_arrows",
          "label": "Show Carousel Arrows",
          "default": true
        },
        {
          "type": "color_background",
          "id": "arrow_color",
          "label": "Arrow Color",
          "default": "#000000"
        },
        {
          "type": "range",
          "id": "arrow_size",
          "min": 24,
          "max": 48,
          "step": 4,
          "unit": "px",
          "label": "Arrow Size",
          "default": 48
        },
        {
          "type": "header",
          "content": "Category Title Typography"
        },
        {
          "type": "select",
          "id": "category_title_tag",
          "label": "Category Title Tag",
          "options": [
            { "value": "h2", "label": "Heading 2" },
            { "value": "h3", "label": "Heading 3" },
            { "value": "h4", "label": "Heading 4" },
            { "value": "h5", "label": "Heading 5" },
            { "value": "h6", "label": "Heading 6" }
          ],
          "default": "h5"
        },
        {
          "type": "select",
          "id": "category_title_font_weight",
          "label": "Category Title Font Weight",
          "options": [
            { "value": "font-light", "label": "Light" },
            { "value": "font-normal", "label": "Normal" },
            { "value": "font-medium", "label": "Medium" },
            { "value": "font-semibold", "label": "Semi Bold" },
            { "value": "font-bold", "label": "Bold" }
          ],
          "default": "font-semibold"
        },
        {
          "type": "color_background",
          "id": "category_title_color",
          "label": "Category Title Color",
          "default": "#000000"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category List",
      "blocks": [
        { "type": "section_header" },
        { "type": "category_carousel" }
      ]
    }
  ]
}
{% endschema %}
