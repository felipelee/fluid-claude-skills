{%- style -%}
  .pi.section-{{ section.id }} {
    {%- assign p = section.settings.section_padding -%}
    {%- if p -%}padding: {{ p.top | default: 80 }}px {{ p.right | default: 0 }}px {{ p.bottom | default: 80 }}px {{ p.left | default: 0 }}px;{%- else -%}padding: 80px 0;{%- endif -%}
    {%- assign r = section.settings.section_border_radius -%}
    {%- if r -%}border-radius: {{ r.tl }}px {{ r.tr }}px {{ r.br }}px {{ r.bl }}px;{%- endif -%}
    {% if section.settings.section_border_width > 0 %}border: {{ section.settings.section_border_width }}px solid {{ section.settings.section_border_color }};{% endif %}
    background-color: {{ section.settings.background_color | default: 'transparent' }};
    {%- if section.settings.background_image != blank -%}background-image: url({{ section.settings.background_image | img_url: '2400x' }});background-size:cover;background-position:center;background-repeat:no-repeat;{%- endif -%}
  }
  .pi.section-{{ section.id }} .pi__container {
    position: relative;
    max-width: {{ section.settings.container_max_width | default: '1280px' }};
    margin: 0 auto;
    {%- assign cp = section.settings.container_padding -%}
    {%- if cp -%}padding: {{ cp.top | default: 0 }}px {{ cp.right | default: 64 }}px {{ cp.bottom | default: 0 }}px {{ cp.left | default: 64 }}px;{%- else -%}padding: 0 64px;{%- endif -%}
    background-color: {{ section.settings.container_background_color | default: 'transparent' }};
    {%- if section.settings.container_background_image != blank -%}background-image: url({{ section.settings.container_background_image | img_url: '2400x' }});background-size:cover;background-position:center;background-repeat:no-repeat;{%- endif -%}
    {%- assign ccr = section.settings.container_border_radius -%}
    {%- if ccr -%}border-radius: {{ ccr.tl }}px {{ ccr.tr }}px {{ ccr.br }}px {{ ccr.bl }}px;{%- endif -%}
    {% if section.settings.container_border_width > 0 %}border: {{ section.settings.container_border_width }}px solid {{ section.settings.container_border_color }};{% endif %}
  }
  {%- if section.settings.container_overlay_color != blank and section.settings.container_overlay_opacity > 0 -%}
    {%- assign _cov = section.settings.container_overlay_opacity | divided_by: 100.0 -%}
    .pi.section-{{ section.id }} .pi__container::before { content: ""; position: absolute; inset: 0; background: {{ section.settings.container_overlay_color }}; opacity: {{ _cov }}; pointer-events: none; }
  {%- endif -%}
  .pi.section-{{ section.id }} .pi__container > * { position: relative; }
  @media (max-width: 991px) { .pi.section-{{ section.id }} .pi__container { padding-left: 24px; padding-right: 24px; } }
  @media (max-width: 767px) { .pi.section-{{ section.id }} .pi__container { padding-left: 16px; padding-right: 16px; } }

  .pi.section-{{ section.id }} .pi__grid {
    display: grid;
    grid-template-columns: {% if section.settings.image_position == 'right' %}1fr 1fr{% else %}1fr 1fr{% endif %};
    gap: clamp(32px, 5vw, 80px);
    align-items: center;
  }
  @media (max-width: 991px) { .pi.section-{{ section.id }} .pi__grid { grid-template-columns: 1fr; gap: 32px; } }

  .pi.section-{{ section.id }} .pi__media-slot {
    {% if section.settings.image_position == 'right' %}order: 2;{% else %}order: 1;{% endif %}
    position: relative;
  }
  .pi.section-{{ section.id }} .pi__media-slot .media-wrap {
    width: 100%;
    aspect-ratio: {{ section.settings.image_aspect_ratio | default: '1/1' }};
    overflow: hidden;
    position: relative;
    background: var(--clr-gray);
  }
  .pi.section-{{ section.id }} .pi__media-slot .media-wrap img {
    width: 100%; height: 100%; object-fit: cover;
  }
  .pi.section-{{ section.id }} .pi__media-placeholder {
    width: 100%;
    aspect-ratio: {{ section.settings.image_aspect_ratio | default: '1/1' }};
    display: flex; align-items: center; justify-content: center;
    background: repeating-linear-gradient(45deg, var(--clr-gray) 0 18px, var(--clr-light) 18px 36px);
    color: var(--clr-muted); opacity: 0.5;
    border-radius: 16px;
  }

  .pi.section-{{ section.id }} .pi__text {
    {% if section.settings.image_position == 'right' %}order: 1;{% else %}order: 2;{% endif %}
    display: flex; flex-direction: column; gap: 20px;
  }

  .pi.section-{{ section.id }} .pi__intro { display: flex; flex-direction: column; gap: 12px; margin-bottom: 6px; }

  .pi.section-{{ section.id }} .pi__list { display: flex; flex-direction: column; gap: 4px; }
  .pi.section-{{ section.id }} .pi__item {
    display: grid; grid-template-columns: 1fr auto; align-items: baseline;
    gap: 16px;
    padding: 18px 0;
    border-bottom: 1px solid {{ section.settings.divider_color | default: 'var(--clr-gray)' }};
  }
  .pi.section-{{ section.id }} .pi__item:last-child { border-bottom: none; }
  .pi.section-{{ section.id }} .pi__item-name {
    font-size: 16.5px; font-weight: 600;
    color: {{ section.settings.name_color | default: 'var(--clr-primary)' }};
    line-height: 1.3;
  }
  .pi.section-{{ section.id }} .pi__item-badge {
    display: inline-flex; align-items: center;
    padding: 2px 10px;
    margin-left: 8px;
    font-size: 11px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase;
    background: {{ section.settings.hero_badge_background | default: 'var(--clr-accent)' }};
    color: {{ section.settings.hero_badge_color | default: 'var(--clr-white)' }};
    border-radius: 999px;
    vertical-align: middle;
  }
  .pi.section-{{ section.id }} .pi__item-desc {
    font-size: 14px; line-height: 1.6;
    color: {{ section.settings.desc_color | default: 'var(--clr-body)' }};
    margin-top: 4px;
    grid-column: 1 / -1;
  }
  .pi.section-{{ section.id }} .pi__item-value {
    font-size: 14px; font-weight: 600;
    color: {{ section.settings.value_color | default: 'var(--clr-muted)' }};
    font-family: {{ section.settings.value_font | default: 'var(--ff-heading)' }};
    letter-spacing: -0.01em;
    white-space: nowrap;
  }

  .pi.section-{{ section.id }} .pi__footnote {
    font-size: 13px;
    color: {{ section.settings.footnote_color | default: 'var(--clr-muted)' }};
    margin-top: 8px;
  }
{%- endstyle -%}

<section class="pi section-{{ section.id }}" {{ section.fluid_attributes }}>
  <div class="pi__container">
    <div class="pi__grid">

      <div class="pi__media-slot">
        {%- assign image_block = section.blocks | where: 'type', 'image' | first -%}
        {% if image_block and image_block.settings.image %}
          {%- assign _alt = image_block.settings.alt | default: image_block.settings.image.alt | default: 'Ingredients' -%}
          {%- capture _wrap_style -%}
            {%- assign br = image_block.settings.border_radius -%}{% if br %}border-radius: {{ br.tl }}px {{ br.tr }}px {{ br.br }}px {{ br.bl }}px;{% else %}border-radius: 16px;{% endif %}
            {% if image_block.settings.border_width > 0 %}border: {{ image_block.settings.border_width }}px solid {{ image_block.settings.border_color }};{% endif %}
          {%- endcapture -%}
          <div class="media-wrap" style="{{ _wrap_style | strip_newlines }}" {{ image_block.fluid_attributes }}>
            <img src="{{ image_block.settings.image | img_url: '1600x' }}" alt="{{ _alt | escape }}" loading="lazy" style="object-fit: {{ image_block.settings.fit | default: 'cover' }}; object-position: {{ image_block.settings.object_position | default: 'center' }};">
          </div>
        {% else %}
          <div class="pi__media-placeholder">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" width="64" height="64"><circle cx="12" cy="12" r="10"/><path d="M12 2c5 3 5 17 0 20"/><path d="M12 2c-5 3-5 17 0 20"/><path d="M2 12h20"/></svg>
          </div>
        {% endif %}
      </div>

      <div class="pi__text">
        {%- assign eyebrow_blocks = section.blocks | where: 'type', 'eyebrow' -%}
        {%- assign heading_blocks = section.blocks | where: 'type', 'heading' -%}
        {%- assign subhead_blocks = section.blocks | where: 'type', 'subhead' -%}
        {%- assign ing_blocks     = section.blocks | where: 'type', 'ingredient' -%}
        {%- assign foot_blocks    = section.blocks | where: 'type', 'footnote' -%}

        {% if eyebrow_blocks.size > 0 or heading_blocks.size > 0 or subhead_blocks.size > 0 %}
          <div class="pi__intro">
            {% for block in eyebrow_blocks %}<div class="rte" {{ block.fluid_attributes }}>{{ block.settings.text }}</div>{% endfor %}
            {% for block in heading_blocks %}<div class="rte" {{ block.fluid_attributes }}>{{ block.settings.text }}</div>{% endfor %}
            {% for block in subhead_blocks %}<div class="rte" {{ block.fluid_attributes }}>{{ block.settings.text }}</div>{% endfor %}
          </div>
        {% endif %}

        {% if ing_blocks.size > 0 %}
          <div class="pi__list">
            {% for block in ing_blocks %}
              <div class="pi__item" {{ block.fluid_attributes }}>
                <div>
                  <span class="pi__item-name">
                    {{ block.settings.name | default: 'Ingredient' | escape }}
                    {% if block.settings.is_hero %}<span class="pi__item-badge">{{ section.settings.hero_badge_label | default: 'Hero' | escape }}</span>{% endif %}
                  </span>
                  {% if block.settings.description != blank %}
                    <div class="pi__item-desc">{{ block.settings.description | escape }}</div>
                  {% endif %}
                </div>
                {% if block.settings.value != blank %}<div class="pi__item-value">{{ block.settings.value | escape }}</div>{% endif %}
              </div>
            {% endfor %}
          </div>
        {% endif %}

        {% for block in foot_blocks %}
          <p class="pi__footnote" {{ block.fluid_attributes }}>{{ block.settings.text | escape }}</p>
        {% endfor %}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Ingredients",
  "tag": "section",
  "class": "product-ingredients-section",
  "settings": [
    { "type": "header", "content": "Layout" },
    { "type": "radio", "id": "image_position", "label": "Image position", "default": "left",
      "options": [ { "value": "left", "label": "Left" }, { "value": "right", "label": "Right" } ]
    },
    { "type": "select", "id": "image_aspect_ratio", "label": "Image aspect ratio", "default": "1/1",
      "options": [
        { "value": "1/1",  "label": "Square (1:1)" },
        { "value": "4/3",  "label": "Standard (4:3)" },
        { "value": "4/5",  "label": "Portrait (4:5)" },
        { "value": "3/4",  "label": "Portrait (3:4)" },
        { "value": "16/9", "label": "Widescreen (16:9)" }
      ]
    },

    { "type": "header", "content": "List Style" },
    { "type": "select", "id": "name_color",  "label": "Ingredient name color",  "options": "background_colors", "default": "var(--clr-primary)" },
    { "type": "select", "id": "desc_color",  "label": "Description text color", "options": "background_colors", "default": "var(--clr-body)" },
    { "type": "select", "id": "value_color", "label": "Value/amount color",     "options": "background_colors", "default": "var(--clr-muted)" },
    { "type": "select", "id": "value_font",  "label": "Value font",             "options": "font_families",    "default": "var(--ff-heading)" },
    { "type": "select", "id": "divider_color","label": "Row divider color",     "options": "background_colors", "default": "var(--clr-gray)" },
    { "type": "select", "id": "footnote_color","label": "Footnote text color",  "options": "background_colors", "default": "var(--clr-muted)" },

    { "type": "header", "content": "Hero Ingredient Badge" },
    { "type": "text",   "id": "hero_badge_label",      "label": "Badge label", "default": "Hero" },
    { "type": "select", "id": "hero_badge_background", "label": "Badge background", "options": "background_colors", "default": "var(--clr-accent)" },
    { "type": "select", "id": "hero_badge_color",      "label": "Badge text",       "options": "background_colors", "default": "var(--clr-white)" },

    { "type": "header", "content": "Container" },
    { "type": "select", "id": "container_max_width", "label": "Max Width", "default": "1280px",
      "options": [
        { "value": "1080px", "label": "Comfy (1080px)" },
        { "value": "1280px", "label": "Default (1280px)" },
        { "value": "1440px", "label": "Wide (1440px)" },
        { "value": "100%",   "label": "Full (100%)" }
      ]
    },
    { "type": "padding", "id": "container_padding", "label": "Container Padding" },
    { "type": "corner_radius", "id": "container_border_radius", "label": "Container Border Radius" },
    { "type": "select", "id": "container_background_color", "label": "Container Background Color", "options": "background_colors", "default": "transparent" },
    { "type": "image_picker", "id": "container_background_image", "label": "Container Background Image" },
    { "type": "select", "id": "container_overlay_color", "label": "Container Overlay Color", "options": "background_colors", "default": "transparent" },
    { "type": "range", "id": "container_overlay_opacity", "label": "Container Overlay Opacity", "min": 0, "max": 100, "step": 5, "default": 0, "unit": "%" },
    { "type": "range", "id": "container_border_width", "label": "Container Border Width", "min": 0, "max": 10, "step": 1, "default": 0, "unit": "px" },
    { "type": "select", "id": "container_border_color", "label": "Container Border Color", "options": "background_colors", "default": "var(--clr-primary)" },

    { "type": "header", "content": "Section Shell" },
    { "type": "padding", "id": "section_padding", "label": "Section Padding" },
    { "type": "corner_radius", "id": "section_border_radius", "label": "Section Border Radius" },
    { "type": "select", "id": "background_color", "label": "Background Color", "options": "background_colors", "default": "transparent" },
    { "type": "image_picker", "id": "background_image", "label": "Background Image" },
    { "type": "range", "id": "section_border_width", "label": "Section Border Width", "min": 0, "max": 10, "step": 1, "default": 0, "unit": "px" },
    { "type": "select", "id": "section_border_color", "label": "Section Border Color", "options": "background_colors", "default": "var(--clr-primary)" }
  ],
  "blocks": [
    { "type": "eyebrow", "name": "Eyebrow",
      "settings": [ { "type": "richtext", "id": "text", "label": "Text", "default": "<h5 style=\"color: var(--clr-primary); text-transform: uppercase; letter-spacing: 0.08em;\">What's inside</h5>" } ]
    },
    { "type": "heading", "name": "Heading",
      "settings": [ { "type": "richtext", "id": "text", "label": "Text", "default": "<h2 style=\"color: var(--clr-primary);\">Clean, thoughtful ingredients.</h2>" } ]
    },
    { "type": "subhead", "name": "Subhead",
      "settings": [ { "type": "richtext", "id": "text", "label": "Text", "default": "<p style=\"color: var(--clr-body); font-size: 17px;\">No fillers, no junk \u2014 just what works.</p>" } ]
    },
    { "type": "image", "name": "Image", "limit": 1,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "alt", "label": "Alt Text" },
        { "type": "radio", "id": "fit", "label": "Fit", "default": "cover",
          "options": [ { "value": "cover", "label": "Cover" }, { "value": "contain", "label": "Contain" } ]
        },
        { "type": "select", "id": "object_position", "label": "Focal point", "default": "center",
          "options": [ { "value": "center", "label": "Center" }, { "value": "top", "label": "Top" }, { "value": "bottom", "label": "Bottom" }, { "value": "left", "label": "Left" }, { "value": "right", "label": "Right" } ]
        },
        { "type": "corner_radius", "id": "border_radius", "label": "Border Radius" },
        { "type": "range",  "id": "border_width", "label": "Border Width", "min": 0, "max": 10, "step": 1, "default": 0, "unit": "px" },
        { "type": "select", "id": "border_color", "label": "Border Color", "options": "background_colors", "default": "var(--clr-primary)" }
      ]
    },
    { "type": "ingredient", "name": "Ingredient Row",
      "settings": [
        { "type": "text", "id": "name",        "label": "Name",        "default": "Vitamin D3" },
        { "type": "text", "id": "value",       "label": "Value / amount", "default": "400 IU" },
        { "type": "text", "id": "description", "label": "Description", "default": "Supports bone health and immune function." },
        { "type": "checkbox", "id": "is_hero", "label": "Mark as hero ingredient (adds badge)", "default": false }
      ]
    },
    { "type": "footnote", "name": "Footnote", "limit": 2,
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "\u2020 These statements have not been evaluated by the FDA." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Ingredients",
      "blocks": [
        { "type": "image" },
        { "type": "eyebrow" },
        { "type": "heading" },
        { "type": "subhead" },
        { "type": "ingredient", "settings": { "name": "Vitamin D3", "value": "400 IU", "description": "Supports bone health and immune function.", "is_hero": true } },
        { "type": "ingredient", "settings": { "name": "Vitamin C", "value": "60 mg",  "description": "Powerful antioxidant for daily support." } },
        { "type": "ingredient", "settings": { "name": "Zinc",       "value": "5 mg",  "description": "Immune-boosting mineral." } },
        { "type": "ingredient", "settings": { "name": "Probiotic blend", "value": "10B CFU", "description": "Gut-friendly strains for digestive support." } },
        { "type": "footnote" }
      ]
    }
  ]
}
{% endschema %}
