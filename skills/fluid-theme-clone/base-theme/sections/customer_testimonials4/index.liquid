                     {% assign testimonial_position = 'testimonial_' | append: testimonial_num | append: '_position' %}
                     {% assign testimonial_image = 'testimonial_' | append: testimonial_num | append: '_image' %}
                     
                     <div class="testimonial4-testimonial-card" 
                          style="background-color: {{ section.settings.testimonial_card_background | default: 'transparent' }};">
                       <div class="testimonial-content mb-lg">
                        <div class="rte text-sm">
                            {{ section.settings[testimonial_text] }}
                        </div>
                       </div>

                       <div class="author-info flex align-center space-md">
                        <div class="author-avatar">
                          {% assign img_input = section.settings[testimonial_image] %}
                          {% assign img_fluid_media_id = '' %}
                          
                          {% if img_input.fluid_media_id %}
                            {% assign img_fluid_media_id = img_input.fluid_media_id %}
                            {% assign img_embed_type = img_input.embed_type %}
                          {% endif %}
            
                          {% assign use_fluid_image_widget = false %}
                          
