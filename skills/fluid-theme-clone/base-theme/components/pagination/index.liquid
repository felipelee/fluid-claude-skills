{%- assign _from = paginate.current_offset | plus: 1 -%}
{%- assign _to   = paginate.current_offset | plus: paginate.page_size -%}
{%- assign _total = paginate.items | default: paginate.total_count -%}
{%- if _to > _total -%}{%- assign _to = _total -%}{%- endif -%}
{%- if _total == 0 -%}{%- assign _from = 0 -%}{%- endif -%}

<div class="pagination">
  <div class="pagination-summary">
    Showing <span>{{ _from }}</span>–<span>{{ _to }}</span> of <span>{{ _total }}</span> results
  </div>
  <nav class="pagination-list" aria-label="Pagination">
    {%- if paginate.previous -%}
      <a href="{{ paginate.previous.url }}{{ anchor }}" class="pagination-arrow pagination-prev" aria-label="Previous page">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><polyline points="15 18 9 12 15 6"/></svg>
      </a>
    {%- endif -%}
    {%- for part in paginate.parts -%}
      {%- if part.is_link -%}
        <a href="{{ part.url }}{{ anchor }}">{{ part.title }}</a>
      {%- elsif part.title == paginate.current_page -%}
        <span class="is-active" aria-current="page">{{ part.title }}</span>
      {%- else -%}
        <span class="pagination-gap" aria-hidden="true">…</span>
      {%- endif -%}
    {%- endfor -%}
    {%- if paginate.next -%}
      <a href="{{ paginate.next.url }}{{ anchor }}" class="pagination-arrow pagination-next" aria-label="Next page">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
    {%- endif -%}
  </nav>
</div>
